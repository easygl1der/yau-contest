        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Given a weight function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\rho ( x ) > 0"
                    },
                    {
                        "type": "text",
                        "content": ", let the inner-product corresponding to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\rho ( x )"
                    },
                    {
                        "type": "text",
                        "content": "be defined as follows: "
                    }
                ]
            },
            "bbox": [
                191,
                323,
                803,
                357
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "(f, g) := \\int_ {a} ^ {b} \\rho (x) f (x) g (x) \\mathrm {d} x,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/c2d410ea585d7b0b79fb19535df5c605642038e25d9307108bf70a889a179d1d.jpg"
                }
            },
            "bbox": [
