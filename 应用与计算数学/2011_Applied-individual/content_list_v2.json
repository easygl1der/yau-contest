                794
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "and the following recurrent formula holds: "
                    }
                ]
            },
            "bbox": [
                255,
                802,
                626,
                818
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "T _ {n + 1} (x) = 2 x T _ {n} (x) - T _ {n - 1} (x), \\quad n = 1, 2, \\dots .",
                "math_type": "latex",
                "image_source": {
                    "path": "images/e3af4c46d1415c14405818883654d14bf392a97f1d6fce50eece6f1ef27ce250.jpg"
                }
            },
            "bbox": [
                299,
                827,
                695,
                845
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(4) Find the best quadratic approximation to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f ( x ) = x ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": "on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "[ - 1 , 1 ]"
                    },
                    {
                        "type": "text",
                        "content": "using "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\rho ( x ) = 1 / \\sqrt { 1 - x ^ { 2 } }"
                    },
                    {
                        "type": "text",
                        "content": ". "
