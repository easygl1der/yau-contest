                190
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "and "
                    }
                ]
            },
            "bbox": [
                193,
                193,
                231,
                208
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "p (1) = 1, \\qquad q (1) = 2,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/44fd68351bb43ef6ea5edee8da2cfa5db3b307ace63a55c73c1dd1a986cfb6aa.jpg"
                }
            },
            "bbox": [
                394,
                209,
                598,
                227
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "find "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p ( 0 ) - q ( 0 )"
                    }
                ]
            },
            "bbox": [
                193,
                229,
                337,
                246
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Lay aside "
                    },
                    {
                        "type": "equation_inline",
                        "content": "m"
                    },
                    {
                        "type": "text",
                        "content": "black balls and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "red balls in a jug. Supposes "
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 \\leq r \\leq"
                    },
                    {
                        "type": "equation_inline",
                        "content": "k \\leq n"
                    },
                    {
                        "type": "text",
                        "content": ". Each time one draws a ball from the jug at random. "
                    }
                ]
            },
            "bbox": [
                191,
                252,
                801,
                285
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1) If each time one draws a ball without return, what is the probability that in the "
                            },
                            {
                                "type": "equation_inline",
                                "content": "k"
                            },
                            {
                                "type": "text",
                                "content": "-th time of drawing one obtains exactly the "
                            },
                            {
                                "type": "equation_inline",
                                "content": "r"
                            },
                            {
                                "type": "text",
                                "content": "-th red ball? "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2) If each time one draws a ball with return, what is the probability that in the first "
                            },
                            {
                                "type": "equation_inline",
                                "content": "k"
                            },
                            {
                                "type": "text",
                                "content": "times of drawings one obtained totally an odd number of red balls? "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                230,
                288,
                801,
                387
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y"
                    },
                    {
                        "type": "text",
                        "content": "be independent and identically distributed random variables. Show that "
                    }
                ]
            },
            "bbox": [
                191,
                394,
                801,
                426
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "E [ | X + Y | ] \\geq E [ | X | ].",
                "math_type": "latex",
                "image_source": {
                    "path": "images/bb489900f1e8bc02e5f29388528fbcb266d05d39cb79e8aaed944985eb87e698.jpg"
                }
            },
            "bbox": [
                403,
                432,
                591,
                451
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Hint: Consider separately two cases: "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E [ X ^ { + } ] \\geq E [ X ^ { - } ]"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E [ X ^ { + } ] <"
                    },
                    {
                        "type": "equation_inline",
                        "content": "E [ X ^ { - } ]"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                193,
                454,
                801,
                489
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. Suppose that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 1 } , \\cdots , X _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "are a random sample from the Bernoulli distribution with probability of success "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y _ { 1 } , \\cdots , Y _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "be an independent random sample from the Bernoulli distribution with probability of success "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                495,
                801,
                562
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Give a minimum sufficient statistic and the UMVU (uniformly minimum variance unbiased) estimator for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\theta = p _ { 1 } - p _ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Give the Cramer-Rao bound for the variance of the unbiased estimators for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "v ( p _ { 1 } ) = p _ { 1 } ( 1 - p _ { 1 } )"
                            },
                            {
                                "type": "text",
                                "content": "or the UMVU estimator for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "v ( p _ { 1 } )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) Compute the asymptotic power of the test with critical region "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                221,
                564,
                801,
                664
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "| \\sqrt {n} (\\hat {p _ {1}} - \\hat {p _ {2}}) / \\sqrt {2 \\hat {p} \\hat {q}} | \\geq z _ {1 - \\alpha}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/caed64ccfa3f22108755ef3464506fb5b81c1f3773d3ab1fa12757fd09214d39.jpg"
                }
            },
            "bbox": [
                376,
                669,
                618,
                690
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "when "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { 1 } = p"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { 2 } = p + n ^ { - 1 / 2 } \\Delta"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\hat { p } = 0 . 5 \\hat { p } _ { 1 } + 0 . 5 \\hat { p } _ { 2 }"
                    }
                ]
            },
            "bbox": [
                255,
                694,
                771,
                713
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "6. Suppose that an experiment is conducted to measure a constant "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta"
                    },
                    {
                        "type": "text",
                        "content": ". Independent unbiased measurements "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y"
                    },
                    {
                        "type": "text",
                        "content": "of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta"
                    },
                    {
                        "type": "text",
                        "content": "can be made with either of two instruments, both of which measure with normal errors: for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "i = 1 , 2"
                    },
                    {
                        "type": "text",
                        "content": ", instrument "
                    },
                    {
                        "type": "equation_inline",
                        "content": "i"
                    },
                    {
                        "type": "text",
                        "content": "produces independent errors with a "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N ( 0 , \\sigma _ { i } ^ { 2 } )"
                    },
                    {
                        "type": "text",
                        "content": "distribution. The two error variances "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma _ { 1 } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma _ { 2 } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "are known. When a measurement "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y"
                    },
                    {
                        "type": "text",
                        "content": "is made, a record is kept of the instrument used so that after "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "measurements the data is "
                    },
                    {
                        "type": "equation_inline",
