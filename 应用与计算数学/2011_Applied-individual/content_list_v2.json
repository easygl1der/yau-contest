                363,
                626,
                401
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\| f \\| : = ( f , f )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                193,
                407,
                383,
                426
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(1) Define a sequence of polynomials as follows: "
                    }
                ]
            },
            "bbox": [
                223,
                429,
                640,
                447
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\begin{array}{l} p _ {0} (x) = 1, \\quad p _ {1} (x) = x - a _ {1}, \\\\ p _ {n} (x) = \\left(x - a _ {n}\\right) p _ {n - 1} (x) - b _ {n} p _ {n - 2} (x), \\quad n = 2, 3, \\dots \\\\ \\end{array}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/ee692403150a7d2e94da21e863ca231a84638c00a299e629978b744aabe00d21.jpg"
                }
            },
            "bbox": [
                265,
                456,
                729,
                492
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    }
                ]
            },
            "bbox": [
                257,
                501,
                314,
                514
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "a _ {n} = \\frac {\\left(x p _ {n - 1} , p _ {n - 1}\\right)}{\\left(p _ {n - 1} , p _ {n - 1}\\right)}, \\quad n = 1, 2, \\dots",
                "math_type": "latex",
                "image_source": {
                    "path": "images/7d8b773f9722a8df42050363382416039c8c0c004904e1913a9d02aaca883946.jpg"
                }
            },
            "bbox": [
                336,
                521,
                648,
                557
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "b _ {n} = \\frac {\\left(x p _ {n - 1} , p _ {n - 2}\\right)}{\\left(p _ {n - 2} , p _ {n - 2}\\right)}, \\quad n = 2, 3, \\dots .",
                "math_type": "latex",
                "image_source": {
                    "path": "images/4043a36535c7246ffd4fa1103410b529b3607f0ee2f9aa7424f21435e8a2f7a1.jpg"
                }
            },
            "bbox": [
                337,
                561,
                658,
                596
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ p _ { n } ( x ) \\}"
                    },
                    {
                        "type": "text",
                        "content": "is an orthogonal sequence of monic polynomials. "
                    }
                ]
            },
            "bbox": [
                255,
                602,
                801,
                634
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(2) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\{ q _ { n } ( x ) \\}"
                            },
                            {
                                "type": "text",
                                "content": "be an orthogonal sequence of monic polynomials corresponding to the "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\rho"
                            },
                            {
                                "type": "text",
                                "content": "inner product. (A polynomial is called monic if its leading coefficient is 1.) Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\{ q _ { n } ( x ) \\}"
                            },
                            {
                                "type": "text",
                                "content": "is unique and it minimizes "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\| q _ { n } \\|"
                            },
                            {
                                "type": "text",
                                "content": "amongst all monic polynomials of degree "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(3) Hence or otherwise, show that if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\rho ( x ) = 1 / \\sqrt { 1 - x ^ { 2 } }"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "[ a , b ] ="
                            },
                            {
                                "type": "equation_inline",
                                "content": "[ - 1 , 1 ]"
                            },
                            {
                                "type": "text",
                                "content": ", then the corresponding orthogonal sequence is the Chebyshev polynomials: "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                223,
                636,
                811,
                768
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "T _ {n} (x) = \\cos (n \\operatorname {a r c c o s} x), \\quad n = 0, 1, 2, \\dots .",
                "math_type": "latex",
                "image_source": {
                    "path": "images/2c9520377467f57988851cbb2796a44c0cf7d67daf557860dbe2686ece256e42.jpg"
                }
