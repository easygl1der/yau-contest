    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. If two polynomials "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p ( x )"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "q ( x )"
                    },
                    {
                        "type": "text",
                        "content": ", both of fifth degree, satisfy "
                    }
                ]
            },
            "bbox": [
                191,
                136,
                754,
                154
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "p (i) = q (i) = \\frac {1}{i}, \\qquad i = 2, 3, 4, 5, 6,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/5c387d5aa80d1d5701ffe59eac3381cb1d07cee2d2fedd7d1eade7494dd59c28.jpg"
                }
            },
            "bbox": [
