                178
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. The Chebyshev polynomial of the first kind is defined on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "[ - 1 , 1 ]"
                    },
                    {
                        "type": "text",
                        "content": "by "
                    }
                ]
            },
            "bbox": [
                115,
                224,
                727,
                242
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "T _ {n} (x) = \\cos (n \\operatorname {a r c c o s} x).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/e1d91e5373630036e7a73dd896aa6d5ab614d61f1a4ad20d0ab81a13aa192937.jpg"
                }
            },
            "bbox": [
                383,
                247,
                591,
                263
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Prove: The envelope for the extremals of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T _ { n + 1 } ( x ) - T _ { n - 1 } ( x )"
                    },
                    {
                        "type": "text",
                        "content": "forms an ellipse. "
                    }
                ]
            },
            "bbox": [
                115,
                269,
                781,
                287
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Consider a fixed point iteration "
                    }
                ]
            },
            "bbox": [
                115,
                319,
                418,
                335
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "x _ {n} = g \\left(x _ {n - 1}\\right),",
                "math_type": "latex",
                "image_source": {
                    "path": "images/888c73760a5aef1348ae6ffc61c9d7db30ddbed61a723e2225bb95600af68e53.jpg"
                }
            },
            "bbox": [
                426,
                342,
                547,
                359
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g : \\mathbb { R } \\to \\mathbb { R }"
                    },
                    {
                        "type": "text",
                        "content": "is a smooth function. Suppose this fixed point method does converge to a fixed point "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x ^ { * }"
                    },
                    {
                        "type": "text",
                        "content": ". The Steffensen algorithm is an acceleration method to find "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x ^ { * }"
                    },
                    {
                        "type": "text",
                        "content": "which reads "
                    }
                ]
            },
            "bbox": [
                114,
                363,
                860,
                411
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\hat {x} _ {n} = x _ {n - 2} - \\frac {\\left(x _ {n - 1} - x _ {n - 2}\\right) ^ {2}}{x _ {n} - 2 x _ {n - 1} + x _ {n - 2}}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/88cb102df31c46fbd84a232f15c3d329fed6af0c8d9877d807c03def7eb3973c.jpg"
                }
            },
            "bbox": [
                346,
                409,
                628,
                445
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "or "
                    }
                ]
            },
            "bbox": [
                115,
                445,
                139,
                456
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "x _ {n + 1} = G \\left(x _ {n}\\right)",
                "math_type": "latex",
                "image_source": {
                    "path": "images/7dfcc414e65fec2a01088b5f300343f62bd6b60e14fd05cfb7e96d3c2ec1c8b0.jpg"
                }
            },
            "bbox": [
                426,
                458,
                547,
                476
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    }
                ]
            },
            "bbox": [
                115,
                479,
                173,
                493
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "G (x) = x - \\frac {(g (x) - x) ^ {2}}{g (g (x)) - 2 g (x) + x}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/7626a81dcc20cc7b0f93ccf1033928b7d3e11a969e5116a6c3acb205ea487349.jpg"
                }
            },
            "bbox": [
                342,
                489,
                631,
                527
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Show that the Steffensen algorithm "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\{ x _ { k } \\}"
                            },
                            {
                                "type": "text",
                                "content": "converges quadratically. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Can you extend this method to two dimensions? "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                144,
                527,
                744,
                561
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. We consider a piecewise smooth function "
                    }
                ]
            },
            "bbox": [
                115,
                595,
                499,
                609
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "f (x) = \\left\\{ \\begin{array}{l l} f _ {1} (x), & \\qquad x \\leq 0, \\\\ f _ {2} (x), & \\qquad x > 0 \\end{array} \\right.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/8d6187284ca980c152b07717b87e3bc41cb323247cb879b6bd263f5445294562.jpg"
                }
            },
            "bbox": [
                356,
                615,
                608,
                652
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f _ { 1 } ( x )"
                    },
                    {
                        "type": "text",
                        "content": "is a "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C ^ { \\infty }"
                    },
                    {
                        "type": "text",
                        "content": "function on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( - \\infty , 0 ]"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f _ { 2 } ( x )"
                    },
                    {
                        "type": "text",
                        "content": "is a "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C ^ { \\infty }"
                    },
                    {
                        "type": "text",
                        "content": "function on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "[ 0 , \\infty )"
                    },
                    {
                        "type": "text",
                        "content": ", but "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f _ { 1 } ( 0 ) \\ne f _ { 2 } ( 0 )"
                    },
                    {
                        "type": "text",
                        "content": ". Suppose "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p ( x )"
                    },
                    {
                        "type": "text",
                        "content": "is a "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k"
                    },
                    {
                        "type": "text",
                        "content": "-th degree polynomial "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k \\geq 1"
                    },
                    {
                        "type": "text",
                        "content": ") interpolating "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f ( x )"
                    },
                    {
                        "type": "text",
                        "content": "at "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k + 1"
                    },
                    {
                        "type": "text",
                        "content": "equally-spaced grid points "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x _ { j }"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "j = 0 , 1 , 2 , \\cdots , k"
                    },
                    {
                        "type": "text",
                        "content": "with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x _ { i } < 0 < x _ { i + 1 }"
                    },
                    {
                        "type": "text",
                        "content": "for some "
                    },
                    {
                        "type": "equation_inline",
                        "content": "i"
                    },
                    {
                        "type": "text",
                        "content": "between 0 and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k - 1"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that, when the grid size "
                    },
                    {
                        "type": "equation_inline",
                        "content": "h = x _ { j + 1 } - x _ { j }"
                    },
                    {
                        "type": "text",
                        "content": "is small enough, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p ^ { \\prime } ( x ) \\neq 0"
                    },
                    {
                        "type": "text",
                        "content": "for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x _ { i } \\leq 0 \\leq x _ { i + 1 }"
                    },
                    {
                        "type": "text",
                        "content": ", that is, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p ( x )"
                    },
                    {
                        "type": "text",
                        "content": "is monotone in the interval "
                    },
                    {
                        "type": "equation_inline",
                        "content": "[ x _ { i } , x _ { i + 1 } ]"
                    },
                    {
                        "type": "text",
                        "content": ". (Hint: first prove the case when "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f _ { 1 } ( x ) = c _ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f _ { 2 } ( x ) = c _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "c _ { 1 } \\neq c _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "are two constants.) "
                    }
                ]
            },
            "bbox": [
                114,
                656,
                860,
                757
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "1 "
                    }
                ]
            },
            "bbox": [
                482,
                856,
                494,
                866
            ]
        }
    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "b \\in \\mathbb { R } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": ". Suppose "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A \\in M _ { n \\times n } ( \\mathbb { R } )"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "B \\in M _ { n \\times n } ( \\mathbb { R } )"
                    },
                    {
                        "type": "text",
                        "content": "are two "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\times n"
                    },
                    {
                        "type": "text",
                        "content": "matrices. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "to be non-singular. "
                    }
                ]
            },
            "bbox": [
                115,
                109,
                858,
                143
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) Consider the iterative scheme: "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A x ^ { k + 1 } = b - B x ^ { k }"
                    }
                ]
            },
            "bbox": [
                115,
                146,
                574,
                161
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "State and prove the necessary and sufficient condition for the iterative scheme to converge. "
                    }
                ]
            },
            "bbox": [
                144,
                164,
                857,
                195
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Suppose the spectral radius of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A ^ { - 1 } B"
                            },
                            {
                                "type": "text",
                                "content": "satisfies "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\rho ( A ^ { - 1 } B ) = 0"
                            },
                            {
                                "type": "text",
                                "content": ". Prove that the iterative scheme converges in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": "iterations. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) Consider the following iterative scheme: "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                115,
                196,
                857,
                244
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "x ^ {(k + 1)} = \\omega_ {1} x ^ {(k)} + \\omega_ {2} \\left(c _ {1} - M x ^ {(k)}\\right) + \\omega_ {3} \\left(c _ {2} - M x ^ {(k)}\\right) + \\dots + \\omega_ {k} \\left(c _ {k - 1} - M x ^ {(k)}\\right)",
                "math_type": "latex",
                "image_source": {
                    "path": "images/ae8270ec9bea7aa77087a009a633ff7b764bc15ba5a18391f82a925dea75d2d6.jpg"
                }
            },
            "bbox": [
                161,
                254,
                811,
                274
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "is symmetric and positive definite, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\omega _ { 1 } > 1"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\omega _ { 2 } , . . . , \\omega _ { k } > 0"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "c _ { 1 } , . . . , c _ { k - 1 } \\in"
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": ". Deduce from (a) that the iterative scheme converges if and only if all eigenvalues of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "(denote it as "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda ( M )"
                    },
                    {
                        "type": "text",
                        "content": ") satisfies: "
                    }
                ]
            },
            "bbox": [
                147,
                282,
                858,
                332
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "(\\omega_ {1} - 1) / \\left(\\sum_ {i = 2} ^ {k} \\omega_ {i}\\right) <   \\lambda (M) <   (\\omega_ {1} + 1) / \\left(\\sum_ {i = 2} ^ {k} \\omega_ {i}\\right).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/94f1c94089e66dfba78467503db6d3ef4478c960db72888b31c696fe872e5794.jpg"
                }
            },
            "bbox": [
                287,
                348,
                687,
                393
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(d) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "be non-singular. Now, consider the following system of iterative scheme "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( ^ { * } )"
                    }
                ]
            },
            "bbox": [
                115,
                398,
                858,
                416
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "A x _ {1} ^ {(k + 1)} = b _ {1} - B x _ {2} ^ {(k)}, A x _ {2} ^ {(k + 1)} = b _ {2} - B x _ {1} ^ {(k)}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/b42f1defd6655f03816711da484b937dd9dceb156b589a6c5197115e77e929f6.jpg"
                }
            },
            "bbox": [
                295,
                422,
                677,
                445
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Find and prove the necessary and sufficient condition for the iterative scheme "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( ^ { * } )"
                    },
                    {
                        "type": "text",
                        "content": "to converge. "
                    }
                ]
            },
            "bbox": [
                147,
                451,
                858,
                483
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "For the iterative scheme "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( ^ { * * } )"
                    }
                ]
            },
            "bbox": [
                169,
                485,
                428,
                502
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "A x _ {1} ^ {(k + 1)} = b _ {1} - B x _ {2} ^ {(k)}, A x _ {2} ^ {(k + 1)} = b _ {2} - B x _ {1} ^ {(k + 1)}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/4f1ecea6654c654d40b8504bc4043168057f405d71f82c85b76ce0915d2a8b6f.jpg"
                }
            },
            "bbox": [
                287,
                508,
                685,
                532
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Find and prove the necessary and sufficient condition for the iterative scheme "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( ^ { * * } )"
                    },
                    {
                        "type": "text",
                        "content": "to converge. Compare the rate of convergence of the iterative schemes (*) and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( ^ { * * } )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                147,
                539,
                858,
                574
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. Consider the differential equation "
                    }
                ]
            },
            "bbox": [
                115,
                609,
                435,
                626
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "- u ^ {\\prime \\prime} + \\alpha u = f, x \\in (0, 1).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/791bc6b2ddd7d4d8efe1b9f421e280b2c3351b843d0e6e9d6563da9fa0724d12.jpg"
                }
            },
            "bbox": [
                376,
                634,
                600,
                653
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Here, prime denotes for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d / d x"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\alpha"
                    },
                    {
