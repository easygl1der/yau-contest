                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\| \\delta A \\| = O ( \\epsilon )"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\epsilon"
                    },
                    {
                        "type": "text",
                        "content": "is the machine precision. Show that "
                    }
                ]
            },
            "bbox": [
                178,
                145,
                719,
                162
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left(A - \\lambda_ {i}\\right) \\frac {\\tilde {y} _ {k + 1}}{\\| \\tilde {y} _ {k + 1} \\|} \\| \\leq | \\mu - \\lambda_ {i} | + \\| \\delta A \\| + \\frac {1}{\\| \\tilde {y} _ {k + 1} \\|}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/a2d01fe41b2483a71054c706e1c0ab7c1fec0f1b74c4ffecf27de0c80159ba85.jpg"
