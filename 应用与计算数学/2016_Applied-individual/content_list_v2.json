            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "(A - \\mu I + \\delta A) \\tilde {y} _ {k + 1} = x _ {k},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/d1d633455efa07a2365ae93f8e09a7377db6c04d1584d223dbb3cd0c00f43a2f.jpg"
