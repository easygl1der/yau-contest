    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(1) "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tilde { y } _ { k + 1 }"
                    },
                    {
                        "type": "text",
                        "content": "satisfies "
