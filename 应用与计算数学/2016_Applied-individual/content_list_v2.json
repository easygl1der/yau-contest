        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Applied Math. and Computational Math. Individual (5 problems) "
                    }
                ],
                "level": 1
            },
            "bbox": [
                189,
                131,
                786,
                178
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. Consider the implicit leapfrog scheme "
                    }
                ]
            },
            "bbox": [
                115,
                223,
                564,
                240
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\frac {u _ {m} ^ {n + 1} - u _ {m} ^ {n - 1}}{2 k} + a \\left(1 + \\frac {h ^ {2}}{6} \\delta^ {2}\\right) ^ {- 1} \\delta_ {0} u _ {m} ^ {n} = f _ {m} ^ {n}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/65368c874ed13e14ed86a3d5868af6f4a827796baf86c303c3f98b0b6b50487e.jpg"
                }
            },
            "bbox": [
                305,
                244,
                672,
                286
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "for the one-way wave equation "
                    }
                ]
            },
            "bbox": [
                115,
                291,
                383,
                307
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "u _ {t} + a u _ {x} = f.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/f9614560542a68380f4f98bbfdd18f70b843bba77682d985ae5a6ac7e824b796.jpg"
                }
            },
            "bbox": [
                428,
                309,
                547,
                326
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Here "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\delta ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "is the central second difference operator, and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\delta _ { 0 }"
                    },
                    {
                        "type": "text",
                        "content": "is the central first difference operator. "
                    }
                ]
            },
            "bbox": [
                114,
                329,
                860,
                363
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(1) show that the scheme is of order "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( 2 , 4 )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(2) show that the scheme is stable if and only if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\vert \\frac { a k } { h } \\vert < \\frac { 1 } { \\sqrt { 3 } }"
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                144,
                367,
                655,
                405
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 2. A simple version of an enzyme-mediate chemical reaction process is given by "
                    }
                ]
            },
            "bbox": [
                114,
                420,
                860,
                453
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathrm {S} + \\mathrm {E} \\xrightarrow [ k _ {2} ]{k _ {1}} \\mathrm {C} \\xrightarrow [ k _ {3} ]{k _ {3}} \\mathrm {P} + \\mathrm {E}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/a8a5d690d607ebcc1fc026b98c1a639494a5aee000ee2acd9e2a78c56865bd93.jpg"
                }
            },
            "bbox": [
                389,
                454,
                588,
                483
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S"
                    },
                    {
                        "type": "text",
                        "content": "is the substrate reactant and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P"
                    },
                    {
                        "type": "text",
                        "content": "is the concentration of the desired product. An enzyme (or catalyst) "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E"
                    },
                    {
                        "type": "text",
                        "content": "is a compound whose special property is that it allows for intermediate reaction steps that lead to a the overall reaction, "
                    }
                ]
            },
            "bbox": [
                115,
                486,
                860,
                536
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathrm {S} \\longrightarrow \\mathrm {P}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/3b529d965ad83a638423bf98543bbc4ac38df48a6d8ecad0e1402036d8a6c82e.jpg"
                }
            },
            "bbox": [
                448,
                543,
                526,
                558
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Assume the initial conditions "
                    }
                ]
            },
            "bbox": [
                115,
                567,
                376,
                583
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "S (0) = S _ {0}, \\quad E (0) = E _ {0}, \\quad C (0) = 0, \\quad P (0) = 0;",
                "math_type": "latex",
                "image_source": {
                    "path": "images/39ecd27c5a8a15ceb275f839751b72f6389e71715dddd4238c52388befc0fc7d.jpg"
                }
            },
            "bbox": [
                275,
                590,
                700,
                609
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "\\boldsymbol { k } _ { 1 } , \\boldsymbol { k } _ { 2 } , \\boldsymbol { k } _ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": "are reaction rate constants. "
                    }
                ]
            },
            "bbox": [
                115,
                615,
                435,
                632
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) Convert the chemical reaction equation into a system of rate equations (ODEs) for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ( T )"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E ( T )"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C ( T )"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P ( T )"
                    },
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T"
                    },
                    {
                        "type": "text",
                        "content": "is the dimensional time. Nondimensionalize the equations using the scalings "
                    }
                ]
            },
            "bbox": [
                115,
                636,
                860,
                686
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "T = t / (k _ {1} E _ {0}), \\quad S (T) = S _ {0} s (t), \\quad P (T) = S _ {0} p (t), \\quad E (T) = E _ {0} s (t), \\quad C (T) = E _ {0} c (t),",
                "math_type": "latex",
                "image_source": {
                    "path": "images/d5fa8a5dd2da5f7d86f8d29bb700bfc58c8199b5545ecaef9950a8e1ee368e17.jpg"
                }
            },
            "bbox": [
                122,
                693,
                853,
                712
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\epsilon = \\frac {E _ {0}}{S _ {0}} \\ll 1, \\quad \\lambda = \\frac {k _ {2}}{k _ {1} S _ {0}}, \\quad \\mu = \\frac {k _ {2} + k _ {3}}{k _ {1} S _ {0}}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/0bfe8033b7682c3054e47896cc712ad3f031faaee139503c61c886b21fc2c56a.jpg"
                }
            },
            "bbox": [
                310,
                718,
                663,
                753
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) Use the expansions "
                    },
                    {
                        "type": "equation_inline",
                        "content": "s ( t ) = s _ { 0 } ( t ) + \\epsilon s _ { 1 } ( t ) + O ( \\epsilon ^ { 2 } )"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "c ( t ) = c _ { 0 } ( t ) + \\epsilon c _ { 1 } ( t ) + O ( \\epsilon ^ { 2 } )"
                    },
                    {
                        "type": "text",
                        "content": ", etc to determine the equations for the leading order slow solution. Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "s _ { 0 } ( t )"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { 0 } ( t )"
                    },
                    {
                        "type": "text",
                        "content": "satisfies the following Michaelis-Menten equations "
                    }
                ]
            },
            "bbox": [
                115,
                755,
                860,
                806
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\dot {s} _ {0} (t) = - (\\mu - \\lambda) \\frac {s _ {0}}{\\mu + s _ {0}}, \\quad \\dot {p} _ {0} (t) = (\\mu - \\lambda) \\frac {s _ {0}}{\\mu + s _ {0}}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/5e781260639725987f8007b759b8aaedf8636a5d6be2b647f6734c0afc959cfa.jpg"
                }
            },
            "bbox": [
                270,
                810,
                704,
                844
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "1 "
                    }
                ]
            },
            "bbox": [
                482,
                857,
                494,
                866
            ]
        }
    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 3. We say that a vector "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { u } = ( u _ { 1 } , \\ldots , u _ { n } ) \\in \\mathbb { N } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "is multiplicatively dependent if there is a non-zero vector "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { k } = ( k _ { 1 } , \\ldots , k _ { n } ) \\in \\mathbb { Z } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "for which "
                    }
                ]
            },
            "bbox": [
                114,
                110,
                865,
                143
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "u _ {1} ^ {k _ {1}} \\dots u _ {n} ^ {k _ {n}} = 1. \\tag {1}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/8127efff7c27520240ffd5d4722ff8a63af93bf24bbad41c07dcd8eddd87f53d.jpg"
                }
            },
            "bbox": [
                119,
                152,
                552,
                171
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "This notion plays a very important role in many number theoretic algorithms, such as factorisation and primality testing. It also (in a more general form) appears in some questions in algebraic dynamics. However the algorithm to decide whether "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { u }"
                    },
                    {
                        "type": "text",
                        "content": "is multiplicatively dependent is not immediately obvious. The following statement informally means that if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { u }"
                    },
                    {
                        "type": "text",
                        "content": "is multiplicatively dependent the exponents "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k _ { 1 } , \\ldots , k _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "can be chosen to be reasonably small. Prove that if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { u } = ( u _ { 1 } , \\ldots , u _ { n } ) \\in \\mathbb { N } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "is multiplicatively dependent with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\| \\mathbf { u } \\| _ { \\infty } \\leq H"
                    },
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\left\\| \\mathbf { u } \\right\\| _ { \\infty } = \\operatorname* { m a x } _ { 1 \\leq i \\leq n } \\left| u _ { i } \\right|"
                    },
                    {
                        "type": "text",
                        "content": ", then there is a non-zero vector "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { k } = ( k _ { 1 } , \\ldots , k _ { n } ) \\in \\mathbb { Z } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "with "
                    }
                ]
            },
            "bbox": [
                114,
                179,
                860,
                313
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\| \\mathbf {k} \\| _ {\\infty} \\leq \\left(\\frac {2 n \\log H}{\\log 2}\\right) ^ {n - 1}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/d6538ec2b16add377dcace734d301069e373c6a9692a18332ea273af21a8d16d.jpg"
                }
            },
            "bbox": [
                386,
                321,
                594,
                360
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(and hence for a fixed "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "it can be found in polynomial time of order "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( \\log H ) ^ { n ( n - 1 ) } )"
                    }
                ]
            },
            "bbox": [
                114,
                368,
                835,
                385
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Comment: To solve this problem, you can use the following statement (without proof) which informally means that if a system of homogeneous equations with integer coefficients has a nontrivial solution then it has an integer solutions with reasonably small components. It is required in many applications. "
                    }
                ]
            },
            "bbox": [
                112,
                386,
                860,
                451
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Let A = (aij )i,j=1 "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A = ( a _ { i j } ) _ { i , j = 1 } ^ { m , n }"
                    },
                    {
                        "type": "text",
                        "content": "m,n be an "
                    },
                    {
                        "type": "equation_inline",
                        "content": "m \\times n"
                    },
                    {
                        "type": "text",
                        "content": "matrix of rank "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r \\leq n - 1"
                    },
                    {
                        "type": "text",
                        "content": "with integer entries of size at most "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H"
                    },
                    {
                        "type": "text",
                        "content": ", that is, "
                    }
                ]
            },
            "bbox": [
                114,
                451,
                860,
                483
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "| a _ {i j} | \\leq H, 1 \\leq i \\leq m, 1 \\leq j \\leq n.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/3bdc92426203b3dd9b44327db08fdf515c829bf5334b32009886d17564d9d721.jpg"
                }
            },
            "bbox": [
                339,
                489,
                638,
                507
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Then there is an integer non-zero vector "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { x } = ( x _ { 1 } , \\ldots , x _ { n } ) \\in \\mathbb { Z } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A \\mathbf { x } = \\mathbf { 0 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    }
                ]
            },
            "bbox": [
                115,
                511,
                860,
                529
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\| \\mathbf {x} \\| _ {\\infty} \\leq (2 n H) ^ {n - 1}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/d88cb0f43287c9a7f4aba5c18e453717c8ad079c8052058b7a4e7cdb10af5852.jpg"
                }
            },
            "bbox": [
                411,
                537,
                568,
                556
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\left\\| \\mathbf { x } \\right\\| _ { \\infty } = \\operatorname* { m a x } _ { 1 \\leq i \\leq n } \\left| x _ { i } \\right|"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                115,
                563,
                369,
                582
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. Consider a symmetric matrix "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A _ { n \\times n }"
                    },
                    {
                        "type": "text",
                        "content": ", and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda _ { i }"
                    },
                    {
                        "type": "text",
                        "content": "be a simple eigenvalue of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "with "
                    }
                ]
            },
            "bbox": [
                114,
                601,
                860,
                633
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "| \\lambda_ {j} - \\lambda_ {i} | = O (1), \\quad j \\neq i.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/ba3ae1c195ab564148b9631db73f5aa382a1fe8a2efde440c97f6e02306a9727.jpg"
                }
            },
            "bbox": [
                381,
                638,
                596,
                656
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "In inverse iteration of compute eigenvalue and eigenvector, one needs to solve the following linear system "
                    }
                ]
            },
            "bbox": [
                114,
                662,
                860,
                694
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "(A - \\mu I) y _ {k + 1} = x _ {k},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/1f72c5ea755c552017411c5ae9f0bce7376916e30ce649eec9e42fe91802afd1.jpg"
                }
            },
            "bbox": [
                406,
                699,
                571,
                715
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu"
                    },
                    {
                        "type": "text",
                        "content": "is an approximation of eigenvalue "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda _ { i }"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\| x _ { k } \\| = 1"
                    },
                    {
                        "type": "text",
                        "content": "and obtain "
                    }
                ]
            },
            "bbox": [
                115,
                721,
                689,
                739
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "x _ {k + 1} = \\frac {y _ {k + 1}}{\\| y _ {k + 1} \\|}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/42ad5af25dfe08be0239ac4546ea99366f1f8b1059a302ef8b7a7fe0899c98fa.jpg"
                }
            },
            "bbox": [
