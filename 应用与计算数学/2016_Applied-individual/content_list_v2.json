                307
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 5. A function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f : \\mathbb { R } ^ { n } \\to \\mathbb { R }"
                    },
                    {
                        "type": "text",
                        "content": "in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "is called strongly convex if its Hessian matrix satisfies "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\nabla ^ { 2 } f \\succeq m I"
                    },
                    {
                        "type": "text",
                        "content": "for some "
                    },
                    {
                        "type": "equation_inline",
                        "content": "m > 0"
                    },
                    {
                        "type": "text",
                        "content": ". Show that the following statements are equivalent: "
                    }
