        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left\\| x _ {k + 1} - (\\pm) q _ {i} \\right\\| = O \\big (| \\lambda_ {i} - \\mu | + \\epsilon \\big).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/d5957bf85400d551a545898c2570450baf014849b4ee82f9eb6e0a306bc00c71.jpg"
