            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "However, for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu"
                    },
                    {
                        "type": "text",
                        "content": "close to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda _ { i }"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A - \\mu I"
                    },
                    {
                        "type": "text",
                        "content": "has a very small eigenvalue and the linear system will be ill-conditioned. So there may be large error in the numerical solution to the linear system, denoted by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tilde { y } _ { k + 1 }"
                    },
                    {
                        "type": "text",
                        "content": ". Even though we may get large error in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tilde { y } _ { k + 1 }"
                    },
                    {
                        "type": "text",
                        "content": ", the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tilde { { x } } _ { k + 1 }"
                    },
                    {
                        "type": "text",
                        "content": "we get from "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { \\tilde { x } _ { k + 1 } = \\frac { \\tilde { y } _ { k + 1 } } { \\| \\tilde { y } _ { k + 1 } \\| } } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": "is accurate. "
                    }
                ]
            },
            "bbox": [
