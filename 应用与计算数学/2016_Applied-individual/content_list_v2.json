            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(2) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\alpha _ { i } = x _ { k } ^ { t } q _ { i }"
                    },
                    {
                        "type": "text",
