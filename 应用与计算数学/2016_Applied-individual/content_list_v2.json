        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left\\| \\tilde {y} _ {k + 1} \\right\\| \\geq \\frac {\\left| \\alpha_ {i} \\right|}{\\left| \\mu - \\lambda_ {i} \\right| + \\left\\| \\delta A \\right\\|}.",
                "math_type": "latex",
                "image_source": {
