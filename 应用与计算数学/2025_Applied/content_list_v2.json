                468,
                863,
                498
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "| | U ^ {m} | | _ {\\ell_ {\\infty}} \\leq \\left(\\frac {1 - (1 - \\theta) \\Delta t}{1 + \\theta \\Delta t}\\right) ^ {m} | | U ^ {0} | | _ {\\ell_ {\\infty}},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/026950435eacc84650c602b6a8a6a21f286a7b2f1163d15307f69c56f8b0f9e0.jpg"
                }
