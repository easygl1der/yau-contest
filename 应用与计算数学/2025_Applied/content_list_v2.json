        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 5 Consider the initial-value problem "
                    }
                ]
            },
            "bbox": [
                70,
                254,
                430,
                269
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\begin{array}{l} \\frac {\\partial u}{\\partial t} + u = \\frac {\\partial^ {2} u}{\\partial x ^ {2}}, \\quad - \\infty <   x <   \\infty , \\quad 0 <   t \\leq T, \\\\ u (x, 0) = u _ {0} (x), \\quad - \\infty <   x <   \\infty \\\\ \\end{array}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/164e9e90774b77cafcda1ba1874357c5a89330cc418906e5498a8824f3402071.jpg"
                }
            },
            "bbox": [
                354,
                278,
                685,
                323
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T"
                    },
                    {
                        "type": "text",
                        "content": "is a fixed positive real number, and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u _ { 0 }"
                    },
                    {
                        "type": "text",
                        "content": "is a real-valued continuous function on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R }"
                    },
                    {
                        "type": "text",
                        "content": ". Consider the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta"
                    },
                    {
                        "type": "text",
                        "content": "-scheme "
                    }
                ]
            },
            "bbox": [
                171,
                332,
                863,
                361
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\begin{array}{l} \\frac {U _ {j} ^ {m + 1} - U _ {j} ^ {m}}{\\Delta t} + [ \\theta U _ {j} ^ {m + 1} + (1 - \\theta) U _ {j} ^ {m} ] \\\\ = \\theta \\frac {U _ {j + 1} ^ {m + 1} - 2 U _ {j} ^ {m + 1} + U _ {j - 1} ^ {m + 1}}{(\\Delta x) ^ {2}} + (1 - \\theta) \\frac {U _ {j + 1} ^ {m} - 2 U _ {j} ^ {m} + U _ {j - 1} ^ {m}}{(\\Delta x) ^ {2}} \\\\ \\end{array}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/ee82b12c5d8ec44c2f689efa4e6ce20634440e8b342eba601b7a1bdde1cb7c6a.jpg"
                }
            },
            "bbox": [
                255,
                369,
                781,
                435
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "j \\in \\mathbb Z"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "m = 0 , . . . , M - 1"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Delta x > 0"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Delta t = T / M"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M \\geq 1"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U _ { j } ^ { 0 } = u _ { 0 } ( j \\Delta t )"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "j \\in \\mathbb Z"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                171,
                444,
                863,
                461
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) Define the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\ell _ { \\infty }"
                    },
                    {
                        "type": "text",
                        "content": "-norm as "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\vert \\vert U ^ { m } \\vert \\vert _ { \\ell _ { \\infty } } : = \\operatorname* { m a x } _ { j \\in \\mathbb { Z } } \\vert U _ { j } ^ { m } \\vert"
                    },
                    {
                        "type": "text",
                        "content": ", and assume that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| | U ^ { 0 } | | _ { \\ell _ { \\infty } }"
                    },
                    {
                        "type": "text",
                        "content": "is finite. Prove that for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta \\in [ 0 , 1 ]"
                    },
