                536
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "holds for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 \\leq m \\leq M"
                    },
                    {
                        "type": "text",
                        "content": ", provided that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { A ( \\theta ) \\Delta t \\leq \\frac { ( \\Delta x ) ^ { 2 } } { 2 + ( \\Delta x ) ^ { 2 } } } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A ( \\theta )"
                    },
                    {
                        "type": "text",
                        "content": "is a constant, depending on the choice of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta"
                    },
                    {
                        "type": "text",
                        "content": ", which you should determine. "
                    }
                ]
            },
            "bbox": [
                206,
                546,
                863,
                579
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) Define the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\ell _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "-norm as "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { \\vert \\vert U ^ { m } \\vert \\vert _ { \\ell _ { 2 } } : = \\left( \\Delta x \\sum _ { j \\in \\mathbb { Z } } | U _ { j } ^ { m } | ^ { 2 } \\right) ^ { 1 / 2 } } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": "and suppose that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| | U ^ { m } | | _ { \\ell _ { 2 } }"
                    },
                    {
                        "type": "text",
                        "content": "is finite. "
                    }
                ]
            },
            "bbox": [
                179,
                583,
                863,
                602
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "• For "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\theta \\in [ \\frac { 1 } { 2 } , 1 ]"
                            },
                            {
                                "type": "text",
                                "content": ", show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\| U ^ { m } \\| _ { \\ell _ { 2 } } \\leq \\| U ^ { 0 } \\| _ { \\ell _ { 2 } }"
                            },
                            {
                                "type": "text",
                                "content": "holds for any "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Delta t , \\Delta x > 0"
                            },
                            {
                                "type": "text",
                                "content": "and all "
                            },
                            {
                                "type": "equation_inline",
                                "content": "1 \\leq m \\leq"
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
