        {
            "type": "equation_interline",
            "content": {
                "math_content": "P _ {k} ^ {m} = (- 1) ^ {m} (1 - x ^ {2}) ^ {m / 2} \\frac {d ^ {m}}{d x ^ {m}} P _ {k} (x), \\quad m > 0, \\quad k \\geq m.",
                "math_type": "latex",
