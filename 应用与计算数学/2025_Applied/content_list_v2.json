        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\sum_ {k = 1} ^ {N} a _ {k} P _ {k} ^ {1} (x _ {i}) = y _ {i}, \\quad i = 1, \\dots , N.",
                "math_type": "latex",
