        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "J (\\psi_ {1}, \\ldots , \\psi_ {\\ell}) = \\sum_ {j = 1} ^ {n} \\left\\| y _ {j} - \\sum_ {i = 1} ^ {\\ell} (y _ {j} ^ {\\top} \\psi_ {i}) \\psi_ {i} \\right\\| ^ {2},",
                "math_type": "latex",
