        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left| \\left| f (x) - \\sum_ {k = 1} ^ {N} a _ {k} P _ {k} ^ {1} (x) \\right| \\right| _ {2} ^ {2},",
                "math_type": "latex",
