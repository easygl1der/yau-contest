        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\min  _ {P _ {\\bar {x}} \\in \\Pi_ {m}} \\sum_ {k = 1} ^ {K} \\left| P _ {\\bar {x}} \\left(x _ {k}\\right) - f _ {k} \\right| ^ {2} \\tag {2}",
