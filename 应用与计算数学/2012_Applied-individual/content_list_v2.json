            "content": {
                "math_content": "\\left| c _ {i} - \\frac {1}{i !} f ^ {(i)} (\\bar {x}) \\right| = C (f, i) h ^ {m + 2 - i}, i = 0, 1, \\dots , m,",
                "math_type": "latex",
