                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) denote "
                            },
                            {
                                "type": "equation_inline",
                                "content": "h = \\operatorname* { m a x } _ { k } \\ \\left| x _ { k } - { \\overline { { x } } } \\right|"
                            },
                            {
                                "type": "text",
                                "content": ", prove "
                            }
