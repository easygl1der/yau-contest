                ]
            },
            "bbox": [
                194,
                772,
                657,
                806
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "| c _ {i} - \\frac {1}{i !} f ^ {(i)} (\\overline {{x}}) | = C (f, i) h ^ {m + 1 - i}, i = 0, 1, \\ldots , m,",
                "math_type": "latex",
                "image_source": {
