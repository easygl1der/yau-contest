        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "P _ {\\overline {{x}}} (x) = \\mathbf {b} _ {\\overline {{x}}} (x) ^ {T} \\mathbf {c} (\\overline {{x}}),",
                "math_type": "latex",
