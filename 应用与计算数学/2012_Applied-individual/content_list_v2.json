                456
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "if the constants "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "b"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "c"
                    },
                    {
                        "type": "text",
                        "content": "can be chosen arbitrarily, what is the highest degree "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k"
                    },
                    {
                        "type": "text",
                        "content": "such that the formula is exact for all polynomials of degree up to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k"
                    },
                    {
                        "type": "text",
                        "content": "? Find the constants "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "b"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "c"
                    },
                    {
                        "type": "text",
                        "content": "for which the formula is exact for all polynomials of degree up to this "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                464,
                801,
                531
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Here is the definition of a moving least square approximation of a function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f ( x )"
                    },
                    {
                        "type": "text",
                        "content": "near a point "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x"
                    },
                    {
                        "type": "text",
                        "content": "given "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K"
                    },
                    {
                        "type": "text",
                        "content": "points "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x _ { k }"
                    },
                    {
                        "type": "text",
                        "content": "around "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x"
                    },
                    {
                        "type": "text",
                        "content": "in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R }"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k \\in"
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lfloor 1 , \\cdots , K \\rfloor"
                    },
                    {
                        "type": "text",
                        "content": ". "
