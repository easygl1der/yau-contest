        {
            "type": "equation_interline",
            "content": {
                "math_content": "(u _ {h}) _ {1 / 2} ^ {-} = (u _ {h}) _ {N + 1 / 2} ^ {-}; \\quad (u _ {h}) _ {N + 1 / 2} ^ {+} = (u _ {h}) _ {1 / 2} ^ {+}, \\tag {3}",
