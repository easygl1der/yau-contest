                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(ii) "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p ^ { 2 } \\nmid a _ { 0 }"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(iii) "
                            },
                            {
                                "type": "equation_inline",
