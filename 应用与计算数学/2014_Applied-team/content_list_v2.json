            "bbox": [
                275,
                470,
                719,
                491
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "is called an Eisenstein polynomial if for some prime p we have "
                    }
                ]
            },
            "bbox": [
                194,
                495,
                741,
                512
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(i) "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p \\mid a _ { i }"
                            },
                            {
                                "type": "text",
                                "content": "for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "i = 0 , \\ldots , d - 1"
                            },
                            {
                                "type": "text",
                                "content": ", "
