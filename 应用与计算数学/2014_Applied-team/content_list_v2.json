        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Given a finite positive (Borel) measure "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d \\mu"
                    },
                    {
                        "type": "text",
                        "content": "on [0, 1], define its sequence of moments as follows "
