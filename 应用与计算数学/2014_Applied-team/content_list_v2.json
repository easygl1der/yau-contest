        {
            "type": "equation_interline",
            "content": {
                "math_content": "K _ {m} = \\operatorname {s p a n} \\left\\{v _ {0}, v _ {1}, \\dots , v _ {m - 1} \\right\\}.",
                "math_type": "latex",
