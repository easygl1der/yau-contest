            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { E ( t ) = \\int _ { 0 } ^ { 1 } ( u _ { h } ( x , t ) ) ^ { 2 } d x } \\end{array}"
