        {
            "type": "equation_interline",
            "content": {
                "math_content": "x _ {k} = 2 x _ {k - 1} + b _ {k}, \\quad k = 1, 2, \\dots , n,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/59b5ed084a43c3b8e6117da966d0fbfc8d0191019ec7a1a37c5f2976207ceebd.jpg"
