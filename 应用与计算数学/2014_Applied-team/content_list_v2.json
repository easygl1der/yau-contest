        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Consider the linear system "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A x = b"
                    },
                    {
                        "type": "text",
                        "content": ". The GMRES method is a projection method which obtains a solution in the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "m"
                    },
                    {
                        "type": "text",
                        "content": "-th Krylov subspace "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K _ { m }"
                    },
                    {
                        "type": "text",
                        "content": "so that the residual is orthogonal to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A K _ { m }"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r _ { 0 }"
                    },
                    {
                        "type": "text",
