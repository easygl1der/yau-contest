        {
            "type": "equation_interline",
            "content": {
                "math_content": "u _ {t} + f (u) _ {x} = 0, \\quad 0 \\leq x \\leq 1 \\tag {1}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/8cc0d82d79a4ac599dd23fd03a8e3cfcc04c13c1e60288dfc10572ec05d3d284.jpg"
                }
