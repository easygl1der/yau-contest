            },
            "bbox": [
                218,
                514,
                480,
                564
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Eisenstein polynomials are well-know to be irreducible over Z, so they can be used to construct explicit examples of irreducible polynomials. "
                    }
                ]
