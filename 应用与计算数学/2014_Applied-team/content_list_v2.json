                "level": 1
            },
            "bbox": [
                213,
                612,
                309,
                627
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(i) Prove that a composition "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( g ( X ) )"
                            },
                            {
                                "type": "text",
                                "content": "of two Eisenstein polynomials "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g"
                            },
                            {
                                "type": "text",
                                "content": "is an Eisenstein polynomial again. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(ii) Suggest a multivariate generalisation of the Eisenstein polynomials. That is, describe a class polynomials "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F ( X _ { 1 } , \\ldots , X _ { m } )"
                            },
                            {
                                "type": "text",
                                "content": "in terms of the divisibility properties of their coefficients that are guaranteed to be irreducible. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                221,
                631,
                801,
                730
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. (20 pts) For solving the following partial differential equation "
                    }
