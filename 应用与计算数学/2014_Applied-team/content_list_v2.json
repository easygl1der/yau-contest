                361
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Show that the sequence is completely monotone in the sense that that "
                    }
                ]
            },
            "bbox": [
                193,
                363,
                800,
                381
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "(I - S) ^ {k} c _ {j} \\geq 0 \\quad \\mathrm {f o r a l l} j, k \\geq 0,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/72053908bf6ea3a518ef5617f3f0609281b89b2381a27cff55bf4afd0fc9c39b.jpg"
