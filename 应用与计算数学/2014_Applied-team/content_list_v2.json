            },
            "bbox": [
                216,
                451,
                457,
                467
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "f (X) = a _ {d} X ^ {d} + a _ {d - 1} X ^ {d - 1} + \\dots + a _ {1} X + a _ {0} \\in \\mathbb {Z} [ X ]",
                "math_type": "latex",
                "image_source": {
                    "path": "images/d29a133948371603c4f49950dbd5ddd44f90aaf8d1f1d894376588d58d7a436d.jpg"
                }
