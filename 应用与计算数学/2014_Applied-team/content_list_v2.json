            "bbox": [
                191,
                288,
                801,
                319
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "c _ {j} = \\int_ {0} ^ {1} x ^ {j} d \\mu (x), \\quad j = 0, 1, \\dots .",
                "math_type": "latex",
                "image_source": {
                    "path": "images/d4957a2260a6771d0b272bba23c63ab4ad195fd2c8bb18aed3f8f917cff57625.jpg"
