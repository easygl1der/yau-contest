        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\frac {d}{d t} E (t) \\leq 0 \\tag {4}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/60e8d93a240bd62427f9c3d24435e9d7390d7c92ab42868b33e3f231d0e8c3bc.jpg"
