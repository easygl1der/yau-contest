        }
    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. For solving the following partial differential equation "
                    }
                ]
            },
            "bbox": [
                193,
                137,
                677,
                154
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "u _ {t} + f (u) _ {x} = 0, \\quad 0 \\leq x \\leq 1 \\tag {1}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/28494639568b1e2e7f3fde5b1fa36894af8b6f7ed8d077208c419472a686278f.jpg"
                }
            },
            "bbox": [
                369,
                165,
                800,
                180
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f ^ { \\prime } ( u ) \\geq 0"
                    },
                    {
                        "type": "text",
                        "content": ", with periodic boundary condition, we can use the following semi-discrete upwind scheme "
                    }
                ]
            },
            "bbox": [
                191,
                190,
                801,
                223
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\frac {d}{d t} u _ {j} + \\frac {f \\left(u _ {j}\\right) - f \\left(u _ {j - 1}\\right)}{\\Delta x} = 0, \\quad j = 1, 2, \\dots , N, \\tag {2}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/ad5020f5a010ef0ed8776d38af1766d41f11803acf73daa111c5acbcd5f008c8.jpg"
                }
            },
            "bbox": [
                289,
                231,
                800,
                263
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "with periodic boundary condition "
                    }
                ]
            },
            "bbox": [
                193,
                272,
                487,
                288
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "u _ {0} = u _ {N}, \\tag {3}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/54ee79642abdaa02fa4d6abe7374fa9908875974a19684dbe684d1a7b23bb029.jpg"
                }
            },
            "bbox": [
                460,
                300,
                800,
                315
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u _ { j } = u _ { j } ( t )"
                    },
                    {
                        "type": "text",
                        "content": "approximates "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u ( x _ { j } , t )"
                    },
                    {
                        "type": "text",
                        "content": "at the grid point "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x = x _ { j } = j \\Delta x"
                    },
                    {
                        "type": "text",
                        "content": ", with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\textstyle \\Delta x = { \\frac { 1 } { N } }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                325,
                801,
                361
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(i) (15 pts) Prove the following "
                    },
                    {
                        "type": "equation_inline",
                        "content": "L ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "stability of the scheme "
                    }
                ]
            },
            "bbox": [
                226,
                363,
                731,
                381
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\frac {d}{d t} E (t) \\leq 0 \\tag {4}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/440ff14b3c4751e734240033144b6fa11bcc79462bac45ed29678be9a71f85aa.jpg"
                }
            },
            "bbox": [
                452,
                392,
                800,
                422
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { E ( t ) = \\sum _ { j = 1 } ^ { N } | u _ { j } | ^ { 2 } \\Delta x } \\end{array}"
                    }
                ]
            },
            "bbox": [
                255,
                430,
                504,
                451
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(ii) (15 pts) Do you believe (4) is true for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { E ( t ) = \\sum _ { j = 1 } ^ { N } | u _ { j } | ^ { 2 p } \\Delta x } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": "for arbitrary integer "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\geq 1"
                    },
                    {
                        "type": "text",
                        "content": "? If yes, prove the result. If not, give a counter example. "
                    }
                ]
            },
            "bbox": [
                221,
                451,
                801,
                504
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "be an "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\times n"
                    },
                    {
                        "type": "text",
                        "content": "matrix with real and positive eigenvalues and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "b"
                    },
                    {
                        "type": "text",
                        "content": "be a given vector. Consider the solution of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A x = b"
                    },
                    {
                        "type": "text",
                        "content": "by the following Richardson’s iteration "
                    }
                ]
            },
            "bbox": [
                191,
                514,
                801,
                563
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "x ^ {(k + 1)} = (I - \\omega A) x ^ {(k)} + \\omega b",
                "math_type": "latex",
                "image_source": {
                    "path": "images/092c092e17131ba3e095eb88d983e56ee53808d31e3649a35b7d8696427dc297.jpg"
                }
            },
            "bbox": [
                383,
                571,
                616,
                590
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\omega"
                    },
                    {
                        "type": "text",
                        "content": "is a damping coefficient. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda _ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "be the smallest and the largest eigenvalues of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G _ { \\omega } = I - \\omega A"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                601,
                801,
                634
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(i) (4 points) Prove that the Richardson’s iteration converges if and only if "
                    }
                ]
            },
            "bbox": [
                226,
                639,
                801,
                671
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "0 <   \\omega <   \\frac {2}{\\lambda_ {n}}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/b938d6ede2c9e4c8b4c60ebcaf38be327681acced404439d9564eb071bc83f23.jpg"
                }
            },
            "bbox": [
                445,
                676,
                552,
                708
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(ii) (8 points) Prove that the optimal choice of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\omega"
                    },
                    {
                        "type": "text",
                        "content": "is given by "
                    }
                ]
            },
            "bbox": [
                221,
                714,
                749,
                731
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\omega_ {\\mathrm {o p t}} = \\frac {2}{\\lambda_ {1} + \\lambda_ {n}}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/2278b950e141bc4f9bffa7c598d620b87793b78b7e1f58a5b3be40a577f9efd6.jpg"
                }
            },
            "bbox": [
                430,
                740,
                566,
                772
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Prove also that "
                    }
                ]
            },
            "bbox": [
                257,
                780,
                393,
                795
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\rho (G _ {\\omega}) = \\left\\{ \\begin{array}{l l} 1 - \\omega \\lambda_ {1} & \\quad \\omega \\leq \\omega_ {\\mathrm {o p t}} \\\\ (\\lambda_ {n} - \\lambda_ {1}) / (\\lambda_ {n} + \\lambda_ {1}) & \\quad \\omega = \\omega_ {\\mathrm {o p t}} \\\\ \\omega \\lambda_ {n} - 1 & \\quad \\omega \\geq \\omega_ {\\mathrm {o p t}} \\end{array} \\right.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/74832c5df6212e727114bf6dd0f2e3208d541a01a97b89543bd26c6da16d33d6.jpg"
                }
            },
            "bbox": [
                297,
                804,
