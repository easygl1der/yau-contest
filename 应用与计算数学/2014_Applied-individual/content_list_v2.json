                864
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\rho ( G _ { \\omega } )"
                    },
                    {
                        "type": "text",
                        "content": "is the spectral radius of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G _ { \\omega }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
