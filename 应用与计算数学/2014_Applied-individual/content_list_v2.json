    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(iii) (8 points) Prove that, if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "is symmetric and positive definite, then "
                    }
                ]
            },
            "bbox": [
                216,
                137,
                800,
                167
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\rho (G _ {\\omega_ {\\mathrm {o p t}}}) = \\frac {\\kappa_ {2} (A) - 1}{\\kappa_ {2} (A) + 1}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/af47cdc353d8ff53eac4d38a18b258e31bd3b30517b7971892c63a94ff178318.jpg"
                }
            },
            "bbox": [
                406,
                167,
                591,
                200
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\kappa _ { 2 } ( A )"
                    },
                    {
                        "type": "text",
                        "content": "is the spectral condition number of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                255,
                203,
                702,
                219
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. (10 pts) For solving the following heat equation on interval "
                    }
                ]
            },
            "bbox": [
                193,
                248,
                732,
                265
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "u _ {t} = u _ {x x}, \\quad 0 \\leq x \\leq 1 \\tag {5}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/c072045972462869ced15d6ea72a564d69edb73a7a4f2467431d186db636005b.jpg"
                }
            },
            "bbox": [
                396,
                271,
                800,
                287
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "with boundary condition "
                    }
                ]
            },
            "bbox": [
                193,
                293,
                413,
                309
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "u (0) = u _ {0}, \\quad u (1) = u _ {1}, \\tag {6}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/17aa032d69700bbda8bb93fea64039e2b29d18e44607c58e3b35cd15d4aeea58.jpg"
                }
            },
            "bbox": [
                403,
                316,
                800,
                332
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "we first discretize the interval "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lfloor 0 , 1 \\rfloor"
                    },
                    {
                        "type": "text",
                        "content": "into "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N"
                    },
                    {
                        "type": "text",
                        "content": "subintervals uniformly, that is, the mesh size "
                    },
                    {
                        "type": "equation_inline",
                        "content": "h = 1 / N"
                    },
                    {
                        "type": "text",
                        "content": ". We choose a temporal step size "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k"
                    },
                    {
                        "type": "text",
                        "content": "and approximate the solution "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u ( j h , n k )"
                    },
                    {
                        "type": "text",
                        "content": "by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U _ { j } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "j = 1 , . . . , N - 1"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n = 0 , 1 , 2 , \\ldots"
                    },
                    {
                        "type": "text",
                        "content": ". Using the backward Euler method in time and central finite difference in space, the discrete function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U _ { j } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "satisfies: "
                    }
                ]
            },
            "bbox": [
                191,
                337,
                801,
                420
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "U _ {j} ^ {n + 1} - U _ {j} ^ {n} = \\lambda \\left(U _ {j - 1} ^ {n + 1} - 2 U _ {j} ^ {n + 1} + U _ {j + 1} ^ {n + 1}\\right), \\quad j = 1, \\dots , N - 1, \\tag {7}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/14e78fb3dc54cf2af7c8b2cdd5975595a05ab2fa45e24dbd17f3007b0d128ff0.jpg"
                }
            },
            "bbox": [
                252,
                426,
                800,
                447
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda = k / h ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    }
                ]
            },
            "bbox": [
                193,
                451,
                376,
                468
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "U _ {0} ^ {n + 1} = u _ {0}, U _ {N} ^ {n + 1} = u _ {1}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/a83c7e579d5ddedf82c863c2e2f417562b5089177e9187295dbdf07f7ebc3d3b.jpg"
                }
            },
            "bbox": [
                398,
                473,
                596,
                492
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Show that "
                    }
                ]
            },
            "bbox": [
                193,
                497,
                287,
                511
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\begin{array}{l} \\frac {1}{2} \\sum_ {j = 1} ^ {N - 1} \\left(\\left(U _ {j} ^ {n + 1}\\right) ^ {2} - \\left(U _ {j} ^ {n}\\right) ^ {2}\\right) \\leq - \\lambda \\sum_ {j = 1} ^ {N - 2} \\left(U _ {j + 1} ^ {n + 1} - U _ {j} ^ {n + 1}\\right) ^ {2} \\\\ - \\frac {\\lambda}{2} \\left(\\left(U _ {1} ^ {n + 1}\\right) ^ {2} + \\left(U _ {N - 1} ^ {n + 1}\\right) ^ {2}\\right) + \\frac {\\lambda}{2} \\left(u _ {0} ^ {2} + u _ {1} ^ {2}\\right) \\tag {8} \\\\ \\end{array}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/a7ac58c0bf216155ed5d9718beac3b6e6e2398386497da7154b24ed2a316c4dd.jpg"
                }
            },
            "bbox": [
                215,
