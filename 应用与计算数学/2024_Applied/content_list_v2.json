                                "type": "text",
                                "content": "(b) Using "
                            },
                            {
                                "type": "equation_inline",
                                "content": "v _ { m } ^ { n } = \\sum _ { l = 0 } ^ { N - 1 } \\hat { v } _ { l } ^ { n } \\exp \\left( - i \\frac { 2 \\pi l m } { N } \\right)"
                            },
