        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Throughout, consider "
                    },
                    {
                        "type": "equation_inline",
                        "content": "[ a , b ] = [ 0 , 2 \\pi ]"
                    },
                    {
                        "type": "text",
                        "content": "and the finite difference stencil to have periodic boundary conditions on the spatial lattice "
                    },
                    {
                        "type": "equation_inline",
