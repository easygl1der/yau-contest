                130,
                512,
                334,
                530
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "v _ {n + 1} = v _ {n} + \\mu k \\left(L v _ {n} + L v _ {n + 1}\\right). \\tag {2}",
                "math_type": "latex",
