        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Show that the quadrature formula "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\int _ { - 1 } ^ { 1 } { \\frac { f ( x ) } { \\sqrt { 1 - x ^ { 2 } } } } d x = { \\frac { \\pi } { n } } \\sum _ { k = 0 } ^ { n - 1 } f \\left( \\cos \\pi { \\frac { 2 k + 1 } { 2 n } } \\right)"
                    },
                    {
                        "type": "text",
                        "content": "is exact for all polynomials of degree up to and including "
                    },
                    {
                        "type": "equation_inline",
                        "content": "2 n - 1"
                    },
                    {
                        "type": "text",
                        "content": ". "
