        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "be a continuously differentiable convex function defined on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { R } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": ", i.e., "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f : \\mathbf { R } ^ { n }  \\mathbf { R }"
                    },
                    {
                        "type": "text",
                        "content": "is continuously differentiable and for any "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x , y \\in \\mathbf { R } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "and any "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\alpha \\in ( 0 , 1 )"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f ( \\alpha x + ( 1 - \\alpha ) y ) \\leq \\alpha f ( x ) + ( 1 - \\alpha ) f ( y )"
                    },
                    {
                        "type": "text",
                        "content": ". Suppose that the gradient of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "is Lipschitz continuous, i.e., there exists a constant "
                    },
                    {
                        "type": "equation_inline",
                        "content": "L > 0"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    }
                ]
            },
            "bbox": [
                154,
                533,
                907,
                577
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\| \\nabla f (x) - \\nabla f (y) \\| _ {2} \\leq L \\| x - y \\| _ {2}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/17374d86c093d2501649af2ba9cf8df364513cd403b8edc6e4b39e5e7abe4a8f.jpg"
