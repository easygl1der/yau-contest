                        "content": "x = ( x _ { 0 } , \\ldots , x _ { N - 1 } ) \\in \\mathbf { R } ^ { N }"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x \\neq 0"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\hat { x }"
                    },
                    {
                        "type": "text",
                        "content": "be its discrete Fourier transform, i.e. "
                    }
                ]
            },
            "bbox": [
                134,
                228,
                845,
                244
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\hat {x} _ {w} = \\frac {1}{\\sqrt {N}} \\sum_ {t = 0} ^ {N - 1} x _ {t} \\exp (- 2 \\pi i w t / N), w = 0, \\dots , N - 1.",
                "math_type": "latex",
