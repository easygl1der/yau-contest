        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left. \\frac {\\partial h}{\\partial r} \\right| _ {r = 0} = 0, \\quad \\int_ {0} ^ {\\infty} h (r, t) r d r \\equiv \\frac {1}{6 4}",
                "math_type": "latex",
