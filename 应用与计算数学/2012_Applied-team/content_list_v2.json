[
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "GROUP TEST S.-T YAU COLLEGE MATH CONTESTS 2012 "
                    }
                ],
                "level": 1
            },
            "bbox": [
                252,
                174,
                744,
                206
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Applied Math. and Computational Math. "
                    }
                ],
                "level": 1
            },
            "bbox": [
                198,
                240,
                796,
                265
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Please solve 4 out of the following 5 problems. "
                    }
                ]
            },
            "bbox": [
                295,
                303,
                699,
                319
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. If the function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u ( x )"
                    },
                    {
                        "type": "text",
                        "content": "is in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C ^ { k + 1 }"
                    },
                    {
                        "type": "text",
                        "content": "(has continuous "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( k + 1 )"
                    },
                    {
                        "type": "text",
                        "content": "-th derivative) on the interval "
                    },
                    {
                        "type": "equation_inline",
                        "content": "[ 0 , 2 ]"
                    },
                    {
                        "type": "text",
                        "content": ", and a sequence of polynomials "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { n } ( x )"
                    },
                    {
                        "type": "text",
                        "content": "( "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n ="
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 , 2 , 3 , \\ldots"
                    },
                    {
                        "type": "text",
                        "content": ") of degree at most "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k"
                    },
                    {
                        "type": "text",
                        "content": "satisfies "
                    }
                ]
            },
            "bbox": [
                193,
                365,
                801,
                414
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left| u (x) - p _ {n} (x) \\right| \\leq \\frac {C}{n ^ {k + 1}} \\quad \\forall 0 \\leq x \\leq \\frac {1}{n}, \\tag {1}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/3cf159a8c8a23c6d8554bb8f12096d40be9e60d933331a876cbc6aa73616829f.jpg"
                }
            },
            "bbox": [
                198,
                420,
                672,
                454
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where the constant "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C"
                    },
                    {
                        "type": "text",
                        "content": "is independent of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": ", prove "
                    }
                ]
            },
            "bbox": [
                193,
                457,
                616,
                474
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "| u (x) - p _ {n} (x) | \\leq \\frac {\\tilde {C}}{n ^ {k + 1}} \\quad \\forall \\frac {1}{n} \\leq x \\leq \\frac {2}{n},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/ca6810586e9da74d1d8e37037e969e6f74b079b3ef1ba2f54d0b8029a337c6c5.jpg"
                }
            },
            "bbox": [
                322,
                479,
                675,
                514
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "with another constant "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tilde { C }"
                    },
                    {
                        "type": "text",
                        "content": "which is also independent of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    }
                ]
            },
            "bbox": [
                193,
                520,
                682,
                538
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Consider the one-dimensional elliptic equation "
                    }
                ]
            },
            "bbox": [
                193,
                546,
                623,
                563
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "- \\frac {d ^ {2}}{d x ^ {2}} u (x) = f (x), 0 <   x <   1,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/052823b98331249b3a7a90caff0c2e8085bb226929f4a7f8577f4790dd2390e7.jpg"
                }
            },
            "bbox": [
                364,
                568,
                636,
                602
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "with homogeneous boundary condition, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u ( 0 ) = 0"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u ( 1 ) = 0"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f \\in"
                    },
                    {
                        "type": "equation_inline",
                        "content": "L ^ { 2 } ( 0 , 1 )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                193,
                606,
                801,
                639
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(i) Describe the standard piecewise linear finite element method for this boundary value problem. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(ii) Is this method stable and convergent? If so, what is the order of convergence? "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(iii). In this case, the linear finite element method has a super convergence property at the nodal point "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x _ { j }"
                            },
                            {
                                "type": "equation_inline",
                                "content": "( j = 1 , 2 , . . . , N )"
                            },
                            {
                                "type": "text",
                                "content": ", i.e. "
                            },
                            {
                                "type": "equation_inline",
                                "content": "u _ { h } ( x _ { j } ) ="
                            },
                            {
                                "type": "equation_inline",
                                "content": "u ( x _ { j } )"
                            },
                            {
                                "type": "text",
                                "content": ", here "
                            },
                            {
                                "type": "equation_inline",
                                "content": "u _ { h }"
                            },
                            {
                                "type": "text",
                                "content": "is the finite element solution and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "u"
                            },
                            {
                                "type": "text",
                                "content": "is the exact solution. Could you explain why? "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                191,
                640,
                801,
                772
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A = ( a _ { i j } ) \\in M _ { N \\times N } ( \\mathbb { C } )"
                    },
                    {
                        "type": "text",
                        "content": "be strictly diagonally dominant, that is, "
                    }
                ]
            },
            "bbox": [
                193,
                781,
                800,
                799
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left| a _ {i i} \\right| > \\sum_ {j = 1, j \\neq i} ^ {N} \\left| a _ {i j} \\right| \\text {f o r a l l} 1 \\leq i \\leq N,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/bec3d5db341490971801562d6b4b6276effb69146cdddbf492e3ec1732bafe4c.jpg"
                }
            },
            "bbox": [
                344,
                804,
                655,
                852
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Assume that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A = I + L + U"
                    },
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "I"
                    },
                    {
                        "type": "text",
                        "content": "is the identity matrix, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "L"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U"
                    },
                    {
                        "type": "text",
                        "content": "are the lower and upper triangular matrices with zero diagonal entries. "
                    }
                ]
            },
            "bbox": [
                193,
                856,
                801,
                890
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "1 "
                    }
                ]
            },
            "bbox": [
                492,
                891,
                502,
                901
            ]
        }
    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Now, we consider solving the linear system "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A x = b"
                    },
                    {
                        "type": "text",
                        "content": "by the following iterative scheme: "
                    }
                ]
            },
            "bbox": [
                191,
                137,
                803,
                170
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "(*) \\quad x ^ {k + 1} = (I + \\alpha \\Omega L) ^ {- 1} [ (I - \\Omega) - (1 - \\alpha) \\Omega L - \\Omega U) ] x ^ {k} + (I + \\alpha \\Omega L) ^ {- 1} b",
                "math_type": "latex",
                "image_source": {
                    "path": "images/b8951c140402737b0414c680a21a73106e74a982985a2017430b8cb46a57b443.jpg"
                }
            },
            "bbox": [
                196,
                175,
                801,
                196
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { \\Omega : = \\mathrm { d i a g } ( \\omega _ { 1 } , . . . \\omega _ { N } ) } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "0 \\leq \\alpha \\leq 1"
                    },
                    {
                        "type": "text",
                        "content": ". (When "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\alpha = 1"
                    },
                    {
                        "type": "text",
                        "content": ", it gives the SOR method.) "
                    }
                ]
            },
            "bbox": [
                191,
                200,
                801,
                234
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(1) Prove that the linear system "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A x = b"
                            },
                            {
                                "type": "text",
                                "content": "has a unique solution. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(2) Prove that the necessary condition for the convergence of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( ^ { * } )"
                            },
                            {
                                "type": "text",
                                "content": "is "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                221,
                237,
                801,
                272
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\prod_ {i = 1} ^ {N} \\left| 1 - \\omega_ {i} \\right| <   1",
                "math_type": "latex",
                "image_source": {
                    "path": "images/79128cdc86710d9e6cf61becd07b922028a91bd2b9229183e568128344e86aac.jpg"
                }
            },
            "bbox": [
                431,
                279,
                564,
                323
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(3) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M = ( I + \\alpha \\Omega L ) ^ { - 1 } [ ( I - \\Omega ) - ( 1 - \\alpha ) \\Omega L - \\Omega U ) ]"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that the spectral radius "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\rho ( M )"
                    },
                    {
                        "type": "text",
                        "content": "of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "is bounded by: "
                    }
                ]
            },
            "bbox": [
                223,
                329,
                801,
                363
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\rho (M) \\leq \\max _ {i} \\frac {| 1 - \\omega_ {i} | + | \\omega_ {i} | (| 1 - \\alpha | l _ {i} + u _ {i})}{1 - | \\omega_ {i} \\alpha | l _ {i}}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/a06728633ed96418604cbc0be08464d7d74b27293f4eb3088aaf74959fc1d2cb.jpg"
                }
            },
            "bbox": [
                317,
                369,
                678,
                406
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "whenever "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| \\omega _ { i } \\alpha | l _ { i } < 1"
                    },
                    {
                        "type": "text",
                        "content": "for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 \\leq i \\leq N"
                    },
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { l _ { i } = \\sum _ { j < i } | a _ { i j } | } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { u _ { i } = \\sum _ { j > i } | a _ { i j } | } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                253,
                410,
                801,
                447
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(4) Using (c), prove that the sufficient condition for the convergence of (*) is "
                    }
                ]
            },
            "bbox": [
                223,
                447,
                801,
                480
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "0 <   \\omega_ {i} <   \\frac {2}{1 + l _ {i} + u _ {i}} \\mathrm {f o r a l l} 1 \\leq i \\leq N",
                "math_type": "latex",
                "image_source": {
                    "path": "images/b6f915c27c8a578c6a66c6ff5273cbf2ed9fe02f8bcd7bc1841a65a514477b2b.jpg"
                }
            },
            "bbox": [
                332,
                486,
                665,
                520
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. The famous "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R S A"
                    },
                    {
                        "type": "text",
                        "content": "cryptosystem is based on the assumed difficulty of factoring integers "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N = p q"
                    },
                    {
                        "type": "text",
                        "content": "(called RSA integers) which are products of two large primes "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "q"
                    },
                    {
                        "type": "text",
                        "content": "which should be kept secret. Currently "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "q"
                    },
                    {
                        "type": "text",
                        "content": "are chosen to be about 500 bits long, that is, "
                    }
                ]
            },
            "bbox": [
                191,
                526,
                803,
                593
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "p, q \\approx 2 ^ {5 0 0}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/ff6231136f323daa41af0589a2f3bc7cc86f7dc5045fbd09064af69d41b56a14.jpg"
                }
            },
            "bbox": [
                450,
                599,
                544,
                617
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Assume someone uses the following algorithm to find secret "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "-bit primes "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "q"
                    },
                    {
                        "type": "text",
                        "content": "to form an RSA integer "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N = p q"
                    },
                    {
                        "type": "text",
                        "content": ": "
                    }
                ]
            },
            "bbox": [
                191,
                624,
                801,
                657
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "• Choose a random odd 500-bit integer "
                            },
                            {
                                "type": "equation_inline",
                                "content": "s"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "• Test the odd numbers "
                            },
                            {
                                "type": "equation_inline",
                                "content": "s"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "s + 2"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "s + 4"
                            },
                            {
                                "type": "text",
                                "content": ", etc. for primality until the first prime "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": "is found (note the primality testing is very easy nowdays). "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "• Continue testing "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p + 2"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p + 4"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p + 6"
                            },
                            {
                                "type": "text",
                                "content": ", etc. for primality until the second prime "
                            },
                            {
                                "type": "equation_inline",
                                "content": "q"
                            },
                            {
                                "type": "text",
                                "content": "is found. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "• Compute and publish "
                            },
                            {
                                "type": "equation_inline",
                                "content": "N = p q"
                            },
                            {
                                "type": "text",
                                "content": ", but keep "
