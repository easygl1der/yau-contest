                    },
                    {
                        "type": "equation_inline",
                        "content": "0 \\leq r \\leq r _ { * } ( t )"
                    },
                    {
                        "type": "text",
                        "content": "with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "h ( r _ { * } ( t ) , t ) ="
