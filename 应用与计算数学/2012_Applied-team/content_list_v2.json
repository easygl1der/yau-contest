        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\frac {\\partial h}{\\partial t} = \\Delta_ {r} (h ^ {2}) = \\frac {1}{r} \\frac {\\partial}{\\partial r} \\left(r \\frac {\\partial (h ^ {2})}{\\partial r}\\right), \\quad r > 0, \\quad t > 1",
                "math_type": "latex",
