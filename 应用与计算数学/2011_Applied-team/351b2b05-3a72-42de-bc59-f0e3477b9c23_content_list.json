    {
        "type": "text",
        "text": "1. Let $A$ be an $N$ -by- $N$ symmetric positive definite matrix. The conjugate gradient method can be described as follows: ",
        "bbox": [
            191,
            318,
            803,
            351
        ],
        "page_idx": 0
    },
    {
        "type": "equation",
        "text": "$$\n\\mathbf {r} _ {0} = \\mathbf {b} - A \\mathbf {x} _ {0}, \\mathbf {p} _ {0} = \\mathbf {r} _ {0}, \\mathbf {x} _ {0} = 0\n$$",
        "text_format": "latex",
        "bbox": [
            374,
            357,
            636,
            373
        ],
        "page_idx": 0
    },
    {
        "type": "equation",
        "text": "$$\n\\mathrm {F O R} n = 0, 1, \\dots\n$$",
        "text_format": "latex",
        "bbox": [
            378,
            375,
            527,
            388
        ],
        "page_idx": 0
    },
    {
        "type": "equation",
        "text": "$$\n\\alpha_ {n} = \\lVert \\mathbf {r} _ {n} \\rVert_ {2} ^ {2} / (\\mathbf {p} _ {n} ^ {T} A \\mathbf {p} _ {n})\n$$",
        "text_format": "latex",
        "bbox": [
            418,
            388,
            600,
            407
        ],
        "page_idx": 0
    },
    {
        "type": "equation",
        "text": "$$\n\\mathbf {x} _ {n + 1} = \\mathbf {x} _ {n} + \\alpha_ {n} \\mathbf {p} _ {n}\n$$",
        "text_format": "latex",
        "bbox": [
            418,
            409,
            574,
            423
        ],
        "page_idx": 0
    },
    {
        "type": "equation",
        "text": "$$\n\\mathbf {r} _ {n + 1} = \\mathbf {r} _ {n} - \\alpha_ {n} A \\mathbf {p} _ {n}\n$$",
        "text_format": "latex",
        "bbox": [
            418,
            425,
            584,
            439
        ],
        "page_idx": 0
    },
    {
        "type": "equation",
        "text": "$$\n\\beta_ {n} = - \\mathbf {r} _ {k + 1} ^ {T} A \\mathbf {p} _ {k} / \\mathbf {p} _ {k} ^ {T} A \\mathbf {p} _ {k}\n$$",
        "text_format": "latex",
        "bbox": [
            418,
            439,
            623,
            458
        ],
        "page_idx": 0
    },
    {
        "type": "equation",
        "text": "$$\n\\mathbf {p} _ {n + 1} = \\mathbf {r} _ {n + 1} + \\beta_ {n} \\mathbf {p} _ {n}\n$$",
        "text_format": "latex",
        "bbox": [
            418,
            458,
            589,
            473
        ],
        "page_idx": 0
    },
    {
        "type": "text",
        "text": "END FOR ",
        "bbox": [
            378,
