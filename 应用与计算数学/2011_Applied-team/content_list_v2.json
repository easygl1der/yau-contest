        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(i) Find "
                            },
                            {
                                "type": "equation_inline",
                                "content": "a"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
