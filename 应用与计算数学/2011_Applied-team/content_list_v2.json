                            {
                                "type": "equation_inline",
                                "content": "\\mathbf { p } _ { i } ^ { T } A \\mathbf { p } _ { j } = 0"
                            },
                            {
                                "type": "text",
                                "content": "if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "i \\neq j"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathrm { S p a n } \\{ \\mathbf { p } _ { 0 } , \\mathbf { p } _ { 1 } , \\dots , \\mathbf { p } _ { n - 1 } \\} { = } \\mathrm { S p a n } \\{ \\mathbf { r } _ { 0 } , \\mathbf { r } _ { 1 } , \\dots , \\mathbf { r } _ { n - 1 } \\} \\equiv K _ { n }"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(d) "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbf { r } _ { n }"
                            },
                            {
                                "type": "text",
                                "content": "is orthogonal to "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K _ { n }"
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                223,
                571,
                724,
                621
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. We use the following scheme to solve the PDE "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u _ { t } + u _ { x } = 0"
                    },
                    {
                        "type": "text",
                        "content": ": "
                    }
                ]
            },
            "bbox": [
                193,
                630,
                734,
                646
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "u _ {j} ^ {n + 1} = a u _ {j - 2} ^ {n} + b u _ {j - 1} ^ {n} + c u _ {j} ^ {n}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/77d497b7c28ed68d2aa5f2500cad9e7c96262bba4fd8ee85996fd3fb63659f3c.jpg"
                }
            },
            "bbox": [
                376,
                651,
                618,
                671
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where ∆x "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\frac { \\Delta t } { \\Delta x }"
                    },
                    {
                        "type": "text",
                        "content": ". Here "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "b"
                    },
                    {
                        "type": "equation_inline",
                        "content": "x _ { j } = j \\Delta x"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "c"
                    },
                    {
                        "type": "text",
                        "content": "are constants which may depend on the CFL number , "
                    },
                    {
                        "type": "equation_inline",
                        "content": "t ^ { n } = n \\Delta t"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u _ { j } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "is the numerical approximation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda ="
                    },
                    {
                        "type": "text",
