            },
            "bbox": [
                223,
                513,
                665,
                531
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "f (\\mathbf {x}) \\equiv \\frac {1}{2} \\mathbf {x} ^ {T} A \\mathbf {x} - \\mathbf {b} ^ {T} \\mathbf {x}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/1eb9ef7e8134ae75c27f21756a29b9a0e3ea7939ce377b944cc01063287a3984.jpg"
