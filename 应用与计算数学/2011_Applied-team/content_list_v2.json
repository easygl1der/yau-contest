        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbf { p } _ { i } ^ { T } \\mathbf { r } _ { n } = 0"
                            },
                            {
                                "type": "text",
                                "content": "for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "i < n"
                            },
                            {
                                "type": "text",
                                "content": "and "
