        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "be a random variable such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E [ | X | ] < \\infty"
                    },
                    {
                        "type": "text",
                        "content": ". Show that "
