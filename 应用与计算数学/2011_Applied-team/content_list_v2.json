                            {
                                "type": "equation_inline",
                                "content": "\\lambda \\le \\lambda _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": ". Recall that a scheme is stable if there exist constants "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "C"
                            },
                            {
                                "type": "text",
                                "content": ", which are independent of the mesh sizes "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Delta x"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Delta t"
                            },
                            {
                                "type": "text",
                                "content": ", such that "
                            }
                        ]
                    }
                ]
            },
