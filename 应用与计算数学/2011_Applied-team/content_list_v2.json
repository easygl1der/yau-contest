        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y"
                    },
                    {
                        "type": "text",
                        "content": "be independent random variables, identically distributed according to the Normal distribution with mean 0 and variance 1, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N ( 0 , 1 )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                136,
                801,
                187
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) Find the joint probability density function of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( R , \\theta )"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    }
                ]
            },
            "bbox": [
                221,
                189,
                766,
                206
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "R = (X ^ {2} + Y ^ {2}) ^ {1 / 2} \\quad \\text {a n d} \\quad \\theta = \\arctan (Y / X).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/e1c2bc453f4d3752b04c34192686e225f69193e34e092ea29ee662a272b732b9.jpg"
                }
            },
            "bbox": [
                305,
                210,
                687,
                231
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Are "
                            },
                            {
                                "type": "equation_inline",
                                "content": "R"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\theta"
                            },
                            {
                                "type": "text",
                                "content": "independent? Why, or why not? "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) Find a function "
                            },
                            {
                                "type": "equation_inline",
                                "content": "U"
                            },
                            {
                                "type": "text",
                                "content": "of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "R"
                            },
                            {
                                "type": "text",
                                "content": "which has the uniform distribution on (0, 1), Unif(0, 1). "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(d) Find a function "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V"
                            },
                            {
                                "type": "text",
                                "content": "of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\theta"
                            },
                            {
                                "type": "text",
                                "content": "which is distributed as Unif(0,1). "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(e) Show how to transform two independent observations "
                            },
                            {
                                "type": "equation_inline",
                                "content": "U"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V"
                            },
                            {
                                "type": "text",
                                "content": "from Unif(0,1) into two independent observations "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Y"
                            },
                            {
                                "type": "text",
                                "content": "from "
                            },
                            {
                                "type": "equation_inline",
                                "content": "N ( 0 , 1 )"
                            },
                            {
                                "type": "text",
