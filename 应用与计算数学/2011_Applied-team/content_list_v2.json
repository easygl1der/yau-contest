                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "be an "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N"
                    },
                    {
                        "type": "text",
                        "content": "-by- "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N"
                    },
                    {
                        "type": "text",
                        "content": "symmetric positive definite matrix. The conjugate gradient method can be described as follows: "
                    }
                ]
            },
            "bbox": [
                191,
                318,
                803,
                351
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathbf {r} _ {0} = \\mathbf {b} - A \\mathbf {x} _ {0}, \\mathbf {p} _ {0} = \\mathbf {r} _ {0}, \\mathbf {x} _ {0} = 0",
                "math_type": "latex",
                "image_source": {
                    "path": "images/390951e7ee557c28f3d96e94587bb6eb9891b5ff354fd6284e6164b4c5ede83e.jpg"
                }
            },
            "bbox": [
                374,
                357,
                636,
                373
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathrm {F O R} n = 0, 1, \\dots",
                "math_type": "latex",
                "image_source": {
                    "path": "images/3389dd05c84bc2f55143aea21f9b7ab13e55eeb3bfb13bf3ba07239d9d5dd725.jpg"
                }
            },
            "bbox": [
                378,
                375,
                527,
                388
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\alpha_ {n} = \\lVert \\mathbf {r} _ {n} \\rVert_ {2} ^ {2} / (\\mathbf {p} _ {n} ^ {T} A \\mathbf {p} _ {n})",
                "math_type": "latex",
                "image_source": {
                    "path": "images/9cd7ddfc936e7ae9dfe60f6c034778a7ad0fed9a44c6506bbbcccde14f0824ee.jpg"
                }
            },
            "bbox": [
                418,
                388,
                600,
                407
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathbf {x} _ {n + 1} = \\mathbf {x} _ {n} + \\alpha_ {n} \\mathbf {p} _ {n}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/dc2fde4afe66f550974965cc62385dde0a8dfacb751162b2ae1ff09acd6ca44d.jpg"
                }
            },
            "bbox": [
                418,
                409,
                574,
                423
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathbf {r} _ {n + 1} = \\mathbf {r} _ {n} - \\alpha_ {n} A \\mathbf {p} _ {n}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/c6cba68149e3c29cfbddb8f5cf2eadba4ea8dd631a127ea282f985c9d8d4c14b.jpg"
                }
            },
            "bbox": [
                418,
                425,
                584,
                439
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\beta_ {n} = - \\mathbf {r} _ {k + 1} ^ {T} A \\mathbf {p} _ {k} / \\mathbf {p} _ {k} ^ {T} A \\mathbf {p} _ {k}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/1f3ea6b01971fc8671b12cd5b86a0fc631fe6903b48a28f7968e833c58071a64.jpg"
                }
            },
            "bbox": [
                418,
                439,
                623,
                458
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathbf {p} _ {n + 1} = \\mathbf {r} _ {n + 1} + \\beta_ {n} \\mathbf {p} _ {n}",
                "math_type": "latex",
                "image_source": {
