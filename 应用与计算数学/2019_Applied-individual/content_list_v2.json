                370,
                243,
                385
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Consider Richardson’s difference scheme for the heat equation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u _ { t } = u _ { x x }"
                    },
                    {
                        "type": "text",
                        "content": ": "
                    }
                ]
            },
            "bbox": [
                156,
                388,
                697,
                404
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\frac {1}{2 k} \\left(u (x, t + k) - u (x, t - k)\\right) = \\frac {1}{h ^ {2}} \\left(u (x - h, t) - 2 u (x, t) + u (x + h, t)\\right).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/a4a2a00c1b450ec08ebaa2f0daff433eac75a2cbed7f7dd9b7751b24220cf58f.jpg"
                }
            },
            "bbox": [
                268,
                413,
                796,
                441
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "equation_inline",
                                "content": "( i )"
                            },
                            {
                                "type": "text",
                                "content": "Show that this scheme has second-order truncation error. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "equation_inline",
                                "content": "( i i )"
                            },
                            {
                                "type": "text",
                                "content": "Use either ODE principles or von Neumann analysis to show that this scheme is unconditionally unstable. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "equation_inline",
                                "content": "( i i i )"
                            },
                            {
                                "type": "text",
                                "content": "Demonstrate a minor modification of the left-side of Richardson’s scheme that yields a familiar unconditionally stable scheme and prove it. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                156,
                450,
                905,
                521
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3) (25 points) "
                    }
                ]
            },
            "bbox": [
                134,
                530,
                243,
                545
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\varnothing \\neq K"
                    },
                    {
                        "type": "text",
                        "content": "be a closed convex set in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { R } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": ", i.e., "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K"
                    },
                    {
                        "type": "text",
                        "content": "is a closed set and for any "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x , y \\in K"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda \\in ( 0 , 1 )"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda x + ( 1 - \\lambda ) y \\in K"
                    },
                    {
                        "type": "text",
                        "content": ". For any "
                    },
                    {
                        "type": "equation_inline",
                        "content": "z \\in \\mathbf { R } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": ", let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Pi _ { K } ( z )"
                    },
                    {
                        "type": "text",
                        "content": "denote the metric projection of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "z"
                    },
                    {
                        "type": "text",
                        "content": "onto "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K"
                    },
                    {
                        "type": "text",
                        "content": ", which is the unique optimal solution of following problem: "
                    }
                ]
            },
            "bbox": [
                154,
                549,
                907,
                592
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\min  \\frac {1}{2} \\| y - z \\| _ {2} ^ {2}, \\quad \\text {s . t .} \\quad y \\in K. \\tag {1}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/68a40542069366aa113d4a0a56b89f7cd0a4cc8fb3088c43a49ee9676f13f689.jpg"
                }
            },
            "bbox": [
                421,
                606,
                907,
                634
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Show that "
                    }
                ]
            },
            "bbox": [
                157,
                638,
                238,
                650
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "( i )"
                    },
                    {
                        "type": "text",
                        "content": "the point "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y \\in K"
                    },
                    {
                        "type": "text",
                        "content": "solves (1) if and only if "
                    }
                ]
            },
            "bbox": [
                157,
                652,
                480,
                667
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left(z - y\\right) ^ {T} (d - y) \\leqslant 0, \\quad \\forall d \\in K;",
                "math_type": "latex",
                "image_source": {
                    "path": "images/18fb70f5d232fd528ded639d70c7488f74e4e4165f4334b4db3c886c844d4857.jpg"
                }
            },
            "bbox": [
                415,
                677,
                650,
                694
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "( i i )"
                    },
                    {
                        "type": "text",
                        "content": "for any "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y , z \\in \\mathbf { R } ^ { n }"
                    }
                ]
            },
            "bbox": [
                157,
                703,
                322,
                719
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\| \\Pi_ {K} (y) - \\Pi_ {K} (z) \\| _ {2} \\leq \\| y - z \\| _ {2};",
                "math_type": "latex",
                "image_source": {
                    "path": "images/2f28fdf0bef1fa2d13c4fde373c4df6571a54d25c81c27eaa0ea921e7d11bd4f.jpg"
                }
            },
            "bbox": [
                416,
                718,
                648,
                734
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(iii) "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Theta ( \\cdot )"
                    },
                    {
                        "type": "text",
                        "content": "is continuously differentiable with its gradient given by "
                    }
                ]
            },
            "bbox": [
                157,
                740,
                638,
                755
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\nabla \\Theta (z) = z - \\Pi_ {K} (z),",
                "math_type": "latex",
                "image_source": {
                    "path": "images/ff8ab80273f28d05bd924b0d1d3217126d8aa1d05640fdc22d4d50535ab1855c.jpg"
                }
            },
            "bbox": [
                453,
                766,
                611,
                781
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where for any "
                    },
                    {
                        "type": "equation_inline",
                        "content": "z \\in \\mathbf { R } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { \\Theta ( z ) : = \\frac { 1 } { 2 } \\| z - \\Pi _ { K } ( z ) \\| _ { 2 } ^ { 2 } } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                156,
                791,
                507,
                808
            ]
        },
        {
            "type": "page_number",
            "content": {
