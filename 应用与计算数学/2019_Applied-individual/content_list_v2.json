                159,
                243,
                174
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Given a set "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathcal { X }"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "m \\in \\mathbb { N }"
                    },
                    {
                        "type": "text",
                        "content": "and a hypothesis space "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathcal { H }"
                    },
                    {
                        "type": "text",
                        "content": ", define "
                    }
                ]
            },
            "bbox": [
                157,
                178,
                571,
                193
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\Pi_ {\\mathcal {H}} (m) = \\max  _ {\\left\\{x _ {1}, x _ {2}, \\dots , x _ {m} \\right\\} \\subseteq \\mathcal {X}} | \\{(h (x _ {1}), h (x _ {2}), \\dots , h (x _ {m})) | h \\in \\mathcal {H} \\} |",
                "math_type": "latex",
                "image_source": {
                    "path": "images/a914377454a0a55d00115818a326c3bb1a2a7f69d4f917749024007976a5544c.jpg"
                }
            },
            "bbox": [
                309,
                203,
                756,
                227
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| { \\cal S } |"
                    },
                    {
                        "type": "text",
                        "content": "denotes the cardinality of the set "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\boldsymbol { S }"
                    },
                    {
                        "type": "text",
                        "content": ". The VC dimension of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathcal { H }"
                    },
                    {
                        "type": "text",
                        "content": "is "
                    }
                ]
            },
            "bbox": [
                157,
                237,
                702,
                252
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\operatorname {V C} (\\mathcal {H}) = \\max  \\{m: \\Pi_ {\\mathcal {H}} (m) = 2 ^ {m} \\}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/72e24d3117a289b3b083465c2c164e317caf495afb30c037c8cc29a5e4ef2a3d.jpg"
                }
            },
            "bbox": [
                403,
                263,
                660,
                279
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "equation_inline",
                                "content": "( i )"
                            },
                            {
                                "type": "text",
                                "content": "Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathcal { X } = \\mathbf { R }"
                            },
                            {
                                "type": "text",
                                "content": ". If "
                            },
                            {
                                "type": "equation_inline",
                                "content": "a \\leqslant b"
                            },
                            {
                                "type": "text",
                                "content": ", define "
                            },
                            {
                                "type": "equation_inline",
                                "content": "h ( x ; a , b ) = 1"
                            },
                            {
                                "type": "text",
                                "content": "if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x \\in [ a , b ]"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "h ( x ) = - 1"
                            },
                            {
                                "type": "text",
                                "content": "if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x \\notin [ a , b ]"
                            },
                            {
                                "type": "text",
                                "content": ". Find the VC dimension of the hypothesis space "
                            },
                            {
                                "type": "equation_inline",
                                "content": "{ \\mathcal { H } } = \\{ h ( x ; a , b ) | a , b \\in \\mathbf { R } , a \\leqslant b \\}"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "equation_inline",
                                "content": "( i i )"
                            },
                            {
                                "type": "text",
                                "content": "Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathcal { X } = \\mathbf { R } ^ { d }"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathcal { H }"
                            },
                            {
                                "type": "text",
                                "content": "to be the set of linear classifiers, i.e. "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathcal { H } = \\{ f ( x ) | f ( x ) = \\mathrm { s i g n } ( w ^ { \\top } x + b ) , w \\in \\mathbf { R } ^ { d } , b \\in"
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbf { R } \\}"
                            },
                            {
                                "type": "text",
                                "content": "where "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathrm { s i g n } ( x ) = 1"
                            },
                            {
                                "type": "text",
                                "content": "if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x > 0"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\ \\mathrm { s i g n } ( x ) = - 1"
                            },
                            {
                                "type": "text",
                                "content": "if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x < 0"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathrm { s i g n } ( x ) = 0"
                            },
                            {
                                "type": "text",
                                "content": "if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x = 0"
                            },
                            {
                                "type": "text",
                                "content": ". Show that the VC dimension of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathcal { H }"
                            },
                            {
                                "type": "text",
                                "content": "is "
                            },
                            {
                                "type": "equation_inline",
                                "content": "d + 1"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                156,
                288,
