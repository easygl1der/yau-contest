        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. Consider the elliptic interface problem "
                    }
                ]
            },
            "bbox": [
                115,
                221,
                569,
                237
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "(a (x) u _ {x}) _ {x} = f, x \\in (0, 1)",
                "math_type": "latex",
                "image_source": {
                    "path": "images/a12ebbf1a63d87722111627c94c91f39f6fe1f3c830fba3899de7e4c0e5cd01b.jpg"
                }
            },
            "bbox": [
                381,
                243,
                596,
                261
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "with the Dirichlet boundary condition "
                    }
                ]
            },
            "bbox": [
                115,
                266,
                452,
                282
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "u (0) = u (1) = 0.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/2ab5149cf8b99426aa06a67b3ce87f5c5c10d76f4197135d62c34472d8674a59.jpg"
                }
            },
            "bbox": [
                416,
                288,
                559,
                306
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Here, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "is a smooth function, the elliptic coefficient "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a ( x )"
                    },
                    {
                        "type": "text",
                        "content": "is discontinuous across an interface point "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\xi"
                    },
                    {
                        "type": "text",
                        "content": ", that is, "
                    }
                ]
            },
            "bbox": [
                114,
                311,
                860,
                344
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "a (x) = \\left\\{ \\begin{array}{l l} a _ {0} & \\mathrm {f o r} 0 <   x <   \\xi \\\\ a _ {1} & \\mathrm {f o r} \\xi <   x <   1, \\end{array} \\right.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/262f5542c3118966fc419aa0d1d13178e70f71832ab73e5bad0909804108e488.jpg"
                }
            },
            "bbox": [
                357,
                348,
                608,
                385
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "a _ { 0 } , a _ { 1 } \\ > \\ 0"
                    },
                    {
                        "type": "text",
                        "content": "are positive constants, and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "0 < \\xi < 1"
                    },
                    {
                        "type": "text",
                        "content": "is an interface point. Across the interface, we need to impose two jump conditions "
                    }
                ]
            },
            "bbox": [
                114,
                388,
                860,
                422
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "u (\\xi -) = u (\\xi +), a (\\xi -) u _ {x} (\\xi -) = a (\\xi +) u _ {x} (\\xi +).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/b9709ec6dfb7dd420f521590ee8e585ab932c94ea0826c0ef44982b8c27b63f9.jpg"
                }
            },
            "bbox": [
                287,
                426,
                690,
                445
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Question: "
                    }
                ],
                "level": 1
            },
            "bbox": [
                136,
                449,
                235,
                464
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. (25%) Design a numerical method to solve this problem. The method should be at least first order. It is better to be high order (if your method is first order, you get 20% points). "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. (75%) Prove your accuracy and convergence arguments (if your method is first order, you get 60% points). "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                154,
                468,
                858,
                552
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 2. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "be graph of a social network, where for each pair of members there is either no connection, or a positive or a negative one. "
                    }
                ]
            },
            "bbox": [
                114,
                583,
                858,
                617
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "An unbalanced cycle in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "is a a cycle which have odd number of negative edges. Traversing along such a cycle with social rules such as friend of enemy are enemy would result in having a negative relation of one with himself! "
                    }
                ]
            },
            "bbox": [
                114,
                618,
                858,
                665
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "A resigning in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "at a vertex "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\boldsymbol { v }"
                    },
                    {
                        "type": "text",
                        "content": "of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "is to switch the type (positive or negative) of all edges incident to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "v"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                114,
                667,
                858,
                701
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Question: Show that one can switch all edge of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "into positive edges using a sequence resigning if and only if there is no unbalanced cycle in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                114,
                706,
                858,
                740
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 3. We consider particles which are able to produce new particles of like kind. A single particle forms the original, or zero, generation. Every particle has probability "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { k }"
                    },
                    {
                        "type": "equation_inline",
                        "content": "k = 0 , 1 , 2 , \\ldots"
                    },
                    {
                        "type": "text",
                        "content": ") of creating exactly "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k"
                    },
                    {
                        "type": "text",
                        "content": "new particles; the direct descendants of the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "th generation form the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( n + 1 ) \\mathrm { s t }"
                    },
                    {
                        "type": "text",
                        "content": "generation. The particles of each generation act independently of each other. "
                    }
                ]
            },
            "bbox": [
                114,
                772,
                858,
                854
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "1 "
                    }
                ]
            },
            "bbox": [
                482,
                857,
                494,
                866
            ]
        }
    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Assume "
                    },
                    {
                        "type": "equation_inline",
                        "content": "0 ~ < ~ p _ { 0 } ~ < ~ 1"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { P ( x ) = \\sum _ { k \\geq 0 } p _ { k } x ^ { k } } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { \\mu = P ^ { \\prime } ( 1 ) = \\sum _ { k \\geq 0 } k p _ { k } } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": "be the expected number of direct descendants of one particle. Prove that if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu > 1"
                    },
                    {
                        "type": "text",
                        "content": ", then the probability "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "that the process terminates at or before the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "th generation tends to the unique root "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma \\in ( 0 , 1 )"
                    },
                    {
                        "type": "text",
                        "content": "of equation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma = P ( \\sigma )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                115,
                108,
                863,
                177
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. (Isopermetric inequality). Consider a closed plane curve described by a parametric equation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( x ( t ) , y ( t ) ) , 0 \\leq t \\leq T"
                    },
                    {
                        "type": "text",
                        "content": "with parameter "
                    },
                    {
                        "type": "equation_inline",
                        "content": "t"
                    },
                    {
                        "type": "text",
                        "content": "oriented counterclockwise and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( x ( 0 ) , y ( 0 ) ) = ( x ( T ) , y ( T ) )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                114,
                208,
                862,
                260
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a): Show that the total length of the curve is given by "
                    }
                ]
            },
            "bbox": [
                159,
                262,
                645,
                279
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "L = \\int_ {0} ^ {T} \\sqrt {(x ^ {\\prime} (t)) ^ {2} + (y ^ {\\prime} (t)) ^ {2}} d t",
                "math_type": "latex",
                "image_source": {
                    "path": "images/20a6dbec04cb1312b7d87fd1e176e705bbbf27d0652306d513f2546841b2696b.jpg"
                }
            },
            "bbox": [
                352,
                282,
                626,
                321
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b): Show that the total area enclosed by the curve is given by "
                    }
                ]
            },
            "bbox": [
                159,
                324,
                712,
                342
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "A = \\frac {1}{2} \\int_ {0} ^ {T} \\left(x (t) y ^ {\\prime} (t) - y (t) x ^ {\\prime} (t)\\right) d t",
                "math_type": "latex",
                "image_source": {
                    "path": "images/722e65f8dd046c0f8f09eb3086b8420130257705e128b31200c198620e53dafb.jpg"
                }
            },
            "bbox": [
                337,
                346,
                640,
                384
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c): The classical iso-perimetric inequality states that for closed plane curves with a fixed length "
                            },
                            {
                                "type": "equation_inline",
                                "content": "L"
                            },
                            {
                                "type": "text",
                                "content": ", circles have the largest enclosed area "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A"
                            },
                            {
                                "type": "text",
                                "content": ". Formulate this question into a variational problem. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(d): Derive the Euler-Lagrange equation for the variational problem in (c). "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(e): Show that there are two constants "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "y _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                159,
                387,
                862,
                470
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left(x (t) - x _ {0}\\right) ^ {2} + \\left(y (t) - y _ {0}\\right) ^ {2} \\equiv r ^ {2}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/6acc574a326cdb463962d949abc0f48704eb5edecccc854e4cfc13146ac40e4c.jpg"
                }
            },
            "bbox": [
                354,
                475,
                625,
                494
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r = L / ( 2 \\pi )"
                    },
                    {
                        "type": "text",
                        "content": ". Explain your result. "
                    }
                ]
            },
            "bbox": [
                178,
                498,
                522,
                516
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 5. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A \\in \\mathbb { R } ^ { n \\times m }"
                    },
                    {
                        "type": "text",
                        "content": "with rank "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r < \\operatorname* { m i n } ( m , n )"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A = U \\Sigma V ^ { T }"
                    },
                    {
                        "type": "text",
                        "content": "be the SVD of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": ", with singular values "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma _ { 1 } \\geq \\sigma _ { 2 } \\geq \\cdot \\cdot \\cdot \\geq \\sigma _ { r } > 0"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                115,
                546,
                863,
                582
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Show that, for every "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\epsilon > 0"
                            },
                            {
                                "type": "text",
                                "content": ", there is a full rank matrix "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A _ { \\epsilon } \\in \\mathbb { R } ^ { n \\times m }"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\vert \\vert A - A _ { \\epsilon } \\vert \\vert _ { 2 } = \\epsilon"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A _ { k } = U \\Sigma _ { k } V ^ { T }"
                            },
                            {
                                "type": "text",
                                "content": "where "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Sigma _ { k } = \\operatorname { d i a g } ( \\sigma _ { 1 } , \\ldots , \\sigma _ { k } , 0 , \\ldots , 0 )"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "1 \\leq k \\leq r - 1"
                            },
                            {
                                "type": "text",
                                "content": "Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\operatorname { r a n k } ( A _ { k } ) = k"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                144,
                583,
                858,
                650
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\sigma_ {k + 1} = \\left| \\left| A - A _ {k} \\right| \\right| _ {2} = \\min  \\left\\{\\left| \\left| A - B \\right| \\right| _ {2} \\quad \\right| \\quad \\operatorname {r a n k} (B) \\leq k \\}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/93d6e5cb12101b3c18be7fa91c163c72c6635dfd0dcbeab60e7c4f8e8c5519b8.jpg"
                }
            },
            "bbox": [
                243,
                656,
                729,
                675
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(c) Assume that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r = \\operatorname* { m i n } ( m , n )"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "B \\in \\mathbb { R } ^ { n \\times m }"
                    },
                    {
                        "type": "text",
                        "content": "and assume that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| | A - B | | _ { 2 } < \\sigma _ { r }"
                    },
                    {
                        "type": "text",
                        "content": ". Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\operatorname { r a n k } ( B ) = r"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
