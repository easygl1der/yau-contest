            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "x _ {k + 1} = f \\left(x _ {k}, y _ {k}\\right), y _ {k + 1} = g \\left(x _ {k}, y _ {k}\\right). \\tag {1}",
                "math_type": "latex",
                "image_source": {
