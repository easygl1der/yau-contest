                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) Find both a lower and upper bound for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\| A \\| _ { \\infty }"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(d) Now assume "
