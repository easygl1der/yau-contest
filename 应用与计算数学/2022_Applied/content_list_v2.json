        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\langle f, g \\rangle = \\int_ {- 1} ^ {1} f (x) g (x) w (x) d x, \\quad w (x) > 0 \\quad \\mathrm {f o r} x \\in (- 1, 1),",
                "math_type": "latex",
                "image_source": {
