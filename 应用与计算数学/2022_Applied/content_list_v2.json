            "bbox": [
                292,
                226,
                704,
                263
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { i } ( x )"
                    },
                    {
                        "type": "text",
                        "content": "is a polynomial of degree ??. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x _ { 0 } , x _ { 1 } , \\ldots , x _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "be the roots of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { n + 1 } ( x )"
                    },
                    {
                        "type": "text",
                        "content": ". Construct an orthonormal basis in the subspace of the polynomials of degree no more than "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "such that, for any polynomial in this subspace, the coefficients of its expansion into the basis are equal to the scaled values of this polynomial at the nodes "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x _ { 0 } , x _ { 1 } , \\ldots , x _ { n }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
