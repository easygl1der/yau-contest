        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. Consider "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\left\\{ p _ { i } ( x ) \\right\\} _ { i = 0 } ^ { \\infty }"
                    },
                    {
                        "type": "text",
