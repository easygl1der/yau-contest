        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\beta_ {1 0}, \\quad \\beta_ {2 0}, \\quad \\beta_ {2 1}, \\quad \\alpha_ {2 0}, \\quad \\alpha_ {2 1},",
