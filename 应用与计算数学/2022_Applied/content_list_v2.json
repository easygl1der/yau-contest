        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 6. Suppose you have "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\$ 60 K"
                    },
                    {
                        "type": "text",
                        "content": "to invest and there are 3 investment options available. You must invest in multiples of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\$ 10K"
                    },
                    {
                        "type": "text",
                        "content": ". If "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d _ { i }"
                    },
                    {
                        "type": "text",
                        "content": "dollars are invested in investment ?? then you receive a net value (as the profit) of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r _ { i } ( d _ { i } )"
                    },
                    {
                        "type": "text",
                        "content": "dollars. For "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d _ { i } > 0"
                    },
                    {
                        "type": "text",
                        "content": "we have "
                    }
                ]
            },
            "bbox": [
                111,
                702,
                883,
                752
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\begin{array}{l} r _ {1} (d _ {1}) = (7 d _ {1} + 2) \\times 1 0, \\\\ r _ {2} (d _ {2}) = (3 d _ {2} + 7) \\times 1 0, \\\\ r _ {3} (d _ {3}) = (4 d _ {3} + 5) \\times 1 0, \\\\ \\end{array}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/544817a3d73a65eca19dc293e14c22f235e6325422746ba04e6550f696c6be77.jpg"
                }
            },
            "bbox": [
                415,
                772,
                581,
                830
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "and "
                    },
