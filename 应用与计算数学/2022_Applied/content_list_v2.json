                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "• Construct a cubic polynomial passing through the points "
                            },
                            {
                                "type": "equation_inline",
                                "content": "U _ { j - 2 } ^ { n } , U _ { j - 1 } ^ { n } , U _ { j } ^ { n } , U _ { j + 1 } ^ { n } ."
