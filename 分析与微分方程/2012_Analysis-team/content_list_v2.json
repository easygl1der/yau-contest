        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Please solve 5 out of the following 6 problems. "
                    }
                ]
            },
            "bbox": [
                295,
                300,
                699,
                318
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A = [ a _ { i j } ]"
                            },
                            {
                                "type": "text",
                                "content": "be a real symmetric "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n \\times n"
                            },
                            {
                                "type": "text",
                                "content": "matrix. Define "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f : \\mathbb { R } ^ { n } \\longrightarrow \\mathbb { R }"
                            },
                            {
                                "type": "text",
                                "content": "by "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\begin{array} { r } { f ( x _ { 1 } , \\cdot \\cdot \\cdot , x _ { n } ) = \\exp ( - \\frac { 1 } { 2 } \\sum _ { i , j = 1 } ^ { n } a _ { i j } x _ { i } x _ { j } ) } \\end{array}"
                            },
                            {
                                "type": "text",
                                "content": ". Prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "is in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "L ^ { 1 } ( \\mathbb { R } ^ { n } )"
                            },
                            {
                                "type": "text",
                                "content": "if and only if the matrix "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A"
                            },
                            {
                                "type": "text",
                                "content": "is positive definite. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "Compute "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\begin{array} { r } { \\int _ { \\mathbb { R } ^ { n } } \\exp ( - \\frac { 1 } { 2 } \\sum _ { i , j = 1 } ^ { n } a _ { i j } x _ { i } x _ { j } + \\Sigma _ { i = 1 } ^ { n } b _ { i } x _ { i } ) d x } \\end{array}"
                            },
                            {
                                "type": "text",
                                "content": "when "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A"
                            },
                            {
                                "type": "text",
                                "content": "is positive definite. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V"
                            },
                            {
                                "type": "text",
                                "content": "be a simply connected region in the complex plane and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V \\neq \\mathbb { C }"
                            },
                            {
                                "type": "text",
                                "content": ". Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "a"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "b"
                            },
                            {
                                "type": "text",
                                "content": "be two distinct points in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V"
                            },
                            {
                                "type": "text",
                                "content": ". Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\phi _ { 1 } , \\phi _ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "be two one-to-one holomorphic maps of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V"
                            },
                            {
                                "type": "text",
                                "content": "onto itself. If "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\phi _ { 1 } ( a ) = \\phi _ { 2 } ( a )"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\phi _ { 1 } ( b ) = \\phi _ { 2 } ( b )"
                            },
                            {
                                "type": "text",
                                "content": ", show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\phi _ { 1 } ( z ) = \\phi _ { 2 } ( z )"
                            },
                            {
                                "type": "text",
                                "content": "for all "
                            },
                            {
                                "type": "equation_inline",
                                "content": "z \\in V"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3. In the unit interval [0, 1] consider a subset "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                191,
                361,
                803,
                545
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "E = \\{ x \\}"
                    },
                    {
                        "type": "text",
                        "content": "in the decimal expansion of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x"
                    },
                    {
                        "type": "text",
                        "content": "there is no "
                    },
                    {
                        "type": "equation_inline",
                        "content": "4 \\}"
                    }
                ]
            },
            "bbox": [
                213,
                546,
                677,
                562
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E"
                    },
                    {
                        "type": "text",
                        "content": "is measurable and calculate its measure. "
                    }
                ]
            },
            "bbox": [
                213,
                563,
                677,
                577
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "4. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "1 < p < \\infty , L ^ { p } ( [ 0 , 1 ] , d m )"
                            },
                            {
                                "type": "text",
                                "content": "be the completion of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "C [ 0 , 1 ]"
                            },
                            {
                                "type": "text",
                                "content": "with the norm: "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\begin{array} { r } { | | f | | p = ( \\int _ { 0 } ^ { 1 } | f ( x ) | ^ { p } d m ) ^ { \\frac { 1 } { p } } } \\end{array}"
                            },
                            {
                                "type": "text",
                                "content": ", where "
                            },
                            {
                                "type": "equation_inline",
                                "content": "d m"
                            },
                            {
                                "type": "text",
                                "content": "is the Lebesgue measure. Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\begin{array} { r } { \\operatorname* { l i m } _ { \\lambda \\to \\infty } \\lambda ^ { p } m ( x | | f ( x ) | > \\lambda ) = 0 } \\end{array}"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "5. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathfrak { F } = \\{ e _ { \\nu } \\} , \\nu = 1 , 2 , . . . , n"
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathfrak { F } = \\{ e _ { \\nu } \\}"
                            },
                            {
                                "type": "text",
                                "content": "or "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\nu = 1 , 2 , \\ldots"
                            },
                            {
                                "type": "text",
                                "content": "is an orthonormal basis in an inner product space "
                            },
                            {
                                "type": "equation_inline",
                                "content": "H"
                            },
                            {
                                "type": "text",
                                "content": ". Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "E"
                            },
                            {
                                "type": "text",
                                "content": "be the closed linear subspace spanned by "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathfrak { F }"
                            },
                            {
                                "type": "text",
                                "content": ". For any "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x \\in H"
                            },
                            {
                                "type": "text",
                                "content": "show that the following are equivalent: 1) "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x \\in E"
                            },
                            {
                                "type": "text",
                                "content": "; 2) "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\lvert \\lvert x \\rvert \\rvert ^ { 2 } = \\Sigma _ { \\nu } \\lvert ( x , e _ { \\nu } ) \\rvert ^ { 2 } ; 3 )"
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\boldsymbol { x } = \\Sigma _ { \\nu } ( x , e _ { \\nu } ) e _ { \\nu }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                191,
                586,
                801,
                715
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "H = L ^ { 2 } [ 0 , 2 \\pi ]"
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { < f , g > = \\frac { 1 } { \\pi } \\int _ { 0 } ^ { 2 \\pi } f ( x ) g ( x ) d x . } \\end{array}"
                    }
                ]
            },
            "bbox": [
                213,
                715,
                810,
                734
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "\\mathfrak { F } = \\{ \\frac { 1 } { \\sqrt { 2 } }"
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\cos x , \\sin x , . . . , \\cos n x , \\sin n x , . . . \\}"
                    }
                ]
            },
            "bbox": [
                213,
                734,
                566,
                753
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "be an orthonormal basis. Show that the closed linear sub-space "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E"
                    },
                    {
                        "type": "text",
                        "content": "spanned by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathfrak { F }"
                    },
                    {
                        "type": "text",
                        "content": "is "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                753,
                801,
                785
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "6. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathcal { H } = L ^ { 2 } [ 0 , 1 ]"
                    },
                    {
                        "type": "text",
                        "content": "relative to the Lebesgue measure and define "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( K f ) ( s ) ="
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\textstyle \\int _ { 0 } ^ { s } f ( t ) d t"
                    },
                    {
                        "type": "text",
                        "content": "for each "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathcal { H }"
                    },
                    {
                        "type": "text",
                        "content": ". Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K"
                    },
                    {
                        "type": "text",
                        "content": "is a compact operator without eigenvalues. "
                    }
                ]
            },
