            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(c) Prove the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "obeys "
                    },
                    {
                        "type": "equation_inline",
                        "content": "- \\Delta f = g"
                    },
