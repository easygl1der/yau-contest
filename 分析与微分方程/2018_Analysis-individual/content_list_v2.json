                    },
                    {
                        "type": "equation_inline",
                        "content": "\\frac { \\partial ^ { 2 } } { { \\partial } x _ { 1 } { } ^ { 2 } } + \\cdots + \\frac { \\partial ^ { 2 } } { { \\partial } x _ { n } { } ^ { 2 } }"
                    }
                ]
            },
