            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "6. If "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u"
                    },
                    {
                        "type": "text",
                        "content": "is a positive harmonic function on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { n } \\setminus \\{ 0 \\}"
                    },
                    {
                        "type": "text",
                        "content": "( "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\geq 2"
                    },
                    {
                        "type": "text",
                        "content": "), then exist constants "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a \\ge 0 , b \\ge 0"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    }
                ]
            },
