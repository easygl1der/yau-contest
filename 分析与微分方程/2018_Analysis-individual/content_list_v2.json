        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Please solve the following 6 problems. "
                    }
                ]
            },
            "bbox": [
                290,
                181,
                685,
                200
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Let the sequence of functions "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ f _ { n } \\} _ { n = 1 } ^ { \\infty }"
                    },
                    {
                        "type": "text",
                        "content": "in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "L ^ { 2 } ( \\mathbf { R } ^ { d } )"
                    },
                    {
                        "type": "text",
                        "content": "satisfy that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\| f _ { n } \\| _ { L ^ { 2 } } = 1"
                    }
                ]
            },
            "bbox": [
                115,
                250,
                771,
                268
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(1)Show that there exists a subsequence of function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ f _ { n _ { j } } \\} _ { j = 1 } ^ { \\infty }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f _ { n _ { j } }"
                    },
                    {
                        "type": "text",
                        "content": "converges weakly to some function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "L ^ { 2 } ( \\mathbf R ^ { d } )"
                    },
                    {
                        "type": "text",
                        "content": ", i.e. "
                    }
                ]
            },
            "bbox": [
                115,
                269,
                858,
                303
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left(f _ {n _ {j}}, g\\right)\\rightarrow (f, g)",
                "math_type": "latex",
                "image_source": {
                    "path": "images/daeb04f5cfb455e5131abbeb2c9c67c11011df9aa47ed91cbe4f53f4ef7c9129.jpg"
                }
            },
            "bbox": [
                418,
                310,
                557,
                330
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g \\in L ^ { 2 } ( \\mathbf { R } ^ { d } )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                115,
                336,
                280,
                353
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(2)If "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f _ { n }  f"
                    },
                    {
                        "type": "text",
                        "content": "weakly in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "L ^ { 2 } ( \\mathbf { R } ^ { d } )"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\| f _ { n } \\| _ { L ^ { 2 } } \\to \\| f \\| _ { L ^ { 2 } }"
                    },
                    {
                        "type": "text",
                        "content": "as "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r l } { \\boldsymbol { \\mathscr { n } } } & { { } \\longrightarrow } \\end{array} \\infty"
                    },
                    {
                        "type": "text",
                        "content": ". Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\| f _ { n } - f \\| _ { L ^ { 2 } } \\to 0"
                    },
                    {
                        "type": "text",
                        "content": "as "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\to \\infty"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                115,
                353,
                858,
                387
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f : U \\to \\mathbf { C }"
                    },
                    {
                        "type": "text",
                        "content": "be a non-constant holomorphic function where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U \\subset \\mathbf { C }"
                    },
                    {
                        "type": "text",
                        "content": "is the open set containing the closure "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\overline { { D } }"
                    },
                    {
                        "type": "text",
                        "content": "of the unit disk "
                    },
                    {
                        "type": "equation_inline",
                        "content": "D = \\{ z \\in \\mathbf { C } | | z | < 1 \\}"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                114,
                395,
                858,
                430
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "If "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| f ( z ) | = 1"
                    },
                    {
                        "type": "text",
                        "content": ", for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "z \\in \\partial D"
                    },
                    {
                        "type": "text",
                        "content": ", Prove that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "D \\subset f ( { \\overline { { D } } } )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                134,
                430,
                579,
                448
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Prove that if a sequence of harmonic function on the open disk converges uniformly on compact subset of the disk, then the limit is harmonic. "
                    }
                ]
            },
            "bbox": [
                114,
                456,
                858,
                489
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu"
                    },
                    {
                        "type": "text",
                        "content": "be a Borel measure on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { R } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\rho > 0"
                    },
                    {
                        "type": "text",
                        "content": ", a fixed positive number, and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "B _ { \\rho } ( x ) ="
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ y \\in \\mathbf { R } ^ { n } | d ( x , y ) < \\rho \\}"
                    },
                    {
                        "type": "text",
                        "content": ". For "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\boldsymbol { x } \\in \\mathbf { R } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": ", define a function: "
                    }
                ]
            },
            "bbox": [
                115,
                499,
                858,
                533
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\theta (x): x \\rightarrow \\mu (\\overline {{B _ {\\rho} (x)}})",
                "math_type": "latex",
                "image_source": {
                    "path": "images/18d2c043b124a5d24f5894e499e15d58744d60933a0b89b0c3626d52dc0a3bfa.jpg"
                }
            },
            "bbox": [
                396,
                550,
                574,
                570
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1) Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\theta"
                            },
                            {
                                "type": "text",
                                "content": "is upper semi-continuous, i.e. for every "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x \\in \\mathbf { R } ^ { n } , \\theta ( x ) \\geq \\operatorname* { l i m } \\operatorname* { s u p } _ { y \\to x } \\theta ( y )"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2) Give an example of a Borel measure "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mu"
                            },
                            {
                                "type": "text",
                                "content": ", such that the function "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\theta"
                            },
                            {
                                "type": "text",
                                "content": "is not continuous. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                134,
                573,
                863,
                608
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g"
                    },
                    {
                        "type": "text",
                        "content": "denote a smooth function on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { R } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "with compact support. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "denote the function given by the formula "
                    }
                ]
            },
            "bbox": [
                115,
                617,
                858,
                650
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "f (x) = \\frac {1}{n (n - 1) \\alpha (n)} \\int_ {\\mathbf {R} ^ {n}} \\frac {1}{| x - y | ^ {n - 2}} g (y) d y.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/89d2a005e0af629b061546834da230932940db6d4aadd036501ad84fe7ce9478.jpg"
                }
            },
            "bbox": [
                304,
                656,
                670,
                701
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Here "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\alpha ( n )"
                    },
                    {
                        "type": "text",
                        "content": "is volume of the unit ball in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { R } ^ { n }"
                    }
                ]
            },
            "bbox": [
                134,
                708,
                510,
                722
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "equation_inline",
                                "content": "( a )"
                            },
                            {
                                "type": "text",
                                "content": "Prove that the integral that defines "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "converges for each "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\boldsymbol { x } \\in \\mathbf { R } ^ { n }"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "equation_inline",
                                "content": "( b )"
                            },
                            {
                                "type": "text",
                                "content": "Prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "is differentiable and that the gradient of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "if given by the formula "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                134,
                725,
                852,
                757
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\nabla f | _ {x} = \\frac {1}{n (n - 1) \\alpha (n)} \\int_ {\\mathbf {R} ^ {n}} \\frac {1}{| x - y | ^ {n - 2}} (\\nabla g) | _ {y} d y.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/251272407f805004703eeeebd9a1cc00252ca5a7b904cfbdf62305dcd95af086.jpg"
