                209,
                739,
                229
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f : \\mathbb { R } \\to \\mathbb { R }"
                    },
                    {
                        "type": "text",
                        "content": "be a continuous function which satisfies "
                    }
                ]
            },
            "bbox": [
                193,
                273,
                699,
                290
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\sup _ {x, y \\in \\mathbb {R}} | f (x + y) - f (x) - f (y) | <   \\infty .",
                "math_type": "latex",
                "image_source": {
                    "path": "images/637be48857d29574b6aace30adbe683a9fa354d687550cab20fc0d8c52654e6b.jpg"
                }
            },
            "bbox": [
                346,
                296,
                650,
                326
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "If we have "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\operatorname* { l i m } _ { n \\to \\infty , n \\in \\mathbb { N } } \\frac { f ( n ) } { n } = 2 0 1 4 , \\mathrm { p r o v e } \\operatorname* { s u p } _ { x \\in \\mathbb { R } } | f ( x ) - 2 0 1 4 x | < \\infty ."
                    },
                    {
                        "type": "text",
                        "content": "= 2014, prove sup |f(x) − 2014 x| < ∞. "
                    }
                ]
            },
            "bbox": [
                193,
                332,
                752,
                368
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f _ { 1 } , . . . , f _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "are analytic functions on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "D = \\{ z | | z | < 1 \\}"
                    },
                    {
                        "type": "text",
                        "content": "and continuous on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "D"
                    },
                    {
                        "type": "text",
                        "content": ", prove that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\phi ( z ) = | f _ { 1 } ( z ) | + | f _ { 2 } ( z ) | + . . . + | f _ { n } ( z ) |"
                    },
                    {
                        "type": "text",
                        "content": "achieves maximum values at the boundary "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\partial D"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                376,
                801,
                426
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Prove that if there is a conformal mapping between the annulus "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ z | r _ { 1 } < | z | < r _ { 2 } \\}"
                    },
                    {
                        "type": "text",
                        "content": "and the annulus "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ z | \\rho _ { 1 } < | z | < \\rho _ { 2 } \\}"
                    },
                    {
                        "type": "text",
                        "content": ", then "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { \\frac { r _ { 2 } } { r _ { 1 } } = \\frac { \\rho _ { 2 } } { \\rho _ { 1 } } } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                193,
                435,
                801,
                472
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U ( \\xi )"
                    },
                    {
                        "type": "text",
                        "content": "be a bounded function on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R }"
                    },
                    {
                        "type": "text",
                        "content": "with finitely many points of discontinuity, prove that "
                    }
                ]
            },
            "bbox": [
                191,
                479,
                803,
                513
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "P _ {U} (x) = \\frac {1}{\\pi} \\int_ {\\mathbb {R}} \\frac {y}{(x - \\xi) ^ {2} + y ^ {2}} U (\\xi) d \\xi",
                "math_type": "latex",
                "image_source": {
                    "path": "images/6ba4350169577871dc61300c8eac9a23bfbb263a25a0c49221b17401aac24164.jpg"
