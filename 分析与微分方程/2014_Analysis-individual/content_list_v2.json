            "bbox": [
                347,
                525,
                650,
                561
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "is a harmonic function on the upper half plane "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ z \\in \\mathbb { C } | I m z > 0 \\}"
                    },
                    {
                        "type": "text",
                        "content": "and it converges to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U ( \\xi )"
                    },
                    {
                        "type": "text",
                        "content": "as "
                    },
                    {
                        "type": "equation_inline",
                        "content": "z  \\xi"
                    },
                    {
                        "type": "text",
                        "content": "at a point "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\xi"
                    },
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U ( \\xi )"
                    },
                    {
                        "type": "text",
                        "content": "is continuous. "
                    }
