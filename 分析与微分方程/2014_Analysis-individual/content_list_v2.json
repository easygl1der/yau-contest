        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\int_ {- \\infty} ^ {\\infty} x ^ {2} | f (x) | ^ {2} d x \\int_ {- \\infty} ^ {\\infty} \\xi^ {2} | \\hat {f} (\\xi) | ^ {2} d \\xi \\geq \\frac {(\\int_ {- \\infty} ^ {\\infty} | f (x) | ^ {2} d x) ^ {2}}{1 6 \\pi^ {2}},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/3d1b1fc6f395fe70dec9b8623fa912528945725272ae7723b43c3ba6c7d60fd8.jpg"
