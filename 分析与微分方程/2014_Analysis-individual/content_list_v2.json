                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "{ \\hat { f } } ( \\xi ) \\to \\xi { \\hat { f } } ( \\xi )"
                    },
                    {
                        "type": "text",
                        "content": "after Fourier transform are non-commuting operators. The inequality is a version of the uncertainty principle.) "
                    }
                ]
            },
            "bbox": [
                191,
                696,
                801,
                747
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "6. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Omega"
                    },
                    {
