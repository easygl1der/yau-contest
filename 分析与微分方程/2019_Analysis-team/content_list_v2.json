        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "- \\frac {\\partial^ {2}}{\\partial t ^ {2}} u + \\triangle u = u ^ {3}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/4eaf01038907fb100bb1086540e228210bb49045fe44fe2d61b84859aa8d452d.jpg"
