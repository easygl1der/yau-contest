            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "There exists a universal constant "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C"
                    },
                    {
                        "type": "text",
                        "content": ", for all smooth compactly supported functions "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u , f \\in C _ { 0 } ^ { \\infty } ( \\mathbb { R } ^ { 3 } )"
                    },
                    {
                        "type": "text",
                        "content": "with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Delta u = f"
                    },
                    {
                        "type": "text",
                        "content": ", we have "
                    }
                ]
            },
            "bbox": [
                156,
                217,
                907,
                244
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\| u \\| _ {C ^ {2, \\alpha}} \\leqslant C \\| f \\| _ {C ^ {0, \\alpha}},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/07e065687ace8bb18a3dade57219211ab4e65f239a71aadcb724d094cf84d5c8.jpg"
                }
