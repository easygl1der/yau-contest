            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4) Is there an entire function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "with infinitely many zeroes, so that for every "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r \\in \\mathsf { \\Gamma } ( 0 , 1 )"
                    },
                    {
                        "type": "text",
