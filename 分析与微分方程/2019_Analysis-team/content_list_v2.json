                262
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "0 < \\alpha < 1"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\| \\cdot \\| _ { C ^ { k , \\alpha } }"
                    },
                    {
                        "type": "text",
                        "content": "are H¨older norms. "
                    }
                ]
            },
            "bbox": [
                156,
                267,
                517,
                282
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( X , A , \\mu )"
                    },
                    {
                        "type": "text",
                        "content": "be a probability space and let ¡ ¢ "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T : X  X"
                    },
                    {
                        "type": "text",
                        "content": "be a measurable and measure preserving map, i.e., for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A \\in { \\mathcal { A } }"
                    },
                    {
                        "type": "text",
                        "content": ", we have "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu ( T ^ { - 1 } ( A ) ) = \\mu ( A )"
                    },
                    {
                        "type": "text",
                        "content": ". For "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A , B \\in { \\mathcal { A } }"
                    },
                    {
                        "type": "text",
                        "content": ", if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu ( A - B ) = \\mu ( B - A ) = 0"
                    },
                    {
                        "type": "text",
                        "content": ", we say that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A = B"
                    },
                    {
                        "type": "text",
                        "content": "a.e. "
                    }
                ]
            },
            "bbox": [
                134,
                291,
                907,
                332
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Assume "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A \\in { \\mathcal { A } }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T ^ { - 1 } ( A ) = A"
                    },
                    {
                        "type": "text",
                        "content": "a.e..Prove that there exists a set "
                    },
                    {
                        "type": "equation_inline",
                        "content": "B \\in { \\mathcal { A } }"
                    },
                    {
                        "type": "text",
                        "content": "so that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T ^ { - 1 } B = B"
                    },
                    {
                        "type": "text",
                        "content": "and "
