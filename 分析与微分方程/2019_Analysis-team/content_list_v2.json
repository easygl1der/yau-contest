                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1) Show that there is no non-zero "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f \\in C _ { 0 } ^ { \\infty } ( \\mathbb { R } ^ { 2 } )"
                            },
                            {
                                "type": "text",
                                "content": "(compactly supported smooth function) so that its Fourier transform "
                            },
