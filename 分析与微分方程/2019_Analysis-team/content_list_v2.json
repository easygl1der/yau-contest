                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } \\times \\mathbb { R } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "t \\in \\mathbb R"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( x , y ) \\in \\mathbb { R } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ". We assume that it solves the following semilinear wave equation: "
                    }
                ]
            },
            "bbox": [
