        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "b) Show that there is a continuous function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f : [ 0 , + \\infty ) \\to ( - \\infty , + \\infty )"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f \\not \\equiv 0"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f ( 4 x ) = f ( 2 x ) + f ( x )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                330,
                801,
                362
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Solve the following problem: "
                    }
                ]
            },
            "bbox": [
                193,
                372,
                468,
                386
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left\\{ \\begin{array}{l} \\frac {d ^ {2} u}{d x ^ {2}} - u (x) = 4 e ^ {- x}, \\quad x \\in (0, 1), \\\\ u (0) = 0, \\quad \\frac {d u}{d x} (0) = 0. \\end{array} \\right.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/92277f939c8e10b7a88faf4fe5fb8629e6acb0c4061a837245221a2c9458bbf6.jpg"
                }
            },
            "bbox": [
                327,
                392,
                623,
                431
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Find an explicit conformal transformation of an open set "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U = \\{ | z | >"
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 \\} \\setminus ( - \\infty , - 1 ]"
                    },
                    {
                        "type": "text",
                        "content": "to the unit disc. "
                    }
                ]
            },
            "bbox": [
                193,
                437,
                801,
                470
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Assume "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f \\in C ^ { 2 } [ a , b ]"
                    },
                    {
                        "type": "text",
                        "content": "satisfying "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| f ( x ) | \\leq A , | f ^ { \\prime \\prime } ( x ) | \\leq B"
                    },
                    {
                        "type": "text",
                        "content": "for each "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x \\in [ a , b ]"
                    },
                    {
                        "type": "text",
                        "content": "and there exists "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x _ { 0 } ~ \\in ~ [ a , b ]"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| f ^ { ' } ( x _ { 0 } ) | \\le D"
                    },
                    {
                        "type": "text",
                        "content": ", then "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| f ^ { \\prime } ( x ) | \\leq 2 { \\sqrt { A B } } + D , \\forall x \\in [ a , b ]"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                193,
                478,
                801,
                532
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C ( [ 0 , 1 ] )"
                    },
                    {
                        "type": "text",
                        "content": "denote the Banach space of real valued continuous functions on [0, 1] with the sup norm, and suppose that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X \\subset C ( [ 0 , 1 ] )"
                    },
                    {
                        "type": "text",
                        "content": "is a dense linear subspace. Suppose "
                    },
                    {
                        "type": "equation_inline",
                        "content": "l : X  \\mathbb { R }"
                    },
                    {
                        "type": "text",
                        "content": "is a linear map (not assumed to be continuous in any sense) such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "l ( f ) \\geq 0"
                    },
                    {
                        "type": "text",
                        "content": "if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f \\in X"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f \\geq 0"
                    },
                    {
                        "type": "text",
                        "content": ". Show that there is a unique Borel measure "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu"
                    },
                    {
                        "type": "text",
                        "content": "on [0, 1] such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\textstyle l ( f ) = \\int f d \\mu"
                    },
                    {
                        "type": "text",
                        "content": "for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f \\in X"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                539,
                801,
                639
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "6. For "
                    },
                    {
                        "type": "equation_inline",
                        "content": "s \\geq 0"
                    },
                    {
                        "type": "text",
                        "content": ", let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H ^ { s } ( T )"
                    },
                    {
                        "type": "text",
                        "content": "be the space of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "L ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "functions "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "on the circle "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T = \\mathbb { R } / ( 2 \\pi \\mathbb { Z } )"
                    },
                    {
                        "type": "text",
                        "content": "whose Fourier coefficients "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { \\hat { f } _ { n } = \\int _ { 0 } ^ { 2 \\pi } e ^ { - i n x } f ( x ) d x } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": "/1 satisfy "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Sigma ( 1 + n ^ { 2 } ) ^ { s } | | \\hat { f } _ { n } | ^ { 2 } < \\infty"
                    },
                    {
                        "type": "text",
                        "content": ", with norm "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| | f | | _ { s } ^ { 2 } = ( 2 \\pi ) ^ { - 1 } \\Sigma ( 1 + n ^ { 2 } ) ^ { s } | \\tilde { f } _ { n } | ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
