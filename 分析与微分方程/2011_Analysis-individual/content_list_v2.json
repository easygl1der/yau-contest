                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "a. Show that for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "r > s \\ge 0"
                            },
                            {
                                "type": "text",
                                "content": ", the inclusion map "
                            },
                            {
                                "type": "equation_inline",
                                "content": "i : H ^ { r } ( T ) \\to H ^ { s } ( T )"
                            },
                            {
                                "type": "text",
                                "content": "is compact. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "b. Show that if "
                            },
                            {
                                "type": "equation_inline",
