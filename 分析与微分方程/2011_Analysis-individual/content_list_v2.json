                            {
                                "type": "equation_inline",
                                "content": "H ^ { s } ( T )"
                            },
                            {
                                "type": "text",
                                "content": "includes continuously into "
                            },
                            {
                                "type": "equation_inline",
                                "content": "C ( T )"
                            },
                            {
                                "type": "text",
                                "content": ", the space of continuous functions on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "T"
                            },
                            {
                                "type": "text",
                                "content": ", and the inclusion map is compact. "
                            }
                        ]
                    }
                ]
