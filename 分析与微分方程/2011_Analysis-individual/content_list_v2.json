                    {
                        "type": "equation_inline",
                        "content": "\\textstyle \\int _ { - \\infty } ^ { \\infty } { \\frac { x \\cos x d x } { ( x ^ { 2 } + 1 ) ( x ^ { 2 } + 2 ) } }"
                    }
                ]
            },
            "bbox": [
