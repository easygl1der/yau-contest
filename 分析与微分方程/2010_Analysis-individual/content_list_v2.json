                            {
                                "type": "equation_inline",
                                "content": "f \\in C ^ { 0 } [ 0 , 1 ]"
                            },
                            {
                                "type": "text",
                                "content": ", the space of continuous functions on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\lfloor 0 , 1 \\rfloor"
                            },
                            {
                                "type": "text",
                                "content": ", define a function "
                            }
