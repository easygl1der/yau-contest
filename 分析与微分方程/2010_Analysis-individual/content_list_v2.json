                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f : \\mathbb { R } \\to \\mathbb { R }"
                            },
                            {
                                "type": "text",
                                "content": "be any function. Prove that the set of points "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x"
                            },
                            {
                                "type": "text",
                                "content": "in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R }"
                            },
                            {
                                "type": "text",
                                "content": "where "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "is continuous is a countable intersection of open sets. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( z )"
                            },
                            {
                                "type": "text",
                                "content": "be holomorphic in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "D"
                            },
                            {
                                "type": "text",
                                "content": ": "
                            },
                            {
                                "type": "equation_inline",
                                "content": "| z | < 1"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "| f ( z ) | \\leq 1"
                            },
                            {
                                "type": "text",
                                "content": "(z ∈ D). If "
                            },
                            {
                                "type": "equation_inline",
                                "content": "z _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": "is a point in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "D"
                            },
                            {
                                "type": "text",
                                "content": "such that both "
                            },
                            {
                                "type": "equation_inline",
                                "content": "z _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "- z _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": "are zeros of order "
                            },
                            {
                                "type": "equation_inline",
                                "content": "m"
                            },
                            {
                                "type": "text",
                                "content": "of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( z )"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "0 < | z _ { 0 } | \\leq \\frac { m - 1 } { m }"
                            },
                            {
                                "type": "text",
                                "content": ", then "
                            },
                            {
                                "type": "equation_inline",
                                "content": "| f ( 0 ) | < e ^ { - 2 }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "4. Find a harmonic function "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "on the right half-plane such that when approaching any point in the positive half of the "
                            },
                            {
                                "type": "equation_inline",
                                "content": "y"
                            },
                            {
                                "type": "text",
                                "content": "-axis, the function has limit 1, while when approaching any point in the negative half of the "
                            },
                            {
                                "type": "equation_inline",
                                "content": "y"
                            },
                            {
                                "type": "text",
                                "content": "-axis, the function has limit "
                            },
                            {
                                "type": "equation_inline",
                                "content": "^ { - 1 }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "5. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K ( x , y ) \\in L ^ { 1 } ( [ 0 , 1 ] \\times [ 0 , 1 ] )"
                            },
                            {
                                "type": "text",
                                "content": ". For all "
