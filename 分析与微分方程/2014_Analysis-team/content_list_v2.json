                            {
                                "type": "equation_inline",
                                "content": "f : D  D"
                            },
                            {
                                "type": "text",
                                "content": "is a smooth map such that its Jacobian "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\left| \\frac { \\partial f } { \\partial x } \\right| \\equiv 1"
                            },
                            {
                                "type": "text",
                                "content": ", where "
                            },
                            {
                                "type": "equation_inline",
                                "content": "D"
                            },
                            {
                                "type": "text",
                                "content": "denotes the closure of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "D"
                            },
                            {
                                "type": "text",
                                "content": ". Prove "
                            }
