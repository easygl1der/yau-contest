                            {
                                "type": "equation_inline",
                                "content": "F ( z ) = z ^ { \\alpha } f ( z )"
                            },
                            {
                                "type": "text",
                                "content": ", where "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "is an analytic function over the disk "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\{ z | | z | < R \\}"
