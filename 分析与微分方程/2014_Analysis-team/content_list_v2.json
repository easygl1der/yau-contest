                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Construct an increasing function on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R }"
                            },
                            {
                                "type": "text",
