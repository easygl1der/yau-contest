        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\int_ {\\Omega} | u | ^ {2} d x \\leq C (\\Omega) \\int_ {\\Omega} \\Sigma_ {i = 1} ^ {n} | \\frac {\\partial u}{\\partial x _ {i}} | ^ {2} d x",
