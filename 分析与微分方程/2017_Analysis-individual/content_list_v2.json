                    {
                        "type": "equation_inline",
                        "content": "u \\in H _ { 0 } ^ { 1 } ( \\Omega ) = \\overline { { C _ { 0 } ^ { \\infty } ( \\Omega ) } } \\subset H ^ { 1 } ( \\Omega )"
                    },
