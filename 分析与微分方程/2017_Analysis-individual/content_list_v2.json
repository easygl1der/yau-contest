                                "type": "text",
                                "content": ", depending only on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "E"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Omega"
                            },
                            {
                                "type": "text",
                                "content": ", such that every positive harmonic function "
