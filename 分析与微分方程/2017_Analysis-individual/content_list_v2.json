                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. Suppose "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "is integrable on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "[ - \\pi , \\pi ]"
                            },
                            {
                                "type": "text",
                                "content": ", prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Sigma _ { n = - \\infty } ^ { \\infty } a _ { n } r ^ { | n | } e ^ { i n x }"
                            },
                            {
                                "type": "text",
                                "content": "tends to "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( x )"
                            },
                            {
                                "type": "text",
                                "content": "for a.e. x, as r → 1, r < 1. Here an = 12π π−π f (x)e−inxdx. "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x"
                            },
                            {
                                "type": "equation_inline",
                                "content": "r  1 , r < 1"
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\begin{array} { r } { a _ { n } = \\frac { 1 } { 2 \\pi } \\int _ { - \\pi } ^ { \\prime \\prime } f ( x ) e ^ { - i n x } d x } \\end{array}"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "H"
                            },
                            {
                                "type": "text",
                                "content": "be a Hilbert space equipped with an inner product (.,.) and a norm "
                            },
                            {
                                "type": "equation_inline",
                                "content": "| | . | | ="
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\left( . , . \\right) ^ { \\frac { 1 } { 2 } }"
                            },
                            {
                                "type": "text",
                                "content": ". A sequence "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\left\\{ f _ { k } \\right\\}"
                            },
                            {
                                "type": "text",
                                "content": "is converge to "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f \\in H"
                            },
                            {
                                "type": "text",
                                "content": "if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "| | f _ { k } - f | | \\to 0"
                            },
                            {
                                "type": "text",
                                "content": ". A sequence "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\{ f _ { k } \\} \\subset H"
                            },
                            {
                                "type": "text",
                                "content": "is said converge weakly to "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f \\in H"
                            },
                            {
                                "type": "text",
                                "content": "if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( f _ { k } , g ) \\to ( f , g )"
                            },
                            {
                                "type": "text",
                                "content": "for any "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g \\in H"
                            },
                            {
                                "type": "text",
                                "content": ". Prove the following statements: "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
