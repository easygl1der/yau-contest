                                "type": "text",
                                "content": "is a compact set in a region "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Omega"
                            },
                            {
                                "type": "text",
                                "content": ", prove that there exists a constant "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M > 0"
