                    {
                        "type": "equation_inline",
                        "content": "\\vert \\vert f _ { k } \\vert \\vert  \\vert \\vert f \\vert \\vert"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\left\\{ f _ { k } \\right\\}"
                    },
                    {
                        "type": "text",
