            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H ^ { 2 } ( \\Delta )"
                    },
                    {
                        "type": "text",
                        "content": "be the space of holomorphic functions in the unit disk "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Delta = \\{ | z | < 1 \\}"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { \\int _ { \\Delta } | f | ^ { 2 } | d z | ^ { 2 } < \\infty } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H ^ { 2 } ( \\Delta )"
                    },
                    {
                        "type": "text",
                        "content": "is a Hilbert space and that for any "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r < 1"
                    },
                    {
                        "type": "text",
                        "content": ", the map "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T : H ^ { 2 } ( \\Delta ) \\to H ^ { 2 } ( \\Delta )"
                    },
                    {
                        "type": "text",
                        "content": "given by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T f ( z ) : = f ( r z )"
                    },
                    {
                        "type": "text",
                        "content": "is a compact operator. "
                    }
                ]
            },
            "bbox": [
                193,
                310,
                801,
                380
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. For any continuous function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f ( z )"
                    },
                    {
                        "type": "text",
                        "content": "of period 1, show that the equation "
                    }
                ]
            },
            "bbox": [
