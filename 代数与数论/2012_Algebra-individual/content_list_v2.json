                495
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "be the orthogonal group. Prove that fixed point subspace "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( V \\otimes _ { \\mathbb { C } } V ) ^ { \\mathsf { O } ( \\mathsf { V } ) }"
