                811,
                533
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathfrak { D }"
                    },
                    {
                        "type": "text",
                        "content": "be the ring consisting of all linear differential operators of finite order on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R }"
                    },
                    {
                        "type": "text",
                        "content": "with polynomial coefficients, of the form "
                    }
                ]
            },
            "bbox": [
                191,
                542,
                803,
                576
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "D = \\sum_ {i = 0} ^ {n} a _ {i} (x) \\frac {d ^ {i}}{d x ^ {i}}",
