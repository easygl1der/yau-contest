            "bbox": [
                289,
                223,
                709,
                274
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Prove that the polynomial "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x ^ { 6 } + 3 0 x ^ { 5 } - 1 5 x ^ { 3 } + 6 x - 1 2 0"
                    },
                    {
                        "type": "text",
                        "content": "cannot be written as a product of two polynomials of rational coefficients and positive degrees. "
                    }
                ]
            },
            "bbox": [
                191,
                288,
                801,
                338
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { F } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "be the field of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "-elements and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G L _ { n } ( \\mathbb { F } _ { p } )"
                    },
                    {
                        "type": "text",
                        "content": "the group of invertible "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "matrices. "
                    }
                ]
            },
            "bbox": [
                191,
                346,
                803,
                379
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(1) Compute the order of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G L _ { n } ( \\mathbb { F } _ { p } )"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(2) Find a Sylow p-subgroup of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G L _ { n } ( \\mathbb { F } _ { p } )"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(3) Compute the number of Sylow p-subgroups. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                223,
                382,
                638,
                430
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V"
                    },
                    {
                        "type": "text",
                        "content": "be a finite dimensional vector space over complex field "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { C }"
                    },
                    {
                        "type": "text",
                        "content": "with a nondegenerate symmetric bilinear form "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( , )"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    }
                ]
            },
            "bbox": [
                191,
                439,
                801,
                473
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "O (V) = \\{g \\in G L (V) | (g u, g v) = (u, v), u, v \\in V \\}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/d13a9fb0c24fb26014a594cbe0cbff70b37e6c8e9db0e58e75534e1ec508b2cf.jpg"
