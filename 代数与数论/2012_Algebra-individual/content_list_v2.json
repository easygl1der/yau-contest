                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\in \\mathbb N"
                    },
                    {
                        "type": "text",
                        "content": "and polynomials "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a _ { 0 } ( x ) , \\dotsb , a _ { n } ( x ) \\in"
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } [ x ]"
                    },
                    {
                        "type": "text",
                        "content": ". This ring "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathfrak { D }"
                    },
