        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 5 (20 points). In this problem, all matrices are "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\times n"
                    },
                    {
                        "type": "text",
                        "content": "with complex entries. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V"
                    },
                    {
                        "type": "text",
                        "content": "be matrices such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U V \\neq V U"
                    },
                    {
                        "type": "text",
                        "content": ". Assume that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U"
                    },
                    {
                        "type": "text",
                        "content": "is diagonalizable and commutes with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V U V ^ { - 1 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                136,
                417,
                858,
                468
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) (10 points) For λ, µ ∈ C, let "
                    }
                ]
            },
            "bbox": [
                152,
                480,
                433,
                498
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "E _ {\\lambda , \\mu} = \\left\\{x \\in \\mathbb {C} ^ {n} \\mid U x = \\lambda x, \\quad V U V ^ {- 1} x = \\mu x \\right\\}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/8727a023f2539a39d8a27807099717d1e30e94fe9509a19bfd389e40a8b2fdea.jpg"
                }
            },
            "bbox": [
                319,
                511,
                721,
                531
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Show that there exist couples "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( \\lambda _ { 1 } , \\mu _ { 1 } ) ~ \\neq ~ ( \\lambda _ { 2 } , \\mu _ { 2 } )"
                    },
                    {
                        "type": "text",
                        "content": ", satisfying "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda _ { i } ~ \\neq ~ \\mu _ { i }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E _ { \\lambda _ { i } , \\mu _ { i } } \\neq 0"
                    },
                    {
                        "type": "text",
                        "content": "for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "i = 1 , 2"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                184,
                543,
                858,
                579
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) (10 points) For a matrix "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": ", we define "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathrm { N } ( A ) : = \\mathrm { t r } ( A ^ { * } A )"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A ^ { * } = \\bar { A } ^ { T }"
                    },
                    {
                        "type": "text",
                        "content": "is the conjugate transpose of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": ". Assume that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V"
                    },
                    {
                        "type": "text",
                        "content": "are unitary (namely, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U ^ { * } U = V ^ { * } V"
                    },
                    {
                        "type": "text",
                        "content": "is the identity matrix). Deduce that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathrm { N } ( 1 + V ) \\geq 4"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
