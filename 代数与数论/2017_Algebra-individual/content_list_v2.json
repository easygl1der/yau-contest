        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) (6 points) Show that the set "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathcal { P }"
                            },
                            {
                                "type": "text",
                                "content": "of subextensions of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "L / F"
                            },
                            {
                                "type": "text",
                                "content": "not containing "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x"
                            },
                            {
                                "type": "text",
                                "content": "has a maximal element "
                            },
                            {
                                "type": "equation_inline",
                                "content": "E"
                            },
                            {
                                "type": "text",
