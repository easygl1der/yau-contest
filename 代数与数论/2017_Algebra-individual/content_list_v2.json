                            {
                                "type": "equation_inline",
                                "content": "K / E"
                            },
                            {
                                "type": "text",
                                "content": "be a nontrivial finite extension contained in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "L"
                            },
                            {
                                "type": "text",
                                "content": ". Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x \\in K"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) (6 points) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K ^ { \\prime }"
                            },
                            {
                                "type": "text",
                                "content": "be the Galois closure of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K / E"
                            },
                            {
                                "type": "text",
                                "content": "in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "L"
                            },
                            {
                                "type": "text",
                                "content": ". Show that there exists "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g \\in G = \\operatorname { G a l } ( K ^ { \\prime } / E )"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g x \\neq x"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) (8 points) Deduce that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K / E"
                            },
                            {
                                "type": "text",
                                "content": "is a cyclic Galois extension. "
                            }
                        ]
                    }
                ]
            },
