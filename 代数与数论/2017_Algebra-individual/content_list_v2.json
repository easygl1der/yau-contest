        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 2 (20 points). Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "be a finite abelian group and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\phi : A  A"
                    },
                    {
                        "type": "text",
                        "content": "be an endomorphism. Put "
                    }
                ]
            },
            "bbox": [
                139,
                417,
                858,
                451
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "A _ {\\mathrm {n i l}} := \\{x \\in A \\mid \\phi^ {k} (x) = 0 \\mathrm {f o r s o m e} k \\geq 1 \\}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/305621e2921ecea16524188a8eb4dc32fecaa3d0998d7d52241a366099f8a7a3.jpg"
                }
            },
            "bbox": [
