        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 1 (20 points). Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { Q } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "denote the field of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "-adic numbers and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { Z } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "denote the ring of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "-adic integers ( "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "is a prime number). "
                    }
                ]
            },
            "bbox": [
                139,
                221,
                858,
                256
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) (5 points) Show that for every integer "
                            },
                            {
                                "type": "equation_inline",
                                "content": "k \\geq 0"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( p ^ { - k } \\mathbb { Z } _ { p } ) / \\mathbb { Z } _ { p } \\cong \\mathbb { Z } / p ^ { k } \\mathbb { Z }"
                            },
                            {
                                "type": "text",
                                "content": "as abelian groups. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) (5 points) Determine the endomorphism ring of the abelian group "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( p ^ { - k } \\mathbb { Z } _ { p } ) / \\mathbb { Z } _ { p }"
                            },
                            {
                                "type": "text",
                                "content": "( "
                            },
                            {
                                "type": "equation_inline",
                                "content": "k \\geq 0"
                            },
                            {
                                "type": "text",
                                "content": "). "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) (5 points) Determine the endomorphism ring of the abelian group "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Q } _ { p } / \\mathbb { Z } _ { p }"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(d) (5 points) Determine the endomorphism ring of the abelian group "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Q } / \\mathbb { Z }"
                            }
                        ]
                    }
                ]
            },
            "bbox": [
