        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4 (20 points). The goal of this problem is to prove the Chevalley–Warning theorem. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "be a prime number and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "q"
                    },
                    {
                        "type": "text",
                        "content": "a power of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                136,
                101,
                858,
                137
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) (8 points) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "0 \\leq a < q - 1"
                    },
                    {
                        "type": "text",
                        "content": "be an integer. Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ( X ^ { a } ) : = \\textstyle \\sum _ { x \\in \\mathbb { F } _ { q } } x ^ { a }"
                    },
                    {
                        "type": "text",
                        "content": "xa equals 0. Here we adopt the convention "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x ^ { 0 } = 1"
                    },
                    {
                        "type": "text",
                        "content": "in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { F } _ { q }"
                    },
                    {
                        "type": "text",
                        "content": "even for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x = 0"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                149,
                147,
                855,
                181
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) (12 points) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f _ { 1 } , \\ldots , f _ { m } \\in \\mathbb { F } _ { q } [ X _ { 1 } , \\ldots , X _ { n } ]"
                    },
                    {
                        "type": "text",
                        "content": "be polynomials in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "variables satisfying "
                    }
                ]
            },
            "bbox": [
                149,
                193,
                855,
                225
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\sum_ {i = 1} ^ {m} \\deg (f _ {i}) <   n.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/3bd893a1909535cddb1fcc08c890c22879c4bacc0ac77fe29ab48198da45005b.jpg"
                }
            },
            "bbox": [
                455,
                227,
                589,
                263
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { P = \\prod _ { i = 1 } ^ { m } ( 1 - f _ { i } ^ { q - 1 } ) } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": "satisfies "
                    }
                ]
            },
            "bbox": [
                184,
                271,
                529,
                290
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "S(P):= \\sum_{(x_{1},\\ldots ,x_{n})\\in \\mathbb{F}_{q}^{n}}P(x_{1},\\ldots ,x_{n}) = 0.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/b4f60d99aa429cdb7eccf4dd85a7d030eca1c04d0e0ee06271fab70dbacb463b.jpg"
                }
            },
            "bbox": [
                357,
                302,
                685,
                336
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Deduce that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "divides the cardinality of the set "
                    }
                ]
            },
            "bbox": [
                184,
                349,
                600,
                365
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "V = \\left\\{\\left(x _ {1}, \\dots , x _ {n}\\right) \\in \\mathbb {F} _ {q} ^ {n} \\mid f _ {i} \\left(x _ {1}, \\dots , x _ {n}\\right) = 0 \\quad \\forall i \\right\\}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/9b52c88c1272032a5ec92f4413f72e8d42b708f7bd5e3b5691fb3e3ee45375d7.jpg"
                }
