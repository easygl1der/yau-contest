            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) (15 points) Show that there is a subgroup "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": "of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\phi"
                            },
                            {
                                "type": "text",
                                "content": "restricts to an automorphism of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
