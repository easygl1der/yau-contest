                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 3 (20 points). Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "L / F"
                    },
                    {
                        "type": "text",
                        "content": "be a Galois field extension, not necessarily finite. Let "
                    },
