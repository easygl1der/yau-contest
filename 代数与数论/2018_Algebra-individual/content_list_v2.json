                    {
                        "type": "equation_inline",
                        "content": "K = \\mathbb { Q } ( { \\sqrt [ { 3 } ] { 5 } } )"
                    },
                    {
                        "type": "text",
                        "content": "and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "L"
                    },
                    {
                        "type": "text",
                        "content": "be the Galois closure of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
