                            {
                                "type": "equation_inline",
                                "content": "x ^ { 3 } \\equiv 5"
                            },
                            {
                                "type": "text",
                                "content": "(mod "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": ") has a solution in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { F } _ { p }"
                            },
                            {
                                "type": "text",
                                "content": ". Prove the following decomposition law in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "L"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
