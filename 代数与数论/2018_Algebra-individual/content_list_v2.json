                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) (6 points) Show that if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "2 ^ { k } - 1"
                            },
                            {
                                "type": "text",
                                "content": "is a prime for some integer "
                            },
                            {
                                "type": "equation_inline",
                                "content": "k \\geq 1"
                            },
                            {
                                "type": "text",
                                "content": ", then "
                            },
                            {
                                "type": "equation_inline",
                                "content": "k"
                            },
                            {
                                "type": "text",
                                "content": "is a prime. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) (6 points) Show that if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "2 ^ { k } + 1"
                            },
                            {
                                "type": "text",
                                "content": "is a prime for some integer "
                            },
                            {
                                "type": "equation_inline",
                                "content": "k \\geq 1"
                            },
                            {
                                "type": "text",
                                "content": ", then "
                            },
                            {
                                "type": "equation_inline",
                                "content": "k"
                            },
                            {
                                "type": "text",
                                "content": "is a power of 2. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) (8 points) Prove the following theorem of Goldbach: for integers "
                            },
                            {
                                "type": "equation_inline",
                                "content": "i , j \\geq 0"
                            },
                            {
                                "type": "text",
                                "content": "with "
                            },
                            {
                                "type": "equation_inline",
                                "content": "i \\neq j"
                            },
                            {
                                "type": "text",
                                "content": ", the integers "
                            },
                            {
                                "type": "equation_inline",
                                "content": "2 ^ { 2 ^ { i } } + 1"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "2 ^ { 2 ^ { j } } + 1"
                            },
                            {
                                "type": "text",
                                "content": "are coprime. "
                            }
                        ]
                    }
                ]
