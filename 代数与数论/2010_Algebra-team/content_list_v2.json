            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. For a real number "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r"
                    },
                    {
                        "type": "text",
                        "content": ", let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "[ r ]"
                    },
                    {
                        "type": "text",
                        "content": "denote the maximal integer less or equal than "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { \\frac { 1 } { a } + \\frac { 1 } { b } = 1 } \\end{array}"
                    },
                    {
                        "type": "equation_inline",
                        "content": "r"
                    },
                    {
                        "type": "text",
                        "content": ". Let . Show that the two sequences of integers "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "b"
                    },
                    {
                        "type": "text",
                        "content": "be two positive irrational numbers such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "[ a x ]"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "[ b x ]"
                    },
                    {
                        "type": "text",
                        "content": "for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x = 1 , 2 , 3 , \\cdots"
                    },
                    {
                        "type": "text",
                        "content": "contain all natural numbers without repetition. "
                    }
                ]
            },
            "bbox": [
                208,
                316,
                815,
                382
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\geq 2"
                    },
                    {
                        "type": "text",
                        "content": "be an integer and consider the Fermat equation "
                    }
                ]
            },
            "bbox": [
                208,
                391,
                741,
                407
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "X ^ {n} + Y ^ {n} = Z ^ {n}, \\qquad X, Y, Z \\in \\mathbb {C} [ t ].",
                "math_type": "latex",
                "image_source": {
                    "path": "images/0799bd955fdb95ce97853e56ea8926504a169b91c24a014b6f6002f2613a9718.jpg"
                }
            },
            "bbox": [
                359,
                413,
                663,
                431
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Find all nontrivial solution "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( X , Y , Z )"
                    },
                    {
                        "type": "text",
                        "content": "of the above equation in the sense that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X , Y , Z"
                    },
                    {
                        "type": "text",
                        "content": "have no common zero and are not all constant. "
                    }
                ]
            },
            "bbox": [
                208,
                435,
                815,
                468
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\geq 7"
                    },
                    {
                        "type": "text",
                        "content": "be an odd prime number. "
                    }
                ]
            },
            "bbox": [
                208,
                476,
                544,
                494
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Evaluate the rational number "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\cos ( \\pi / 7 ) \\cdot \\cos ( 2 \\pi / 7 ) \\cdot \\cos ( 3 \\pi / 7 )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Pi _ { n = 1 } ^ { ( p - 1 ) / 2 } \\cos ( n \\pi / p )"
                            },
                            {
                                "type": "text",
                                "content": "is a rational number and determine its value. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                236,
                497,
                813,
                545
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. For a positive integer "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a"
                    },
                    {
                        "type": "text",
                        "content": ", consider the polynomial "
                    }
                ]
            },
            "bbox": [
                208,
                557,
                658,
                574
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "f _ {a} = x ^ {6} + 3 a x ^ {4} + 3 x ^ {3} + 3 a x ^ {2} + 1.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/68956a53a969fbd03cfc31f2ad5f732db3fb6d3f618cd01dc1e2dcdb99fcc6c5.jpg"
                }
            },
            "bbox": [
                369,
                577,
                655,
                596
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Show that it is irreducible. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F"
                    },
                    {
                        "type": "text",
                        "content": "be the splitting field of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f _ { a }"
                    },
                    {
                        "type": "text",
                        "content": ". Show that its Galois group is solvable. "
                    }
                ]
            },
            "bbox": [
                208,
                601,
                815,
                634
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. Prove that a group of order 150 is not simple. "
                    }
                ]
            },
            "bbox": [
                208,
                643,
                633,
                659
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "6. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V \\cong \\mathbb { C } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "be the standard representation of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S L _ { 2 } ( \\mathbb { C } )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                208,
                667,
                707,
                684
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Show that the "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": "-th symmetric power "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V _ { n } \\ = \\ \\operatorname { S y m } ^ { n } V"
                            },
                            {
                                "type": "text",
                                "content": "is irreducible. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Which "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V _ { n }"
                            },
                            {
                                "type": "text",
                                "content": "appear in the decomposition of the tensor product "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V _ { 2 } \\otimes V _ { 3 }"
                            },
                            {
                                "type": "text",
                                "content": "into irreducible representations? "
                            }
                        ]
                    }
                ]
            },
