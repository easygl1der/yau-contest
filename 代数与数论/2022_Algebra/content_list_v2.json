        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. "
                    }
                ],
                "level": 1
            },
            "bbox": [
                112,
                190,
                199,
                204
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p ( x ) = a _ { n } x ^ { n } + \\cdots + a _ { 1 } x + a _ { 0 } \\in R [ x ]"
                            },
                            {
                                "type": "text",
                                "content": "be a polynomial over an integral domain "
                            },
                            {
                                "type": "equation_inline",
                                "content": "R"
                            },
                            {
                                "type": "text",
                                "content": ". Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K"
                            },
                            {
                                "type": "text",
                                "content": "denote the fraction field of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "R"
                            },
                            {
                                "type": "text",
                                "content": ". Suppose "
                            },
                            {
                                "type": "equation_inline",
                                "content": "a / b \\in K"
                            },
                            {
                                "type": "text",
                                "content": "is a root of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p ( x )"
                            },
                            {
                                "type": "text",
                                "content": ", where "
                            },
                            {
                                "type": "equation_inline",
                                "content": "a , b \\in R"
                            },
                            {
                                "type": "text",
                                "content": "and are relatively prime. Then, show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "a | a _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "b | a _ { n }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbf { Q } ( { \\sqrt { 2 } } , { \\sqrt { 3 } } ) = \\mathbf { Q } ( { \\sqrt { 2 } } + { \\sqrt { 3 } } )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                125,
                215,
                883,
                292
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 2. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R"
                    },
                    {
                        "type": "text",
                        "content": "be an integral domain with the fraction field "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K ."
                    },
                    {
                        "type": "text",
                        "content": ". An "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R"
                    },
                    {
                        "type": "text",
                        "content": "-module "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P"
                    },
                    {
                        "type": "text",
                        "content": "is projective if there is an "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R"
                    },
                    {
                        "type": "text",
                        "content": "-module "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Q"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P \\oplus Q \\cong F"
                    },
                    {
                        "type": "text",
                        "content": "for some free "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R"
                    },
                    {
                        "type": "text",
                        "content": "-module "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F ."
                    },
                    {
                        "type": "text",
                        "content": ". A fractional ideal "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "is an "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R"
                    },
                    {
                        "type": "text",
                        "content": "-submodule of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A = d ^ { - 1 } I"
                    },
                    {
                        "type": "text",
                        "content": "for some ideal "
                    },
                    {
                        "type": "equation_inline",
                        "content": "I"
                    },
                    {
                        "type": "text",
                        "content": "of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R"
                    },
                    {
                        "type": "text",
                        "content": "and a nonzero element "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d \\in R"
                    },
                    {
                        "type": "text",
                        "content": ". A fractional ideal "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "is called invertible if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A B = R"
                    },
                    {
                        "type": "text",
                        "content": "for some fractional ideal "
                    },
                    {
                        "type": "equation_inline",
                        "content": "B"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                109,
                310,
                883,
                377
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Show that an invertible fractional ideal "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "is a projective "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R"
                    },
                    {
                        "type": "text",
                        "content": "-module. "
                    }
                ]
            },
            "bbox": [
                112,
                388,
                571,
                404
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 3. Give a direct proof that the Lie algebra "
                    },
                    {
                        "type": "equation_inline",
                        "content": "{ \\mathfrak { s l } } ( 4 , \\mathbf { C } )"
                    },
                    {
                        "type": "text",
                        "content": "is isomorphic to the Lie algebra "
                    },
                    {
                        "type": "equation_inline",
                        "content": "{ \\mathfrak { s o } } ( 6 , \\mathbf { C } )"
                    },
                    {
                        "type": "text",
                        "content": ". (You should construct a Lie algebra homomorphism and prove that it is an ismorphism; you should not use Dynkin diagrams or the classification theory of simple Lie algebras.) "
                    }
                ]
            },
            "bbox": [
                109,
                422,
                883,
                474
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A = { \\mathcal { O } } _ { K }"
                    },
                    {
                        "type": "text",
                        "content": "be the ring of integers of a number field "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K ."
                    },
                    {
                        "type": "text",
                        "content": ". Given a nonzero ideal "
                    },
                    {
                        "type": "equation_inline",
                        "content": "{ \\mathfrak { a } } \\subset A"
                    },
                    {
                        "type": "text",
                        "content": "and an arbitrary nonzero element "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a \\in { \\mathfrak { a } }"
                    },
                    {
                        "type": "text",
                        "content": ", show that there exists "
                    },
                    {
                        "type": "equation_inline",
                        "content": "b \\in { \\mathfrak { a } }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "b"
                    },
                    {
                        "type": "text",
                        "content": "generate ?? (in particular, every ideal is 2-generated). "
                    }
                ]
            },
            "bbox": [
                109,
                493,
                883,
                542
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 5. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "be a prime number and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\zeta _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "be a primitive "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "-th root of unity. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K = \\mathbf { Q } ( \\zeta _ { p } )"
                    }
                ]
            },
            "bbox": [
                112,
                561,
                759,
                580
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\begin{array} { r } { \\Phi _ { p } = \\sum _ { i = 0 } ^ { p - 1 } X ^ { i } } \\end{array}"
                            },
                            {
                                "type": "text",
                                "content": "is the minimal polynomial of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\zeta _ { p }"
                            },
                            {
                                "type": "text",
                                "content": "over ??. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Compute the trace "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathrm { T r } _ { K / \\mathbf { Q } } ( 1 - \\zeta _ { p } )"
                            },
                            {
                                "type": "text",
                                "content": "and the norm "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathcal { N } _ { K / \\mathbf { Q } } ( 1 - \\zeta _ { p } )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( 1 - \\zeta _ { p } ) \\mathcal { O } _ { K } \\cap \\mathbf { Z } = p \\mathbf { Z }"
                            },
                            {
                                "type": "text",
                                "content": "and deduce that for all "
                            },
                            {
                                "type": "equation_inline",
                                "content": "y \\in { \\mathcal { O } } _ { K }"
                            },
                            {
                                "type": "text",
                                "content": ", we have "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                125,
                587,
                656,
                660
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathrm {T r} _ {K / \\mathbf {Q}} (y (1 - \\zeta_ {p})) \\in p \\mathbf {Z}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/47681803b16234cbbbc6de5b0bdc6a7d4e5752f2fc474e5386ee79c8e86a2b16.jpg"
                }
            },
            "bbox": [
                436,
                676,
                602,
                696
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(d) Determine explicitly the ring of integers of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K ."
                    }
                ]
            },
            "bbox": [
                125,
                720,
                472,
                738
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 6. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta \\in \\overline { { \\mathbf { Q } } }"
                    },
                    {
                        "type": "text",
                        "content": "be a root of the polynomial "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f ( X ) = X ^ { 3 } + 1 2 X ^ { 2 } + 8 X + 1"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K = \\mathbf { Q } ( \\theta )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                112,
                758,
                766,
                776
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g ( X ) = X ^ { 3 } + p X + q \\in \\mathbf { Z } [ X ]"
                            },
                            {
                                "type": "text",
                                "content": ". Compute the discriminant disc "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( g )"
                            },
                            {
                                "type": "text",
                                "content": "of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g ( X )"
                            },
                            {
                                "type": "text",
                                "content": "in terms of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p , q"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( X )"
                            },
                            {
                                "type": "text",
                                "content": "is irreducible over ??. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) Compute the discriminant "
                            },
                            {
                                "type": "equation_inline",
                                "content": "d _ { K } ( 1 , \\theta , \\theta ^ { 2 } )"
                            },
                            {
                                "type": "text",
                                "content": ". Please provide necessary details. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(d) For any arbitrary number field "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F"
                            },
                            {
                                "type": "text",
                                "content": "of degree "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": ", let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "a _ { 1 } , a _ { 2 } , \\dots , a _ { n } \\in \\mathcal { O } _ { F } ."
                            },
                            {
                                "type": "text",
                                "content": ". Find and verify a sufficient condition in terms of the discriminant "
                            },
                            {
                                "type": "equation_inline",
                                "content": "d _ { F } ( a _ { 1 } , \\dots , a _ { n } )"
                            },
                            {
                                "type": "text",
                                "content": "that the "
                            },
                            {
                                "type": "equation_inline",
                                "content": "a _ { 1 } , \\ldots , a _ { n }"
                            },
                            {
                                "type": "text",
                                "content": "form an integral basis of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(e) Write down an explicit integral basis of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K"
                            },
                            {
                                "type": "text",
                                "content": "in terms of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\boldsymbol { \\theta }"
                            },
                            {
                                "type": "text",
                                "content": "by using the above sufficient condition you have found. Please justify your arguments. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
