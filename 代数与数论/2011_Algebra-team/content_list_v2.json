                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F ^ { \\prime }"
                            },
                            {
                                "type": "text",
                                "content": "be a field and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F"
                            },
                            {
                                "type": "text",
                                "content": "the algebraic closure of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F ^ { \\prime }"
                            },
                            {
                                "type": "text",
                                "content": ". Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( x , y )"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g ( x , y )"
                            },
                            {
                                "type": "text",
                                "content": "be polynomials in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F [ x , y ]"
                            },
                            {
                                "type": "text",
                                "content": "such that g.c.d. "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( f , g ) = 1"
                            },
                            {
                                "type": "text",
                                "content": "in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F [ x , y ]"
                            },
                            {
                                "type": "text",
                                "content": ". Show that there are only finitely many "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( a , b ) \\in F ^ { \\times 2 }"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( a , b ) ="
                            },
                            {
                                "type": "equation_inline",
                                "content": "g ( a , b ) = 0"
                            },
                            {
                                "type": "text",
                                "content": ". Can you generalize this to the cases of more than twovariables? "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\boldsymbol { D }"
                            },
                            {
                                "type": "text",
                                "content": "be a PID, and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "D ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "the free module of rank "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": "over "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\boldsymbol { D }"
                            },
                            {
                                "type": "text",
                                "content": ". Then any submodule of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "D ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "is a free module of rank "
                            },
                            {
                                "type": "equation_inline",
                                "content": "m \\leq n"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3. Identify pairs of integers "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n \\neq m \\in \\mathbb { Z } _ { + }"
                            },
                            {
                                "type": "text",
                                "content": "such that the quotient rings "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Z } [ x , y ] / ( x ^ { 2 } - y ^ { n } ) \\cong \\mathbb { Z } [ x , y ] / ( x ^ { 2 } - y ^ { m } )"
                            },
                            {
                                "type": "text",
                                "content": "; and identify pairs of integers "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n \\neq m \\in \\mathbb { Z } _ { + }"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Z } [ x , y ] / ( x ^ { 2 } - y ^ { n } ) \\not \\cong \\mathbb { Z } [ x , y ] / ( x ^ { 2 } - y ^ { m } )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "4. Is it possible to find an integer "
