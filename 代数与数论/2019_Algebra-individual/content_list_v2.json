        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "be a finite group. Assume that for any representation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V"
                    },
                    {
                        "type": "text",
                        "content": "of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "over a field of characteristic zero, the character "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\chi _ { V }"
                    },
                    {
                        "type": "text",
                        "content": "takes value in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { Q }"
                    },
                    {
                        "type": "text",
                        "content": ". Assume "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g"
                    },
                    {
                        "type": "text",
                        "content": "is an element in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g ^ { \\mathrm { 2 0 1 9 } } = 1"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                134,
                159,
                905,
                187
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Prove that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g ^ { 1 9 }"
                    },
                    {
                        "type": "text",
                        "content": "are conjugate in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    }
                ]
            },
            "bbox": [
                157,
                192,
                462,
                205
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "be a prime number, and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { F } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "be the finite field with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "elements. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F = \\mathbb { F } _ { p } ( t )"
                    },
                    {
                        "type": "text",
                        "content": "be the field of rational functions over "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { F } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": ". Consider all subfields "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C"
                    },
                    {
                        "type": "text",
                        "content": "of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F ^ { \\dagger }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F / C"
                    },
                    {
                        "type": "text",
                        "content": "is a finite Galois extension. "
                    }
                ]
            },
            "bbox": [
                134,
                216,
                907,
                244
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. Show that among such subfields, there is a smallest one "
                            },
                            {
                                "type": "equation_inline",
                                "content": "C _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": ", i.e., "
                            },
                            {
                                "type": "equation_inline",
                                "content": "C _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": "is contained in any other "
                            },
                            {
                                "type": "equation_inline",
                                "content": "C"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. What is the degree of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F / C _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": "? "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                171,
                256,
                902,
                288
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R \\subset R ^ { \\prime }"
                    },
                    {
                        "type": "text",
                        "content": "be an integral extension of commutative rings. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathfrak { p ^ { \\prime } }"
                    },
                    {
                        "type": "text",
                        "content": "be a prime ideal of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R ^ { \\prime }"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathfrak { p ^ { \\prime } }"
                    },
                    {
                        "type": "text",
                        "content": "is a maximal ideal of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R ^ { \\prime }"
                    },
                    {
                        "type": "text",
                        "content": "if and only if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathfrak { p ^ { \\prime } } \\cap R"
                    },
                    {
                        "type": "text",
                        "content": "is a maximal ideal of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                134,
                300,
                905,
                329
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "4) 1. Prove that GL "
                            },
                            {
                                "type": "equation_inline",
                                "content": "{ \\bf \\Phi } _ { n } ( \\mathbb { C } )"
                            },
                            {
                                "type": "text",
                                "content": "is path-connected. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Let "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                134,
                338,
                478,
                369
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "X = \\left\\{A \\in \\operatorname {G L} _ {n} (\\mathbb {C}) \\mid A ^ {m} = \\operatorname {I d} \\right\\},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/91da7f46689f90e5c9247547752b163a700a41a22960c0564532ebc55b84aa50.jpg"
                }
            },
            "bbox": [
                436,
                372,
                663,
                386
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Describe the path-connected component of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "and prove your answer. "
                    }
                ]
            },
            "bbox": [
                193,
                394,
                709,
                407
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5) The Fibonacci sequence is defined by "
                    }
                ]
            },
            "bbox": [
                134,
                417,
                435,
                431
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "F _ {0} = 0, \\quad F _ {1} = 1, \\quad F _ {n + 2} = F _ {n + 1} + F _ {n}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/554f5beffda8ea131e46689cae13ad7f233a2e99bef9593f70d102f7c1f0fbe8.jpg"
                }
            },
            "bbox": [
                386,
                443,
                677,
                458
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "be a prime number. "
                    }
                ]
            },
            "bbox": [
                156,
                469,
                349,
                483
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. Show that if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p \\equiv 1 , 4"
                            },
                            {
                                "type": "text",
                                "content": "(mod 5), then "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": "divides "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F _ { p - 1 }"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { F } _ { p ^ { 2 } }"
                            },
                            {
                                "type": "text",
                                "content": "be the finite field of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "elements. Show that the norm map "
                            },
                            {
                                "type": "equation_inline",
                                "content": "N : \\mathbb { F } _ { p ^ { 2 } } ^ { \\times } \\to \\mathbb { F } _ { p } ^ { \\times }"
                            },
                            {
                                "type": "text",
                                "content": "is surjective, and deduce the cardinality of the kernel of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "N"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3. Show that if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p \\equiv 2 , 3"
                            },
                            {
                                "type": "text",
                                "content": "(mod 5), then "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": "divides "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F _ { p + 1 }"
                            }
                        ]
                    }
                ]
            },
