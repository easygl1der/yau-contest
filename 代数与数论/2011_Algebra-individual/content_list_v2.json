                171,
                715,
                218
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Individual 2:30–5:00 pm, July 10, 2011 (Please select 5 problems to solve) "
                    }
                ]
            },
            "bbox": [
                347,
                256,
                650,
                310
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "For the following problems, every example and statement must be backed up by proof. Examples and statements without proof will receive no-credit. "
                    }
                ]
            },
            "bbox": [
                191,
                326,
                806,
                378
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K = \\mathbb { Q } ( { \\sqrt { - 3 } } )"
                    },
                    {
                        "type": "text",
                        "content": ", an imaginary quadratic field. "
                    }
                ]
            },
            "bbox": [
                193,
                386,
                640,
                404
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Does there exists a finite Galois extension "
                            },
                            {
                                "type": "equation_inline",
                                "content": "L / \\mathbb { Q }"
                            },
                            {
                                "type": "text",
                                "content": "which contains "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\operatorname { G a l } ( L / \\mathbb { Q } ) \\cong S _ { 3 } { } ^ { * }"
                            },
                            {
                                "type": "text",
                                "content": "? (Here "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S _ { 3 }"
                            },
                            {
                                "type": "text",
                                "content": "is the symmetric group in 3 letters.) "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Does there exists a finite Galois extension "
                            },
                            {
                                "type": "equation_inline",
                                "content": "L / \\mathbb { Q }"
                            },
                            {
                                "type": "text",
                                "content": "which contains "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\operatorname { G a l } ( L / \\mathbb { Q } ) \\cong \\mathbb { Z } / 4 \\mathbb { Z } ^ { \\mathfrak { \\cdot } }"
                            },
                            {
                                "type": "text",
                                "content": "? "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) Does there exists a finite Galois extension "
                            },
                            {
                                "type": "equation_inline",
                                "content": "L / \\mathbb { Q }"
                            },
                            {
                                "type": "text",
                                "content": "which contains "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\operatorname { G a l } ( L / \\mathbb { Q } ) \\cong Q \\mathrm { : }"
                            },
                            {
                                "type": "text",
                                "content": "? Here "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Q"
                            },
                            {
                                "type": "text",
                                "content": "is the quaternion group with 8 elements "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\{ \\pm 1 , \\pm i , \\pm j , \\pm k \\}"
                            },
                            {
                                "type": "text",
                                "content": ", a finite subgroup of the group of units "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { H } ^ { \\times }"
                            },
                            {
                                "type": "text",
                                "content": "of the ring "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { H }"
                            },
                            {
                                "type": "text",
                                "content": "of all Hamiltonian quaternions. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                221,
                406,
                800,
                552
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "be a two-dimensional (complex) representation of a finite group "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "such that 1 is an eigenvalue of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f ( \\sigma )"
                    },
                    {
                        "type": "text",
                        "content": "for every "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma \\in G"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "is a direct sum of two one-dimensional representations of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "1 "
                    }
                ]
            },
            "bbox": [
                191,
                564,
                806,
                615
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F \\subset \\mathbb { R }"
                    },
                    {
                        "type": "text",
                        "content": "be the subset of all real numbers that are roots of monic polynomials "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f ( X ) \\in \\mathbb { Q } [ X ]"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                623,
                805,
                657
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(1) Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F"
                            },
                            {
                                "type": "text",
                                "content": "is a field. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(2) Show that the only field automorphisms of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F"
                            },
                            {
                                "type": "text",
                                "content": "are the identity automorphism "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\alpha ( x ) = x"
                            },
                            {
                                "type": "text",
                                "content": "for all "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x \\in F"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                223,
                659,
                798,
                707
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V"
                    },
                    {
                        "type": "text",
                        "content": "be a finite-dimensional vector space over "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T : V  V"
                    },
                    {
                        "type": "text",
                        "content": "be a linear transformation such that "
                    }
                ]
            },
            "bbox": [
                191,
                718,
                803,
                751
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(1) the minimal polynomial of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "T"
                            },
                            {
                                "type": "text",
                                "content": "is irreducible; "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(2) there exists a vector "
                            },
                            {
                                "type": "equation_inline",
                                "content": "v \\in V"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\{ T ^ { \\ i } v \\mid i \\geq 0 \\}"
                            },
                            {
                                "type": "text",
                                "content": "spans "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V"
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                221,
                755,
                774,
                785
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V"
                    },
                    {
                        "type": "text",
                        "content": "contains no non-trivial proper "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T"
                    },
                    {
                        "type": "text",
                        "content": "-invariant subspace. "
                    }
                ]
            },
            "bbox": [
                191,
                791,
                763,
                808
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. Given a commutative diagram "
                    }
                ]
            },
            "bbox": [
                193,
                816,
                487,
                834
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\begin{array}{c c c c c c c c}A&\\rightarrow&B&\\rightarrow&C&\\rightarrow&D&\\rightarrow&E\\\\\\downarrow&&\\downarrow&&\\downarrow&&\\downarrow&&\\downarrow\\\\A ^ {\\prime}&\\rightarrow&B ^ {\\prime}&\\rightarrow&C ^ {\\prime}&\\rightarrow&D ^ {\\prime}&\\rightarrow&E ^ {\\prime}\\end{array}",
                "math_type": "latex",
