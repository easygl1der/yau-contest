            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(1.2) (10pt) Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g"
                    },
                    {
                        "type": "text",
                        "content": "is a product of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\dim [ ( g - 1 ) V ]"
                    },
                    {
                        "type": "text",
                        "content": "reflections. "
                    }
                ]
            },
            "bbox": [
