            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(1.1) (10pt) For "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a = ( g - 1 ) b \\neq 0"
                    },
                    {
                        "type": "text",
                        "content": ", show that "
                    }
                ]
            },
            "bbox": [
