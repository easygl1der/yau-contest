        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(6.1) (5pt) Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "is irreducible over "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Q }"
                            },
                            {
                                "type": "text",
                                "content": "; "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(6.2) (15 pt) Show in steps that the split field "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K"
