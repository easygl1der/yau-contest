            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 2. (20pt) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "q"
                    },
                    {
                        "type": "text",
                        "content": "be two distinct prime numbers. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "be a non-abelian finite group satisfying the following conditions: "
                    }
                ]
            },
            "bbox": [
                137,
                484,
                864,
                521
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. all nontrivial elements have order either "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": "or "
                            },
                            {
                                "type": "equation_inline",
                                "content": "q"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. The "
                            },
                            {
                                "type": "equation_inline",
                                "content": "q"
                            },
                            {
                                "type": "text",
                                "content": "-Sylow subgroup "
                            },
                            {
                                "type": "equation_inline",
                                "content": "H _ { q }"
                            },
                            {
                                "type": "text",
                                "content": "is normal and is a nontrivial abelian group. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                158,
                537,
                772,
                585
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Show in steps the following statement: "
                    }
                ]
            },
            "bbox": [
                137,
                602,
                462,
                619
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "The group "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "is of the form "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( \\mathbb { Z } / p \\mathbb { Z } ) \\ltimes ( \\mathbb { Z } / q \\mathbb { Z } ) ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": ", where the action of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 \\in \\mathbb { Z } / p \\mathbb { Z }"
                    },
                    {
                        "type": "text",
                        "content": "on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( \\mathbb { Z } / q \\mathbb { Z } ) ^ { n } \\simeq \\mathbb { F } _ { q } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "is given by a matrix "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { M ( 1 ) \\in \\mathrm { G L } _ { n } ( \\mathbb { F } _ { q } ) } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": "whose eigenvalues are all primitive "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "-th roots of unities. "
                    }
                ]
            },
            "bbox": [
                186,
                636,
                866,
                691
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(2.1) (5pt) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "H _ { p }"
                            },
                            {
                                "type": "text",
                                "content": "denote a "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": "-Sylow subgroup of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G"
                            },
                            {
                                "type": "text",
                                "content": ". Show that its inclusion into "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G"
                            },
                            {
                                "type": "text",
                                "content": "induces an isomorphism "
                            },
                            {
                                "type": "equation_inline",
                                "content": "H _ { p } \\cong G / H _ { q }"
                            },
                            {
                                "type": "text",
                                "content": ", and that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G \\simeq H _ { p } \\ltimes H _ { q }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(2.2) (5pt) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "{ \\cal M } : { \\cal H } _ { p } { \\longrightarrow } \\mathrm { A u t } ( { \\cal H } _ { q } ) \\simeq \\mathrm { G L } _ { n } ( \\mathbb { F } _ { q } )"
                            },
                            {
                                "type": "text",
                                "content": "be the homomorphism induced from the conjugations. Show that for each "
                            },
                            {
                                "type": "equation_inline",
                                "content": "1 \\ne a \\in H _ { p }"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M ( a )"
                            },
                            {
                                "type": "text",
                                "content": "is semisimple whose eigenvalues are all primitive "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": "-th roots of unities. In particular "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "is injective. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(2.3) (5pt) Show that if two nontrivial elements "
                            },
                            {
                                "type": "equation_inline",
                                "content": "a , b \\in H _ { p }"
                            },
                            {
                                "type": "text",
                                "content": "commute with each other, then "
                            },
                            {
                                "type": "equation_inline",
                                "content": "a = b ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "for some "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n \\in \\mathbb N"
                            },
                            {
                                "type": "text",
                                "content": ", and that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "H _ { p } \\simeq \\mathbb { Z } / p \\mathbb { Z }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(2.4) (5pt) Complete the solution of the problem. "
                            }
                        ]
                    }
                ]
