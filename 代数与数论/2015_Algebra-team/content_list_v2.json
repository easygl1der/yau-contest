        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\sum_ {n \\geq 0} a _ {n} (\\rho) t ^ {n} = \\frac {1}{| G |} \\sum_ {g \\in G} \\frac {\\overline {{\\chi_ {\\rho} (g)}}}{\\det (\\mathrm {i d} _ {V} - \\pi (g) t)}.",
                "math_type": "latex",
