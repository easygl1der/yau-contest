                    },
                    {
                        "type": "equation_inline",
                        "content": "\\rho"
                    },
                    {
                        "type": "text",
                        "content": "in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { C } { \\lvert V \\rvert } _ { n }"
                    },
                    {
                        "type": "text",
                        "content": ". Show that "
                    }
                ]
            },
