            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. (20pt) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V \\ = \\ \\mathbb { R } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "be an Euclidean space equipped with usual inner product, and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g"
                    },
                    {
                        "type": "text",
                        "content": "an orthogonal matrix acting on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V"
                    },
                    {
                        "type": "text",
                        "content": ". For "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a \\ \\in \\ V"
                    },
                    {
                        "type": "text",
                        "content": ", let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "s _ { a }"
                    },
                    {
                        "type": "text",
                        "content": "denote the reflection "
                    }
                ]
            },
            "bbox": [
                137,
                277,
                864,
                330
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "s _ {a} (x) := x - 2 \\frac {(x , a)}{(a , a)} a, \\qquad \\forall x \\in V.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/8e5d00608d084e203e44c4be9b36e49231b1f1dce5c442b934b9494a86aed4d0.jpg"
                }
            },
