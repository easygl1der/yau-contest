        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) ( 5 points) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "B"
                            },
                            {
                                "type": "text",
                                "content": "be two real "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n \\times n"
                            },
                            {
                                "type": "text",
                                "content": "matrices such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A B = B A"
                            },
                            {
                                "type": "text",
                                "content": ". Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\operatorname* { d e t } ( A ^ { 2 } + B ^ { 2 } ) \\ge 0"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) (15 points) Generalize this to the case of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "k"
                            },
                            {
                                "type": "text",
                                "content": "pairwise commuting matrices. "
