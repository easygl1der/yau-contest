    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 5. (20 points) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { F }"
                    },
                    {
                        "type": "text",
                        "content": "be a finite field and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f _ { i } \\in \\mathbb { F } [ X _ { 1 } , X _ { 2 } , . . . , X _ { n } ]"
                    },
                    {
                        "type": "text",
                        "content": "be polynomials of degree "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d _ { i }"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 \\leq i \\leq r"
                    },
                    {
                        "type": "text",
                        "content": ", such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f _ { i } ( 0 , . . . , 0 ) = 0"
                    },
                    {
                        "type": "text",
                        "content": "for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "i"
                    },
                    {
                        "type": "text",
                        "content": ". Show that if "
                    }
                ]
            },
            "bbox": [
                115,
                108,
                894,
                143
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "n > \\sum_ {i = 1} ^ {r} d _ {i},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/763b6d7e734b950c79ab24d50f9c1e4a3411e57602b9607443c25d8f7e41e883.jpg"
                }
            },
            "bbox": [
                455,
                148,
                552,
                192
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "then there exists nonzero solution to the system of equations: "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f _ { i } = 0"
                    },
                    {
                        "type": "text",
                        "content": ", for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 \\leq i \\leq"
                    },
                    {
                        "type": "equation_inline",
                        "content": "r"
                    },
                    {
                        "type": "text",
                        "content": ". (Hint: you may first verify that the number of integral solutions is congruent to the following number modulo "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    }
                ]
            },
            "bbox": [
                115,
                193,
                894,
                244
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\sum_ {X \\in \\mathbb {F} ^ {n}} \\prod_ {i = 1} ^ {r} \\left(1 - f _ {i} (X) ^ {q - 1}\\right).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/8545cc88fa4948933e92d7166ec9d43b617470af26e9626855dfb93866480344.jpg"
                }
            },
            "bbox": [
