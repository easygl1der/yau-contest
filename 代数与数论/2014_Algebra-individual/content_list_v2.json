            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "This exam of 6 problems is designed to test how much you know rather than how much you don’t know. You are not expected to finish all problems but do as much as you can. "
                    }
                ]
            },
            "bbox": [
                132,
                181,
                877,
                242
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "be a finite subgroup of GL(V ) where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V"
                    },
                    {
                        "type": "text",
                        "content": "is an "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "-dimensional complex vector space. "
                    }
                ]
            },
            "bbox": [
                114,
                282,
                892,
                316
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) (5 points) Let "
                    }
                ]
            },
            "bbox": [
                146,
                319,
                305,
                337
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "H = \\{h \\in G: h v = \\eta (h) v \\text {f o r s o m e} \\eta (h) \\in \\mathbb {C} ^ {\\times} \\text {a n d a l l} v \\in V \\}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/0e8053fab712b0a9b160e17ba51f3f6e9f6d621e09972988d030febb0db071c8.jpg"
                }
            },
            "bbox": [
                233,
                341,
                773,
                359
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Prove that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H"
                    },
                    {
                        "type": "text",
                        "content": "is a normal subgroup of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "and that the map "
                    },
                    {
                        "type": "equation_inline",
                        "content": "h \\mapsto \\eta ( h )"
                    },
                    {
                        "type": "text",
                        "content": "is an isomorphism between "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H"
                    },
                    {
                        "type": "text",
                        "content": "and its image in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { C } ^ { \\times }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                176,
                363,
                892,
                397
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) (5 points) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\chi _ { V }"
                            },
                            {
                                "type": "text",
                                "content": "be the character function of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G"
                            },
                            {
                                "type": "text",
                                "content": "acting on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V"
                            },
                            {
                                "type": "text",
                                "content": ", i.e., "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\chi _ { V } ( g ) = \\operatorname { t r } ( g )"
                            },
                            {
                                "type": "text",
                                "content": "with "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g"
                            },
                            {
                                "type": "text",
                                "content": "viewed as an automorphism of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V"
                            },
                            {
                                "type": "text",
                                "content": ". Prove "
                            },
                            {
                                "type": "equation_inline",
                                "content": "| \\chi _ { V } ( g ) | \\le n"
                            },
                            {
                                "type": "text",
                                "content": "for all "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g \\in G"
                            },
                            {
                                "type": "text",
                                "content": ", and the equality holds if and only if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g \\in H"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) (10 points) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "W"
                            },
                            {
                                "type": "text",
                                "content": "be an irreducible representation of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G"
                            },
                            {
                                "type": "text",
                                "content": ". Then "
                            },
                            {
                                "type": "equation_inline",
                                "content": "W"
                            },
                            {
                                "type": "text",
                                "content": "is isomorphic to a direct summand of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V ^ { \\otimes m }"
                            },
                            {
                                "type": "text",
                                "content": "for some "
                            },
                            {
                                "type": "equation_inline",
                                "content": "m"
                            },
                            {
                                "type": "text",
                                "content": "(as representations of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G"
                            },
                            {
                                "type": "text",
                                "content": "). "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                144,
                398,
                892,
                481
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 2. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a _ { 1 } , \\ldots , a _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "be nonnegative real numbers. "
                    }
                ]
            },
            "bbox": [
                115,
                487,
                615,
                504
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) (6 points) Prove that the "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n \\times n"
                            },
                            {
                                "type": "text",
                                "content": "matrix "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A = \\left( t ^ { a _ { i } + a _ { j } } \\right)"
                            },
                            {
                                "type": "text",
                                "content": "is positive semi-definite for every real number "
                            },
                            {
                                "type": "equation_inline",
                                "content": "t > 0"
                            },
                            {
                                "type": "text",
                                "content": ". Find the rank of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) (7 points) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\boldsymbol { B } = ( c _ { i j } ) _ { n \\times n }"
                            },
                            {
                                "type": "text",
                                "content": "be an "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n \\times n"
                            },
                            {
                                "type": "text",
                                "content": "-matrix with "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\begin{array} { r } { c _ { i j } = \\frac { 1 } { 1 + a _ { i } + a _ { j } } } \\end{array}"
                            },
                            {
                                "type": "text",
                                "content": ". Prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A"
                            },
                            {
                                "type": "text",
                                "content": "is a positive semi-definite matrix. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) (7 points) Prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "B"
                            },
                            {
                                "type": "text",
                                "content": "is positive definite if and only if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "a _ { i }"
                            },
                            {
                                "type": "text",
                                "content": "are all distinct. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                144,
                506,
                892,
                592
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 3. Consider the equations "
                    }
                ]
            },
            "bbox": [
                115,
                598,
                436,
                615
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "X ^ {2} - 8 2 Y ^ {2} = \\pm 2",
                "math_type": "latex",
                "image_source": {
                    "path": "images/ddf54aa5b4f06f81e95d5340f7fc0171c75a4dbf62d4b7b8a7914b48fa861e63.jpg"
                }
            },
            "bbox": [
                428,
                619,
                581,
                636
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) (5 points) Show that if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( x , y )"
                            },
                            {
                                "type": "text",
                                "content": "is a solution for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X ^ { 2 } - 8 2 Y ^ { 2 } = \\pm 2"
                            },
                            {
                                "type": "text",
                                "content": ", then "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( 9 x - 8 2 y , x - 9 y )"
                            },
                            {
                                "type": "text",
                                "content": "is a solution for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X ^ { 2 } - 8 2 Y ^ { 2 } = \\mp 2"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) (7 points) Show that the equations have solutions over "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Z } / p ^ { n } \\mathbb { Z }"
                            },
                            {
                                "type": "text",
                                "content": "for any "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": "and odd prime "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) (8 points) Show that the equations have no solutions over "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Z }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                144,
                642,
                892,
                727
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T"
                    },
                    {
                        "type": "text",
                        "content": "be nonabelian finite simple groups, and write "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G = S \\times T"
                    }
                ]
            },
            "bbox": [
                115,
                732,
                847,
                749
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) (7 points) Show that the total number of normal subgroups of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G"
                            },
                            {
                                "type": "text",
                                "content": "is four. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) (6 points) If "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "T"
                            },
                            {
                                "type": "text",
                                "content": "are isomorphic, show that G has a maximal proper subgroup not containing either direct factor. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) (7 points) If "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G"
                            },
                            {
                                "type": "text",
                                "content": "has a maximal proper subgroup that contains neither of the direct factors of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G"
                            },
                            {
                                "type": "text",
                                "content": ", show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "T"
                            },
                            {
                                "type": "text",
                                "content": "are isomorphic. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                114,
                750,
                892,
                832
            ]
        },
