        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. For any prime "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "and a nonzero element "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a \\in \\mathbf { F } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": ", prove that the polynomial "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A ( x ) = x ^ { p } - x - a"
                    },
                    {
                        "type": "text",
                        "content": "is irreducible and separable over "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { F } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                109,
                170,
                885,
                208
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 2. Determine the automorphism group of the splitting field of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f ( x ) = x ^ { 3 } - 3 x + 1"
                    },
                    {
                        "type": "text",
                        "content": "over Q. "
                    }
                ]
            },
            "bbox": [
                109,
                227,
                836,
                247
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R = F [ x , y ] / ( x ^ { 2 } - y ^ { 3 } )"
                    },
                    {
                        "type": "text",
                        "content": "for some field "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                112,
                266,
                524,
                285
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "R"
                            },
                            {
                                "type": "text",
                                "content": "is an integral domain. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) If "
                            },
                            {
                                "type": "equation_inline",
                                "content": "t"
                            },
                            {
                                "type": "text",
                                "content": "denotes the element "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x / y"
                            },
                            {
                                "type": "text",
                                "content": "in the fraction field "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K"
                            },
                            {
                                "type": "text",
                                "content": "of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "R"
                            },
                            {
                                "type": "text",
                                "content": ", prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K"
                            },
                            {
                                "type": "text",
                                "content": "is equal to "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F ( t )"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) Prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F [ t ]"
                            },
                            {
                                "type": "text",
                                "content": "is the integral closure of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "R"
                            },
                            {
                                "type": "text",
                                "content": "in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K = F [ t ]"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                125,
                292,
                769,
                362
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { 1 } , . . . , p _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "be "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "distinct prime numbers. Show: "
                    },
                    {
                        "type": "equation_inline",
                        "content": "{ \\sqrt { p _ { 1 } } } + \\cdots + { \\sqrt { p _ { n } } }"
                    },
                    {
                        "type": "text",
                        "content": "is not rational. "
                    }
                ]
            },
            "bbox": [
                109,
                381,
                805,
                401
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 5. Find all integral solutions √ "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( x , y )"
                    },
                    {
                        "type": "text",
                        "content": "for the equation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x ^ { 2 } + 1 3 = y ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": ". (Hint: You can use the fact that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { Q } ( { \\sqrt { - 1 3 } } )"
                    },
                    {
                        "type": "text",
                        "content": "has class number 2). "
                    }
                ]
            },
            "bbox": [
                109,
                420,
                885,
                455
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 6. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "be a prime number and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { Q } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "be the field of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "-adic numbers. Fix an algebraic closure "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\overline { { \\mathbf { Q } _ { p } } }"
                    },
                    {
                        "type": "text",
                        "content": "of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { Q } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g \\colon { \\mathbf { Z } } _ { \\geq 0 } \\to { \\mathbf { N } }"
                    },
                    {
                        "type": "text",
                        "content": "be a strictly increasing function. For each "
                    },
                    {
                        "type": "equation_inline",
                        "content": "i \\in \\mathbf { Z } _ { \\geq 0 }"
                    },
                    {
                        "type": "text",
                        "content": ", pick a primitive "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( p ^ { g ( i ) } - 1 )"
                    },
                    {
                        "type": "text",
                        "content": "-th root of unity "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\zeta _ { i }"
                    },
                    {
                        "type": "text",
                        "content": "in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\overline { { \\mathbf { Q } _ { p } } }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                109,
                477,
                885,
                534
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Show that for each "
                            },
                            {
                                "type": "equation_inline",
                                "content": "i \\geq 0"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K _ { i } : = \\mathbf { Q } _ { p } ( \\zeta _ { i } )"
                            },
                            {
                                "type": "text",
                                "content": "is an unramified Galois extension of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbf { Q } _ { p }"
                            },
                            {
                                "type": "text",
                                "content": "of degree "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g ( i )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Give an explicit function "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g"
                            },
                            {
                                "type": "text",
                                "content": "as above such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K _ { i - 1 } \\subset K _ { i }"
                            },
                            {
                                "type": "text",
                                "content": "for all "
                            },
                            {
                                "type": "equation_inline",
                                "content": "i > 0"
                            },
                            {
                                "type": "text",
                                "content": ". Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "0 = N _ { 0 } < N _ { 1 } < N _ { 2 } \\cdot \\cdot \\cdot"
                            },
                            {
                                "type": "text",
                                "content": "be an increasing sequence of nonnegative integers. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\begin{array} { r } { \\alpha _ { i } : = \\sum _ { j = 0 } ^ { i } \\zeta _ { j } p ^ { N _ { j } } } \\end{array}"
                            },
                            {
                                "type": "text",
                                "content": "< <. Show that for each "
                            },
                            {
                                "type": "equation_inline",
                                "content": "i \\geq 0"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K _ { i } = \\mathbf { Q } _ { p } ( \\alpha _ { i } )"
                            },
                            {
                                "type": "text",
                                "content": "and that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\left( \\alpha _ { i } \\right)"
                            },
                            {
                                "type": "text",
                                "content": "is a Cauchy sequence in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\overline { { \\mathbf { Q } _ { p } } }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\eta \\in \\overline { { \\mathbf { Q } _ { p } } }"
                            },
                            {
                                "type": "text",
                                "content": "be of degree "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g"
                            },
                            {
                                "type": "text",
                                "content": "over "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbf { Q } _ { p }"
                            },
                            {
                                "type": "text",
                                "content": ", prove that there exists "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M \\in \\mathbf { N }"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\zeta _ { i }"
                            },
                            {
                                "type": "text",
                                "content": "does not satisfy any ηcongruence "
                            }
                        ]
                    }
                ]
            },
