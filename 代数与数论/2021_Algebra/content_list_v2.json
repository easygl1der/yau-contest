        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "in which the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "s _ { i }"
                    },
                    {
                        "type": "text",
                        "content": "’s are "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
