        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(d) Take a suitable sequence "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( N _ { i } )"
                    },
                    {
                        "type": "text",
                        "content": "as above such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\left( { { a } _ { i } } \\right)"
                    },
                    {
                        "type": "text",
                        "content": "does not converge in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\overline { { \\mathbf { Q } _ { p } } }"
                    },
                    {
                        "type": "text",
                        "content": ". Conclude that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { Q } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "is not complete with respect to the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "-adic topology. "
                    }
