        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "s _ {g - 1} \\eta^ {g - 1} + s _ {g - 2} \\eta^ {g - 2} + \\dots + s _ {1} \\eta + s _ {0} \\equiv 0 \\pmod {p ^ {M}}",
                "math_type": "latex",
