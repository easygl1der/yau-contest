                233
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "This exam of 160 points is designed to test how much you know rather than how much you don’t know. You are not expected to finish all problems but do as much as you can. "
                    }
                ]
            },
            "bbox": [
                199,
                239,
                795,
                308
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. (20pt) "
                    }
                ]
            },
            "bbox": [
                176,
                371,
                259,
                390
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1.1 (15 pt) Classify finite groups of order 26 up to isomorphisms. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1.2 (5 pt) For each finite group "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G"
                            },
                            {
                                "type": "text",
                                "content": "of order 26, describe the group "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A u t ( G )"
                            },
                            {
                                "type": "text",
                                "content": "of automorphisms of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                189,
                402,
                816,
                469
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. (20 pt) Consider "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f \\in \\mathbb { Z } _ { > 0 }"
                    },
                    {
                        "type": "text",
                        "content": "and nonzero vector spaces "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V _ { i }"
                    },
                    {
                        "type": "text",
                        "content": "indexed by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "i \\in"
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { Z } / f \\mathbb { Z }"
                    },
                    {
                        "type": "text",
                        "content": ". Suppose that there are linear maps "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\phi _ { i } : V _ { i } \\to V _ { i + 1 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\psi _ { i } : V _ { i } \\to V _ { i - 1 }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    }
                ]
            },
            "bbox": [
                174,
                481,
                818,
                535
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\phi_ {i - 1} \\circ \\psi_ {i} = 0, \\quad \\psi_ {i + 1} \\circ \\phi_ {i} = 0.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/226f3c50fdfff42404c87d6c3721a4240d8bb1eba83f7f4625d21a3183cff544.jpg"
                }
            },
            "bbox": [
                370,
                537,
                620,
                556
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(We may think of a circular graph with oriented edges such that the “Orpheus condition” holds: Whenever you turn back while traveling through the graph you are killed.) "
                    }
                ]
            },
            "bbox": [
                174,
                563,
                818,
                617
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Prove that there exists lines "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\ell _ { i } \\subset V _ { i }"
                    },
                    {
                        "type": "text",
                        "content": "for every "
                    },
                    {
                        "type": "equation_inline",
                        "content": "i \\in \\mathbb { Z } / f \\mathbb { Z }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    }
                ]
            },
            "bbox": [
                202,
                618,
                756,
                636
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\phi_ {i} (\\ell_ {i}) \\subset \\ell_ {i + 1}, \\quad \\psi_ {i} (\\ell_ {i}) \\subset \\ell_ {i - 1}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/b4b4f34834afbc81aa44d86f2d517c96be932c93d0afc23e157adcec4a68cc45.jpg"
                }
            },
            "bbox": [
                375,
                651,
                616,
                671
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "under one of the following two conditions: "
                    }
                ]
            },
            "bbox": [
                174,
                685,
                532,
                703
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2.1 (10 pt) all "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\psi _ { i } = 0"
                            },
                            {
                                "type": "text",
                                "content": ", or "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2.2 (10 pt) "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathrm { d i m } V _ { i }"
                            },
                            {
                                "type": "text",
                                "content": "are equal to each other. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                189,
                715,
                547,
                763
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. (20pt) For a parameter "
                    },
                    {
                        "type": "equation_inline",
                        "content": "t = ( t _ { 0 } , t _ { 1 } , \\cdot \\cdot \\cdot t _ { 5 } ) \\in \\mathbb { F } _ { 5 } ^ { 6 }"
                    },
                    {
                        "type": "text",
                        "content": "with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "t _ { 0 } \\neq 0"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ t _ { i } , i > 0 \\}"
                    },
                    {
                        "type": "text",
                        "content": "an ordering of elements in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { F } _ { 5 }"
                    },
                    {
                        "type": "text",
                        "content": ", define a polynomial "
                    }
                ]
            },
            "bbox": [
                174,
                776,
                816,
                814
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "P _ {t} (x) = (x - t _ {1}) (x - t _ {2}) (x - t _ {3}) + t _ {0} (x - t _ {4}) (x - t _ {5}).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/997e027b4cffb969f08aa24000790d87801b7b5107aa249923c41d3c39cb42f5.jpg"
                }
            },
            "bbox": [
                276,
                828,
                715,
                848
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "1 "
                    }
                ]
            },
            "bbox": [
                491,
                875,
                503,
                886
            ]
        }
    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3.1 (7 pt) Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P _ { t } ( x )"
                    },
                    {
                        "type": "text",
                        "content": "is irreducible in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { F } _ { 5 } [ x ]"
                    },
                    {
                        "type": "text",
                        "content": "; "
                    }
                ]
            },
            "bbox": [
                189,
                157,
                609,
                179
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3.2 (6 pt) Show that two parameters "
                    },
                    {
                        "type": "equation_inline",
                        "content": "t , t ^ { \\prime }"
                    },
                    {
                        "type": "text",
                        "content": "give the same polynomial if and only if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "t _ { 0 } = t _ { 0 } ^ { \\prime }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ t _ { 4 } , t _ { 5 } \\} = \\{ t _ { 4 } ^ { \\prime } , t _ { 5 } ^ { \\prime } \\}"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                189,
                188,
                816,
                228
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3.3 (7 pt) Show that every irreducible cubic monic polynomial over "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { F } _ { 5 }"
                    },
                    {
                        "type": "text",
                        "content": "is obtained by this way. "
                    }
                ]
            },
            "bbox": [
                189,
                237,
                818,
                273
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. (40 pt) For "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k"
                    },
                    {
                        "type": "text",
                        "content": "non-negative integer, let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V _ { k } : = \\mathbb { R } [ x ] _ { \\leq k }"
                    },
                    {
                        "type": "text",
                        "content": "be the vector space of real polynomials of degree at most "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k"
                    },
                    {
                        "type": "text",
                        "content": "with an action by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\operatorname { S L _ { 2 } } ( \\mathbb { R } )"
                    },
                    {
                        "type": "text",
                        "content": "by "
                    }
                ]
            },
            "bbox": [
                174,
                285,
                818,
                323
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\gamma \\cdot P (x) = (c x + d) ^ {k} P \\left(\\frac {a x + b}{c x + d}\\right), \\qquad \\gamma = \\left( \\begin{array}{c c} a & b \\\\ c & d \\end{array} \\right) \\in \\mathrm {S L} _ {2} (\\mathbb {R}).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/4f9ec69c4f34d73c7064c20cc2dfb0b00fcaa723df6c18da649cb69b552f3bd2.jpg"
                }
            },
            "bbox": [
                235,
                332,
                756,
                375
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4.1 (20 pt) Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V _ { k }"
                    },
                    {
                        "type": "text",
                        "content": "is an irreducible representation of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\operatorname { S L _ { 2 } } ( \\mathbb { R } )"
                    },
                    {
                        "type": "text",
                        "content": "; "
                    }
                ]
            },
            "bbox": [
                189,
                383,
                766,
                402
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4.2 (15 pt) For non-negative integers "
                    },
                    {
                        "type": "equation_inline",
                        "content": "m , n"
                    },
                    {
                        "type": "text",
                        "content": ", consider "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V _ { m , n } : = V _ { m } \\otimes V _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "as a subspace of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { C } [ x , y ]"
                    },
                    {
                        "type": "text",
                        "content": "of polynomials with both "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x , y"
                    },
                    {
                        "type": "text",
                        "content": "-degrees at most "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k"
                    },
                    {
                        "type": "text",
                        "content": ", with diagonal action of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\operatorname { S L _ { 2 } } ( \\mathbb { R } )"
                    },
                    {
                        "type": "text",
                        "content": ". Assume "
                    },
                    {
                        "type": "equation_inline",
                        "content": "m \\ge n \\ge 1"
                    },
                    {
                        "type": "text",
                        "content": ". Show that following exact sequence is exact and split as representations of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\operatorname { S L _ { 2 } } ( \\mathbb { R } )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                189,
                414,
                818,
                489
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "0 \\longrightarrow V _ {m - 1, n - 1} \\stackrel {\\cdot (y - x)} {\\longrightarrow} V _ {m, n} \\stackrel {y = x} {\\longrightarrow} V _ {m + n} \\longrightarrow 0.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/0737f0d5d3bfbf4f2422cb58c1abdc8b3266658ef70c4f71c5f34fc9e2a41d9f.jpg"
                }
            },
            "bbox": [
                359,
                500,
                679,
                526
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "This implies the following decomposition of representations: "
                    }
                ]
            },
            "bbox": [
                223,
                537,
                732,
                556
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "V _ {m} \\otimes V _ {n} = \\oplus_ {i = 0} ^ {n} V _ {m + n - 2 i}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/97d9dca9bf0c2dd0915d2b4cf36b1df361959ea79560bce85c0cfce162e64238.jpg"
                }
            },
            "bbox": [
                415,
                568,
                625,
                589
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4.3 (5 pt) For non-negative integers "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\ell \\ \\geq \\ m \\ \\geq \\ n"
                    },
                    {
                        "type": "text",
                        "content": "consider the space of invariants "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( V _ { \\ell } \\otimes V _ { m } \\otimes V _ { n } ) ^ { \\mathrm { S L } _ { 2 } ( \\mathbb { R } ) }"
                    },
                    {
                        "type": "text",
                        "content": ". Show that this space is either trivial or one-dimensional; it is non-trivial if and only if "
                    }
                ]
            },
            "bbox": [
                189,
                606,
                818,
                660
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\ell + m + n \\equiv 0 \\mod 2, \\qquad \\ell + m \\geq n.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/bfdb9ef092295b0b75bc13a74eacb52db0c9d168590f1bd7b3c5181948ef41cb.jpg"
                }
            },
            "bbox": [
                351,
                672,
                687,
                693
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. (60 pt) "
                    }
                ]
            },
            "bbox": [
                176,
                710,
                266,
                731
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "5.1 (20pt) Find a polynomial "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( x )"
                            },
                            {
                                "type": "text",
                                "content": "with integer coefficients which has a root over "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { F } _ { p }"
                            },
                            {
                                "type": "text",
                                "content": "for each prime "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": "but has not root over "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Q }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "5.2 (20pt) Can you find "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "irreducible? "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "5.3 (20pt) What is the smallest possible degree of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "? "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                189,
                739,
                816,
                838
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "2 "
                    }
                ]
            },
            "bbox": [
