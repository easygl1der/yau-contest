                177,
                815,
                242
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "1 + \\sum_ {n \\geq 1} a _ {n} z ^ {n} \\in \\mathbb {C} [ [ z ] ]",
                "math_type": "latex",
