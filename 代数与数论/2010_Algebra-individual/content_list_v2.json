                291
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V"
                    },
                    {
                        "type": "text",
                        "content": "be a finite dimensional complex vector space. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A , B"
                    },
                    {
                        "type": "text",
                        "content": "be two linear endomorphisms of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V"
                    },
                    {
                        "type": "text",
                        "content": "satisfying "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A B - B A = B"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that there is a common eigenvector for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "B"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                206,
                317,
                816,
                367
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M _ { 2 } ( \\mathbb { R } )"
                    },
                    {
                        "type": "text",
                        "content": "be the ring of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "2 \\times 2"
                    },
                    {
                        "type": "text",
                        "content": "matrices with real entries. Its group of multiplicative units is "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G L _ { 2 } ( \\mathbb { R } )"
                    },
                    {
                        "type": "text",
                        "content": ", consisting of invertible matrices in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M _ { 2 } ( \\mathbb { R } )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                206,
                376,
                816,
                425
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Find an injective homomorphism from the field "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { C }"
                            },
                            {
                                "type": "text",
                                "content": "of complex numbers into the ring "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M _ { 2 } ( \\mathbb { R } )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Show that if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\phi _ { 1 }"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\phi _ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "are two such homomorphisms, then there exists a "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g \\in G L _ { 2 } ( \\mathbb { R } )"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\phi _ { 2 } ( x ) = g \\phi _ { 1 } ( x ) g ^ { - 1 }"
                            },
                            {
                                "type": "text",
                                "content": "for all "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x \\in \\mathbb { C }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "h"
                            },
                            {
                                "type": "text",
                                "content": "be an element in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G L _ { 2 } ( \\mathbb { R } )"
                            },
                            {
                                "type": "text",
                                "content": "whose characteristic polynomial "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( x )"
                            },
                            {
                                "type": "text",
                                "content": "is irreducible over "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R }"
                            },
                            {
                                "type": "text",
                                "content": ". Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F \\subset M _ { 2 } ( \\mathbb { R } )"
                            },
                            {
                                "type": "text",
                                "content": "be the subring generated by "
                            },
                            {
                                "type": "equation_inline",
                                "content": "h"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "a \\cdot I"
                            },
                            {
                                "type": "text",
                                "content": "for all "
                            },
                            {
                                "type": "equation_inline",
                                "content": "a \\in \\mathbb R"
                            },
                            {
                                "type": "text",
                                "content": ", where "
                            },
                            {
                                "type": "equation_inline",
                                "content": "I"
                            },
                            {
                                "type": "text",
                                "content": "is the idenity matrix. Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F"
                            },
                            {
                                "type": "text",
                                "content": "is isomorphic to "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { C }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(d) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "h ^ { \\prime }"
                            },
                            {
                                "type": "text",
                                "content": "be any element in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G L _ { 2 } ( \\mathbb { R } )"
                            },
                            {
                                "type": "text",
                                "content": "with the same characteristic polynomial "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( x )"
                            },
                            {
                                "type": "text",
                                "content": "as "
                            },
                            {
                                "type": "equation_inline",
                                "content": "h"
                            },
                            {
                                "type": "text",
                                "content": "in (c). Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "h"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "h ^ { \\prime }"
                            },
                            {
                                "type": "text",
                                "content": "are conjugate in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G L _ { 2 } ( \\mathbb { R } )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(e) If "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( x )"
                            },
                            {
                                "type": "text",
                                "content": "in (c) and (d) is reducible over "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R }"
                            },
                            {
                                "type": "text",
                                "content": ", will the same conclusion on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "h"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "h ^ { \\prime }"
                            },
                            {
                                "type": "text",
                                "content": "hold? Give reasons. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                236,
                429,
                813,
                640
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "be a non-abelian finite group. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "c ( G )"
                    },
                    {
                        "type": "text",
                        "content": "be the number of conjugacy classes in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "Define "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\overline { { c } } ( G ) : = c ( G ) / | G |"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\left[ | G | = \\operatorname { C a r d } ( G ) \\right)"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                206,
                653,
                816,
                686
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\textstyle { \\overline { { c } } } ( G ) \\leq { \\frac { 5 } { 8 } }"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Is there a finite group "
                            },
                            {
                                "type": "equation_inline",
                                "content": "H"
                            },
                            {
                                "type": "text",
                                "content": "with "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\begin{array} { r } { \\overline { { c } } ( H ) = \\frac { 5 } { 8 } } \\end{array}"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) (open ended question) Suppose that there exists a prime number "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": "and an element "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x \\in G"
                            },
                            {
                                "type": "text",
                                "content": "such that the cardinality of the conjugacy class of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x"
                            },
                            {
                                "type": "text",
                                "content": "is divisible by "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": ". Find a good/sharp upper bound for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "{ \\overline { { c } } } ( G )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                236,
                688,
                813,
                788
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F"
                    },
                    {
                        "type": "text",
                        "content": "be a splitting field over "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { Q }"
                    },
                    {
                        "type": "text",
                        "content": "the polynomial "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x ^ { 8 } - 5 \\in \\mathbb { Q } [ x ]"
                    },
                    {
                        "type": "text",
                        "content": ". Recall that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F"
                    },
                    {
                        "type": "text",
                        "content": "is the subfield of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { C }"
                    },
                    {
                        "type": "text",
                        "content": "generated by all roots of this polynomial. "
                    }
                ]
            },
