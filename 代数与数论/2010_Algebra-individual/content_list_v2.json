        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T \\subset \\mathbb { N } _ { > 0 }"
                    },
                    {
                        "type": "text",
                        "content": "be a finite set of positive integers. For each integer "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n > 0"
                    },
                    {
                        "type": "text",
                        "content": ", define "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "to be the number of all finite sequences "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\left( t _ { 1 } , \\ldots , t _ { m } \\right)"
                    },
                    {
                        "type": "text",
                        "content": "with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "m \\leq n"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "t _ { i } \\in T"
                    },
                    {
                        "type": "text",
                        "content": "for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "i = 1 , \\ldots , m"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "t _ { 1 } + . . . + t _ { m } = n"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that the infinite series "
                    }
                ]
            },
            "bbox": [
