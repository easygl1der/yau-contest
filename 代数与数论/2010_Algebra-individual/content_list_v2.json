                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Find the degree "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\left[ F : \\mathbb { Q } \\right]"
                            },
                            {
                                "type": "text",
                                "content": "of the number field "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Determine the Galois group "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\operatorname { G a l } ( F / \\mathbb { Q } )"
                            }
                        ]
                    }
