    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(c) Suppose "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\neq \\ell"
                    },
                    {
                        "type": "text",
                        "content": ". let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a"
                    },
                    {
                        "type": "text",
                        "content": "be the order of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { F } _ { \\ell }"
                    },
                    {
                        "type": "text",
                        "content": ". Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a"
                    },
                    {
                        "type": "text",
                        "content": "is the first value of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "m"
                    },
                    {
                        "type": "text",
                        "content": "for which the group "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathrm { G L } _ { m } ( \\mathbb { F } _ { p } )"
                    },
                    {
                        "type": "text",
                        "content": "of invertible "
                    },
                    {
                        "type": "equation_inline",
                        "content": "m \\times m"
                    },
                    {
                        "type": "text",
                        "content": "`matrices with entries from "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { F } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "contains an element of order "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\ell"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                127,
                75,
                823,
                125
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Hint: Derive and use the formula for the number of elements in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathrm { G L } _ { m } ( \\mathbb { F } _ { p } )"
                    }
                ]
            },
            "bbox": [
                156,
                135,
                694,
                154
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 5. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\geq 3"
                    },
                    {
                        "type": "text",
                        "content": "be a prime number and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { Z } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "be the ring of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "-adic integers. "
                    }
                ]
            },
            "bbox": [
                112,
                172,
                712,
                191
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Show that an element in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "1 + p \\mathbb { Z } _ { p }"
                            },
                            {
                                "type": "text",
                                "content": "is a "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": "-th power in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Z } _ { p }"
                            },
                            {
                                "type": "text",
                                "content": "if and only if it lives in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "1 + p ^ { 2 } \\mathbb { Z } _ { p }"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Z } _ { p } ^ { \\times }"
                            },
                            {
                                "type": "text",
                                "content": "denote the group of units in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Z } _ { p }"
                            },
                            {
                                "type": "text",
                                "content": ". Show that there exist "
                            },
                            {
                                "type": "equation_inline",
                                "content": "a , b , c \\in \\mathbb { Z } _ { p } ^ { \\times }"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "a ^ { p } + b ^ { p } = c ^ { p }"
                            },
                            {
                                "type": "text",
                                "content": "if and only if "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                125,
                196,
                821,
                257
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\sum_ {i = 1} ^ {p - 1} i ^ {p - 2} t ^ {i} \\equiv 0 (\\mathrm {m o d} p)",
                "math_type": "latex",
                "image_source": {
                    "path": "images/350f415d711a66839d551f75cd0589878de7503e85633900bef43e4b34ee0fd0.jpg"
                }
            },
            "bbox": [
                406,
                258,
                573,
                301
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "for some integer "
                    },
                    {
                        "type": "equation_inline",
                        "content": "t \\in \\{ 2 , 3 , . . . , p - 1 \\}"
                    },
                    {
