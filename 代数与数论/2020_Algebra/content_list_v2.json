            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F"
                    },
                    {
                        "type": "text",
                        "content": "be a field of characteristic zero. Consider the polynomial ring "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F [ x _ { 1 } , \\ldots , x _ { n } ]"
                    }
                ]
            },
            "bbox": [
                112,
                171,
                800,
                189
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) Prove Newton’s identity over the field "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F"
                    }
                ]
            },
            "bbox": [
                127,
                196,
                447,
                213
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "p _ {k} - p _ {k - 1} e _ {1} + \\dots + (- 1) ^ {k - 1} p _ {1} e _ {k - 1} + (- 1) ^ {k} k e _ {k} = 0,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/235e3d37414d5395c948762323b82b62a7d5616fa3aeb3245986d7d6df46f508.jpg"
                }
            },
            "bbox": [
                302,
                232,
                676,
                252
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    }
                ]
            },
            "bbox": [
                158,
                273,
                205,
                287
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "e _ {k} \\left(x _ {1}, \\dots , x _ {n}\\right) = \\sum_ {1 \\leq i _ {1} <   \\dots <   \\beta_ {k} \\leq n} x _ {i _ {1}} \\dots x _ {i _ {k}}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/3ddca206763840367e904cced98bd81bf3cc889862ff65bee706d71878277b2f.jpg"
                }
            },
            "bbox": [
                346,
                284,
                630,
                321
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 \\leq k \\leq n"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "e _ { 0 } = 1"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "e _ { k } = 0"
                    },
                    {
                        "type": "text",
                        "content": "when "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k > n"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    }
                ]
            },
            "bbox": [
                156,
                337,
                493,
                354
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "p _ {k} (x _ {1}, \\dots , x _ {n}) = x _ {1} ^ {k} + \\dots + x _ {n} ^ {k}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/c28bfd173af467b16caef5db4f17db34614fa4c6e7e1bd29204edc1d98e72977.jpg"
                }
            },
            "bbox": [
                375,
                372,
                604,
                393
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) Prove that over the field of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F"
                    },
                    {
                        "type": "text",
                        "content": "of characteristic zero, an "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\times n"
                    },
                    {
                        "type": "text",
                        "content": "matrix "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "is nilpotent if and only if the trace of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A ^ { k }"
                    },
                    {
                        "type": "text",
                        "content": "is equal to zero for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k = 1 , 2 \\ldots"
                    }
                ]
            },
            "bbox": [
                125,
                421,
                823,
                455
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Hint: use Part (a). "
                    }
                ]
            },
            "bbox": [
                156,
                464,
                294,
                479
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(c) Prove that over the field of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F"
                    },
                    {
                        "type": "text",
                        "content": "of characteristic zero, two "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\times n"
                    },
                    {
                        "type": "text",
                        "content": "matrix "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "B"
                    },
                    {
                        "type": "text",
                        "content": "have the same characteristic polynomial if and only if the trace of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A ^ { k }"
                    },
                    {
                        "type": "text",
                        "content": "and trace of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "B ^ { k }"
                    },
                    {
                        "type": "text",
                        "content": "are equal for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k = 1 , 2 \\dots"
                    }
                ]
            },
            "bbox": [
                127,
                489,
                823,
                539
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Hint: use Part (a). "
                    }
                ]
            },
            "bbox": [
                156,
                549,
                294,
                565
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Problem 2. "
                    }
                ],
                "level": 1
            },
            "bbox": [
                112,
                585,
                200,
                599
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "be a finitely generated "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R"
                    },
                    {
                        "type": "text",
                        "content": "-module and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "{ \\mathfrak { a } } \\subset R"
                    },
                    {
                        "type": "text",
                        "content": "an ideal. Suppose "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\phi : M \\to M"
                    },
                    {
                        "type": "text",
                        "content": "is an "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R"
                    },
                    {
                        "type": "text",
                        "content": "-module map such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\phi ( M ) \\subseteq \\mathfrak { a } M"
                    },
                    {
                        "type": "text",
                        "content": "φ. Prove that there is a monic polynomial "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p ( t ) \\subset R [ t ]"
                    },
                    {
                        "type": "text",
                        "content": "φwith coefficients from a such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p ( \\phi ) = 0"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                125,
                611,
                823,
                662
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Hint: "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p ( t )"
                    },
                    {
                        "type": "text",
                        "content": "is basically just the characteristic polynomial. "
                    }
                ]
            },
            "bbox": [
                156,
                671,
                565,
                688
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) If "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "is a finitely generated "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R"
                    },
                    {
                        "type": "text",
                        "content": "-module such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "{ \\mathfrak { a } } M = M"
                    },
                    {
                        "type": "text",
                        "content": "for some ideal "
                    },
                    {
                        "type": "equation_inline",
                        "content": "{ \\mathfrak { a } } \\subset R"
                    },
                    {
                        "type": "text",
                        "content": ", then there exits "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x \\in R"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 - x \\in { \\mathfrak { a } }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x M = 0"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                125,
                696,
                823,
                729
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R = F [ x , y ] / ( y ^ { 2 } - x ^ { 2 } - x ^ { 3 } )"
                    },
                    {
                        "type": "text",
                        "content": "for some field "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                112,
                748,
                558,
                767
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "R"
                            },
                            {
                                "type": "text",
                                "content": "is an integral domain. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Compute the normalization of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "R"
                            },
                            {
                                "type": "text",
                                "content": "(i.e., the integral closure of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "R"
                            },
                            {
                                "type": "text",
                                "content": "in its field of fraction). "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                125,
                775,
                772,
                816
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\ell"
                    },
                    {
                        "type": "text",
                        "content": "be two prime numbers and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "[ \\ell _ { x } ]"
                    },
                    {
                        "type": "text",
                        "content": "denote the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\ell"
                    },
                    {
                        "type": "text",
                        "content": "-th cyclotomic polynomial "
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 + x + \\cdot \\cdot \\cdot + x ^ { \\ell - 1 }"
                    }
                ]
            },
            "bbox": [
                112,
                837,
                823,
                869
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "[ \\ell _ { x } ]"
                            },
                            {
                                "type": "text",
                                "content": "is an irreducible element of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Q } [ x ]"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "[ \\ell _ { x } ]"
                            },
                            {
                                "type": "text",
                                "content": "is divisible by "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x - 1"
                            },
                            {
                                "type": "text",
                                "content": "in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { F } _ { p } [ x ]"
                            },
                            {
                                "type": "text",
                                "content": "if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p = \\ell"
                            },
                            {
                                "type": "text",
                                "content": ". Here "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { F } _ { p }"
                            },
                            {
                                "type": "text",
                                "content": "is the finite field "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Z } / p \\mathbb { Z }"
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                125,
                880,
                772,
                922
            ]
        },
        {
