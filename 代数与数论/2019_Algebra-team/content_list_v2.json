            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Algebra and Number Theory Team (5 problems) "
                    }
                ],
                "level": 1
            },
            "bbox": [
                337,
                105,
                687,
                146
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "be the group of permutations of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ 1 , 2 , . . . , n \\}"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma \\in S _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "be the permutation "
                    }
                ]
            },
            "bbox": [
                134,
                159,
                776,
                174
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "(1, n) (2, n - 1) \\dots (k, n - k + 1) \\dots .",
                "math_type": "latex",
                "image_source": {
                    "path": "images/c5a907ad29b2ce7c93347403fc22631bd9976b9d0edc41f4d773e6ec641b70db.jpg"
                }
            },
            "bbox": [
                400,
                185,
                665,
                200
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Prove that the centraliser "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Z _ { S _ { n } } ( \\sigma )"
                    },
                    {
                        "type": "text",
                        "content": "is isomorphic to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S _ { [ \\frac { n } { 2 } ] } \\ltimes ( \\mathbb { Z } / 2 \\mathbb { Z } ) ^ { [ \\frac { n } { 2 } ] }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                156,
                210,
                663,
                228
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2) Recall that the algebra of regular functions on a vector space "
                    },
                    {
                        "type": "equation_inline",
                        "content": "W"
                    },
                    {
                        "type": "text",
                        "content": "is the symmetric algebra of linear forms on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "W"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                134,
                235,
                907,
                262
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V = \\mathbb { C } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { C } [ \\operatorname { E n d } _ { \\mathbb { C } } ( V ) ]"
                    },
                    {
                        "type": "text",
                        "content": "be the algebra of regular functions on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\operatorname { E n d } _ { \\mathbb { C } } ( V )"
                    },
                    {
                        "type": "text",
                        "content": ". The natural action of the group "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G = S L _ { 2 } ( \\mathbb { C } )"
                    },
                    {
                        "type": "text",
                        "content": "on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V"
                    },
                    {
                        "type": "text",
                        "content": "induces an action of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G \\times G"
                    },
                    {
                        "type": "text",
                        "content": "on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\operatorname { E n d } _ { \\mathbb { C } } ( V )"
                    },
                    {
                        "type": "text",
                        "content": "by left and right multiplication. Thus we get an action of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G \\times G"
                    },
                    {
                        "type": "text",
                        "content": "on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { C } [ \\operatorname { E n d } _ { \\mathbb { C } } ( V ) ]"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                154,
                268,
                909,
                311
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Compute the algebra of fixed points "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { C } [ \\operatorname { E n d } _ { \\mathbb { C } } ( V ) ] ^ { G \\times G }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                156,
                313,
                556,
                331
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R"
                    },
                    {
                        "type": "text",
                        "content": "be a Noetherian ring and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "I \\subset R"
                    },
                    {
                        "type": "text",
                        "content": "be an ideal. Define the Rees algebra as "
                    }
                ]
            },
            "bbox": [
                134,
                338,
                737,
                354
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\operatorname {R e e s} (I, R) := \\bigoplus_ {n \\geqslant 1} I ^ {n} t ^ {n} \\subset R [ t ].",
                "math_type": "latex",
                "image_source": {
                    "path": "images/7bd563c129dcf7344efc640db7f3c7450c11ace66cc190001c709f948f1fcc2e.jpg"
                }
            },
            "bbox": [
                418,
                365,
                645,
                395
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Prove that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R e e s ( I , R )"
                    },
                    {
                        "type": "text",
                        "content": "is Noetherian. "
                    }
                ]
            },
            "bbox": [
                157,
                406,
                431,
                420
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "be a odd prime. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Phi _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "be the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "-th cyclotomic field, i.e., "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Phi _ { p } = \\mathbb { Q } ( \\zeta _ { p } )"
                    },
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\zeta _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "is a primitive "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "-th root of unity. "
                    }
                ]
            },
            "bbox": [
                134,
                430,
                907,
                458
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Phi _ { p } / \\mathbb { Q }"
                            },
                            {
                                "type": "text",
                                "content": "is a Galois extension with Galois group "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( \\mathbb { Z } / p \\mathbb { Z } ) ^ { \\times }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Deduce that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Phi _ { p }"
                            },
                            {
                                "type": "text",
                                "content": "contains a unique quadratic extension of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Q }"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3. Write "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g _ { p }"
                            },
                            {
                                "type": "text",
                                "content": "for the Gauss sum "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\textstyle \\sum _ { a = 1 } ^ { p - 1 } { \\left( { \\frac { a } { p } } \\right) } \\zeta _ { p } ^ { a }"
                            },
                            {
                                "type": "text",
                                "content": ". Show that "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                171,
                469,
                685,
                524
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "• "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\begin{array} { r } { \\overline { { g _ { p } } } = \\big ( \\frac { - 1 } { p } \\big ) g _ { p } } \\end{array}"
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                208,
                530,
                324,
                565
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Determine the unique quadratic extension of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { Q }"
                    },
                    {
                        "type": "text",
                        "content": "contained in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Phi _ { p }"
                    }
                ]
            },
            "bbox": [
                173,
                569,
                670,
                585
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "5) 1. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "E / F"
                            },
                            {
                                "type": "text",
                                "content": "be a finite Galois extension. Assume that the Galois group "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G a l ( E / F )"
                            },
                            {
                                "type": "text",
                                "content": "is generated by a single element "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\sigma"
                            },
                            {
                                "type": "text",
                                "content": ". Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x"
                            },
                            {
                                "type": "text",
                                "content": "be an element of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "E"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "t r _ { E / F } ( x ) = 0"
                            },
                            {
                                "type": "text",
                                "content": ". Show that there exists "
                            },
                            {
                                "type": "equation_inline",
                                "content": "y \\in E"
                            },
                            {
                                "type": "text",
                                "content": "such that x = σ(y) − y. "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x = \\sigma ( y ) - y"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F"
                            },
                            {
                                "type": "text",
                                "content": "be a field of characteristic "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": ", and let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "E / F"
                            },
                            {
                                "type": "text",
                                "content": "be a Galois extension of degree "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": ". Show that there exists "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x \\in F"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "E \\cong F [ T ] / ( T ^ { p } - T - x )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
