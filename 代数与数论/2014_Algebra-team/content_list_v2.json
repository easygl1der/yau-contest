        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\operatorname {S L} _ {2} (\\mathbb {R}) = \\{g = \\left( \\begin{array}{c c} a & b \\\\ c & d \\end{array} \\right) \\in M _ {2} (\\mathbb {R}): \\det  g = 1 \\}",
