[
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "GROUP TEST S.-T YAU COLLEGE MATH CONTESTS 2012 "
                    }
                ],
                "level": 1
            },
            "bbox": [
                310,
                174,
                680,
                208
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Algebra and Number Theory "
                    }
                ],
                "level": 1
            },
            "bbox": [
                289,
                223,
                709,
                248
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Please solve 5 out of the following 6 problems. "
                    }
                ]
            },
            "bbox": [
                300,
                249,
                685,
                266
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a _ { 1 } , \\cdots , a _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "b _ { 1 } , \\cdots , b _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "be complex numbers such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a _ { i } + b _ { j } \\neq"
                    },
                    {
                        "type": "text",
                        "content": "0 for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "i , j = 1 , \\cdots , n"
                    },
                    {
                        "type": "text",
                        "content": ". Define "
                    },
                    {
                        "type": "equation_inline",
                        "content": "c _ { i j } : = \\frac { 1 } { a _ { i } + b _ { j } }"
                    },
                    {
                        "type": "text",
                        "content": "for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "i , j = 1 , \\cdots , n"
                    },
                    {
                        "type": "text",
                        "content": ", and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C"
                    },
                    {
                        "type": "text",
                        "content": "be the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\times n"
                    },
                    {
                        "type": "text",
                        "content": "determinant with entries "
                    },
                    {
                        "type": "equation_inline",
                        "content": "c _ { i j }"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that "
                    }
                ]
            },
            "bbox": [
                191,
                290,
                801,
                356
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "d e t (C) = \\frac {\\prod_ {1 \\leq i <   j \\leq n} (a _ {i} - a _ {j}) (b _ {i} - b _ {j})}{\\prod_ {1 \\leq i , j \\leq n} (a _ {i} + b _ {j})}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/b6e1b6e469c626e9c69e06bd8f52f1fdc901018360f31de1ec5e3b72a5d6b731.jpg"
                }
            },
            "bbox": [
                336,
                360,
                658,
                401
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Recall that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { F } _ { 7 }"
                    },
                    {
                        "type": "text",
                        "content": "is the finite field with 7 elements, and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G L _ { 3 } ( \\mathbb { F } _ { 7 } )"
                    },
                    {
                        "type": "text",
                        "content": "is the group of all invertible "
                    },
                    {
                        "type": "equation_inline",
                        "content": "3 \\times 3"
                    },
                    {
                        "type": "text",
                        "content": "matrices with entries in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { F } _ { 7 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                407,
                801,
                442
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(1) Find a 7-Sylow subgroup "
                            },
                            {
                                "type": "equation_inline",
                                "content": "P _ { 7 }"
                            },
                            {
                                "type": "text",
                                "content": "of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G L _ { 3 } ( \\mathbb { F } _ { 7 } )"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(2) Determine the normalizer subgroup "
                            },
                            {
                                "type": "equation_inline",
                                "content": "N"
                            },
                            {
                                "type": "text",
                                "content": "of the 7-Sylow subgroup you found in (a). "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(3) Find a 2-Sylow subgroup of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G L _ { 3 } ( \\mathbb { F } _ { 7 } )"
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                223,
                445,
                800,
                510
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V"
                    },
                    {
                        "type": "text",
                        "content": "be a finite dimensional vector space with a positive definite quadratic form "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( - , - )"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "O ( V )"
                    },
                    {
                        "type": "text",
                        "content": "denote the orthogonal group: "
                    }
                ]
            },
            "bbox": [
                191,
                520,
                801,
                554
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "O (V) = \\{g \\in G L (V): \\qquad (g x, g y) = (x, y), \\quad \\forall x, y \\in V \\}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/ea9c2c265831858689ab1441347c98ae7ed5c1aab35eb713e0961d895434cae0.jpg"
                }
            },
            "bbox": [
                243,
                558,
                749,
                577
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "For any non-zero "
                    },
                    {
                        "type": "equation_inline",
                        "content": "v \\in V"
                    },
                    {
                        "type": "text",
                        "content": ", let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "s _ { v }"
                    },
                    {
                        "type": "text",
                        "content": "denote the reflection on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V"
                    },
                    {
                        "type": "text",
                        "content": ": "
                    }
                ]
            },
            "bbox": [
                193,
                582,
                697,
                598
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "s _ {v} (w) = w - 2 \\frac {(v , w)}{(v , v)} v.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/ebd59390f3536708e7cf2a45a0329cc9f86b2dee45b9058df12d1d027dc3adb7.jpg"
                }
            },
            "bbox": [
                400,
                602,
                596,
                640
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(1) Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "s _ { v } \\in O ( V )"
                            },
                            {
                                "type": "text",
                                "content": "; "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(2) Show that if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "v"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "w"
                            },
                            {
                                "type": "text",
                                "content": "are vectors in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V"
                            },
                            {
                                "type": "text",
                                "content": "with "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\| v \\| = \\| w \\|"
                            },
                            {
                                "type": "text",
                                "content": ",then there is either a reflection or product of two reflections that takes "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\boldsymbol { v }"
                            },
                            {
                                "type": "text",
                                "content": "into "
                            },
                            {
                                "type": "equation_inline",
                                "content": "w"
                            },
                            {
                                "type": "text",
                                "content": "; "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(3) Deduce that every element of the orthogonal group of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V"
                            },
                            {
                                "type": "text",
                                "content": "can be written as the product of at most "
                            },
                            {
                                "type": "equation_inline",
                                "content": "2 \\dim V"
                            },
                            {
                                "type": "text",
                                "content": "reflections. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                223,
                643,
                800,
                740
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Consider the real Lie group "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S L _ { 2 } ( \\mathbb { R } )"
                    },
                    {
                        "type": "text",
                        "content": "of 2 by 2 matrices of determinant one. Compute the fundamental group of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S L _ { 2 } ( \\mathbb { R } )"
                    },
                    {
                        "type": "text",
                        "content": "and describe the Lie group structure on the universal covering "
                    }
                ]
            },
            "bbox": [
                191,
                751,
                801,
                802
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\widetilde {S L} _ {2} (\\mathbb {R}) \\to S L _ {2} (\\mathbb {R}).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/4f8c3e6ea5e170eddae425a46ce35b1b834adbca5d9a403668d3d15e4daf4043.jpg"
                }
            },
            "bbox": [
                413,
                804,
                583,
                827
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f \\in \\mathbb { C } [ x , y , z ]"
                    },
                    {
                        "type": "text",
                        "content": "be an irreducible homogenous polynomial of degree "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d > 0"
                    },
                    {
                        "type": "text",
                        "content": ". For each integer "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\geq d"
                    },
                    {
                        "type": "text",
                        "content": ", define "
                    }
                ]
            },
            "bbox": [
                191,
                834,
                801,
                866
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "P (n) = \\dim_ {\\mathbb {C}} \\mathbb {C} [ x, y, z ] _ {n} / f \\cdot \\mathbb {C} [ x, y, z ] _ {n - d}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/e828c9273335a48fc13c8077870f7c0cbe820dbde9b462e0e043c047ffd1375f.jpg"
                }
            },
            "bbox": [
                326,
                872,
                670,
                891
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": []
            },
            "bbox": [
                492,
                892,
                502,
                901
            ]
        }
    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { C } [ x , y , z ] _ { d }"
                    },
                    {
                        "type": "text",
                        "content": "is the subspace of homogenous polynomials of degree "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": ". Show there are constants "
                    },
                    {
                        "type": "equation_inline",
                        "content": "c"
                    },
                    {
                        "type": "text",
                        "content": "such that for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "sufficiently large, "
                    }
                ]
            },
            "bbox": [
                193,
                136,
                801,
                170
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "P (n) = d n + c.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/f25ebb066307613abc01b083a1e0ab0d74df8266ed4d289827a8d7833a0b0cc1.jpg"
                }
            },
            "bbox": [
                433,
                175,
                563,
                193
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "6. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "be an odd prime and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { Z } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "-adic integer which can be defined as the projective limit of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { Z } / p ^ { n } \\mathbb { Z }"
                    },
                    {
                        "type": "text",
                        "content": "and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { Q } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "be its fractional field. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { Z } _ { p } ^ { \\times }"
                    },
                    {
                        "type": "text",
                        "content": "denote the group of invertible elements in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { Z } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "which is also the projective limit of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( \\mathbb { Z } / p ^ { n } \\mathbb { Z } ) ^ { \\times }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                200,
                801,
                268
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(1) For any integer "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a"
                    },
                    {
                        "type": "text",
                        "content": "is not divisible by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": ", show that the sequence "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( a ^ { p ^ { n } } ) _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "convergent to an element "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\omega ( a ) \\in \\mathbb { Z } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "satisfying "
                    }
                ]
            },
            "bbox": [
                223,
                271,
                801,
                305
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\omega (a) ^ {p - 1} = 1, \\qquad \\omega (a) \\equiv a \\pmod {p}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/1db75845c5855a9143c68380cdbe8b442ef2d36fcfdbe419b7c10a20f16684e5.jpg"
                }
            },
            "bbox": [
                334,
                309,
                658,
                328
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Moreover, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\omega ( a )"
                    },
                    {
                        "type": "text",
                        "content": "depends only on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a"
                    },
                    {
                        "type": "text",
                        "content": "mod "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    }
                ]
            },
            "bbox": [
                255,
                332,
                628,
                349
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(2) Define a logarithmic function log on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 + p \\mathbb { Z } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "by usual formula: "
                    }
                ]
            },
            "bbox": [
                223,
                349,
                801,
                367
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\log (1 + p x) = \\sum_ {n = 1} ^ {\\infty} (- 1) ^ {n - 1} \\frac {p ^ {n}}{n} x ^ {n}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/bdb355df9995cbd1e5cec2cfdd5a50305b34e3a422c3ab67e9f7a37c71bb83d4.jpg"
                }
            },
            "bbox": [
                359,
                372,
                633,
                414
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Show that the logarithmic function is convergent and define an isomorphism "
                    }
                ]
            },
            "bbox": [
                255,
                418,
                801,
                450
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "1 + p \\mathbb {Z} _ {p} \\to p \\mathbb {Z} _ {p}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/73d423c31b8e145fc50cdff8bdfb05384ce7f84e031b40543f333bb585d29c13.jpg"
                }
            },
            "bbox": [
                430,
                451,
                566,
                469
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Moreover, on the dense subgroup "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\log ( 1 + p ) \\mathbb { Z }"
                    },
                    {
                        "type": "text",
                        "content": ", the inverse is given by "
                    }
                ]
            },
            "bbox": [
                255,
                470,
                801,
                504
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\log (1 + p) \\cdot x \\mapsto (1 + p) ^ {x}, \\quad \\forall x \\in \\mathbb {Z}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/69e8f9e20a48944047f7cd35ce081af53a2f9068204373d60f5919757d1f7a58.jpg"
                }
            },
            "bbox": [
                332,
                508,
                660,
                527
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(3) Deduce from above that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { Z } _ { p } ^ { \\times } \\simeq \\mathbb { Z } _ { p } \\times \\mathbb { Z } / ( p - 1 ) \\mathbb { Z }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                223,
                531,
                675,
                551
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "2 "
                    }
                ]
            },
            "bbox": [
                196,
                112,
                206,
                122
            ]
