            "type": "equation_interline",
            "content": {
                "math_content": "\\sigma^ {f} = 1, \\quad \\tau^ {e} = 1, \\quad a n d \\quad \\sigma \\tau \\sigma^ {- 1} = \\tau^ {p}.",
