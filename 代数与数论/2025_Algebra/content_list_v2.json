                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F ^ { * 2 } : = \\{ a ^ { 2 } | a \\in F ^ { * } \\} \\subset F ^ { * }"
                    },
                    {
                        "type": "text",
                        "content": ". Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F"
                    },
                    {
                        "type": "text",
                        "content": "has a Galois extension of group "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { Z } / 2 \\mathbb { Z } \\times \\mathbb { Z } / 2 \\mathbb { Z }"
                    },
                    {
                        "type": "text",
                        "content": "if and only if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "[ F ^ { * } : F ^ { * 2 } ] > 2"
                    },
                    {
                        "type": "text",
                        "content": ". Furthermore, show that such Galois extensions are precisely the splitting fields of irreducible polynomials of the form "
                    }
                ]
            },
