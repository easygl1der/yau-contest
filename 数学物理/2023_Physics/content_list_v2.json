[
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "S.-T. Yau College Student Mathematics Contests 2023 "
                    }
                ],
                "level": 1
            },
            "bbox": [
                238,
                138,
                702,
                155
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Mathematical Physics "
                    }
                ],
                "level": 1
            },
            "bbox": [
                356,
                170,
                573,
                189
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Solve every problem. "
                    }
                ]
            },
            "bbox": [
                380,
                204,
                555,
                220
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Consider the Lagrangian "
                    }
                ]
            },
            "bbox": [
                107,
                273,
                341,
                291
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "L (x, y, \\dot {x}, \\dot {y}) = \\frac {1}{2} \\frac {\\dot {x} ^ {2} + \\dot {y} ^ {2} + 2 (x \\dot {y} - y \\dot {x})}{x ^ {2} + y ^ {2}} \\tag {1}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/fe08c25c80eb799dffdf5aa96b58d3ec5909384833200c10b5ba3294718a3466.jpg"
                }
            },
            "bbox": [
                336,
                304,
                851,
                342
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) Compute the Hamiltonian "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H ( x , y , p _ { z } , p _ { y } )"
                    },
                    {
                        "type": "text",
                        "content": ", and show the final form can be written as "
                    }
                ]
            },
            "bbox": [
                138,
                354,
                852,
                387
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\frac {1}{2} f (x, y) \\left[ \\left(p _ {x} - A _ {x} (x, y)\\right) ^ {2} + \\left(p _ {y} - A _ {y} (x, y)\\right) ^ {2} \\right] \\tag {2}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/aca789c07996b890ef847b22c0ad9af1d739f8782307decfec9830d04fcbcc28.jpg"
                }
            },
            "bbox": [
                330,
                387,
                851,
                419
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "for some "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f , A _ { x } , A _ { y }"
                    },
                    {
                        "type": "text",
                        "content": ". Find the vector potential "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\vec { A }"
                    },
                    {
                        "type": "text",
                        "content": "and then compute the corresponding magnetic field away from the origin. (Hint: recall that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\vec { B } = \\mathrm { c u r l } \\vec { A } = \\nabla \\times \\vec { A }"
                    },
                    {
                        "type": "text",
                        "content": "). "
                    }
                ]
            },
            "bbox": [
                169,
                428,
                852,
                467
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Prove that the Lagrangian "
                            },
                            {
                                "type": "equation_inline",
                                "content": "L ( x , y , \\dot { x } , \\dot { y } )"
                            },
                            {
                                "type": "text",
                                "content": "is invariant under two symmetries: rotations and scale transformations. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) Derive the conserved quantities for both symmetries. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(d) Rewrite the Lagrangian in polar coordinates, write down the Euler-Lagrange equations and solve them. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                138,
                472,
                852,
                574
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. A particle of mass "
                    },
                    {
                        "type": "equation_inline",
                        "content": "m"
                    },
                    {
                        "type": "text",
                        "content": "in 2 dimensions is confined by an isotropic harmonic oscillator potential of frequency "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\omega"
                    },
                    {
                        "type": "text",
                        "content": ", while subject to a weak and anisotropic perturbation of strength "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\alpha \\ll 1"
                    },
                    {
                        "type": "text",
                        "content": ". The total Hamiltonian of the particle is "
                    }
                ]
            },
            "bbox": [
                104,
                588,
                854,
                643
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "H = H _ {0} + V = \\frac {p _ {x} ^ {2}}{2 m} + \\frac {p _ {y} ^ {2}}{2 m} + \\frac {1}{2} m \\omega^ {2} \\left(x ^ {2} + y ^ {2}\\right) + \\alpha m \\omega^ {2} x y \\tag {3}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/b0f968e091069b927b368ccd78e989c34d53bf408483d050f1772178810be674.jpg"
                }
            },
            "bbox": [
                264,
                656,
                851,
                691
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) When "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\alpha = 0"
                            },
                            {
                                "type": "text",
                                "content": ", what are the energies and degeneracies of the three lowest-lying unperturbed states? "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Use perturbation theory to correct the energies of the above three states to the first order in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\alpha"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) Find the exact spectrum of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "H"
                            },
                            {
                                "type": "text",
                                "content": ". (Hint: you may want to rotate "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "y"
                            },
                            {
                                "type": "text",
                                "content": "into a new coordinates) "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(d) Check that the perturbative results in part b. are recovered from the exact spectrum. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                138,
                704,
                852,
                866
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "1 "
                    }
                ]
            },
            "bbox": [
                462,
                890,
                473,
                902
            ]
        }
    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. One can express the electric fields "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\vec { E }"
                    },
                    {
                        "type": "text",
                        "content": "and magnetic fields "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\vec { B }"
                    },
                    {
                        "type": "text",
                        "content": "in terms of the scalar and vector potentials, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A ^ { \\mu } = \\left( \\phi , { \\vec { A } } \\right)"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                106,
                135,
                854,
                175
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) Write down the expression of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\vec { E }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\vec { B }"
                    },
                    {
                        "type": "text",
                        "content": "in terms of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( \\phi , { \\vec { A } } )"
                    },
                    {
                        "type": "text",
                        "content": "and show that the result is unchanged under gauge transformation "
                    }
                ]
            },
            "bbox": [
                138,
                185,
                854,
                223
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\phi \\rightarrow \\phi + \\frac {\\partial}{\\partial t} f, \\quad \\vec {A} \\rightarrow \\vec {A} - \\nabla f, \\tag {4}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/debc26ffa22f0c21dc56f2217e75d91df3474a619d48bac865a367217be071ad.jpg"
                }
            },
            "bbox": [
                388,
                232,
                854,
                267
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f = f ( \\vec { x } , t )"
                    },
                    {
                        "type": "text",
                        "content": "is a scalar function. "
                    }
                ]
            },
            "bbox": [
                171,
                273,
                491,
                292
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Show that two of the 4 Maxwell equations of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\vec { E }"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\vec { B }"
                            },
                            {
                                "type": "text",
                                "content": "are satisfied automatically in terms of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A ^ { \\mu } = \\left( \\phi , { \\vec { A } } \\right)"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) Derive the equations for the scalar and vector potentials from the remaining Maxwell equations in Lorentz gauge. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                137,
                297,
                852,
                378
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\frac {1}{c} \\partial_ {t} \\phi + \\nabla \\cdot \\vec {A} = 0, \\tag {5}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/4cb2cf0a80a51e57b67e57e5aa64077cda1c8a222af8c55a337abb973133b638.jpg"
                }
            },
            "bbox": [
                439,
                387,
                852,
                421
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(d) Recall that the Green’s function of the wave equation "
                    }
                ]
            },
            "bbox": [
                138,
                431,
                629,
                450
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left(\\frac {1}{c ^ {2}} \\partial_ {t} ^ {2} - \\nabla^ {2}\\right) G (t, \\vec {r}) = \\delta (t) \\delta^ {3} (\\vec {r}) \\tag {6}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/a3b1ba3f8d5af302113001df24a12c3a55907d2c608cfbc23f237fd48ff3bad3.jpg"
                }
            },
            "bbox": [
                380,
                459,
                854,
                498
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "is "
                    }
                ]
            },
            "bbox": [
                171,
                506,
                191,
                520
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "G (t - t _ {0}, \\vec {r} - \\vec {r} _ {0}) = \\frac {\\theta (t - t _ {0})}{4 \\pi | \\vec {r} - \\vec {r} _ {0} |} \\delta \\left(t - t _ {0} - \\frac {| \\vec {r} - \\vec {r} _ {0} |}{c}\\right). \\tag {7}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/bd654f0192e630ed1cb1d2bbd424d3ba64f0e1c0e9b630950a088c08b133d4aa.jpg"
                }
            },
            "bbox": [
                300,
                518,
                854,
                558
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Assume a particle of electric charge "
                    },
                    {
                        "type": "equation_inline",
                        "content": "e"
                    },
                    {
                        "type": "text",
                        "content": "moves with trajectory "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\vec { R } ( t )"
                    },
                    {
                        "type": "text",
                        "content": "with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "{ \\vec { v } } ( t ) ="
                    },
                    {
                        "type": "equation_inline",
                        "content": "d \\vec { R } ( t ) / d t"
                    },
                    {
                        "type": "text",
                        "content": ". Use the Green’s function to derive the potential "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\phi ( \\vec { r } , t )"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\vec { A } ( \\vec { r } , t )"
                    },
                    {
                        "type": "text",
                        "content": "of this particle at "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( \\vec { r } , t )"
                    },
                    {
                        "type": "text",
                        "content": ". You may assume that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| \\vec { R } ( t ) | \\ll | \\vec { r } |"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| \\vec { R } ( t ) | \\ll c t"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| \\vec { v } ( t ) | \\ll c"
                    },
                    {
                        "type": "text",
                        "content": "and expand your result up to the order "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathcal { O } ( 1 / | \\vec { r } | )"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathcal { O } ( | \\vec { v } ( t ) | / c )"
                    },
                    {
                        "type": "text",
                        "content": ". This is also called non-relativistic and far-field approximations. "
                    }
                ]
            },
            "bbox": [
                169,
                563,
                852,
                657
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Consider a one-dimensional system of free massless bosons with one polarization, and the dispersion relation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E _ { k } = \\hbar v | k |"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\boldsymbol { v }"
                    },
                    {
                        "type": "text",
                        "content": "is the particle velocity, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k"
                    },
                    {
                        "type": "text",
                        "content": "wavevector, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E _ { k }"
                    },
                    {
                        "type": "text",
                        "content": "energy. The particles are not interacting either among themselves or with external scattering potentials. If the system is in equilibrium at temperature "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    }
                ]
            },
            "bbox": [
                106,
                669,
                854,
                743
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Assume that the chemical potential "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mu"
                            },
                            {
                                "type": "text",
                                "content": "is "
                            },
                            {
                                "type": "equation_inline",
                                "content": "0"
                            },
                            {
                                "type": "text",
                                "content": ", calculate the heat capacity "
                            },
                            {
                                "type": "equation_inline",
                                "content": "C"
                            },
                            {
                                "type": "text",
                                "content": "per unit length. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Repeat the calculations for massive fermions, for which "
                            },
                            {
                                "type": "equation_inline",
                                "content": "E _ { k } = \\hbar ^ { 2 } k ^ { 2 } / 2 m"
                            },
                            {
                                "type": "text",
                                "content": "and the chemical potential "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mu"
                            },
                            {
                                "type": "text",
                                "content": "is far above the bottom of the energy spectrum: "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mu \\gg k _ { B } T"
                            },
                            {
                                "type": "text",
                                "content": ". (Consider one spin direction for the fermions, and you may make reasonable approximations.) "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                138,
                753,
                852,
                868
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "2 "
                    }
                ]
            },
            "bbox": [
                462,
                888,
                473,
                902
            ]
        }
    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Hint: you might find the following formulae useful to evaluate some integrals needed "
                    }
                ]
            },
            "bbox": [
                130,
                138,
                844,
                155
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\sum_ {k = 1} ^ {\\infty} \\frac {1}{k ^ {2}} = \\frac {\\pi^ {2}}{6}, \\quad \\sum_ {k = 1} ^ {\\infty} \\frac {(- 1) ^ {k + 1}}{k ^ {2}} = \\frac {\\pi^ {2}}{1 2}. \\tag {8}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/09e9621470dffe5ca029b059cd95b0cfbf41495433b5e3250a0bdc5b4d29bf94.jpg"
                }
            },
            "bbox": [
                348,
                167,
                851,
                213
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. Consider the vacuum Einstein’s equation in four dimensional spacetime with a cosmological constant "
                    }
                ]
            },
            "bbox": [
                106,
                229,
                852,
                263
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "R _ {\\mu \\nu} - \\frac {1}{2} g _ {\\mu \\nu} R + g _ {\\mu \\nu} \\Lambda = 0. \\tag {9}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/9e20bfc44dbdaf5cc1c186d218e076c6075549d8bb7136159da042057b5e5b28.jpg"
                }
            },
            "bbox": [
                385,
                263,
                851,
                296
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
