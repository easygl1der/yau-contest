                561,
                197
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. "
                    }
                ],
                "level": 1
            },
            "bbox": [
                154,
                223,
                253,
                236
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Consider a single observation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X \\sim N ( \\mu , \\sigma ^ { 2 } )"
                    },
                    {
                        "type": "text",
                        "content": "with both "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "unknown. We are interested in constructing confidence interval (CI) for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                129,
                237,
                860,
                268
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Consider the following CI: "
                    }
                ]
            },
            "bbox": [
                151,
                275,
                369,
                290
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\operatorname {C I} (X; c _ {1}, c _ {2}) = \\left\\{ \\begin{array}{l l} c _ {1} X \\leq \\mu \\leq c _ {2} X & \\text {i f} X > 0 \\\\ c _ {2} X \\leq \\mu \\leq c _ {1} X & \\text {i f} X <   0 \\end{array} \\right..",
                "math_type": "latex",
                "image_source": {
                    "path": "images/9df096c1b7b59b0a3d3ee18291c0ae7ca7fad3951a92f2519c050a791337fa9a.jpg"
                }
            },
            "bbox": [
                352,
                300,
                685,
                338
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "What is the coverage probability of this CI? "
                    }
                ]
            },
            "bbox": [
                171,
                347,
                502,
                363
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F ( x ; b _ { 1 } , b _ { 2 } )"
                    },
                    {
                        "type": "text",
                        "content": "be a function that is measurable in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x"
                    },
                    {
                        "type": "text",
                        "content": "and is a distribution function on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "b _ { 1 } < b _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ", and which generates a randomized confidence interval whose lower and upper endpoints are random variables "
                    },
                    {
                        "type": "equation_inline",
                        "content": "b _ { 1 } < b _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "with distribution function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F ( x ; b _ { 1 } , b _ { 2 } )"
                    },
                    {
                        "type": "text",
                        "content": ". Then, there is a randomized confidence interval given by a distribution function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G ( c _ { 1 } , c _ { 2 } )"
                    },
                    {
                        "type": "text",
                        "content": "randomly choosing a interval of the form "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\operatorname { C I } ( x ; c _ { 1 } , c _ { 2 } )"
                    },
                    {
                        "type": "text",
                        "content": "with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( C _ { 1 } , C _ { 2 } ) \\sim G"
                    },
                    {
                        "type": "text",
                        "content": "and satisfying the following “minimax” property: "
                    }
                ]
            },
            "bbox": [
                151,
                370,
                863,
                444
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\inf  _ {\\mu , \\sigma} E _ {\\mu , \\sigma} P _ {G} \\{\\mu \\in \\operatorname {C I} (X; c _ {1}, c _ {2}) \\} \\geq \\sup  _ {F} \\inf  _ {\\mu , \\sigma} E _ {\\mu , \\sigma} P _ {F (X; \\cdot)} \\{\\mu \\in (b _ {1}, b _ {2}) \\}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/25ac00429ae93f30988d0f9be788f1da4e3cd6f4c207fc629f1a7ba43c16ddee.jpg"
                }
            },
            "bbox": [
                280,
                462,
                754,
                483
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "E _ {\\mu , \\sigma} E _ {G} \\left[ (c _ {2} - c _ {1}) | X | \\right] = E _ {\\mu , \\sigma} E _ {F (X; \\cdot)} \\left[ (b _ {2} - b _ {1}) \\right].",
                "math_type": "latex",
                "image_source": {
                    "path": "images/42e39de773df61e935357c0a9691da1d8bf7648c3df8d761dbe0f07155bab005.jpg"
                }
            },
            "bbox": [
                344,
                502,
                692,
                518
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Problem 2. "
                    }
                ],
                "level": 1
            },
            "bbox": [
                154,
                537,
                253,
                551
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Consider a joint distribution of the random variable pair "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ X , Y \\}"
                    },
                    {
                        "type": "text",
                        "content": ", and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P _ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "be the two marginal distributions on the real line (that is, for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y"
                    },
                    {
                        "type": "text",
                        "content": ", respectively). Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { 1 } ( x )"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { 2 } ( y )"
                    },
                    {
                        "type": "text",
                        "content": "be the respective densities for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P _ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "with respect to a dominating measure "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\nu ( \\cdot )"
                    },
                    {
                        "type": "text",
                        "content": "be any function such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\nu ( X )"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\nu ( Y )"
                    },
                    {
                        "type": "text",
                        "content": "are not bounded and their expectations "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E _ { 1 } ( \\nu ( X ) )"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E _ { 2 } ( \\nu ( Y ) )"
                    },
                    {
                        "type": "text",
                        "content": "are both finite under "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P _ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ", respectively. Suppose a single observation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r"
                    },
                    {
                        "type": "text",
                        "content": "comes from population 1 with probability 1/2 and from population 2 with probability "
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 / 2"
                    },
                    {
                        "type": "text",
                        "content": ". The problem is to choose the population, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "i"
                    },
                    {
                        "type": "text",
                        "content": ", for which the expectation is greater, based on the single observation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                129,
                552,
                863,
                651
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Consider a randomized decision rule (or selection rule) to be given by a function "
                    }
                ]
            },
            "bbox": [
                154,
                652,
                751,
                665
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\phi : \\mathcal {R} \\to [ 0, 1 ]",
                "math_type": "latex",
                "image_source": {
                    "path": "images/3a6e41718006240d130538a98161506ac60f2115977c841042fdeb8e07651360.jpg"
                }
            },
            "bbox": [
                448,
                678,
                547,
                693
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\phi ( r )"
                    },
                    {
                        "type": "text",
                        "content": "is the probability of choosing population 1 based on the observation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r"
                    },
                    {
                        "type": "text",
                        "content": ". Assume "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\phi ( r )"
                    },
                    {
                        "type": "text",
                        "content": "is a one-to-one function. "
                    }
                ]
            },
            "bbox": [
                129,
                703,
                860,
                730
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "For any given decision function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\phi ( r )"
                    },
                    {
                        "type": "text",
                        "content": ", for any two densities "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { 1 } ( x )"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { 2 } ( y )"
                    },
                    {
                        "type": "text",
                        "content": "(with respect to the Lebesgue measure) such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E _ { 1 } ( \\nu ( X ) ) > E _ { 2 } ( \\nu ( Y ) )"
                    },
                    {
                        "type": "text",
                        "content": ", is the probability of correctly selecting population 1 always greater than or equal to 1/2? If so, prove it. If not, for any given decision function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\phi ( r )"
                    },
                    {
                        "type": "text",
                        "content": ", construct a "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { 1 } ( x )"
                    },
                    {
                        "type": "text",
                        "content": "and a "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { 2 } ( y )"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E _ { 1 } ( \\nu ( X ) ) > E _ { 2 } ( \\nu ( Y ) )"
                    },
                    {
                        "type": "text",
                        "content": "but the probability of correctly selecting population 1 is less than "
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 / 2"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                129,
                732,
                863,
                804
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "1 "
                    }
                ]
            },
            "bbox": [
                492,
                865,
                502,
                876
            ]
        }
    ],
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Problem 3. "
                    }
                ],
                "level": 1
            },
            "bbox": [
                156,
                137,
                253,
                149
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\geq 2"
                    },
                    {
                        "type": "text",
                        "content": "be a natural number. Prove that there exist independent random variables "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 1 } , X _ { 2 } , \\ldots , X _ { n } ="
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 0 }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    }
                ]
            },
            "bbox": [
                131,
                149,
                897,
                178
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "P \\left(X _ {k - 1} <   X _ {k}\\right) = 1 - \\frac {1}{4 \\cos^ {2} \\left(\\frac {\\pi}{n + 2}\\right)}, \\quad \\text {f o r a l l} 1 \\leq k \\leq n.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/a61e787f017219f49bba859dc1a783de41b95d29518c2dba0565f991c923b948.jpg"
                }
            },
            "bbox": [
                285,
                177,
                709,
                209
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. "
                    }
                ],
                "level": 1
            },
            "bbox": [
                156,
                224,
                253,
                236
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Consider a one-way ANOVA with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "cells and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n / p"
                    },
                    {
                        "type": "text",
                        "content": "observations per cell: "
                    }
                ]
            },
            "bbox": [
                154,
                237,
                682,
                252
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "Y _ {i j} = \\beta_ {j} + R _ {i j}, \\quad i = 1, \\dots , n / p, \\quad j = 1, \\dots , p,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/56bc792a9eccccdca48b458dbcd7bca2e0d28b146d8b09bbf30025f1b21dafc7.jpg"
                }
            },
            "bbox": [
                321,
                263,
                670,
                279
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ R _ { i j } \\}"
                    },
                    {
                        "type": "text",
                        "content": "are i.i.d. Assume the true values "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\beta _ { j } = 0"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                129,
                290,
                527,
                305
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\psi"
                    },
                    {
                        "type": "text",
                        "content": "be a given function and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\hat { \\beta } _ { j }"
                    },
                    {
                        "type": "text",
                        "content": "denote the solution of the equation "
                    }
                ]
            },
            "bbox": [
                154,
                306,
                690,
                319
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "0 = \\sum_ {i = 1} ^ {n / p} \\psi \\left(Y _ {i j} - \\hat {\\beta} _ {j}\\right).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/5f30e2b67c8545568307d7b8477da0dd3787b35a15e7bb3eb8e7b2a3a1caf216.jpg"
                }
            },
            "bbox": [
                418,
                332,
                573,
                372
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\psi"
                    },
                    {
                        "type": "text",
                        "content": "be a bounded function such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\psi ^ { \\prime }"
                    },
                    {
                        "type": "text",
                        "content": "is bounded and continuous near zero. Suppose "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E \\psi ( R ) = 0"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E \\psi ^ { \\prime } ( R ) = d \\neq 0"
                    },
                    {
                        "type": "text",
                        "content": ". Assume "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p ( \\log p ) / n \\to 0"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that there are solutions "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ \\hat { \\beta } _ { j } \\}"
                    },
                    {
                        "type": "text",
                        "content": "of the equation and a constant "
                    },
                    {
                        "type": "equation_inline",
                        "content": "B > 0"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    }
                ]
            },
            "bbox": [
                129,
                382,
                865,
                425
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "P \\left\\{\\max _ {j} | \\hat {\\beta} _ {j} | \\geq \\left(\\frac {1}{B} \\frac {p \\log n}{n}\\right) ^ {1 / 2} \\right\\} \\leq \\frac {2 p}{n} \\to 0.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/74d8616dbf55d3ad07d53ddf33e7f73600e9e1995382d653090d066945e29db1.jpg"
                }
            },
            "bbox": [
                334,
                435,
                660,
                475
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": []
            },
            "bbox": [
                492,
                865,
                502,
                876
            ]
        }
    ]
]