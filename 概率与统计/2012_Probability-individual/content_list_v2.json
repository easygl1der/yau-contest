            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Probability and Statistics "
                    }
                ],
                "level": 1
            },
            "bbox": [
                314,
                240,
                682,
                263
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Please solve 5 out of the following 6 problems, or highest scores of 5 problems will be counted. "
                    }
                ]
            },
            "bbox": [
                290,
                285,
                705,
                319
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Solve the following two problems: "
                    }
                ]
            },
            "bbox": [
                194,
                363,
                512,
                380
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1) An urn contains "
                    },
                    {
                        "type": "equation_inline",
                        "content": "b"
                    },
                    {
                        "type": "text",
                        "content": "black balls and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r"
                    },
                    {
                        "type": "text",
                        "content": "red balls. One of the balls was drawn at random, and putted back in the urn with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a"
                    },
                    {
                        "type": "text",
                        "content": "additional balls of the same color. Now suppose that the second ball drawn at random is red. What is the probability that the first ball drawn was black? "
                    }
                ]
            },
            "bbox": [
                191,
                381,
                801,
                445
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2) Let ( "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { n }"
                    },
                    {
                        "type": "text",
                        "content": ") be a sequence of random variables satisfying "
                    }
                ]
            },
            "bbox": [
                213,
                447,
                709,
                464
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\lim  _ {a \\to \\infty} \\sup  _ {n \\geq 1} P (| X _ {n} | > a) = 0.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/a943ac0d790bf7fd3ee281c4fb907e052cfa842d354541062f5a23ad163da54f.jpg"
                }
            },
            "bbox": [
                386,
                470,
                608,
                497
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Assume that sequence of random variables ( "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y _ { n }"
                    },
                    {
                        "type": "text",
                        "content": ") converges to 0 in probability. Prove that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( X _ { n } Y _ { n } )"
                    },
                    {
                        "type": "text",
                        "content": "converges to 0 in probability. "
                    }
                ]
            },
            "bbox": [
                193,
                502,
                801,
                538
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Solve the following two problems: "
                    }
                ]
            },
            "bbox": [
                193,
                545,
                512,
                561
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( \\Omega , { \\mathcal { F } } , P )"
                    },
                    {
                        "type": "text",
                        "content": "be a probability space, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathcal { G }"
                    },
                    {
                        "type": "text",
                        "content": "be a sub-algebra of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathcal { F }"
                    },
                    {
                        "type": "text",
                        "content": ". Assume that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "is a non-negative integrable random variable. Set "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y ="
                    },
                    {
                        "type": "equation_inline",
                        "content": "E [ X | { \\mathcal { G } } ]"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that "
                    }
                ]
            },
            "bbox": [
                193,
                562,
                801,
                611
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "( \\mathrm { a } ) [ X > 0 ] \\subset [ Y > 0 ]"
                    },
                    {
                        "type": "text",
                        "content": ",a.s.;"
                    }
                ]
            },
            "bbox": [
                215,
                611,
                438,
                627
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "( \\mathrm { b } ) [ Y > 0 ] = \\mathrm { e s s . i n f } \\{ A : A \\in { \\mathcal { G } } , ~ [ X > 0 ] \\subset A \\}"
                    }
                ]
            },
            "bbox": [
                215,
                627,
                618,
                645
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y"
                    },
                    {
                        "type": "text",
                        "content": "have a bivariate normal distribution with zero means, variances "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tau ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ", respectively, and correlation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\rho"
                    },
                    {
                        "type": "text",
                        "content": ". Find the conditional expectation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E ( X | X + Y )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                646,
                801,
                695
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Suppose that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ p ( i , j ) : i = 1 , 2 , \\cdots , m ; j = 1 , 2 , \\cdots , n \\}"
                    },
                    {
                        "type": "text",
                        "content": "is a finite bivariate joint probability distribution, that is, "
                    }
                ]
            },
            "bbox": [
                191,
                703,
                801,
                736
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "p (i, j) > 0, \\sum_ {i = 1} ^ {m} \\sum_ {j = 1} ^ {n} p (i, j) = 1.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/3c296d2e14ea7fcd17d218f999bdd793a8d4d3267bde66cc5fd4390a3789718e.jpg"
                }
            },
            "bbox": [
                366,
                741,
                628,
                785
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(i) Can "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ p ( i , j ) \\}"
                    },
                    {
                        "type": "text",
                        "content": "be always expressed as "
                    }
                ]
            },
            "bbox": [
                213,
                791,
                561,
                809
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "p (i, j) = \\sum_ {k} \\lambda_ {k} a _ {k} (i) b _ {k} (j)",
                "math_type": "latex",
                "image_source": {
                    "path": "images/a5cbfc0b336e378d143ca9d3f97f1570dae0df338297cc6b3145afcc9e54a222.jpg"
                }
            },
            "bbox": [
                389,
                815,
                606,
                848
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "for some finiteP "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { \\lambda _ { k } \\geq 0 , ~ \\sum _ { k } \\lambda _ { k } = 1 , \\ : a _ { k } ( i ) \\geq 0 , ~ \\sum _ { i = 1 } ^ { m } a _ { k } ( i ) = 1 , ~ b _ { k } ( j ) \\geq } \\end{array}"
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda _ { k } \\geq 0"
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\textstyle \\sum _ { k } \\lambda _ { k } = 1"
                    },
                    {
                        "type": "text",
                        "content": "0, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { \\sum _ { j = 1 } ^ { n } b _ { k } ( j ) = 1 } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": "? "
                    }
                ]
            },
            "bbox": [
                191,
                854,
                801,
                892
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": []
            },
            "bbox": [
                492,
                892,
                502,
                901
            ]
        }
    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(ii) Prove or disprove the above relation by use of conditional probability. "
                    }
                ]
            },
            "bbox": [
                193,
                137,
                800,
                171
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 1 } , \\cdots , X _ { m }"
                    },
                    {
                        "type": "text",
                        "content": "be an independent and identically distributed (i.i.d.) random sample from a cumulative distribution function (CDF) "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y _ { 1 } , \\cdots , Y _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "an i.i.d. random sample from a CDF "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": ". We want to test "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H _ { 0 } : F = G"
                    },
                    {
                        "type": "text",
                        "content": "versus "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H _ { 1 } : F \\neq G"
                    },
                    {
                        "type": "text",
                        "content": ". The total sample size is "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N = m + n"
                    },
                    {
                        "type": "text",
                        "content": ". Consider the following two nonparametric tests. "
                    }
                ]
            },
            "bbox": [
                191,
                178,
                801,
                261
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "• The Wilcoxon rank sum tests. The test proceeds by first ranking the pooled X and Y samples and then taking the sum of the ranks associated with the Y sample. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R _ { y _ { 1 } } , \\ldots , R _ { y _ { n } }"
                    },
                    {
                        "type": "text",
                        "content": "be the rankings of the sample "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y _ { 1 } < \\cdots < y _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "from the pooled sample in increasing order. The Wilcoxon rank sum statistic is defined as "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { W = \\sum _ { j = 1 } ^ { n } R _ { y _ { j } } } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                236,
                263,
                801,
                363
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "• The Mann-Whitney "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U"
                    },
                    {
                        "type": "text",
                        "content": "-test. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U _ { i j } ~ = ~ 1"
                    },
                    {
                        "type": "text",
                        "content": "if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { i } ~ < ~ Y _ { j }"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U _ { i j } = 0"
                    },
                    {
                        "type": "text",
                        "content": "otherwise. The Mann-Whitney "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U"
                    },
                    {
                        "type": "text",
                        "content": "-statistic is defined as "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { U = \\sum _ { i = 1 } ^ { m } \\sum _ { j = 1 } ^ { n } U _ { i j } } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": ". The probability "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\gamma = P ( X < Y )"
                    },
                    {
                        "type": "text",
                        "content": "can be estimated as "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U / ( m n )"
                    },
                    {
                        "type": "text",
                        "content": ". The decision rule is based on assessing if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\gamma = 0 . 5"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                238,
                363,
                801,
                448
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Assume that there are no tied data values. "
                    }
                ]
            },
            "bbox": [
                213,
                451,
                584,
                466
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { W = U + \\frac { 1 } { 2 } n ( n + 1 ) } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": ", which shows that the two test statistics differ only by a constant and yield exactly the same "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "-values. "
                    }
                ]
            },
            "bbox": [
                221,
                470,
                800,
                518
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) Using the central limit theorem, the Wilcoxon rank sum statistic "
                    },
                    {
                        "type": "equation_inline",
                        "content": "W"
                    },
                    {
                        "type": "text",
                        "content": "can be converted to a "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Z"
                    },
                    {
                        "type": "text",
                        "content": "-variable, which provides an easyto-use approximation. The transformation is "
                    }
                ]
            },
            "bbox": [
                221,
                520,
                800,
                568
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "Z _ {W} = \\frac {W - \\mu_ {W}}{\\sigma_ {W}},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/55a017a7005598783e9c06687fb919ddc80c2cca654a8e3ff5cdb9154768e3db.jpg"
                }
            },
            "bbox": [
                426,
                574,
                569,
                608
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu _ { W }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma _ { W } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "are the mean and variance of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "W"
                    },
                    {
                        "type": "text",
                        "content": "under "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H _ { 0 }"
                    },
                    {
                        "type": "text",
                        "content": ". Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { \\mu _ { W } = \\frac { 1 } { 2 } n ( N + 1 ) } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { \\sigma _ { W } ^ { 2 } = \\frac { 1 } { 1 2 } m n ( N + 1 ) } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                255,
                612,
                800,
                648
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "be a random variable with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E X ^ { 2 } < \\infty"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y = | X |"
                    },
                    {
                        "type": "text",
                        "content": ". Assume that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "has a Lebesgue density symmetric about 0. Show that random variables "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y"
                    },
                    {
                        "type": "text",
                        "content": "are uncorrelated, but they are not independent. "
                    }
                ]
            },
            "bbox": [
                191,
                653,
                801,
                705
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "6. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E _ { 1 } , \\cdots , E _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "be i.i.d. random variables with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E _ { i } \\sim \\mathrm { E x p o n e n t i a l } ( 1 )"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U _ { 1 } , \\cdots , U _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "be i.i.d. uniformly (on [0,1]) distributed random variables. Further, assume that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E _ { 1 } , \\cdots , E _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U _ { 1 } , \\cdots , U _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "are independent. "
                    }
                ]
            },
            "bbox": [
                191,
                712,
                801,
                777
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Find the density of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X = ( E _ { 1 } + \\cdot \\cdot \\cdot + E _ { m } ) / ( E _ { 1 } + \\cdot \\cdot \\cdot + E _ { n } )"
                            },
                            {
                                "type": "text",
                                "content": ", where "
                            },
                            {
                                "type": "equation_inline",
                                "content": "m < n"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
