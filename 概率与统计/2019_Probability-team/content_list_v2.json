        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1) Suppose "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( X _ { n } ) _ { n \\geq 1 }"
                    },
                    {
                        "type": "text",
                        "content": "is a sequence of i.i.d. random variables and the common law is exponential with parameter one. Show that "
                    }
                ]
            },
            "bbox": [
                134,
                159,
                907,
                187
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathbb {P} \\left[ \\lim  _ {n \\to \\infty} \\sup  _ {\\log n} \\frac {X _ {n}}{1} = 1 \\right] = 1.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/dd0a2dc284a784ac59d07b4b8d540bf5588d2c3c869f90eaa937ab795fb656f0.jpg"
                }
            },
            "bbox": [
                436,
                187,
                631,
                217
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( X _ { n } ) _ { n \\geq 1 }"
                    },
                    {
                        "type": "text",
                        "content": "be i.i.d. real random variables and set "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { S _ { n } = \\sum _ { i = 1 } ^ { n } X _ { i } } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": "for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\geq 1"
                    },
                    {
                        "type": "text",
                        "content": ". Suppose that for some constant "
                    },
                    {
                        "type": "equation_inline",
                        "content": "c \\in \\mathbb { R }"
                    },
                    {
                        "type": "text",
                        "content": "we have "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S _ { n } / n \\to c"
                    },
                    {
                        "type": "text",
                        "content": "as "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\longrightarrow \\infty"
                    },
                    {
                        "type": "text",
                        "content": "almost surely. Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": "has a finite first moment and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { E } [ X _ { 1 } ] = c"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                132,
                227,
                907,
                272
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3) Consider uniform permutation of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ 1 , 2 , \\ldots , n \\}"
                    },
                    {
                        "type": "text",
                        "content": "and denote by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "the number of cycles in the permutation. Find a sequence of reals "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( a _ { n } ) _ { n \\geq 1 }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    }
                ]
            },
            "bbox": [
                132,
                280,
                907,
                310
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\lim  _ {n \\rightarrow \\infty} \\frac {\\mathbb {E} [ X _ {n} ]}{a _ {n}} = 1,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/95656bea110a9bda32e7a7ac03f931ef639724b2bd8a9257336b58dcb8e6b1bb.jpg"
                }
            },
            "bbox": [
                470,
                318,
                596,
                350
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "and justify your answer. "
                    }
                ]
            },
            "bbox": [
                157,
                359,
                339,
                373
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4) The Erd¨os-R´enyi random graph "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G ( n , p )"
                    },
                    {
                        "type": "text",
                        "content": "with parameters "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\geq 1"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\in [ 0 , 1 ]"
                    },
                    {
                        "type": "text",
                        "content": "is the random graph whose vertex set is "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V = \\{ 1 , 2 , \\dots , n \\}"
                    },
                    {
                        "type": "text",
                        "content": "and where for each pair "
                    },
                    {
                        "type": "equation_inline",
                        "content": "i \\neq j \\in V"
                    },
                    {
                        "type": "text",
                        "content": "the edge "
                    },
                    {
                        "type": "equation_inline",
                        "content": "i  j"
                    },
                    {
                        "type": "text",
                        "content": "is present with probability "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "independently of all the other pairs. "
                    }
                ]
            },
            "bbox": [
                134,
                382,
                907,
                426
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) For "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\epsilon > 0"
                    },
                    {
                        "type": "text",
                        "content": ", if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { p _ { n } \\geq ( 1 + \\epsilon ) \\frac { \\log n } { n } } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": ", then "
                    }
                ]
            },
            "bbox": [
                164,
                432,
                455,
                451
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathbb {P} \\left[ G \\left(n, p _ {n}\\right) \\text {h a s a n i s o l a t e d v e r t e x} \\right]\\rightarrow 0, \\quad \\text {a s} n \\rightarrow \\infty .",
                "math_type": "latex",
                "image_source": {
                    "path": "images/65e4afe1b92af2f7b5ad4665be1e16c4c42dba633e26fb9f29fdfa6ba677ec2f.jpg"
                }
            },
            "bbox": [
                356,
                460,
                744,
                476
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) For "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\epsilon > 0"
                    },
                    {
                        "type": "text",
                        "content": ", if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { p _ { n } \\leq ( 1 - \\epsilon ) \\frac { \\log n } { n } } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": ", then "
                    }
                ]
            },
            "bbox": [
                164,
                487,
                455,
                505
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathbb {P} \\left[ G \\left(n, p _ {n}\\right) \\text {h a s a n i s o l a t e d v e r t e x} \\right]\\rightarrow 1, \\quad \\text {a s} n \\rightarrow \\infty .",
                "math_type": "latex",
                "image_source": {
                    "path": "images/b99901f9d7b473acf05df81ac7f9b98a0a804ea444b775e2f27169e765576bd3.jpg"
                }
