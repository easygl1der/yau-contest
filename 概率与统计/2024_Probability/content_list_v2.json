    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathcal { X }"
                    },
                    {
                        "type": "text",
                        "content": "be the set of all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "covariates under consideration. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\alpha _ { 0 } \\subset { \\mathcal { X } }"
                    },
                    {
                        "type": "text",
                        "content": "be the subset that contains and only contains all the important covariates affecting Y (the corresponding "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\beta _ { j }"
                    },
                    {
                        "type": "text",
                        "content": "’s are nonzero). Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\alpha"
                    },
                    {
                        "type": "text",
                        "content": "be any subset of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathcal { X }"
                    },
                    {
                        "type": "text",
                        "content": ", and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\beta ( \\alpha )"
                    },
                    {
                        "type": "text",
                        "content": "be the vector of the components in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\beta"
                    },
                    {
                        "type": "text",
                        "content": "that correspond to the covariates in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\alpha"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A = \\{ \\alpha : \\alpha _ { 0 } \\subset \\alpha \\}"
                    },
                    {
                        "type": "text",
                        "content": "be the collection of models that including all important covariates. We assume: "
                    }
                ]
            },
            "bbox": [
                253,
                157,
                782,
                248
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(I) There exist positive constants "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C _ { 1 } , C _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "such that for all sufficiently large "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    }
                ]
            },
            "bbox": [
                263,
                258,
                781,
                287
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "C _ {1} <   \\lambda_ {\\min } \\left\\{\\frac {1}{n} H _ {n} (\\beta) \\right\\} <   \\lambda_ {\\max } \\left\\{\\frac {1}{n} H _ {n} (\\beta) \\right\\} <   C _ {2},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/08d04214547564cdf2c816e420c9c25cd9606412864a70aa54b85f2f9c5fb3ef.jpg"
                }
            },
            "bbox": [
                366,
                299,
                705,
                328
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda _ { \\mathrm { m i n } } \\Big \\{ { \\textstyle \\frac { 1 } { n } } H _ { n } ( \\beta ) \\Big \\}"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda _ { \\mathrm { m a x } } \\bigg \\{ \\frac { 1 } { n } H _ { n } ( \\beta ) \\bigg \\}"
                    },
                    {
                        "type": "text",
                        "content": "are the smallest and largest eigenvalues of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\scriptstyle { \\frac { 1 } { n } } H _ { n } ( \\beta )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                289,
                338,
                792,
                380
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(II) For any given "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\epsilon > 0"
                    },
                    {
                        "type": "text",
                        "content": ", there exists a constant "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\delta > 0"
                    },
                    {
                        "type": "text",
                        "content": "such that, when "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "is sufficiently large, "
                    }
                ]
            },
            "bbox": [
                256,
                383,
                781,
                412
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "(1 - \\epsilon) H _ {n} (\\boldsymbol {\\beta} (\\alpha)) \\leq H _ {n} (\\tilde {\\boldsymbol {\\beta}}) \\leq (1 + \\epsilon) H _ {n} (\\boldsymbol {\\beta} (\\alpha))",
                "math_type": "latex",
                "image_source": {
                    "path": "images/4c5a0314521fd2e9aad34eb41376284a3e872cb020a94ce6255402243ce716a0.jpg"
                }
            },
            "bbox": [
                375,
                425,
                699,
                441
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\alpha \\in A"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tilde { \\beta }"
                    },
                    {
                        "type": "text",
                        "content": "satisfying "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\| { \\tilde { \\beta } } - \\beta ( \\alpha ) \\| \\leq \\delta"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                289,
                452,
                627,
                470
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "For any model "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\alpha"
                    },
                    {
                        "type": "text",
                        "content": ", let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\hat { \\beta } _ { \\alpha }"
                    },
                    {
                        "type": "text",
                        "content": "be the MLE of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\beta ( \\alpha )"
                    },
                    {
                        "type": "text",
                        "content": "based on this model. Show that "
                    }
                ]
            },
            "bbox": [
                253,
                479,
                779,
                508
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\max _ {\\alpha \\in A} \\| \\hat {\\boldsymbol {\\beta}} _ {\\alpha} - \\boldsymbol {\\beta} (\\alpha) \\| = O _ {p} (n ^ {- 1 / 3}).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/d6b5b07055f412f89a4a567e90c46c6ed210e3e16f182f2f3e05f45b82b3054d.jpg"
                }
            },
            "bbox": [
                406,
                508,
                630,
                532
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. Consider a random sample of size "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": ", and write the data as an "
                    },
                    {
