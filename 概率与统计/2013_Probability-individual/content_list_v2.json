        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Please solve 5 out of the following 6 problems. "
                    }
                ]
            },
            "bbox": [
                280,
                209,
                764,
                229
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. Let ( "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { n }"
                    },
                    {
                        "type": "text",
                        "content": ") be a sequence of random variables. "
                    }
                ]
            },
            "bbox": [
                137,
                286,
                645,
                304
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(1) Assume that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\textstyle \\sum _ { n = 0 } ^ { \\infty } P ( | X _ { n } | > n ) < \\infty"
                            },
                            {
                                "type": "text",
                                "content": ". Prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\begin{array} { r } { \\operatorname* { l i m } \\operatorname* { s u p } _ { n  \\infty } \\frac { | X _ { n } | } { n } \\leq 1 } \\end{array}"
                            },
                            {
                                "type": "text",
                                "content": "|Xn| ≤ 1. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(2) Prove that (Xn) converges in probability to 0 if and only if for certain "
                            },
                            {
                                "type": "equation_inline",
                                "content": "r > 0"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\begin{array} { r } { E [ \\frac { | X _ { n } | ^ { r } } { 1 + | X _ { n } | ^ { r } } ]  0 } \\end{array}"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                139,
                309,
                905,
                382
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 2. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y"
                    },
                    {
                        "type": "text",
                        "content": "be independent "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N ( 0 , 1 )"
                    },
                    {
                        "type": "text",
                        "content": "random variables. "
                    }
                ]
            },
            "bbox": [
                139,
                397,
                742,
                414
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(1) Find "
                            },
                            {
                                "type": "equation_inline",
                                "content": "E [ X + Y | X \\geq 0 , Y \\geq 0 ]"
                            },
                            {
                                "type": "text",
                                "content": "; "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(2) Find the distribution function of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X + Y"
                            },
                            {
                                "type": "text",
                                "content": "given that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X \\geq 0"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Y \\geq 0"
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                168,
                423,
                806,
                467
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(Hint: For b) using the fact that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U = ( X + Y ) / \\sqrt { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V \\ : = \\ : ( X \\ : - \\ : Y ) / \\sqrt { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "are independent and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N ( 0 , 1 )"
                    },
                    {
                        "type": "text",
                        "content": "distributed.) "
                    }
                ]
            },
            "bbox": [
                137,
                473,
                907,
                516
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ X _ { n } \\}"
                    },
                    {
                        "type": "text",
                        "content": "be a sequence of independent and identically distributed continuous real valued random variables, and regard "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "as time. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "be the following event: "
                    }
                ]
            },
            "bbox": [
                137,
                533,
                907,
                595
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "A _ {n} = \\{X _ {n} = \\max  \\{X _ {1}, X _ {2}, \\dots , X _ {n} \\} \\}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/607c993d9e488ece720eb72d94a02c5607e8da015a6264b590bdb9872000c664.jpg"
                }
            },
            "bbox": [
                364,
                601,
                682,
                620
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "We say that a maximum record occurs at "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "in such an event. "
                    }
                ]
            },
            "bbox": [
                139,
                632,
                672,
                648
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(1) Evaluate the probability "
                            },
                            {
                                "type": "equation_inline",
                                "content": "P ( A _ { n } )"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(2) Denote by "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Y _ { n }"
                            },
                            {
                                "type": "text",
                                "content": "the number of maximum records occurred until time "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": ", i.e., "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                168,
                657,
                838,
                699
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "Y _ {n} = \\text {t h e n u m b e r o f} \\{1 \\leq k \\leq n: X _ {k} = \\max  \\left\\{X _ {1}, X _ {2}, \\dots , X _ {k} \\right\\} \\}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/cf435cea5ec2671abc50ab7a70f874b4cb0f4901fff5c112ec6f640b734f52fc.jpg"
                }
            },
            "bbox": [
                245,
                719,
                800,
                737
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Evaluate the expectation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E Y _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "and the variance "
                    },
                    {
                        "type": "equation_inline",
                        "content": "D Y _ { n }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                139,
                756,
                601,
                774
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X = ( X _ { 1 } , \\cdots , X _ { n } )"
                    },
                    {
                        "type": "text",
                        "content": "be an iid sample from an exponential density with mean "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta"
                    },
                    {
                        "type": "text",
                        "content": ". Consider testing "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H _ { 0 } : \\theta = \\theta _ { 0 }"
                    },
                    {
                        "type": "text",
                        "content": "vs. "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H _ { 1 } : \\theta > \\theta _ { 0 }"
                    },
                    {
                        "type": "text",
                        "content": ". Let P (X) = your p-value for an appropriate test. "
                    }
                ]
            },
            "bbox": [
                137,
                781,
                907,
                844
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "1 "
                    }
                ]
            },
            "bbox": [
                517,
                870,
                529,
                882
            ]
        }
    ],
    [
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) What is "
                            },
                            {
                                "type": "equation_inline",
                                "content": "E _ { \\theta _ { 0 } } ( P ( X ) )"
                            },
                            {
                                "type": "text",
                                "content": "? Derive your answer explicitly. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Derive "
                            },
                            {
                                "type": "equation_inline",
                                "content": "E _ { \\theta } ( P ( X ) )"
                            },
                            {
                                "type": "text",
                                "content": "for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\theta \\neq \\theta _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": ". Specifically, assuming only one sample, i.e. "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n = 1"
                            },
                            {
                                "type": "text",
                                "content": "calculate "
                            },
                            {
                                "type": "equation_inline",
                                "content": "E _ { \\theta } ( P ( X ) )"
                            },
                            {
                                "type": "text",
                                "content": "as explicitly as possible for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\theta \\neq \\theta _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) When there is only one sample, is "
                            },
                            {
                                "type": "equation_inline",
                                "content": "E _ { \\theta } ( P ( X ) )"
                            },
                            {
                                "type": "text",
                                "content": "a decreasing function of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\theta"
                            },
                            {
                                "type": "text",
                                "content": "? In general, can you prove your result for an arbitrary MLR family? "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                139,
                105,
                905,
                236
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 5. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "be iid uniform on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta - { \\textstyle \\frac { 1 } { 2 } }"
                    },
                    {
                        "type": "text",
                        "content": "to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta + { \\textstyle { \\frac { 1 } { 2 } } }"
                    }
                ]
            },
            "bbox": [
                139,
                255,
                648,
                277
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) Show that for any given "
                    },
                    {
                        "type": "equation_inline",
                        "content": "0 < \\alpha < 1"
                    },
                    {
                        "type": "text",
                        "content": ", you can find "
                    },
                    {
                        "type": "equation_inline",
                        "content": "c > 0"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    }
                ]
            },
            "bbox": [
                139,
                294,
                737,
                311
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "P _ {\\theta} \\{\\bar {X} - c <   \\theta <   \\bar {X} + c \\} = 1 - \\alpha ,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/c2dad741ee3688393dcea3f1398273546cce0704cad5464fe32e464be5b09dcd.jpg"
                }
            },
            "bbox": [
                406,
                329,
                690,
                348
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "is the sample mean. "
                    }
                ]
            },
            "bbox": [
                186,
                366,
                443,
                384
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) Show that for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\epsilon"
                    },
                    {
                        "type": "text",
                        "content": "positive and sufficiently small "
                    }
                ]
            },
            "bbox": [
                139,
                401,
                578,
                418
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "P _ {\\theta} \\left\\{\\bar {X} - c <   \\theta <   \\bar {X} + c \\mid | X _ {2} - X _ {1} | \\geq 1 - \\epsilon \\right\\} = 1",
                "math_type": "latex",
                "image_source": {
                    "path": "images/9efff5b0a259e5c4051c2fb54d0dfdca393a61000b2f97d5b85a4a78cdebda6b.jpg"
                }
            },
            "bbox": [
                341,
                436,
                756,
                456
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(c) The statement in (a) is used to assert that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X \\pm c"
                    },
                    {
                        "type": "text",
                        "content": "is a "
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 0 0 ( 1 - \\alpha ) \\%"
                    },
                    {
                        "type": "text",
                        "content": "confidence interval for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta"
                    },
                    {
                        "type": "text",
                        "content": ". Does the assertion in (b) contradict this? If your sample observations are "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 1 } = 1 , X _ { 2 } = 2"
                    },
                    {
                        "type": "text",
                        "content": ", would you use the confidence interval in (a)? "
                    }
                ]
            },
            "bbox": [
                139,
                479,
                905,
                542
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 6. Suppose you want to estimate the total number of enemy tanks in a war on the basis of the captured tanks. Assume without loss of generality that the tank serial numbers are "
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 , 2 , \\cdots , N"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N"
                    },
                    {
                        "type": "text",
                        "content": "is the unknown total number of enemy tanks. Also assume the serial numbers of the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "captured tanks are iid uniform on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "1 , 2 , \\cdots , N"
                    },
                    {
                        "type": "text",
                        "content": ". (This is a simplified assumption which provides a good approximation if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n < < N"
                    },
                    {
                        "type": "text",
                        "content": "). "
                    }
                ]
            },
            "bbox": [
                137,
                562,
                905,
                669
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Find the complete sufficient statistic. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Suggest how you may find the minimum variance unbiased estimate of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "N"
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                139,
