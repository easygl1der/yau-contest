        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. A box contains 750 red balls and 250 blue balls. Repeatedly pick a ball uniformly at random from the box and remove it until all remaining balls have a single color. (Note: no replacement). "
                    }
                ]
            },
            "bbox": [
                133,
                227,
                866,
                282
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Please find integer "
                    },
                    {
                        "type": "equation_inline",
                        "content": "m"
                    },
                    {
                        "type": "text",
                        "content": "such that the expectation value for the total number of the remaining balls "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\in [ m , m + 1 ]"
                    }
                ]
            },
            "bbox": [
                133,
                286,
                864,
                324
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 2. Suppose a number "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 0 } \\in \\{ 1 , - 1 \\}"
                    },
                    {
                        "type": "text",
                        "content": "at the root of a binary tree "
                    }
                ]
            },
            "bbox": [
                135,
                347,
                761,
                367
            ]
        },
        {
            "type": "image",
            "content": {
                "image_source": {
                    "path": "images/a9369f4fc904209ce717b3d32972c084676c9d12e7500a0b8e4caabb097f7292.jpg"
                },
                "image_caption": [],
                "image_footnote": []
            },
            "bbox": [
                380,
                380,
                619,
                508
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "is propagated away from the root as follows. The root is the node at level 0. After obtaining the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "2 ^ { h }"
                    },
                    {
                        "type": "text",
                        "content": "numbers at the nodes at level "
                    },
                    {
                        "type": "equation_inline",
                        "content": "h"
                    },
                    {
                        "type": "text",
                        "content": ", each number at level "
                    },
                    {
                        "type": "equation_inline",
                        "content": "h + 1"
                    },
                    {
                        "type": "text",
                        "content": "is obtained from the number adjacent to it (at level "
                    },
                    {
                        "type": "equation_inline",
                        "content": "h"
                    },
                    {
                        "type": "text",
                        "content": ") by flipping its sign with probability "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\in"
                    },
                    {
                        "type": "equation_inline",
                        "content": "( 0 , 1 / 2 )"
                    },
                    {
                        "type": "text",
                        "content": "independently. "
                    }
                ]
            },
            "bbox": [
                133,
                527,
                864,
                602
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { h }"
                    },
                    {
                        "type": "text",
                        "content": "be the average of the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "2 ^ { h }"
                    },
                    {
                        "type": "text",
                        "content": "values received at the nodes at level "
                    },
                    {
                        "type": "equation_inline",
                        "content": "h"
                    },
                    {
                        "type": "text",
                        "content": ". Define the signal-to-noise ratio at level "
                    },
                    {
                        "type": "equation_inline",
                        "content": "h"
                    },
                    {
                        "type": "text",
                        "content": "to be "
                    }
                ]
            },
            "bbox": [
                135,
                604,
                864,
                642
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "R _ {h} := \\frac {\\left(\\mathbb {E} [ X _ {h} | X _ {0} = 1 ] - \\mathbb {E} [ X _ {h} | X _ {0} = - 1 ]\\right) ^ {2}}{V a r [ X _ {h} | X _ {0} = 1 ]}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/d790e7a2700e7ebc197ba14ce0796fd8f491fb7a574ccfff881fcc814b8df2ec.jpg"
                }
            },
            "bbox": [
                313,
                648,
                687,
                694
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Find the threshold number "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { c }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R _ { h }"
                    },
                    {
                        "type": "text",
                        "content": "converges to 0 if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\in ( p _ { c } , 1 / 2 )"
                    },
                    {
                        "type": "text",
                        "content": "and diverges if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\in ( 0 , p _ { c } )"
                    },
                    {
                        "type": "text",
                        "content": ", as "
                    },
                    {
                        "type": "equation_inline",
                        "content": "h \\to \\infty"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                133,
                700,
                864,
                738
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 3. Consider the space representing an infinite sequence of coin flips, namely "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Omega : = \\{ H , T \\} ^ { \\infty }"
                    },
                    {
                        "type": "text",
                        "content": ", (H: head, T: tail) with the associated "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma"
                    },
                    {
                        "type": "text",
                        "content": "-field "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathcal { F }"
                    },
                    {
                        "type": "text",
                        "content": "generated by finite dimensional rectangles. For "
                    },
                    {
                        "type": "equation_inline",
                        "content": "0 \\leq p \\leq 1"
                    },
                    {
                        "type": "text",
                        "content": ", denote by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { P } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "the probability measure on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( \\Omega , { \\mathcal { F } } )"
                    },
                    {
                        "type": "text",
                        "content": "corresponding to flipping a coin an infinite number of times with probability of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H"
                    },
                    {
                        "type": "text",
                        "content": "being "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "and probability of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T"
                    },
                    {
                        "type": "text",
                        "content": "being "
                    },
                    {
                        "type": "equation_inline",
                        "content": "q = 1 - p"
                    },
                    {
                        "type": "text",
                        "content": "at each flip. "
                    }
                ]
            },
            "bbox": [
                133,
                762,
                864,
                853
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Show that for each "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\in \\left\\lfloor 0 , 1 \\right\\rfloor"
                    },
                    {
                        "type": "text",
                        "content": ", there exists "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    }
                ]
            },
            "bbox": [
                161,
                857,
                627,
                875
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathbb {P} _ {p} (A _ {p}) > 1 / 2",
                "math_type": "latex",
                "image_source": {
                    "path": "images/3b1f7a20928033c823985d25d79d4a2c9c2df4eb199408c62074a70d0fbea52e.jpg"
                }
            },
            "bbox": [
                441,
                883,
                558,
                905
            ]
        },
        {
            "type": "page_header",
            "content": {
                "page_header_content": [
