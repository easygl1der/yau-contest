    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "and for any "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p ^ { \\prime } \\neq p"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p ^ { \\prime } \\in [ 0 , 1 ]"
                    }
                ]
            },
            "bbox": [
                135,
                112,
                382,
                131
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathbb {P} _ {p ^ {\\prime}} (A _ {p}) <   1 / 2",
                "math_type": "latex",
                "image_source": {
                    "path": "images/98b09db120b704152f7f385cda8c13ac8785a5823509e2435620993ea10c6ca9.jpg"
                }
            },
            "bbox": [
                439,
                130,
                563,
                151
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G : = G ( n , p )"
                    },
                    {
                        "type": "text",
                        "content": "be a random graph with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "vertices where each possible edge has probability "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "of existing. The existence of the edges are independent to each other. With "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": ", we say "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A \\subset \\{ 1 , 2 , \\cdots , n \\}"
                    },
                    {
                        "type": "text",
                        "content": "is a fully connected set if and only if "
                    }
                ]
            },
            "bbox": [
                133,
                181,
                866,
                239
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "i , j \\in A \\implies i - t h"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "j - t h"
                    },
                    {
                        "type": "text",
                        "content": "vertices are (directly) connected with an edge in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    }
                ]
            },
            "bbox": [
                148,
                252,
                849,
                272
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Define "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T"
                    },
                    {
                        "type": "text",
                        "content": "as the size of the largest fully connected set "
                    }
                ]
            },
            "bbox": [
                135,
                286,
                589,
                304
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "T := \\max  \\{| A |: \\mathrm {A i s a f u l l y c o n n e c t e d s e t} \\}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/b220fbe793d079861b7d4855aac6a4b0395e0926d8473485fc1cf14296b2645b.jpg"
                }
            },
            "bbox": [
                316,
                319,
                683,
                339
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Let’s fix "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\in ( 0 , 1 )"
                    },
                    {
                        "type": "text",
                        "content": ", please prove that "
                    }
                ]
            },
            "bbox": [
                135,
                353,
                447,
                371
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\lim  _ {n \\to \\infty} \\mathbb {P} \\left(\\frac {T}{2 \\log_ {\\frac {1}{p}} n} \\leq 1 + \\epsilon\\right) = 1, \\quad \\forall \\epsilon > 0,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/0fde634c10ed06671c56ae862b3bbf2d045a09743b92d08cc00fb27e7438a3ed.jpg"
                }
            },
            "bbox": [
                326,
                383,
                676,
                434
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "and "
                    }
                ]
            },
            "bbox": [
                135,
                446,
                174,
                462
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\lim _ {n \\to \\infty} \\mathbb {P} \\left(\\frac {T}{\\sqrt {2 \\log_ {\\frac {1}{p}} n}} \\geq 1 - \\epsilon\\right) = 1, \\quad \\forall \\epsilon > 0,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/5e8633efb021a30081e16661878c2e85940229845be75721c9b90a4b41d97a0b.jpg"
                }
            },
            "bbox": [
                313,
                458,
                686,
                518
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Hint: "
                    }
                ]
            },
            "bbox": [
                135,
                523,
                184,
                540
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathbb {P} \\left(T = n\\right) = p ^ {\\binom {n} {2}} = p ^ {n (n - 1) / 2}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/b8bfdde8f9ea69666743473a6e8016e3f58435c4c52ab3889376ac89a73a434f.jpg"
                }
            },
            "bbox": [
                379,
                537,
                620,
                561
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 5. Consider a population of constant size "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N + 1"
                    },
                    {
                        "type": "text",
                        "content": "that is suffering from an infectious disease. We can model that spread of the disease as Markov process. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X ( t )"
                    },
                    {
                        "type": "text",
                        "content": "be the number of healthy individuals at time "
                    },
                    {
                        "type": "equation_inline",
                        "content": "t"
                    },
                    {
                        "type": "text",
                        "content": "and suppose that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X ( 0 ) = N"
                    },
                    {
                        "type": "text",
                        "content": ". We assume that if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X ( t )"
                    }
                ]
            },
            "bbox": [
                133,
                593,
                866,
                667
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\lim _ {h \\to 0} \\frac {1}{h} \\mathbb {P} \\left(X (t + h) = n - 1 | X (t) = n)\\right) = \\lambda n \\left(N + 1 - n\\right)",
                "math_type": "latex",
                "image_source": {
                    "path": "images/f6772d6e5eec251f3b568338b1ad96549af7d2bdd51730b224477d04b76eb5e1.jpg"
                }
            },
            "bbox": [
                264,
                679,
                736,
                715
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "For "
                    },
                    {
                        "type": "equation_inline",
                        "content": "0 \\leq s \\leq 1"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "0 \\leq t"
                    },
                    {
                        "type": "text",
                        "content": ", define "
                    }
                ]
            },
            "bbox": [
                135,
                726,
                372,
                744
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "G (s, t) := \\mathbb {E} \\left(s ^ {X (t)}\\right)",
                "math_type": "latex",
                "image_source": {
                    "path": "images/6d56616dd201ebf23e3e1ed8bc965d7acb340eb164a9edcb061dcf7defb6cbce.jpg"
                }
            },
            "bbox": [
                421,
                742,
                578,
                763
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Please find a non-trivial partial differential equation for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G ( s , t )"
                    },
                    {
                        "type": "text",
                        "content": ", which involves "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\partial _ { t } G"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                135,
                771,
                844,
                789
            ]
        },
