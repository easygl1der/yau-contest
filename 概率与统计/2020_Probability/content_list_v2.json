        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Z = ( X , Y )"
                    },
                    {
                        "type": "text",
                        "content": "be an "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "-valued random variable such that (1) "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "and Y are independent; (2) both "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": ",and Y have mean zero and finite (nonvanishing) second moments; (3) the distribution of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Z"
                    },
                    {
                        "type": "text",
                        "content": "is invariant under the rotation counter-clockwise around the origin by an angle "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta"
                    },
                    {
                        "type": "text",
                        "content": "not a multiple of 90 degrees. Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "θand Y must be normal random variables with the same variance. "
                    }
