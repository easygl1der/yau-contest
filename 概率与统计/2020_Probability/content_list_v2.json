            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "S _ {n} = a + X _ {1} + X _ {2} + \\dots + X _ {n},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/7314497193e47bb487b74e17aaa8e0e257df282522a2ddbce6945a427242db14.jpg"
