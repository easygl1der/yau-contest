        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a"
                    },
                    {
                        "type": "text",
                        "content": "is a positive integer and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ X _ { i } \\}"
                    },
                    {
                        "type": "text",
                        "content": "are independent and identically distributed random variables with a common distribution "
                    }
                ]
            },
            "bbox": [
                111,
                498,
                823,
                531
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathbb {P} \\{X _ {i} = 1 \\} = p, \\quad \\mathbb {P} \\{X _ {i} = - 1 \\} = 1 - p.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/01d735fbbbb3de4bd8b13768314636262182cbde75d2102ec08d03e584119d4e.jpg"
