        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tau _ { 0 } = \\operatorname* { i n f } \\{ n : S _ { n } = 0 \\}"
                    },
                    {
                        "type": "text",
                        "content": "be the first time the random walk reaches the state "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x = 0"
                    },
                    {
                        "type": "text",
                        "content": ". For all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\in [ 0 , 1 ]"
                    },
                    {
                        "type": "text",
                        "content": "τfind the probability "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { P } _ { a } \\{ \\tau _ { 0 } < \\infty \\}"
                    },
                    {
                        "type": "text",
                        "content": "that the random walk will eventually hit the state "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x = 0"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
