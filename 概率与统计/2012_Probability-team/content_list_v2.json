[
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "GROUP TEST S.-T YAU COLLEGE MATH CONTESTS 2012 "
                    }
                ],
                "level": 1
            },
            "bbox": [
                252,
                174,
                744,
                208
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Probability and Statistics "
                    }
                ],
                "level": 1
            },
            "bbox": [
                314,
                239,
                684,
                263
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Please solve 5 out of the following 6 problems. "
                    }
                ]
            },
            "bbox": [
                295,
                300,
                699,
                318
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Let (Xn) be a sequence of i.i.d. random variables. "
                    }
                ]
            },
            "bbox": [
                193,
                362,
                653,
                376
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1) Assume that each "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X _ { n }"
                            },
                            {
                                "type": "text",
                                "content": "satisfies the exponential distribution with parameter 1 (i.e. "
                            },
                            {
                                "type": "equation_inline",
                                "content": "P ( X _ { n } \\geq x ) = e ^ { - x } , x \\geq 0 \\quad"
                            },
                            {
                                "type": "text",
                                "content": "). Prove that "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) "
                            },
                            {
                                "type": "equation_inline",
                                "content": "P ( X _ { n } > \\alpha \\log n , i . o . ) = 0"
                            },
                            {
                                "type": "text",
                                "content": ", if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\alpha > 1"
                            },
                            {
                                "type": "text",
                                "content": "; "
                            },
                            {
                                "type": "equation_inline",
                                "content": "P ( X _ { n } > \\alpha \\log n , i . o . ) = 1"
                            },
                            {
                                "type": "text",
                                "content": ", if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\alpha \\leq 1"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                191,
                379,
                801,
                441
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Here “i.o” stands for “infinitely often”, and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A _ { n } , i . o ."
                    },
                    {
                        "type": "text",
                        "content": ". stands lim "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\operatorname* { s u p } _ { n \\to \\infty } A _ { n }"
                    }
                ]
            },
            "bbox": [
                213,
                445,
                836,
                461
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "L = \\operatorname* { l i m } \\operatorname* { s u p } _ { n \\to \\infty } ( X _ { n } / \\log n )"
                    },
                    {
                        "type": "text",
                        "content": ", then "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P ( L = 1 ) = 1"
                    }
                ]
            },
            "bbox": [
                213,
                461,
                697,
                478
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2) Assume that each "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "satisfies the Poisson distribution with parameter "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda"
                    },
                    {
                        "type": "text",
                        "content": "(i.e. "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { P ( X _ { n } = k ) = \\frac { \\lambda ^ { k } } { k ! } e ^ { - \\lambda } , k = 0 , 1 , 2 , \\cdots . } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": ") Put "
                    }
                ]
            },
            "bbox": [
                191,
                478,
                801,
                514
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "L = \\limsup_{n\\to \\infty}\\bigl(X_{n}\\log \\log n / \\log n\\bigr).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/8c0625140cffb966dfe14e467b3357099bf3c367819b4af366bca941bba0bab3.jpg"
                }
            },
            "bbox": [
                359,
                518,
                636,
                545
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Prove that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P ( L = 1 ) = 1"
                    }
                ]
            },
            "bbox": [
                193,
                549,
                418,
                565
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X _ { i }"
                            },
                            {
                                "type": "text",
                                "content": "be i.i.d exponential r.v with rate one, "
                            },
                            {
                                "type": "equation_inline",
                                "content": "i \\geq 1"
                            },
                            {
                                "type": "text",
                                "content": ". Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "N"
                            },
                            {
                                "type": "text",
                                "content": "be a geometric random variable with success probability "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "0 < p < 1"
                            },
                            {
                                "type": "text",
                                "content": ", i.e. "
                            },
                            {
                                "type": "equation_inline",
                                "content": "P ( N = k ) = ( 1 - p ) ^ { k - 1 } p , k = 1 , 2 , \\cdot \\cdot \\cdot"
                            },
                            {
                                "type": "text",
                                "content": ", and independent of all "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X _ { i }"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "i \\geq 1"
                            },
                            {
                                "type": "text",
                                "content": ". Find the distribution of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\textstyle \\sum _ { i = 1 } ^ { N } X _ { i }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Y"
                            },
                            {
                                "type": "text",
                                "content": "be i.i.d real valued r.v’s. Prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "P ( | X + Y | < 1 ) \\leq"
                            },
                            {
                                "type": "equation_inline",
                                "content": "3 P ( | X - Y | < 1 )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "4. Suppose "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S = X _ { 1 } + X _ { 2 } + \\cdot \\cdot \\cdot + X _ { n }"
                            },
                            {
                                "type": "text",
                                "content": ", a sum of independent random variables with "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X _ { i }"
                            },
                            {
                                "type": "text",
                                "content": "distributed Binomial(1, pi). Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { P } ( S \\ e v e n ) ="
                            },
                            {
                                "type": "equation_inline",
                                "content": "1 / 2"
                            },
                            {
                                "type": "text",
                                "content": "if and only if at least one "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p _ { i }"
                            },
                            {
                                "type": "text",
                                "content": "equals "
                            },
                            {
                                "type": "equation_inline",
                                "content": "1 / 2"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "5. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "B _ { \\theta }"
                            },
                            {
                                "type": "text",
                                "content": "denote the closed unit ball in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R } ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "with center "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\theta"
                            },
                            {
                                "type": "text",
                                "content": ". Suppose "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X _ { 1 } , X _ { 2 } , \\cdots , X _ { n }"
                            },
                            {
                                "type": "text",
                                "content": "are independently and uniformly distributed on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "B _ { \\theta }"
                            },
                            {
                                "type": "text",
                                "content": ", for an unknown "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\theta"
                            },
                            {
                                "type": "text",
                                "content": "in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R } ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": ". Denote that maximum likelihood estimator by "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\hat { \\theta }"
                            },
                            {
                                "type": "text",
                                "content": ". Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "| \\hat { \\theta } - \\theta | = O _ { p } ( 1 / n )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "6. Suppose that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X _ { 1 } , \\cdots , X _ { n }"
                            },
                            {
                                "type": "text",
                                "content": "are a random sample from the Bernoulli distribution with probability of success "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p _ { 1 }"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Y _ { 1 } , \\cdots , Y _ { n }"
                            },
                            {
                                "type": "text",
                                "content": "be an independent random sample from the Bernoulli distribution with probability of success "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p _ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                191,
                573,
                801,
                889
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "1 "
                    }
                ]
            },
            "bbox": [
