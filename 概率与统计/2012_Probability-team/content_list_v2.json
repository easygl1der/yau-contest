            ]
        }
    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) Derive the maximum likelihood ratio test statistic for "
                    }
                ]
            },
            "bbox": [
                223,
                137,
                724,
                154
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "H _ {0}: p _ {1} = p _ {2} \\longleftrightarrow H _ {1}: p _ {1} \\neq p _ {2}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/a1821087887f5a2ff7f0774401320d0a792381b36191713759aa6e2374dda799.jpg"
                }
            },
            "bbox": [
                366,
                159,
                628,
                177
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(Note: No simplification of the resulting test statistic is required. However, you need to give the asymptotic null.) "
                    }
                ]
            },
            "bbox": [
                255,
                181,
                800,
                215
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) Compute the asymptotic power of the test with critical region "
                    }
                ]
            },
            "bbox": [
                223,
                215,
                796,
                231
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left| \\sqrt {n} \\left(\\hat {p} _ {1} - \\hat {p} _ {2}\\right) / \\sqrt {2 \\hat {p} \\hat {q}} \\right| \\geqslant z _ {1 - \\alpha}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/b97fac5c53afeb791ef112de1de09a342e5b121aba69e1c8432193dea066aa03.jpg"
                }
            },
            "bbox": [
                376,
                237,
                618,
                258
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "when "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { 1 } = p"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p _ { 2 } = p + n ^ { - 1 / 2 } \\Delta"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\hat { p } = 0 . 5 . \\hat { p } _ { 1 } + 0 . 5 \\hat { p } _ { 2 }"
                    }
                ]
            },
            "bbox": [
                263,
                262,
                784,
                280
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "2 "
                    }
                ]
