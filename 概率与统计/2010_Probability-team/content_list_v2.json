                            },
                            {
                                "type": "equation_inline",
                                "content": "W"
                            },
                            {
                                "type": "text",
                                "content": ", there exists a constant "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\delta > 0"
                            },
                            {
                                "type": "text",
                                "content": "such that "
