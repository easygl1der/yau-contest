                    {
                        "type": "equation_inline",
                        "content": "u ^ { n } = ( u _ { 1 } ^ { n } , u _ { 2 } ^ { n } , \\cdot \\cdot \\cdot , u _ { N } ^ { n } )"
                    },
                    {
                        "type": "text",
