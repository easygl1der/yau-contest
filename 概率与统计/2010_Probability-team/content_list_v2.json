        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left\\| u ^ {n} \\right\\| \\leq C \\| u ^ {0} \\|, \\quad n \\Delta t \\leq T \\tag {3}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/1d32ca1fe25e717b7ed93c0639c84e94f5feefbaad47881b12520282f30cb5a5.jpg"
