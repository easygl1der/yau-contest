        {
            "type": "equation_interline",
            "content": {
                "math_content": "u _ {j} ^ {n + 1} = u _ {j} ^ {n} - \\lambda \\left(u _ {j} ^ {n} - u _ {j - 1} ^ {n}\\right) \\tag {1}",
                "math_type": "latex",
                "image_source": {
