                    },
                    {
                        "type": "equation_inline",
                        "content": "C = C ( T )"
                    },
                    {
                        "type": "text",
                        "content": "independent of the time step "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Delta t"
                    },
                    {
                        "type": "text",
                        "content": "and the spatial mesh size "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Delta x"
                    },
                    {
                        "type": "text",
                        "content": ". Here "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| | \\cdot | |"
                    },
                    {
                        "type": "text",
