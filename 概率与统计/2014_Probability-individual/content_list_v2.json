                    {
                        "type": "text",
                        "content": "is a sequence of random numbers drawn from the uniform distribution "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U ( 0 , 1 )"
                    },
                    {
                        "type": "text",
                        "content": ". One observes these numbers sequentially. At time "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": ", one keeps a record of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y _ { n } \\ { \\stackrel { d e f } { = } } \\ X _ { ( n ) } = \\operatorname* { m a x } _ { i = 1 } ^ { n } X _ { i } = \\operatorname* { m a x } \\{ Y _ { n - 1 } , X _ { n } \\}"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Z _ { n } \\stackrel { d e f } { = } \\bar { X } _ { n } ="
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { \\sum _ { i = 1 } ^ { n } X _ { i } / n = ( n - 1 ) / n Z _ { n - 1 } + 1 / n X _ { n } } \\end{array}"
                    },
                    {
                        "type": "text",
