            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. The sequence "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( X _ { 1 } , X _ { 2 } , \\ldots , X _ { n } , \\ldots )"
                    },
                    {
                        "type": "text",
