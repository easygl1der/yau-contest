                290,
                854,
                327
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathrm {F o r a n y} A \\in \\mathcal {F}, P (A | T) = Q (T, A) \\mathrm {a l m o s t s u r e l y}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/054b4f979d6a58b43d0fc7286f110ff417be1ecf763c2fdc37fa1aebdbbb5bc0.jpg"
                }
            },
            "bbox": [
                276,
                335,
                707,
                354
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. Four statisticians I, II, III and IV play a sequence of games. For each game, the winning probabilities of I, II, III and IV are "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( 1 - \\theta ) / 2"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( 1 - \\theta ) / 2"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta / 2"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta / 2"
                    },
                    {
                        "type": "text",
                        "content": ", respectively, where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "0 < \\theta < 1"
                    },
                    {
                        "type": "text",
                        "content": ". There is only one winner in each game and no tie is allowed. Assume that outcomes of games are independent of each other. For a fixed integer "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r \\geq 2"
                    },
                    {
                        "type": "text",
                        "content": ", the stopping rule is to terminate as soon as one of the following conditions hold: (1) I and II together win "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r"
                    },
                    {
                        "type": "text",
                        "content": "games; (2) III and IV together win "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r + 1"
                    },
                    {
                        "type": "text",
                        "content": "games. At the time of termination, let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 4 }"
                    },
                    {
                        "type": "text",
                        "content": "denote the numbers of games won by I, II, III and IV, respectively. "
                    }
                ]
            },
            "bbox": [
                106,
                366,
                854,
                512
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Prove or disprove the statistic "
                            },
                            {
                                "type": "equation_inline",
                                "content": "T = \\left( X _ { 1 } + X _ { 2 } , X _ { 3 } + X _ { 4 } \\right)"
                            },
                            {
