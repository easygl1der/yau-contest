                                "content": "is complete. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Find a uniformly minimum variance unbiased estimator of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\theta"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
