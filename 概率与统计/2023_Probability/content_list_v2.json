            "bbox": [
                127,
                656,
                854,
                712
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 1 } , X _ { 2 } , \\ldots , X _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "be a sequence of i.i.d. random variables with a uniform distribution on "
                    },
                    {
                        "type": "equation_inline",
