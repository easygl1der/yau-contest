                    },
                    {
                        "type": "equation_inline",
                        "content": "[ 0 , \\infty ) ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E ( | H ( X , Y ) | ) < \\infty"
                    },
                    {
                        "type": "text",
                        "content": ". Define function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\phi ( u ) = u / ( 1 + u )"
                    },
                    {
                        "type": "text",
                        "content": "for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u \\geq 0"
                    },
                    {
                        "type": "text",
                        "content": ". For integer "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n = 0 , 1 , 2 , \\ldots"
                    },
                    {
                        "type": "text",
                        "content": ", let "
                    }
                ]
            },
            "bbox": [
                104,
                527,
                854,
                584
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "U _ {n} = \\sum_ {j = 1} ^ {2 ^ {n}} \\frac {j - 1}{2 ^ {n}} I \\left(\\frac {j - 1}{2 ^ {n}} \\leq \\phi (X) <   \\frac {j}{2 ^ {n}}\\right), V _ {n} = E (H (X, Y) | U _ {n}).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/9f36b458f8f256e725199cd084d6714d8849ab56d6a00bfe40791726181745cc.jpg"
