        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Define "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { R _ { n } \\ = \\ \\sum _ { k = 1 } ^ { n } I ( A _ { k } ) } \\end{array}"
                    },
                    {
                        "type": "text",
