                316,
                849,
                393
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Assume that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G _ { 0 }"
