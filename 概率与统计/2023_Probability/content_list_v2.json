        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Denote by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\boldsymbol { B }"
                    },
                    {
                        "type": "text",
                        "content": "the Borel sigma field on the real line "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R"
                    },
                    {
                        "type": "text",
                        "content": ", and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( \\Omega , { \\mathcal { F } } )"
                    },
                    {
                        "type": "text",
                        "content": "be a measurable space. Define a mapping "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Q ( t , A )"
                    },
                    {
                        "type": "text",
                        "content": "for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "t \\in R"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A \\in { \\mathcal { F } }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Q ( t , \\cdot )"
                    },
                    {
                        "type": "text",
                        "content": "is a probability measure on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( \\Omega , { \\mathcal { F } } )"
                    },
                    {
                        "type": "text",
                        "content": "for each "
                    },
                    {
                        "type": "equation_inline",
                        "content": "t \\in R"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Q ( \\cdot , A )"
                    },
                    {
                        "type": "text",
                        "content": "is a Borel function for each "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A \\in { \\mathcal { F } }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                106,
