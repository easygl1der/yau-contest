                                "type": "equation_inline",
                                "content": "X _ { 1 } \\sim G _ { 0 }"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "• Conditional on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X _ { 1 } , X _ { 2 } , \\ldots , X _ { n }"
                            },
                            {
                                "type": "text",
                                "content": ", the distribution of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X _ { n + 1 }"
                            },
                            {
                                "type": "text",
                                "content": "is "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\textstyle \\alpha _ { 0 } G _ { 0 } + \\sum _ { i = 1 } ^ { n } \\delta _ { X _ { i } }"
                            },
                            {
                                "type": "text",
                                "content": ", appropriately normalized, where "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\delta _ { x }"
