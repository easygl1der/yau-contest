                    },
                    {
                        "type": "equation_inline",
                        "content": "P \\circ T ^ { - 1 }"
                    },
                    {
                        "type": "text",
                        "content": "denotes the induced probability measure by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T"
                    },
                    {
                        "type": "text",
                        "content": ". Prove or disprove the following statement: "
                    }
