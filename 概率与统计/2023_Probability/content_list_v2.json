                856,
                194
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Denote by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Pi"
                    },
                    {
                        "type": "text",
                        "content": "a probability measure on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( R , B )"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P"
                    },
                    {
                        "type": "text",
                        "content": "a probability measure on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( \\Omega , { \\mathcal { F } } )"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T"
                    },
                    {
                        "type": "text",
                        "content": "a random variable on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( \\Omega , { \\mathcal { F } } , P )"
                    },
                    {
                        "type": "text",
                        "content": ". Assume that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Pi"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T"
                    },
                    {
                        "type": "text",
                        "content": "satisfy "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Pi = P \\circ T ^ { - 1 }"
                    },
                    {
                        "type": "text",
                        "content": ", and for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A \\in F"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    }
                ]
            },
            "bbox": [
                127,
                196,
                854,
                251
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "P (A) = \\int_ {R} Q (t, A) \\Pi (d t),",
                "math_type": "latex",
                "image_source": {
                    "path": "images/7db316a7fb834148838218238d418ed63b2425b5244b83881eb0c53f488d6c5f.jpg"
