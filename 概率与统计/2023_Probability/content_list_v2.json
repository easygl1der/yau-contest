                    },
                    {
                        "type": "equation_inline",
                        "content": "G _ { 0 }"
                    },
                    {
                        "type": "text",
                        "content": "and concentration parameter "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\alpha _ { 0 } > 0"
                    },
                    {
                        "type": "text",
                        "content": "if "
                    },
                    {
                        "type": "equation_inline",
