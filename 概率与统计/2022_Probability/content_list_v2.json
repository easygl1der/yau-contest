        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ X _ { n } \\}"
                    },
                    {
                        "type": "text",
                        "content": "be a sequence of Gaussian random variables. Suppose that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "is a random variable such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "converges to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "in distribution as "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n  \\infty"
                    },
                    {
                        "type": "text",
                        "content": ". Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "is also a (possibly degenerate, i.e., variance zero) Gaussian random variable. "
                    }
                ]
            },
            "bbox": [
                111,
                191,
                883,
                241
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 2. For two probability measures "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\nu"
                    },
                    {
                        "type": "text",
                        "content": "on the real line ??, the total variation distance "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\| \\mu - \\nu \\| _ { T V }"
                    },
                    {
                        "type": "text",
                        "content": "is defined as "
                    }
                ]
            },
            "bbox": [
                111,
                257,
                883,
                287
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left\\| \\mu - \\nu \\right\\| _ {T V} = \\sup  \\left\\{\\mu (C) - \\nu (C): C \\in \\mathcal {B} (\\mathbf {R}) \\right\\},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/bf562f9d9b5c215fdc82d642dbcf518b7b786419be2658900196a4b4d28f2934.jpg"
                }
            },
            "bbox": [
                344,
                291,
                650,
                308
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathcal B ( { \\bf R } )"
                    },
                    {
                        "type": "text",
                        "content": "is the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma"
                    },
                    {
                        "type": "text",
                        "content": "-algebra of Borel sets on ??. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathcal { C } ( \\mu , \\nu )"
                    },
                    {
                        "type": "text",
                        "content": "be the space of couplings of the probability measures "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\nu"
                    },
                    {
                        "type": "text",
                        "content": ", i.e., the space of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { R } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "valued random variables "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( X , Y )"
                    },
                    {
                        "type": "text",
                        "content": "defined on some (not necessarily same) probability space "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( \\varOmega , \\mathcal { F } , \\mathbb { P } )"
                    },
                    {
                        "type": "text",
                        "content": "such that the marginal distributions of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y"
                    },
                    {
                        "type": "text",
                        "content": "are "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu"
                    },
                    {
                        "type": "text",
                        "content": "and ??, respectively. Show that "
                    }
                ]
            },
            "bbox": [
                111,
                324,
                883,
                375
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left\\| \\mu - v \\right\\| _ {T V} = \\inf  \\left\\{\\mathbb {P} (X \\neq Y): (X, Y) \\in \\mathcal {C} (\\mu , v) \\right\\}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/1eacf11b4836f5e3a3725970ff3ae36fbf15b01633d0feb3e4d5d9b4e4bac1cf.jpg"
                }
            },
            "bbox": [
                334,
                393,
                658,
                411
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "For simplicity you may assume that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\nu"
                    },
                    {
                        "type": "text",
                        "content": "are absolutely continuous with respect to the Lebesgue measure on ??. "
                    }
                ]
            },
            "bbox": [
                112,
                430,
                883,
                460
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 3. We throw a fair die repeatedly and independently. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tau _ { 1 1 }"
                    },
                    {
                        "type": "text",
                        "content": "be the first time the pattern 11 (two consecutive 1’s) appears and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tau _ { 1 2 }"
                    },
                    {
                        "type": "text",
                        "content": "the first time the pattern 12 (1 followed by 2) appears. "
                    }
                ]
            },
            "bbox": [
                111,
                479,
                883,
                513
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Calculate the expected value "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { E } \\tau _ { 1 1 }"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Which is larger, "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { E } \\tau _ { 1 1 }"
                            },
                            {
                                "type": "text",
                                "content": "or "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { E } \\tau _ { 1 2 } ?"
                            },
                            {
                                "type": "text",
                                "content": "It is sufficient to give an intuitive argument to justify your answer. You can also calculate "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { E } \\tau _ { 1 2 }"
                            },
                            {
                                "type": "text",
                                "content": "if you wish. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                125,
                522,
                880,
                580
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ X _ { n } \\}"
                    },
                    {
                        "type": "text",
                        "content": "be a Markov chain on a discrete state space "
                    },
                    {
                        "type": "equation_inline",
                        "content": "s"
                    },
                    {
                        "type": "text",
                        "content": "with transition function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p ( x , y ) , x , y \\in S"
                    },
                    {
                        "type": "text",
                        "content": ". Suppose that there is a state "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y _ { 0 } \\in S"
                    },
                    {
                        "type": "text",
                        "content": "and a positive number "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\boldsymbol { \\theta }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p ( x , y _ { 0 } ) \\ge \\theta"
                    },
                    {
                        "type": "text",
                        "content": "for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x \\in S"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                111,
                601,
                883,
                635
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) Show that is a positive constant "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda < 1"
                    },
                    {
                        "type": "text",
                        "content": "such that for any two initial distribution "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\nu"
                    }
                ]
            },
            "bbox": [
                125,
                643,
                754,
                660
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\sum_ {y \\in S} \\left| \\mathbb {P} _ {\\mu} \\left\\{X _ {1} = y \\right\\} - \\mathbb {P} _ {\\nu} \\left\\{X _ {1} = y \\right\\} \\right| \\leq \\lambda \\sum_ {y \\in S} | \\mu (y) - \\nu (y) |.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/6b7b9eb874a976847256ad20866908708a694878a0695e941a082fc99de3e0c1.jpg"
                }
            },
            "bbox": [
                339,
                676,
                697,
                708
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) Show that the Markov chain has a unique stationary distribution "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\pi"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    }
                ]
            },
            "bbox": [
                125,
                732,
                648,
                748
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\sum_ {y \\in S} \\left| \\mathbb {P} _ {\\mu} \\left\\{X _ {n} = y \\right\\} - \\pi (y) \\right| \\leq 2 \\lambda^ {n}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/cec6d2457c471ada2d59c726568981810da5e1a886b32cbe11dbda84e4d6780e.jpg"
                }
            },
            "bbox": [
                411,
                766,
                627,
                796
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 5. Consider a linear regression model with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "predictors and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "observations: "
                    }
                ]
            },
            "bbox": [
                112,
                815,
                705,
                830
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathbf {Y} = X \\boldsymbol {\\beta} + \\mathbf {e},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/ee4d0aa63508e6e60be90def017431a72d8ef035054c3be1cfea7fbcfdd505ba.jpg"
                }
            },
            "bbox": [
                452,
                851,
                542,
                867
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { n \\times p }"
                    },
                    {
                        "type": "text",
                        "content": "is the design matrix, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\beta"
                    },
                    {
                        "type": "text",
                        "content": "is the unknown coefficient vector, and the random error vector ?? has a multivariate normal distribution with mean zero and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathrm { V a r } ( \\mathbf { e } ) = \\sigma ^ { 2 } I _ { n }"
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma ^ { 2 } > 0"
                    },
                    {
                        "type": "text",
                        "content": "unknown and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "I _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "is the identity matrix). "
                    }
                ]
            },
            "bbox": [
                111,
                887,
