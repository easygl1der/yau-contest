        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Find the uniformly minimum variance unbiased estimator (UMVUE) of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\gamma"
                    },
                    {
                        "type": "text",
                        "content": "or prove it does not exist. "
                    }
                ]
            },
            "bbox": [
                112,
                164,
                797,
                180
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 6. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 1 } , \\dots , X _ { 2 0 2 2 }"
                    },
                    {
                        "type": "text",
                        "content": "be independent random variables with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { i } \\sim \\ N ( \\ \\theta _ { i } , i ^ { 2 } ) , 1 \\leq i \\leq 2 0 2 2 ."
                    },
                    {
                        "type": "text",
                        "content": "For estimating the unknown mean vector "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\theta \\in R ^ { 2 0 2 2 }"
                    },
                    {
                        "type": "text",
                        "content": ", consider the loss function "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { L ( \\boldsymbol { \\theta } , \\mathbf { d } ) = \\sum _ { i = 1 } ^ { 2 0 2 2 } ( d _ { i } - \\theta _ { i } ) ^ { 2 } / i ^ { 2 } } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { X } ="
                    },
                    {
                        "type": "equation_inline",
                        "content": "( X _ { 1 } , \\dots , X _ { 2 0 2 2 } )"
                    },
                    {
                        "type": "text",
                        "content": "is a minimax estimator of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\boldsymbol { \\theta }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                111,
