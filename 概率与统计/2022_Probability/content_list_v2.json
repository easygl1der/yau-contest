        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Here "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\operatorname { r a n k } ( X ) = k \\leq p"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "may or may not be greater than "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": ", but we assume "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n - k > 1"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { x } _ { 1 } = ( x _ { 1 , 1 } , \\hdots , x _ { 1 , p } )"
                    },
                    {
                        "type": "text",
                        "content": "be the first row of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "and define "
                    }
                ]
            },
            "bbox": [
                111,
                97,
                883,
                128
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\gamma = \\frac {\\mathbf {x} _ {1} \\boldsymbol {\\beta}}{\\sigma}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/d61dbf2637c968bb51b44fb384782a1e405aaeb1e4a54dccc554d2702cf6b513.jpg"
