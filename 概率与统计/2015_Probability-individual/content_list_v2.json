        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. (a) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y"
                    },
                    {
                        "type": "text",
                        "content": "be two random variables with zero means, variance 1, and correlation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\rho"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that "
                    }
                ]
            },
            "bbox": [
                139,
                229,
                889,
                263
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathbb {E} [ \\max \\{X ^ {2}, Y ^ {2} \\} ] \\leq 1 + \\sqrt {1 - \\rho^ {2}}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/45b77c994cd241bcad6cf49e1b970e7fe087fd50b355e0af806ce615203def62.jpg"
                }
            },
            "bbox": [
                371,
                269,
                655,
                292
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y"
                    },
                    {
                        "type": "text",
                        "content": "have a bivariate normal distribution with zero means, variances "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tau ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ", respectively, and correlation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\rho"
                    },
                    {
                        "type": "text",
                        "content": ". Find the conditional expectation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { E } ( X | Y )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                139,
                300,
                889,
                336
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 2. We flip a fair coin until heads turns out twice consecutively. What is the expected number of flips? "
                    }
                ]
            },
            "bbox": [
                139,
                350,
                889,
                385
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( X _ { n } , n \\geq 1 )"
                    },
                    {
                        "type": "text",
                        "content": "be a sequence of independent Gaussian variables, with respective mean "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu _ { n }"
                    },
                    {
                        "type": "text",
                        "content": ", and variance "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma _ { n } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                139,
                400,
                889,
                435
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) Prove that if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\textstyle \\sum _ { n } X _ { n } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "converges in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "L ^ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": ", then "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\textstyle \\sum _ { n } X _ { n } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "converges in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "L ^ { p }"
                    },
                    {
                        "type": "text",
                        "content": ", for every "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\in [ 1 , \\infty )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                152,
                444,
                887,
                479
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) Assume that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu _ { n } = 0"
                    },
                    {
                        "type": "text",
                        "content": ", for every "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\textstyle \\sum _ { n } \\sigma _ { n } ^ { 2 } = \\infty"
                    },
                    {
                        "type": "text",
                        "content": ", then "
                    }
                ]
            },
            "bbox": [
                152,
                488,
                754,
                508
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\mathbb {P} \\left(\\sum_ {n} X _ {n} ^ {2} = \\infty\\right) = 1.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/3af45f37aaee078ea7de34f5ff057928f18505c52f9e9bb5a92e8e7d43b5dfd5.jpg"
                }
            },
            "bbox": [
                447,
                514,
                628,
                549
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 1 } , \\ldots , X _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "be a random sample of size "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "from the exponential distribution with pdf "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f ( x ; \\theta ) ~ = ~ \\theta ^ { - 1 } \\exp ( - x / \\theta )"
                    },
                    {
                        "type": "text",
                        "content": "for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x , \\theta \\ > \\ 0"
                    },
                    {
                        "type": "text",
                        "content": ", zero elsewhere. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y _ { 1 } = \\operatorname* { m i n } \\{ X _ { 1 } , \\dots , X _ { n } \\}"
                    },
                    {
                        "type": "text",
                        "content": ". Consider an estimator "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n Y _ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                139,
                571,
                889,
                624
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Show this estimate is unbiased. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Prove or disprove: This estimate is a consistent estimator. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) Prove or disprove: This estimate is an efficient estimator. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                152,
                634,
                694,
                706
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 5. Let the independent normal random variables "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y _ { 1 } , \\dots , Y _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "have, respectively, the probability density functions "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N ( \\mu , \\gamma ^ { 2 } x _ { i } ^ { 2 } )"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "i = 1 , \\ldots , n"
                    },
                    {
                        "type": "text",
                        "content": ", where the given "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x _ { 1 } , \\ldots , x _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "are not all equal and no one of which is zero. "
                    }
                ]
            },
            "bbox": [
                139,
                715,
                889,
                768
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Construct a confidence interval for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\gamma"
                            },
                            {
                                "type": "text",
                                "content": "with significance level "
                            },
                            {
                                "type": "equation_inline",
                                "content": "1 - \\alpha"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Discuss the test of the hypothesis "
                            },
                            {
                                "type": "equation_inline",
                                "content": "H _ { 0 } : \\gamma = 1 , \\mu"
                            },
                            {
                                "type": "text",
                                "content": "unspecified, against all alternatives "
                            },
                            {
                                "type": "equation_inline",
                                "content": "H _ { 1 } : \\gamma \\neq 1 , \\mu"
                            },
                            {
                                "type": "text",
                                "content": "unspecified. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                152,
