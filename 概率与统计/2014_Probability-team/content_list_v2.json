        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. Suppose that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "converges to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "in distribution and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "converges to a constant "
                    },
                    {
                        "type": "equation_inline",
                        "content": "c"
                    },
                    {
                        "type": "text",
                        "content": "in distribution. Show that "
                    }
                ]
            },
            "bbox": [
                139,
                275,
                907,
                315
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Y _ { n }"
                            },
                            {
                                "type": "text",
                                "content": "converges to "
                            },
                            {
                                "type": "equation_inline",
                                "content": "c"
                            },
                            {
                                "type": "text",
                                "content": "in probability; "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X _ { n } Y _ { n }"
                            },
                            {
                                "type": "text",
                                "content": "converges to "
                            },
                            {
                                "type": "equation_inline",
                                "content": "c X"
                            },
                            {
                                "type": "text",
                                "content": "in distribution. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                169,
                322,
                532,
                361
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 2. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y"
                    },
                    {
                        "type": "text",
                        "content": "be two random variables with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| Y | > 0"
                    },
                    {
                        "type": "text",
                        "content": ", a.s.. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Z = X / Y"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                139,
                381,
                889,
                400
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Assume the distribution function of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( X , Y )"
                            },
                            {
                                "type": "text",
                                "content": "has the density "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p ( x , y )"
                            },
                            {
                                "type": "text",
                                "content": ". What is the density function of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Z"
                            },
                            {
                                "type": "text",
                                "content": "? "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Assume "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Y"
                            },
                            {
                                "type": "text",
                                "content": "are independent and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X"
                            },
                            {
                                "type": "text",
                                "content": "is "
                            },
                            {
                                "type": "equation_inline",
                                "content": "N ( 0 , 1 )"
                            },
                            {
                                "type": "text",
                                "content": "distributed, "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Y"
                            },
                            {
                                "type": "text",
                                "content": "has the uniform distribution on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( 0 , 1 )"
                            },
                            {
                                "type": "text",
                                "content": ". Give the density function of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Z"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                139,
                405,
                905,
                486
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( \\Omega , { \\mathcal { F } } , P )"
                    },
                    {
                        "type": "text",
                        "content": "be a probability space. "
                    }
                ]
            },
            "bbox": [
                139,
                506,
                579,
                524
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathcal { G }"
                            },
                            {
                                "type": "text",
                                "content": "be a sub "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\sigma"
                            },
                            {
                                "type": "text",
                                "content": "-algebra of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathcal { F }"
                            },
                            {
                                "type": "text",
                                "content": ", and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "1 \\in { \\mathcal { F } }"
                            },
                            {
                                "type": "text",
                                "content": ". Prove that the following properties are equivalent: "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(i) "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Gamma"
                            },
                            {
                                "type": "text",
                                "content": "is independent of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathcal { G }"
                            },
                            {
                                "type": "text",
                                "content": "under "
                            },
                            {
                                "type": "equation_inline",
                                "content": "P"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(ii) for every probability "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Q"
                            },
                            {
                                "type": "text",
                                "content": "on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( \\Omega , { \\mathcal { F } } )"
                            },
                            {
                                "type": "text",
                                "content": ", equivalent to "
                            },
                            {
                                "type": "equation_inline",
                                "content": "P"
                            },
                            {
                                "type": "text",
                                "content": ", with "
                            },
                            {
                                "type": "equation_inline",
                                "content": "d Q / d P"
                            },
                            {
                                "type": "text",
                                "content": "being "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathcal { G }"
                            },
                            {
                                "type": "text",
                                "content": "measurable, we have "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Q ( \\Gamma ) = P ( \\Gamma )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X , Y , Z"
                            },
                            {
                                "type": "text",
                                "content": "be random variables and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Y"
                            },
                            {
                                "type": "text",
                                "content": "is integrable. Show that if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( X , Y )"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Z"
                            },
                            {
                                "type": "text",
                                "content": "are independent, then "
                            },
                            {
                                "type": "equation_inline",
                                "content": "E [ Y | X , Z ] = E [ Y | X ]"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                139,
                530,
                905,
                680
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 1 } , . . . , X _ { n }"
                    },
                    {
                        "type": "text",
                        "content": "be i.i.d. "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N ( 0 , \\sigma ^ { 2 } )"
                    },
                    {
                        "type": "text",
                        "content": ", and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "be the mean of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\vert X _ { 1 } \\vert , . . . , \\vert X _ { n } \\vert"
                    }
                ]
            },
            "bbox": [
                139,
                699,
                887,
                718
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. Find "
                            },
                            {
                                "type": "equation_inline",
                                "content": "c \\in R"
                            },
                            {
                                "type": "text",
                                "content": "so that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\hat { \\sigma } = c M"
                            },
                            {
                                "type": "text",
                                "content": "is a consistent estimator of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\sigma"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Determine the limiting distribution for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\sqrt { n } ( \\hat { \\sigma } - \\sigma )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3. Identify an approximate "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( 1 - \\alpha ) \\%"
                            },
                            {
                                "type": "text",
                                "content": "confidence interval for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\sigma"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "4. Is "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\hat { \\sigma } = c M"
                            },
                            {
                                "type": "text",
                                "content": "asymptotically efficient? Please justify your answer. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
