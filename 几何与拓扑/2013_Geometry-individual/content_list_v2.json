            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "u ^ {\\prime \\prime} (t) + f (t) u (t) = 0",
                "math_type": "latex",
                "image_source": {
                    "path": "images/aaf422c7cc41734b959e177132512c85de56d6a66b3c4967c54f8b794c401210.jpg"
                }
            },
            "bbox": [
