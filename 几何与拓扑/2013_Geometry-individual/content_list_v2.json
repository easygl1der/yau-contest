                229
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. Find the homology and fundamental group of the space "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\boldsymbol { X } = \\boldsymbol { S } ^ { 1 } \\times \\boldsymbol "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S ^ { 1 } / \\{ p , q \\}"
                            },
                            {
                                "type": "text",
                                "content": "obtained from the torus by identifying two distinct points "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p , q"
                            },
                            {
                                "type": "text",
                                "content": "to one point. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Suppose "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( X , d )"
                            },
                            {
                                "type": "text",
                                "content": "is a compact metric space and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f : X \\to X"
                            },
                            {
                                "type": "text",
                                "content": "is a map so that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "d ( f ( x ) , f ( y ) ) = d ( x , y )"
                            },
                            {
                                "type": "text",
                                "content": "for all "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "y \\in X"
                            },
                            {
                                "type": "text",
                                "content": ". Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "is an onto map. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "ba a complete regular surface and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K"
                            },
                            {
                                "type": "text",
                                "content": "be the Gaussian curvature. Suppose "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\sigma : [ 0 , \\infty ) \\to M"
                            },
                            {
                                "type": "text",
                                "content": "is a geodesic such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K ( \\sigma ( t ) ) \\leq f ( t )"
                            },
                            {
                                "type": "text",
                                "content": ", where "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "is a differentiable function on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "[ 0 , \\infty )"
                            },
                            {
                                "type": "text",
                                "content": ". Prove that any solution "
                            },
                            {
                                "type": "equation_inline",
                                "content": "u ( t )"
                            },
                            {
                                "type": "text",
                                "content": "of the equation "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                191,
