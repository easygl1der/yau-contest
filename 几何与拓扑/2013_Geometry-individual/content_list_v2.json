            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "4. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g _ { 1 }"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g _ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "be Riemannian metrics on a differentiable manifold "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": ", and denote by "
                            },
                            {
                                "type": "equation_inline",
                                "content": "R _ { 1 }"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "R _ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "their respective Riemannian curvature tensor. Suppose that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "R _ { 1 } ( X , Y , Y , X ) = R _ { 2 } ( X , Y , Y , X )"
                            },
                            {
                                "type": "text",
                                "content": "holds for any tangent vectors "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Y \\in T _ { p } M"
                            },
                            {
                                "type": "text",
                                "content": ". Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "R _ { 1 } ( X , Y , Z , W ) = R _ { 2 } ( X , Y , Z , W )"
                            },
                            {
                                "type": "text",
                                "content": "for any "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Y"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "Z"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "W \\in T _ { p } M"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "5. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "be an even dimensional, orientable Riemannian manifold with positive sectional curvature. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\sigma : [ 0 , l ] \\ \\to \\ M"
                            },
                            {
                                "type": "text",
                                "content": "be a closed geodesic, namely, "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\sigma"
                            },
                            {
                                "type": "text",
                                "content": "is a geodesic with "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\sigma ( 0 ) = \\sigma ( l )"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\sigma ^ { \\prime } ( 0 ) = \\sigma ^ { \\prime } ( l )"
                            },
                            {
                                "type": "text",
                                "content": ". Show that there exist an "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\epsilon > 0"
                            },
                            {
                                "type": "text",
                                "content": "and a smooth map "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F : [ 0 , l ] \\times ( - \\epsilon , \\epsilon ) "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": ", such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F ( t , 0 ) = \\sigma ( t )"
                            },
                            {
                                "type": "text",
                                "content": ", and for any fixed "
                            },
                            {
                                "type": "equation_inline",
                                "content": "s \\neq 0"
                            },
                            {
                                "type": "text",
                                "content": "in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( - \\epsilon , \\epsilon )"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\sigma _ { s } ( t ) = "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F ( t , s )"
                            },
                            {
                                "type": "text",
                                "content": "is a closed smooth curve with length less than that of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\sigma"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "6. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( M ^ { 2 } , d s ^ { 2 } )"
                            },
                            {
                                "type": "text",
                                "content": "be a minimal surface in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R } ^ { 3 }"
                            },
                            {
                                "type": "text",
                                "content": ", where "
                            },
                            {
                                "type": "equation_inline",
                                "content": "d s ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "is the restriction of the Euclidean metric. Assume that the Gaussian curvature "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K"
                            },
                            {
                                "type": "text",
                                "content": "of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( M ^ { 2 } , d s ^ { 2 } )"
                            },
                            {
                                "type": "text",
                                "content": "is negative. Denote by "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\widetilde { K }"
                            },
                            {
                                "type": "text",
                                "content": "the Gaussian curvature of the metric "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\widetilde { d s ^ { 2 } } = - K d s ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": ". Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\widetilde K = 1"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
