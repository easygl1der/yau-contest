            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "has a zero on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "[ 0 , t _ { 0 } ]"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma ( t _ { 0 } )"
                    },
                    {
                        "type": "text",
                        "content": "is the first conjugate point to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma ( 0 )"
                    },
                    {
                        "type": "text",
                        "content": "along "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sigma"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
