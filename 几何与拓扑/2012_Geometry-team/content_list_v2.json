        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Geometry and Topology "
                    }
                ],
                "level": 1
            },
            "bbox": [
                324,
                239,
                673,
                265
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Please solve 5 out of the following 6 problems. "
                    }
                ]
            },
            "bbox": [
                295,
                300,
                699,
                318
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. Prove that the real projective space "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R P } ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "is a differentiable manifold of dimension "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "N"
                            },
                            {
                                "type": "text",
                                "content": "be "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": "-dimensional smooth, compact, connected manifolds, and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f : { \\cal M }  N"
                            },
                            {
                                "type": "text",
                                "content": "a smooth map with rank equals to "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": "everywhere. Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "is a covering map. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3. Given any Riemannian manifold "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( M ^ { n } , g )"
                            },
                            {
                                "type": "text",
                                "content": ", show that there exists a unique Riemannian connection on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "4. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "be the unit sphere in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R } ^ { n + 1 }"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f : S ^ { n } \\to S ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "a continuous map. Assume that the degree of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "is an odd integer. Show that there exists "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x _ { 0 } \\in S ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( - x _ { 0 } ) = - f ( x _ { 0 } )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "5. State and prove the Stokes theorem for oriented compact manifolds. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "6. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "be a surface in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R } ^ { 3 }"
                            },
                            {
                                "type": "text",
                                "content": ". Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "D"
                            },
                            {
                                "type": "text",
                                "content": "be a simply-connected domain in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "such that the boundary "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\partial D"
                            },
                            {
                                "type": "text",
                                "content": "is compact and consists of a finite number of smooth curves. Prove the Gauss-Bonnet Formula: "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                191,
                362,
                801,
                692
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\int_ {\\partial D} k _ {g} d s + \\sum_ {j} (\\pi - \\alpha_ {j}) + \\iint_ {D} K d A = 2 \\pi ,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/914c85885566d7a374a3dc3e211310fcffbdfea21b9e948db7febf2e21ad85b3.jpg"
                }
            },
            "bbox": [
                305,
                696,
                687,
                739
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k _ { g }"
                    },
                    {
                        "type": "text",
                        "content": "is the geodesic curvature of the boundary curve. Each "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\alpha _ { j }"
                    },
                    {
                        "type": "text",
                        "content": "is the interior angle at a vertex of the boundary, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K"
                    },
                    {
                        "type": "text",
                        "content": "is the Gaussian curvature of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": ", and the 2-form "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d A"
                    },
                    {
                        "type": "text",
                        "content": "is the area element of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
