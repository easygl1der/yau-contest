        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Geometry and Topology Individual "
                    }
                ],
                "level": 1
            },
            "bbox": [
                314,
                131,
                663,
                175
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Please solve 5 out of the following 6 problems. "
                    }
                ]
            },
            "bbox": [
                245,
                181,
                729,
                200
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "m"
                            },
                            {
                                "type": "text",
                                "content": "be positive integers. Show that the product of spheres "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S ^ { n } \\times S ^ { m }"
                            },
                            {
                                "type": "text",
                                "content": "has trivial tangent bundle if and only if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": "or "
                            },
                            {
                                "type": "equation_inline",
                                "content": "m"
                            },
                            {
                                "type": "text",
                                "content": "is odd. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Show that there does not exist a compact three-dimensional manifold "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "whose boundary is the real projective space "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R } \\mathbb { P } ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "be a smooth manifold without boundary and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X"
                            },
                            {
                                "type": "text",
                                "content": "a smooth vector field on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\left( U ; x _ { 1 } , \\ldots , x _ { n } \\right)"
                            },
                            {
                                "type": "text",
                                "content": ". If "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X"
                            },
                            {
                                "type": "text",
                                "content": "does not vanish at centered at "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": "∈  such that in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p \\in M"
                            },
                            {
                                "type": "text",
                                "content": ", show that there exists a local coordinate chart "
                            },
                            {
                                "type": "equation_inline",
                                "content": "U"
                            },
                            {
                                "type": "text",
                                "content": "the vector field "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X"
                            },
                            {
                                "type": "text",
                                "content": "takes the form "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\begin{array} { r } { X = \\frac { \\partial } { \\partial x _ { 1 } } } \\end{array}"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "4. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M \\to \\mathbb { R } ^ { 3 }"
                            },
                            {
                                "type": "text",
                                "content": "be a compact simply-connected closed surface. Prove that if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "has constant mean curvature, then "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "is a standard sphere. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "5. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "be an "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": "-dimensional compact Riemannian manifold with diameter "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\pi / c"
                            },
                            {
                                "type": "text",
                                "content": "and Ricci curvature "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\ge ( n - 1 ) c ^ { 2 } > 0"
                            },
                            {
                                "type": "text",
                                "content": ". Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "is isometric to the standard "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": "-sphere in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R } ^ { n + 1 }"
                            },
                            {
                                "type": "text",
                                "content": "with radius "
                            },
                            {
                                "type": "equation_inline",
                                "content": "1 / c"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "6. Suppose "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( M , g )"
                            },
                            {
                                "type": "text",
                                "content": "is a Riemannian manifold and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p \\in M"
                            },
                            {
                                "type": "text",
                                "content": ". Show that the second-order Taylor series of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g"
                            },
                            {
                                "type": "text",
                                "content": "in normal coordinates centered at "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": "is "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                112,
