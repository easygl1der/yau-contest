        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "6. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M _ { 1 } , M _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "be two complete "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "-dimensional Riemannian manifolds and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\gamma _ { i } : [ 0 , a ] "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M _ { i }"
                    },
                    {
                        "type": "text",
                        "content": "are two arc length parametrized geodesics. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\rho _ { i }"
                    },
                    {
                        "type": "text",
                        "content": "be the distance function to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\gamma _ { i } ( 0 )"
                    },
                    {
                        "type": "text",
                        "content": "on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M _ { i }"
                    },
                    {
                        "type": "text",
                        "content": ". Assume that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\gamma _ { i } ( a )"
                    },
                    {
                        "type": "text",
                        "content": "is within the cut locus of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\gamma _ { i } ( 0 )"
                    },
                    {
                        "type": "text",
                        "content": "and for any "
                    },
                    {
                        "type": "equation_inline",
                        "content": "0 \\leq t \\leq a"
                    },
                    {
                        "type": "text",
                        "content": "we have the inequality of sectional curvatures "
                    }
                ]
            },
            "bbox": [
                114,
                650,
                860,
                717
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "K _ {1} (X _ {1}, \\frac {\\partial}{\\partial \\gamma_ {1}}) \\geq K _ {2} (X _ {2}, \\frac {\\partial}{\\partial \\gamma_ {2}}),",
                "math_type": "latex",
                "image_source": {
                    "path": "images/dff11cebb42c625f7ef1620789e7f8c342a384f9250ae4f1ac2e900e74aef6bb.jpg"
