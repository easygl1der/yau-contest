                297
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "be a topological space. The suspension "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ( X )"
                    },
                    {
                        "type": "text",
                        "content": "of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "is the space obtained from "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X \\times \\lfloor 0 , 1 \\rfloor"
                    },
                    {
                        "type": "text",
                        "content": "by contracting "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X \\times \\{ 0 \\}"
                    },
                    {
                        "type": "text",
                        "content": "to a point and contracting "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X \\times \\{ 1 \\}"
                    },
                    {
                        "type": "text",
                        "content": "to another point. Describe the relation between the homology groups of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ( X )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                114,
                330,
                860,
                381
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F : M \\to N"
                    },
                    {
                        "type": "text",
                        "content": "be a smooth map between two manifolds. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 1 } , X _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "be smooth vector fields on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y _ { 1 } , Y _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "be smooth vector fields on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y _ { 1 } = F _ { * } X _ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y _ { 2 } = F _ { * } X _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ", then "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F _ { * } [ X _ { 1 } , X _ { 2 } ] = [ Y _ { 1 } , Y _ { 2 } ]"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "[ ~ , ~ ]"
                    },
                    {
                        "type": "text",
                        "content": "is the Lie bracket. "
                    }
                ]
            },
            "bbox": [
                114,
                413,
                860,
                464
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M _ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "be two compact convex closed surfaces in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f : M _ { 1 } \\to M _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "a diffeomerphism such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M _ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "have the same inner normal vectors and Gauss curvatures at the corresponding points. Prove that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "is a translation. "
                    }
