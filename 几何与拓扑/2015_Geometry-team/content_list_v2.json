                595
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "R _ {i j k l, h} + R _ {i j l h, k} + R _ {i j h k, l} = 0",
                "math_type": "latex",
                "image_source": {
                    "path": "images/9d20201318d0ad67fa3638d5d242a8fb2fbb8dbfb0715c16eb3622d365c4c124.jpg"
