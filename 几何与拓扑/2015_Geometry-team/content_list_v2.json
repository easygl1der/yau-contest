        {
            "type": "equation_interline",
            "content": {
                "math_content": "H e s s (\\rho_ {1}) (\\widetilde {X} _ {1}, \\widetilde {X} _ {1}) \\leq H e s s (\\rho_ {2}) (\\widetilde {X} _ {2}, \\widetilde {X} _ {2}),",
                "math_type": "latex",
