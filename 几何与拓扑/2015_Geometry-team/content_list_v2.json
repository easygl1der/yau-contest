        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S O ( 3 )"
                    },
                    {
                        "type": "text",
                        "content": "be the set of all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "3 \\times 3"
                    },
                    {
                        "type": "text",
                        "content": "real matrices "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "with determinant 1 and satisfying "
                    },
                    {
                        "type": "equation_inline",
                        "content": "{ } ^ { t } A A = I"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "I"
                    },
                    {
                        "type": "text",
                        "content": "is the identity matrix and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "^ t A"
                    },
                    {
                        "type": "text",
                        "content": "is the transpose of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": ". Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S O ( 3 )"
                    },
                    {
                        "type": "text",
                        "content": "is a smooth manifold, and find its fundamental group. You need to prove your claims. "
                    }
                ]
            },
            "bbox": [
                114,
                247,
