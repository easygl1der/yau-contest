            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Geometry and Topology "
                    }
                ],
                "level": 1
            },
            "bbox": [
                366,
                105,
                658,
                124
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Team (5 problems) "
                    }
                ],
                "level": 1
            },
            "bbox": [
                416,
                128,
                608,
                146
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1) Is "
                            },
                            {
                                "type": "equation_inline",
                                "content": "T S ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "diffeomorphic to "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S ^ { 2 } \\times \\mathbb { R } ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "? Verify your answer. Here "
                            },
                            {
                                "type": "equation_inline",
                                "content": "T S ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "is the total space of the tangent bundle of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2) Solve the problem which Russell Crowe assigns to his students in the movie “A beautiful mind” (2001): "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                132,
                159,
                907,
                212
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\begin{array}{l} V = \\{F: \\mathbb {R} ^ {3} \\backslash X \\rightarrow \\mathbb {R} ^ {3} s. t. \\nabla \\times F = 0 \\} \\\\ W = \\{F = \\nabla g \\} \\\\ \\dim (V / W) =? \\\\ \\end{array}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/57495cd42ea8c25a0d1ba38d8120190941b2c516a5b0aa7c61aae2847e611505.jpg"
                }
            },
            "bbox": [
                391,
                229,
                675,
                288
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "First give the general answer for any closed "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X \\subset \\mathbb { R } ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": ", and then specialize it to (a) "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X = \\{ x = y = z = 0 \\}"
                    },
                    {
                        "type": "text",
                        "content": ", (b) "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X = \\{ x = y = 0 \\}"
                    },
                    {
                        "type": "text",
                        "content": "and (c) "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X = \\{ x = 0 \\}"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                156,
                298,
                907,
                329
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "T ^ { 2 } = S ^ { 1 } \\times S ^ { 1 }"
                            },
                            {
                                "type": "text",
                                "content": "be the 2-torus with the standard orientation, and let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F : T ^ { 2 }  T ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "be a smooth map of degree 1 such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F \\circ F = \\operatorname { I d }"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F"
                            },
                            {
                                "type": "text",
                                "content": "has no fixed points. Prove that the induced map "
                            },
                            {
                                "type": "equation_inline",
                                "content": "F ^ { * } : H ^ { 1 } ( T ^ { 2 } )  H ^ { 1 } ( T ^ { 2 } )"
                            },
                            {
                                "type": "text",
                                "content": "is the identity. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "4) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "U ( n )"
                            },
                            {
                                "type": "text",
                                "content": "be the group of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n \\times n"
                            },
                            {
                                "type": "text",
                                "content": "unitary matrices, and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "O ( n )"
                            },
                            {
                                "type": "text",
                                "content": "be the group of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n \\times n"
                            },
                            {
                                "type": "text",
                                "content": "orthogonal matrices. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S U ( n ) = \\{ A \\in U ( n ) | \\operatorname* { d e t } A = 1 \\}"
                            },
                            {
                                "type": "text",
                                "content": "be the special unitary group and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S O ( n ) = \\{ A \\in O ( n ) | \\operatorname* { d e t } A = 1 \\}"
                            },
                            {
                                "type": "text",
                                "content": "be the special orthogonal group. All "
                            },
                            {
                                "type": "equation_inline",
                                "content": "U ( n ) , S U ( n ) , O ( n ) , S O ( n )"
                            },
                            {
                                "type": "text",
                                "content": "are Lie groups with natural manifold structures. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                134,
                336,
                907,
                445
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Compute the dimensions of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S U ( n )"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S O ( n )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Compute the fundamental groups of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S U ( n )"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S O ( n )"
                            },
                            {
                                "type": "text",
                                "content": "(n > 2). "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                164,
                455,
                667,
                489
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( M , g )"
                    },
                    {
                        "type": "text",
                        "content": "be a compact Riemannian manifold and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R"
                    },
                    {
                        "type": "text",
                        "content": "be its Riemannian curvature tensor. "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( M , g )"
                    },
                    {
                        "type": "text",
                        "content": "will be called weakly negative if for any point "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\in M"
                    },
                    {
                        "type": "text",
                        "content": "and for any nonzero vector field "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X \\in T _ { p } M"
                    },
                    {
                        "type": "text",
                        "content": ", there exists a nonzero vector field "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y \\in T _ { p } M"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R ( X , Y , Y , X ) < 0"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                134,
                497,
                907,
                542
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "be a Killing vector field and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { f = \\frac { 1 } { 2 } g ( X , X ) = \\frac { 1 } { 2 } | X | ^ { 2 } } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": ". Show that for any vector field "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V"
                    }
                ]
            },
            "bbox": [
                164,
                548,
                877,
                565
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "(\\operatorname {H e s s} f) (V, V) = g (\\nabla_ {V} X, \\nabla_ {V} X) - R (V, X, X, V).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/c078533084d195a458e208ae4a03bc805b0642a6f2cd6c8ad4236ea9f540d460.jpg"
                }
            },
            "bbox": [
                369,
                575,
                734,
                592
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Here the Hessian of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "is "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( \\mathrm { H e s s } f ) ( Y , Z ) : = g ( \\nabla _ { Y } \\mathrm { g r a d } ( f ) , Z )"
                    },
                    {
                        "type": "text",
                        "content": "for any vector fields "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y , Z"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\operatorname { g r a d } ( f )"
                    },
                    {
                        "type": "text",
                        "content": "is the gradient vector of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                601,
                907,
                631
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) Prove that if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( M , g )"
                    },
                    {
                        "type": "text",
                        "content": "is weakly negative, then there are no nontrivial Killing vector fields. "
                    }
                ]
            },
            "bbox": [
                163,
                634,
                847,
                651
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "1 "
                    }
                ]
            },
            "bbox": [
                507,
