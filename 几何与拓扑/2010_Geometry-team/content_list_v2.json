            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Team (Please select 5 problems to solve) "
                    }
                ]
            },
            "bbox": [
                349,
                231,
                648,
                268
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S ^ { n } \\subset \\mathbb { R } ^ { n + 1 }"
                            },
                            {
                                "type": "text",
                                "content": "be the unit sphere, and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R } ^ { n } \\subset \\mathbb { R } ^ { n + 1 }"
                            },
                            {
                                "type": "text",
                                "content": "the equator "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": "- plane through the center of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": ". Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "N"
                            },
                            {
                                "type": "text",
                                "content": "be the north pole of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": ". Define a mapping "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\pi : S ^ { n } \\backslash \\{ N \\} \\longrightarrow \\mathbb { R } ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "called the stereographic projection that takes "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A \\in S ^ { n } \\backslash \\{ N \\}"
                            },
                            {
                                "type": "text",
                                "content": "into the intersection "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A ^ { \\prime } \\in \\mathbb { R } ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "of the equator "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": "- plane "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R } ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "with the line which passes through "
                            },
                            {
                                "type": "equation_inline",
                                "content": "A"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "N"
                            },
                            {
                                "type": "text",
                                "content": ". Prove that the stereographic projection is a conformal change, and derive the standard metric of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "by the stereographic projection. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "be a (connected) Riemannian manifold of dimension 2. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "be a smooth non-constant function on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "is bounded from above and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Delta f \\geq 0"
                            },
                            {
                                "type": "text",
                                "content": "everywhere on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": ". Show that there does not exist any point "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p \\in M"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f ( p ) = \\operatorname* { s u p } \\{ f ( x ) : x \\in M \\}"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "be a compact smooth manifold of dimension "
                            },
                            {
                                "type": "equation_inline",
                                "content": "d"
                            },
                            {
                                "type": "text",
                                "content": ". Prove that there exists some "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n \\in \\mathbb { Z } ^ { + }"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "can be regularly embedded in the Euclidean space "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R } ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "4. Show that any "
                            },
                            {
                                "type": "equation_inline",
                                "content": "C ^ { \\infty }"
                            },
                            {
                                "type": "text",
                                "content": "function f on a compact smooth manifold "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "(without boundary) must have at least two critical points. When "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "is the 2-torus, show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f"
                            },
                            {
                                "type": "text",
                                "content": "must have more than two critical points. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "5. Construct a space "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X"
                            },
                            {
                                "type": "text",
                                "content": "with "
                            },
                            {
                                "type": "equation_inline",
                                "content": "H _ { 0 } ( X ) = \\mathbb { Z }"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "H _ { 1 } ( X ) = \\mathbb { Z } _ { 2 } \\times \\mathbb { Z } _ { 3 }"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "H _ { 2 } ( X ) ="
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Z }"
                            },
                            {
                                "type": "text",
                                "content": ", and all other homology groups of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X"
                            },
                            {
                                "type": "text",
                                "content": "vanishing. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "6. (a). Define the degree "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\deg f"
                            },
                            {
                                "type": "text",
                                "content": "of a "
                            },
                            {
                                "type": "equation_inline",
                                "content": "C ^ { \\infty }"
                            },
                            {
                                "type": "text",
                                "content": "map "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f : S ^ { 2 } \\longrightarrow S ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "and prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\deg f"
                            },
                            {
                                "type": "text",
                                "content": "as you present it is well-defined and independent of any choices you need to make in your definition. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b). Prove in detail that for each integer "
                            },
                            {
                                "type": "equation_inline",
                                "content": "k"
                            },
                            {
                                "type": "text",
                                "content": "(possibly negative), there is a "
                            },
                            {
                                "type": "equation_inline",
                                "content": "C ^ { \\infty }"
                            },
                            {
                                "type": "text",
                                "content": "map "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f : S ^ { 2 } \\longrightarrow S ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "of degree "
                            },
                            {
                                "type": "equation_inline",
                                "content": "k"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
