            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Geometry and Topology "
                    }
                ],
                "level": 1
            },
            "bbox": [
                356,
                112,
                640,
                133
            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "(6 problems) "
                    }
                ],
                "level": 1
            },
            "bbox": [
                437,
                135,
                560,
                154
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n > 1"
                    },
                    {
                        "type": "text",
                        "content": "be a positive integer. "
                    }
                ]
            },
            "bbox": [
                161,
                191,
                517,
                208
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(i) Is the tangent bundle of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S ^ { 2 n } \\times S ^ { 2 n }"
                            },
                            {
                                "type": "text",
                                "content": "trivial? Justify your answer. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(ii) Is the tangent bundle of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S ^ { 2 n } \\times S ^ { 2 n - 1 }"
                            },
                            {
                                "type": "text",
                                "content": "trivial? Justify your answer. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                169,
                209,
                720,
                242
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 2. The Lie group "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S U ( 2 )"
                    },
                    {
                        "type": "text",
                        "content": "is diffeomorphic to the 3-sphere "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": ", with Lie algebra spanned by "
                    }
                ]
            },
            "bbox": [
                140,
                263,
                854,
                295
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "X _ {1} = \\left( \\begin{array}{c c} i & 0 \\\\ 0 & - i \\end{array} \\right), \\quad X _ {2} = \\left( \\begin{array}{c c} 0 & 1 \\\\ - 1 & 0 \\end{array} \\right), \\quad X _ {3} = \\left( \\begin{array}{c c} 0 & i \\\\ i & 0 \\end{array} \\right).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/bf40ff0f5c118f71b01362ce5a8cc4be25b80dd5f9bdff9e6c9a7c4a206f52ca.jpg"
                }
            },
            "bbox": [
                289,
                295,
                705,
                330
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "A positive-definite inner product on the Lie algebra determines a left-invariant Riemannian metric on the Lie group. The Berger metrics "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g _ { \\epsilon }"
                    },
                    {
                        "type": "text",
                        "content": "on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": "are obtained by making the inner product on the Lie algebra such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\epsilon ^ { - 1 } X _ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X _ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": "form an orthonormal frame, where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\epsilon > 0"
                    },
                    {
                        "type": "text",
                        "content": "is a positive number. "
                    }
                ]
            },
            "bbox": [
                140,
                330,
                854,
                395
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(i) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\nabla"
                            },
                            {
                                "type": "text",
                                "content": "be the Levi-Civita connection for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g _ { \\epsilon }"
                            },
                            {
                                "type": "text",
                                "content": ". Prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\nabla _ { X _ { i } } X _ { i } = 0"
                            },
                            {
                                "type": "text",
                                "content": "for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "i = 1 , 2 , 3"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(ii) Compute the scalar curvature for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g _ { \\epsilon }"
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                169,
                398,
                834,
                431
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\geq 1"
                    },
                    {
                        "type": "text",
                        "content": "be a positive integer, and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U ( n )"
                    },
                    {
                        "type": "text",
                        "content": "be the group of unitary matrices in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { C } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                140,
                452,
                854,
                484
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(i) Compute "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\pi _ { 2 } ( U ( n ) )"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\pi _ { 3 } ( U ( n ) )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(ii) Prove that the determinant map "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\operatorname * { d e t } : U ( n ) \\to S ^ { 1 }"
                            },
                            {
                                "type": "text",
                                "content": "induces an isomorphism on fundamental groups. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                169,
                487,
                849,
                536
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. Prove that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { C P } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "does not admit an immersion into "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { 6 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                160,
                556,
                697,
                574
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 5. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( M , g )"
                    },
                    {
                        "type": "text",
                        "content": "be a closed, oriented, two-dimensional smooth Riemannian manifold with Gaussian curvature "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K"
                    },
                    {
                        "type": "text",
                        "content": ". Suppose "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u"
                    },
                    {
                        "type": "text",
                        "content": "is a smooth function, and define a new metric "
                    },
                    {
                        "type": "equation_inline",
                        "content": "{ \\tilde { g } } : = e ^ { 2 u } g"
                    },
                    {
                        "type": "text",
                        "content": "in the same conformal class as "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g"
                    },
                    {
                        "type": "text",
                        "content": ", with Gaussian curvature "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tilde { K }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                140,
                592,
                854,
                642
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(i) Prove that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u"
                    },
                    {
                        "type": "text",
                        "content": "satisfies the equation "
                    }
                ]
            },
            "bbox": [
                173,
                645,
                477,
                660
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\Delta u - K + \\tilde {K} e ^ {2 u} = 0,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/18ff17fb587da7785f5444f91ff69f0f45dad2be2e1e06765faf5069f32cbdcc.jpg"
                }
            },
            "bbox": [
                413,
                666,
                583,
                684
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Delta"
                    },
                    {
                        "type": "text",
                        "content": "is the Laplace–Beltrami operator defined by the metric "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                199,
                689,
                728,
                705
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(ii) Suppose the Euler characteristic "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\chi ( M ) = 0"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that either "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tilde { K } \\equiv 0"
                    },
                    {
                        "type": "text",
                        "content": "or "
                    }
                ]
            },
            "bbox": [
                169,
                707,
                766,
                722
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\int_ {M} \\tilde {K} e ^ {2 f} d \\mathrm {V o l} _ {g} <   0,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/42a80e80b0b6ab7db5b3edd6af244d645d6f06425276658fde56c1b1a37f5aca.jpg"
                }
            },
            "bbox": [
                419,
                727,
                578,
                762
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "is a solution to the equation "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Delta f = K"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                200,
                763,
                571,
                781
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 6. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\geq 1"
                    },
                    {
                        "type": "text",
                        "content": "be a positive integer. "
                    }
                ]
            },
            "bbox": [
                161,
                801,
                517,
                818
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(i) Does there exist a self-homeomorphism of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { C P } ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "with no fixed points? Either construct such a homeomorphism or prove that none exists. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(ii) Does there exist a self-homeomorphism of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { C P } ^ { 2 } \\times \\mathbb { C P } ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "with no fixed points? Either construct such a homeomorphism or prove that none exists. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                169,
                820,
                849,
                883
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "1 "
                    }
                ]
            },
            "bbox": [
                493,
                914,
                503,
                924
            ]
        }
    ]
]