        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Geometry and Topology "
                    }
                ],
                "level": 1
            },
            "bbox": [
                324,
                239,
                673,
                263
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Please solve 5 out of the following 6 problems, or highest scores of 5 problems will be counted. "
                    }
                ]
            },
            "bbox": [
                290,
                282,
                705,
                317
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\pi _ { 3 } ( S ^ { 2 } ) \\neq 0"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "be a smooth manifold of dimension "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": ", and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X _ { 1 } , \\cdots , X _ { k }"
                            },
                            {
                                "type": "text",
                                "content": "be "
                            },
                            {
                                "type": "equation_inline",
                                "content": "k"
                            },
                            {
                                "type": "text",
                                "content": "everywhere linearly independent smooth vector fields on an open set "
                            },
                            {
                                "type": "equation_inline",
                                "content": "U \\subset M"
                            },
                            {
                                "type": "text",
                                "content": "satisfying that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "[ X _ { i } , X _ { j } ] = 0"
                            },
                            {
                                "type": "text",
                                "content": "for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "1 \\leq i , j \\leq k"
                            },
                            {
                                "type": "text",
                                "content": ". Prove that for any coordinates point "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p \\in U"
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\{ y ^ { 1 } , \\cdots , y ^ { n } \\}"
                            },
                            {
                                "type": "text",
                                "content": "there is a coordinate chart such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\begin{array} { r } { X _ { i } = \\frac { \\partial } { \\partial y ^ { i } } } \\end{array}"
                            },
                            {
                                "type": "equation_inline",
                                "content": "( V , y ^ { i } )"
                            },
                            {
                                "type": "text",
                                "content": "on with "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V"
                            },
                            {
                                "type": "text",
                                "content": "for each "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p \\in V \\subseteq U"
                            },
                            {
                                "type": "equation_inline",
                                "content": "1 \\leq i \\leq k"
                            },
                            {
                                "type": "text",
                                "content": "and . "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3. Show that any self homeomorphism of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { C P } ^ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "is orientation preserving. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "4. Prove the following version of the isoperimetric inequality: Suppose "
                            },
                            {
                                "type": "equation_inline",
                                "content": "C"
                            },
                            {
                                "type": "text",
                                "content": "is a simple (that is, without self-intersection), smooth, closed curve in the Euclidean plane, with length "
                            },
                            {
                                "type": "equation_inline",
                                "content": "L"
                            },
                            {
                                "type": "text",
                                "content": ". Show that the area enclosed by "
                            },
                            {
                                "type": "equation_inline",
                                "content": "C"
                            },
                            {
                                "type": "text",
                                "content": "is less than or equal to "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\frac { L ^ { 2 } } { 4 \\pi }"
                            },
                            {
                                "type": "text",
                                "content": ", and the equality occurs when and only when "
                            },
                            {
                                "type": "equation_inline",
                                "content": "C"
                            },
                            {
                                "type": "text",
                                "content": "is a round circle. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "5. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "x : M \\to \\mathbb { R } ^ { 3 }"
                            },
                            {
                                "type": "text",
                                "content": "be a closed surface in 3-dimensional Euclidean space. Its Gaussian curvature and mean curvature are denoted by "
                            },
                            {
                                "type": "equation_inline",
                                "content": "K"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "H"
                            },
                            {
                                "type": "text",
                                "content": "respectively. Prove that: "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                191,
                341,
                801,
                651
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\iint_ {M} H d A + \\iint_ {M} p K d A = 0, \\quad \\iint_ {M} p H d A + \\iint_ {M} d A = 0,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/ce94ff5b9285f08c4b7f1f9a06f9303f3ca0ec93f9306724bce688fedc432c04.jpg"
                }
            },
            "bbox": [
                263,
                653,
                736,
                699
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p = { \\vec { x } } \\cdot { \\vec { n } }"
                    },
                    {
                        "type": "text",
                        "content": "is the support function of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\vec { x }"
                    },
                    {
                        "type": "text",
                        "content": "denotes the position vector of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\vec { n }"
                    },
                    {
                        "type": "text",
                        "content": "denotes the unit normal to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d A"
                    },
                    {
                        "type": "text",
                        "content": "is the area element of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                703,
                801,
                752
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "6. Write the structure equation of an orthonormal frame on a Riemannian manifold. Prove the following Riemannian metric "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g"
                    },
                    {
                        "type": "text",
                        "content": "has constant sectional curvature "
                    },
                    {
                        "type": "equation_inline",
                        "content": "c"
                    },
                    {
                        "type": "text",
                        "content": "using the structure equation: "
                    }
                ]
            },
            "bbox": [
                191,
                766,
                801,
                816
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "g = \\frac {\\sum_ {i = 1} ^ {n} (d x ^ {i}) ^ {2}}{[ 1 + \\frac {c}{4} \\sum_ {i = 1} ^ {n} (x ^ {i}) ^ {2} ] ^ {2}}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/19003e5ec080f7451ecb37413b55cce0b106fdb849de50db40a3c5bc07d3c6b3.jpg"
                }
            },
            "bbox": [
                400,
                821,
                596,
                860
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( x ^ { 1 } , \\ldots , x ^ { n } )"
                    },
                    {
                        "type": "text",
                        "content": "is a local coordinate system. "
                    }
                ]
            },
            "bbox": [
                193,
                864,
                603,
                881
            ]
        },
