[
    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Geometry and Topology Individual "
                    }
                ],
                "level": 1
            },
            "bbox": [
                324,
                159,
                673,
                204
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Please solve 5 out of the following 6 problems. "
                    }
                ]
            },
            "bbox": [
                255,
                209,
                739,
                229
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "be the quotient space of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "under the identifications "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x \\sim - x"
                    },
                    {
                        "type": "text",
                        "content": "for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x"
                    },
                    {
                        "type": "text",
                        "content": "in the equator "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": ". Compute the homology groups "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H _ { n } ( X )"
                    },
                    {
                        "type": "text",
                        "content": ". Do the same for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": "with antipodal points of the equator "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 2 } \\subset S ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": "identified. "
                    }
                ]
            },
            "bbox": [
                191,
                269,
                801,
                321
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M \\to \\mathbb { R } ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": "be a graph defined by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "z = f ( u , v )"
                    },
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ u , v , z \\}"
                    },
                    {
                        "type": "text",
                        "content": "is a Descartes coordinate system in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": ". Suppose that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "is a minimal surface. Prove that: "
                    }
                ]
            },
            "bbox": [
                191,
                334,
                801,
                382
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) The Gauss curvature "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K"
                    },
                    {
                        "type": "text",
                        "content": "of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "can be expressed as "
                    }
                ]
            },
            "bbox": [
                193,
                384,
                662,
                401
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "K = \\Delta \\log \\left(1 + \\frac {1}{W}\\right), \\quad W := \\sqrt {1 + \\left(\\frac {\\partial f}{\\partial u}\\right) ^ {2} + \\left(\\frac {\\partial f}{\\partial v}\\right) ^ {2}},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/feaebb50ca627906d6dd68cbc1893e978ce1cba0ead7ad7ff94642d11488c541.jpg"
                }
            },
            "bbox": [
                258,
                407,
                739,
                451
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Delta"
                    },
                    {
                        "type": "text",
                        "content": "denotes the Laplacian with respect to the induce metric on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "(i.e., the first fundamental form of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "). "
                    }
                ]
            },
            "bbox": [
                193,
                455,
                801,
                487
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) If "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "is defined on the whole "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u v"
                    },
                    {
                        "type": "text",
                        "content": "-plane, then "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "is a linear function (Bernstein theorem). "
                    }
                ]
            },
            "bbox": [
                193,
                487,
                801,
                521
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M = \\mathbb { R } ^ { 2 } / \\mathbb { Z } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "be the two dimensional torus, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "L"
                    },
                    {
                        "type": "text",
                        "content": "the line "
                    },
                    {
                        "type": "equation_inline",
                        "content": "3 x = 7 y"
                    },
                    {
                        "type": "text",
                        "content": "in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S = \\pi ( L ) \\subset M"
                    },
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\pi : \\mathbb { R } ^ { 2 } \\to M"
                    },
                    {
                        "type": "text",
                        "content": "is the projection map. Find a differential form on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "which represents the Poincar´e dual of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                536,
                801,
                586
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p : ( \\tilde { M } , \\tilde { g } )  ( M , g )"
                    },
                    {
                        "type": "text",
                        "content": "be a Riemannian submersion. This is a submersion "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p : \\tilde { M } \\to M"
                    },
                    {
                        "type": "text",
                        "content": "such that for each "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x \\in { \\tilde { M } }"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "D p : \\ker ^ { \\perp } ( D p ) \\to"
                    },
                    {
                        "type": "equation_inline",
                        "content": "T _ { p ( x ) } ( M )"
                    },
                    {
                        "type": "text",
                        "content": "is a linear isometry. "
                    }
                ]
            },
            "bbox": [
                191,
                600,
                801,
                652
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": "shortens distances. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) If "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( \\tilde { M } , \\tilde { g } )"
                            },
                            {
                                "type": "text",
                                "content": "is complete, so is "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( M , g )"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) Show by example that if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( M , g )"
                            },
                            {
                                "type": "text",
                                "content": "is complete, "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( \\tilde { M } , \\tilde { g } )"
                            },
                            {
                                "type": "text",
                                "content": "may not be complete. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                223,
                653,
                801,
                722
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Psi : M \\to \\mathbb { R } ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": "be an isometric immersion of a compact surface "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "into "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\int _ { M } H ^ { 2 } d \\sigma \\geq 4 \\pi"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H"
                    },
                    {
                        "type": "text",
                        "content": "is the mean curvature of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d \\sigma"
                    },
                    {
                        "type": "text",
                        "content": "is the area element of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                193,
                738,
                801,
                788
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "6. The unit tangent bundle of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "is the subset "
                    }
                ]
            },
            "bbox": [
                193,
                802,
                601,
                819
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "T ^ {1} (S ^ {2}) = \\left\\{(p, v) \\in \\mathbb {R} ^ {3} \\mid \\| p \\| = 1, (p, v) = 0 \\text {a n d} \\| v \\| = 1 \\right\\}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/5a495364f1c31a85e518071c1329d6b330a8a9c076108036f2c375c7f78e93c2.jpg"
                }
            },
            "bbox": [
                250,
                822,
                746,
                843
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Show that it is a smooth submanifold of the tangent bundle "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T ( S ^ { 2 } )"
                    },
                    {
                        "type": "text",
                        "content": "of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T ^ { 1 } ( S ^ { 2 } )"
                    },
                    {
                        "type": "text",
                        "content": "is diffeomorphic to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } P ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                193,
                846,
                801,
                881
            ]
        },
