                121
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Compute "
                    }
                ]
            },
            "bbox": [
                156,
                135,
                228,
                152
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\frac {\\partial^ {2} g _ {2 2}}{\\partial x ^ {1} \\partial x ^ {1}} \\quad \\text {a t t h e p o i n t} p.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/10cf3e4a8263f10b4a31e048522a04e3cc176946423ae645e619420714c676d0.jpg"
                }
            },
            "bbox": [
                401,
                148,
                581,
                186
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(c) Show that "
                    }
                ]
            },
            "bbox": [
                129,
                207,
                233,
                223
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\max  _ {0 \\leq t \\leq \\delta} \\left| \\frac {\\partial g _ {2 2}}{\\partial x ^ {1}} (\\gamma (t)) \\right| \\leq C \\delta A,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/2b5a9ddc57f7685963cfb7e290e8787f52d992f5fe1f08ed93d85e21056b26f6.jpg"
