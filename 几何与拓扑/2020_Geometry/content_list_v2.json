    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) Denote "
                    }
                ]
            },
            "bbox": [
                127,
                75,
                214,
                90
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "g _ {i j} = \\left\\langle \\frac {\\partial}{\\partial x ^ {i}}, \\frac {\\partial}{\\partial x ^ {j}} \\right\\rangle , \\quad 1 \\leq i, j \\leq n.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/f3ee0bd4bacb2f364be9011ed5fa2962d7b9dc6e16754193fc805041d0e10b2e.jpg"
