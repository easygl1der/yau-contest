        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { n }"
                    },
                    {
                        "type": "text",
