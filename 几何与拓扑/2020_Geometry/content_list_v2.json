                258
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C > 0"
                    },
                    {
                        "type": "text",
                        "content": "is a constant depending only on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "is the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C ^ { 0 }"
                    },
                    {
                        "type": "text",
                        "content": "-bound of the curvature tensor of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": ">along "
                    },
                    {
                        "type": "equation_inline",
