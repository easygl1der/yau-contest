                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { n + 1 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                112,
                172,
                460,
                191
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) Find a 6-form "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\alpha"
                    },
                    {
                        "type": "text",
                        "content": "on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { 7 } \\setminus \\{ 0 \\}"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    }
                ]
            },
            "bbox": [
                127,
                198,
                433,
                215
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "d \\alpha = 0, \\quad \\text {a n d} \\quad \\int_ {S ^ {6}} \\alpha = 1.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/ea9f102bed67899e9f31b4b05d0a499a4a119b9d982b029cf726e5cd2b8d0fdd.jpg"
