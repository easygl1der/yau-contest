                    {
                        "type": "equation_inline",
                        "content": "0 \\leq t \\leq \\delta"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                155,
                273,
                823,
                308
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "{ \\mathrm { S O } } ( n )"
                    },
                    {
                        "type": "text",
                        "content": "be the set of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\times n"
                    },
                    {
                        "type": "text",
                        "content": "orthogonal real matrices with determinant equal to 1. Endow "
                    },
                    {
                        "type": "equation_inline",
                        "content": "{ \\mathrm { S O } } ( n )"
                    },
                    {
                        "type": "text",
                        "content": "with the relative topology as a subspace of Euclidean space "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { n ^ { 2 } }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                111,
                328,
                823,
                362
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "{ \\mathrm { S O } } ( n )"
                            },
                            {
                                "type": "text",
                                "content": "is compact. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Is SO(3) homeomorphic to the real projective space "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R } \\mathbb { P } ^ { 3 } \\}"
                            },
                            {
                                "type": "text",
                                "content": "Prove your assertion. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) Compute the fundamental group of SO(2020). "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                125,
                369,
                728,
                439
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 5. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "be a topological space and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\pi : \\mathbb { R } ^ { 2 } \\to X"
                    },
                    {
                        "type": "text",
                        "content": "a covering map. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "K"
                    },
                    {
                        "type": "text",
                        "content": "be a compact subset of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "B"
                    },
                    {
                        "type": "text",
                        "content": "πthe closed unit ball centered at the origin in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                111,
                460,
                823,
                494
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Suppose "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\pi : \\mathbb { R } ^ { 2 } \\setminus B \\to X \\setminus K"
                            },
                            {
                                "type": "text",
                                "content": "is a homeomorphism. Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\pi : \\mathbb { R } ^ { 2 } \\to X"
                            },
                            {
                                "type": "text",
                                "content": "is a homeomor-"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Suppose "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R } ^ { 2 } \\setminus B"
                            },
                            {
                                "type": "text",
                                "content": "is homeomorphic to "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X \\backslash K"
                            },
                            {
                                "type": "text",
                                "content": ", where the homeomorphism may not be "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\pi"
                            },
                            {
                                "type": "text",
                                "content": ". Is "
                            },
                            {
                                "type": "equation_inline",
                                "content": "X"
                            },
                            {
                                "type": "text",
                                "content": "necessarily homeomorphic to "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R } ^ { 2 } ?"
