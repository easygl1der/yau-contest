            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(c) Let "
                    }
                ]
            },
            "bbox": [
                129,
                381,
                187,
                397
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "H (f) = \\int_ {S ^ {1 1}} \\varphi \\wedge d \\varphi .",
                "math_type": "latex",
                "image_source": {
                    "path": "images/e2bf7c6481a6055bcceaed740cdcf27ef4d19bc63f12590133043797d517fd59.jpg"
