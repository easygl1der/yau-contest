            },
            "bbox": [
                125,
                799,
                470,
                816
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left. t \\frac {\\partial}{\\partial x ^ {\\alpha}} \\right| _ {\\gamma (t)} \\quad \\text {o r} \\quad \\left. \\frac {\\partial}{\\partial x ^ {\\alpha}} \\right| _ {\\gamma (t)},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/dc1082b8e221ef87e94b69e03db78abf419e8114a6bfc4b9b6a0f0afed8f553a.jpg"
