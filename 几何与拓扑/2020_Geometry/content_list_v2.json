        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) For any smooth map "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f : S ^ { 1 1 } \\to S ^ { 6 }"
                    },
                    {
                        "type": "text",
                        "content": ", show that there exists a 5-form "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\varphi"
                    },
                    {
                        "type": "text",
                        "content": "on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 1 1 }"
                    },
                    {
                        "type": "text",
