                ]
            },
            "bbox": [
                156,
                444,
                617,
                460
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(d) Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H ( f )"
                    },
                    {
                        "type": "text",
                        "content": "is an even integer, for any smooth map "
