                393,
                566,
                430
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H ( f )"
                    },
                    {
                        "type": "text",
                        "content": "is independent of the choice of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\varphi"
