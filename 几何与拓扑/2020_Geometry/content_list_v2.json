                    {
                        "type": "text",
                        "content": "is a Jacobi field along "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\gamma ( t ) ?"
                    },
                    {
                        "type": "text",
                        "content": "Prove your assertion. "
                    }
                ]
            },
            "bbox": [
                156,
                891,
                513,
