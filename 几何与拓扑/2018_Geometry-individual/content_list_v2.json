                620
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d W"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "L"
                    },
                    {
                        "type": "text",
                        "content": "is the area element of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "and the length of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C"
                    },
                    {
                        "type": "text",
                        "content": ", respectively. "
                    }
                ]
            },
            "bbox": [
                115,
                623,
                779,
                640
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "be an "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "-dimensional closed submanifold in the Euclidean space "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { n + p }"
                    },
                    {
                        "type": "text",
                        "content": ". Prove the following inequality "
                    }
                ]
            },
            "bbox": [
                114,
                673,
                858,
                706
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\int_ {M} H ^ {n} d V \\geq v o l (S ^ {n}),",
                "math_type": "latex",
                "image_source": {
                    "path": "images/16a4c26b4a1d259ca5c81eff55554632166563128ab6c3a42483dc9df63d9d08.jpg"
                }
            },
            "bbox": [
                396,
                706,
