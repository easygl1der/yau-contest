        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Please solve 5 out of the following 6 problems. "
                    }
                ]
            },
            "bbox": [
                245,
                181,
                729,
                200
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N"
                    },
                    {
                        "type": "text",
                        "content": "be smooth, connected, orientable "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "-manifolds for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\geq 3"
                    },
                    {
                        "type": "text",
                        "content": ", and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M \\# N"
                    },
                    {
                        "type": "text",
                        "content": "denote their connect sum. "
                    }
                ]
            },
            "bbox": [
                115,
                244,
                858,
                278
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Compute the fundamental group of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M \\# N"
                            },
                            {
                                "type": "text",
                                "content": "in terms of that of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "and of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "N"
                            },
                            {
                                "type": "text",
                                "content": "(you may assume that the basepoint is on the boundary sphere along which we glue "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "N"
                            },
                            {
                                "type": "text",
                                "content": "). "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Compute the homology groups of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M \\# N"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(c) For part (a), what changes if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n = 2"
                            },
                            {
                                "type": "text",
                                "content": "? Use this to describe the fundamental groups of orientable surfaces. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                115,
                282,
                857,
                379
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Determine all of the possible degrees of maps "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 2 }  S ^ { 1 } \\times S ^ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                115,
                414,
                667,
                431
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Classify all vector bundles over the circle "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": "up to isomorphism. "
                    }
                ]
            },
            "bbox": [
                115,
                464,
                699,
                481
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Suppose "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C"
                    },
                    {
                        "type": "text",
                        "content": "is a regular curve in the unit sphere "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ". For any point "
                    },
                    {
                        "type": "equation_inline",
                        "content": "W \\in S ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ", there exists the only oriented great circle "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S _ { W }"
                    },
                    {
                        "type": "text",
                        "content": "(determined by the right hand rule) in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "W"
                    },
                    {
                        "type": "text",
                        "content": "is the pole of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S _ { W }"
                    },
                    {
                        "type": "text",
                        "content": ". Denote by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n ( W )"
                    },
                    {
                        "type": "text",
                        "content": "the number of points at which the oriented great circle "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S _ { W }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C"
                    },
                    {
                        "type": "text",
                        "content": "intersect. Prove the Crofton formula "
                    }
                ]
            },
            "bbox": [
                114,
                513,
                858,
                580
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\iint_ {S ^ {2}} n (W) d W = 4 L,",
                "math_type": "latex",
                "image_source": {
                    "path": "images/9b172a54734bd032fc7d78f8b5df6202e05731a4ff89391e0b770c2e23409798.jpg"
                }
            },
            "bbox": [
                396,
                583,
