            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d V"
                    },
                    {
                        "type": "text",
                        "content": "is the mean curvature (i.e., norm of the mean curvature vector) and the volume element of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "is the standard unit sphere of dimension "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                114,
                741,
                858,
                774
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "6. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "be an even dimensional compact and oriented Riemannian manifold with positive sectional curvature. Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
