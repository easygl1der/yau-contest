    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 6. A hypersurface "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Sigma \\subset \\mathbf { R ^ { n + 1 } }"
                    },
                    {
                        "type": "text",
                        "content": "is called a shrinker if it satisfies the equation "
                    }
                ]
            },
            "bbox": [
                112,
                98,
                689,
                114
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "H (x) = \\frac {1}{2} \\langle x, \\vec {n} \\rangle .",
                "math_type": "latex",
                "image_source": {
                    "path": "images/d0d276e0d963fa50251b56d7e88e9ac46dcbaba15df4511b6d0c1d01e9268659.jpg"
                }
            },
            "bbox": [
                442,
                132,
                553,
                152
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Here "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H"
                    },
                    {
                        "type": "text",
                        "content": "is the mean curvature, which is "
                    },
                    {
                        "type": "equation_inline",
                        "content": "- \\langle \\mathrm { t r } _ { A } , \\vec { n } \\rangle"
                    },
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "is the second fundamental form, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x"
                    },
                    {
                        "type": "text",
                        "content": "is the position vector, and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\vec { n }"
                    },
                    {
                        "type": "text",
                        "content": "is outer unit normal vector. "
                    }
                ]
            },
            "bbox": [
                111,
                169,
                883,
                202
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S ^ { n } ( { \\sqrt { 2 n } } )"
                            },
                            {
                                "type": "text",
                                "content": ", the sphere with radius "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\sqrt { 2 n }"
                            },
                            {
                                "type": "text",
                                "content": ", is a shrinker. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Show that any compact shrinker without boundary must intersect with "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S ^ { n } ( { \\sqrt { 2 n } } )"
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                125,
                210,
                714,
                253
            ]
        }
    ]
]