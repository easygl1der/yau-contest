                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbf { P } ^ { 2 \\mathbf { n } }"
                            },
                            {
                                "type": "text",
                                "content": "can not be the boundary of a compact manifold. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbf { P } ^ { 3 }"
                            },
                            {
                                "type": "text",
                                "content": "is the boundary of some compact manifold. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                125,
