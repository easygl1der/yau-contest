        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 6. Suppose "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Sigma"
                    },
                    {
                        "type": "text",
                        "content": "is a smooth compact embedded hypersurface (i.e. a codimension 1 submanifold) without boundary in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { R } ^ { \\mathbf { n } }"
                    },
