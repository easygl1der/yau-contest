            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 2. Suppose "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "is a noncompact, complete "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "-dimensional manifold, and suppose there is an open subset "
                    },
                    {
                        "type": "equation_inline",
                        "content": "U \\subset M"
                    },
                    {
                        "type": "text",
                        "content": "and an open set "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V \\subset { \\mathbf { R } } ^ { \\mathfrak { n } }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M \\backslash U"
                    },
                    {
                        "type": "text",
                        "content": "is isomorphic to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { R ^ { n } } \\backslash V"
                    },
                    {
                        "type": "text",
                        "content": ". If "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathrm { R i c } M \\ge 0"
                    },
                    {
                        "type": "text",
                        "content": ", show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "is isometric to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { R } ^ { \\mathbf { n } }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                111,
                258,
                883,
                309
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 3. Compute all the homotopy groups of the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "-torus "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T ^ { n } = S ^ { 1 } \\times S ^ { 1 } \\times \\cdot \\cdot \\cdot \\times S ^ { 1 } , n \\geq"
                    },
                    {
                        "type": "text",
                        "content": "2 . "
                    }
                ]
            },
            "bbox": [
                111,
                327,
                787,
                345
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. Consider the upper half space "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbf { H } ^ { 3 } = \\{ ( x , y , z ) ~ | ~ z ~ > ~ 0 \\}"
                    },
                    {
                        "type": "text",
                        "content": "equipped with hyperbolic metric "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g = { \\frac { d x ^ { 2 } + d y ^ { 2 } + d z ^ { 2 } } { z ^ { 2 } } }"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P"
                    },
                    {
                        "type": "text",
                        "content": "be the surface defined by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\{ z = x \\tan \\alpha , \\ z > 0 \\}"
                    },
                    {
                        "type": "text",
                        "content": "for some "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\alpha \\in ( 0 , \\frac { \\pi } { 2 } )"
                    },
                    {
                        "type": "text",
                        "content": ". Compute the mean curvature of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "P"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                111,
                367,
                883,
                431
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 5. Suppose "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "is a compact 2-dimensional Riemannian manifold without boundary, with positive sectional curvature. Show that any two compact closed geodesics on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "must intersect with each other. "
                    }
                ]
            },
            "bbox": [
