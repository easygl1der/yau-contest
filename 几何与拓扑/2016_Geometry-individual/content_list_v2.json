        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Please solve 5 out of the following 6 problems. "
                    }
                ]
            },
            "bbox": [
                245,
                181,
                729,
                200
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "be a compact odd-dimensional manifold with boundary "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\partial M"
                    },
                    {
                        "type": "text",
                        "content": ". Show that the Euler characteristics of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\partial M"
                    },
                    {
                        "type": "text",
                        "content": "are related by: "
                    }
                ]
            },
            "bbox": [
                115,
                244,
                860,
                279
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\chi (M) = \\frac {1}{2} \\chi (\\partial M).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/00e790dd01d8e3982c9a3e6b9817f07fcc06a77fe2bb34891993ddbf17ee43c6.jpg"
                }
            },
            "bbox": [
                408,
                282,
                568,
                315
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Compute the de Rham cohomology of a punctured two-dimensional torus "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T ^ { 2 } - \\{ p \\}"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\in T ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ". If "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T ^ { 2 } = \\mathbb { R } ^ { 2 } / \\mathbb { Z } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "with coordinates "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( x , y ) \\in \\mathbb { R } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ", then is the volume form "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\omega = d x \\wedge d y"
                    },
                    {
                        "type": "text",
                        "content": "exact? "
                    }
                ]
            },
            "bbox": [
                115,
                338,
                860,
                391
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M ^ { n } \\to \\mathbb { R } ^ { n + 1 }"
                    },
                    {
                        "type": "text",
                        "content": "be a closed oriented hypersurface. The "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r"
                    },
                    {
                        "type": "text",
                        "content": "-th mean curvature of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "is defined by "
                    }
                ]
            },
            "bbox": [
                115,
                422,
                860,
                456
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "H _ {r} := \\frac {1}{\\binom {n} {r}} \\sum_ {i _ {1} <   i _ {2} \\dots <   i _ {r}} \\lambda_ {i _ {1}} \\lambda_ {i _ {2}} \\dots \\lambda_ {i _ {r}}, (1 \\leq r \\leq n)",
                "math_type": "latex",
                "image_source": {
                    "path": "images/8ff9e604b8bafdbd373b845a744a0931069cae627de0173fcd5b9d6810ab43b6.jpg"
                }
            },
            "bbox": [
                289,
                456,
                687,
                495
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda _ { i }"
                    },
                    {
                        "type": "equation_inline",
                        "content": "{ \\mathit { i } } = 1 , \\cdots , n"
                    },
                    {
                        "type": "text",
                        "content": ") are principal curvatures of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that if all of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda _ { i }"
                    },
                    {
                        "type": "text",
                        "content": "are positive and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H _ { r } ="
                    },
                    {
                        "type": "text",
                        "content": "constant for a certain "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r"
                    },
                    {
                        "type": "text",
                        "content": ", then "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "is a hypersphere in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { n + 1 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                115,
                495,
                860,
                531
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. State and prove the cut-off function lemma on a differentiable manifold. "
                    }
                ]
            },
            "bbox": [
                115,
                562,
                769,
                579
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "be a compact Riemannian manifold without boundary. Show that if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "has positive Ricci curvature, then "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H ^ { 1 } ( M , \\mathbb { R } ) = 0"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                115,
                612,
                860,
                646
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "6. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "be an orientable, closed and embedded minimal hypersurface in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { n + 1 }"
                    },
                    {
                        "type": "text",
                        "content": ". Denote by "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda _ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": "the first eigenvalue for the Laplace-Beltrami operator on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda _ { 1 } \\geq n / 2"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
