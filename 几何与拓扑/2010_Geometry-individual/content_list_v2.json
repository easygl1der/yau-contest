    [
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Geometry and Topology "
                    }
                ],
                "level": 1
            },
            "bbox": [
                324,
                172,
                673,
                197
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Individual (Please select 5 problems to solve) "
                    }
                ]
            },
            "bbox": [
                349,
                231,
                648,
                268
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "1. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "D ^ { * } = \\{ ( x , y ) \\in \\mathbb { R } ^ { 2 } \\ | \\ 0 < x ^ { 2 } + y ^ { 2 } < 1 \\}"
                            },
                            {
                                "type": "text",
                                "content": "be the punctured unit disc in the Euclidean plane. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g"
                            },
                            {
                                "type": "text",
                                "content": "be the complete Riemannian metric on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "D ^ { * }"
                            },
                            {
                                "type": "text",
                                "content": "with contsant curvature "
                            },
                            {
                                "type": "equation_inline",
                                "content": "^ { - 1 }"
                            },
                            {
                                "type": "text",
                                "content": ". Find the disctance under the metric between the points "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( e ^ { - 2 \\pi } , 0 )"
                            },
                            {
                                "type": "text",
                                "content": "and "
                            },
                            {
                                "type": "equation_inline",
                                "content": "( - e ^ { - \\pi } , 0 )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "2. Show that every closed hypersurface in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R } ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "has a point at which the second fundamental form is positive definite. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "3. Prove that the real projective space "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R } P ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "is orientable if and only if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": "is odd. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "4. Suppose "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\pi : M _ { 1 } \\longrightarrow M _ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "is a "
                            },
                            {
                                "type": "equation_inline",
                                "content": "C ^ { \\infty }"
                            },
                            {
                                "type": "text",
                                "content": "map of one connected differentiable manifold to another. And suppose for each "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p \\in M _ { 1 }"
                            },
                            {
                                "type": "text",
                                "content": ", the differential "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\pi _ { * } : T _ { p } M _ { 1 } \\longrightarrow T _ { \\pi ( p ) } M _ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "is a vector space isomorphism. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a). Show that if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M _ { 1 }"
                            },
                            {
                                "type": "text",
                                "content": "is connected, then "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\pi"
                            },
                            {
                                "type": "text",
                                "content": "is a covering space projection. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b). Given an example where "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M _ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "is compact but "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\pi : M _ { 1 } \\longrightarrow M _ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": "is not a covering space (but has the "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\pi _ { * }"
                            },
                            {
                                "type": "text",
                                "content": "isomorphism property). "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "5. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Sigma _ { g }"
                            },
                            {
                                "type": "text",
                                "content": "be the closed orientable surface of genus "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g"
                            },
                            {
                                "type": "text",
                                "content": ". Show that if "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g > 1"
                            },
                            {
                                "type": "text",
                                "content": ", then "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Sigma _ { g }"
                            },
                            {
                                "type": "text",
                                "content": "is a covering space of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Sigma _ { 2 }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "6. Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "be a smooth 4-dimensional manifold. A symplectic form is a closed 2-form "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\omega"
                            },
                            {
                                "type": "text",
                                "content": "on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "such that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\omega \\wedge \\omega"
                            },
                            {
                                "type": "text",
                                "content": "is a nowhere vanishing 4-form. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a). Construct a symplectic form on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { R } ^ { 4 }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b). Show that there are no symplectic forms on "
                            },
                            {
                                "type": "equation_inline",
                                "content": "S ^ { 4 }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
