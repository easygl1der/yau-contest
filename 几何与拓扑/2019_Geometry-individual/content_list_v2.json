        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Geometry and Topology Individual (5 problems) "
                    }
                ],
                "level": 1
            },
            "bbox": [
                366,
                105,
                658,
                146
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1) Let Conf be the following submanifold of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { C } ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": ": "
                    },
                    {
                        "type": "equation_inline",
                        "content": "^ { - n }"
                    }
                ]
            },
            "bbox": [
                134,
                159,
                505,
                174
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\operatorname {C o n f} _ {n} = \\left\\{\\left(z _ {1}, z _ {2}, \\dots , z _ {n}\\right) \\in \\mathbb {C} ^ {n} \\mid z _ {i} \\neq z _ {j} \\text {f o r a n y} i \\neq j \\right\\}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/b3bd2e2bde88a95362bc2a9b6f7f61291f7e092deb4c10835be1e09780a22e74.jpg"
                }
            },
            "bbox": [
                332,
                185,
                729,
                200
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "For every pair "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( i , j )"
                    },
                    {
                        "type": "text",
                        "content": "with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "i \\neq j"
                    },
                    {
                        "type": "text",
                        "content": ", we define the complex valued 1-form "
                    }
                ]
            },
            "bbox": [
                157,
                211,
                665,
                225
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\omega_ {i j} := \\frac {d z _ {i} - d z _ {j}}{z _ {i} - z _ {j}}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/81f6a7c5e9fadac5226226dab0402fa661098d1c0782a57a6efcf175f6f59538.jpg"
                }
            },
            "bbox": [
                467,
                236,
                596,
                267
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(a) Show that for any "
                            },
                            {
                                "type": "equation_inline",
                                "content": "i \\neq j"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\omega _ { i j }"
                            },
                            {
                                "type": "text",
                                "content": "represents a non-zero de Rham cohomology class in "
                            },
                            {
                                "type": "equation_inline",
                                "content": "H ^ { 1 } ( \\mathrm { C o n f } _ { n } , \\mathbb { C } )"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(b) Show that for any pair-wise distinct indices "
                            },
                            {
                                "type": "equation_inline",
                                "content": "i , j , k"
                            },
                            {
                                "type": "text",
                                "content": ", "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                163,
                277,
                897,
                312
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\omega_ {i j} \\wedge \\omega_ {j k} + \\omega_ {j k} \\wedge \\omega_ {k i} + \\omega_ {k i} \\wedge \\omega_ {i j} = 0.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/b9b538872f15455e5a1057c077301ffa12fe4fb21dc569513fbc2db221b4f6dd.jpg"
                }
            },
            "bbox": [
                411,
                323,
                690,
                338
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "be a compact oriented manifold of (real) dimension 4. Consider the following symmetric bilinear form on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H ^ { 2 } ( M )"
                    }
                ]
            },
            "bbox": [
                134,
                350,
                907,
                379
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "H ^ {2} (M) \\times H ^ {2} (M) \\to \\mathbb {R}, \\quad ([ \\alpha ], [ \\beta ]) \\mapsto \\int_ {M} \\alpha \\wedge \\beta .",
                "math_type": "latex",
                "image_source": {
                    "path": "images/59c20ead48d74dc258e54f9ee570655bcac4c8a0f9dd7224ae47c74e0932b20e.jpg"
                }
            },
            "bbox": [
                356,
                379,
                709,
                407
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tau ( M )"
                    },
                    {
                        "type": "text",
                        "content": "be the signature of this bilinear form, i.e. the number of positive eigenvalues minus the number of negative eigenvalues. Compute "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tau ( M )"
                    },
                    {
                        "type": "text",
                        "content": "for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M = S ^ { 4 } , \\mathbb { C P } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 2 } \\times S ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                154,
                413,
                907,
                443
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X = \\mathbb { R } ^ { 4 } / \\sim"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    }
                ]
            },
            "bbox": [
                134,
                451,
                331,
                467
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\begin{array}{l} \\left(x _ {1}, x _ {2}, x _ {3}, x _ {4}\\right) \\sim \\left(x _ {1}, x _ {2} + 1, x _ {3}, x _ {4}\\right) \\\\ \\left(x _ {1}, x _ {2}, x _ {3}, x _ {4}\\right) \\sim \\left(x _ {1}, x _ {2}, x _ {3}, x _ {4} + 1\\right) \\\\ \\left(x _ {1}, x _ {2}, x _ {3}, x _ {4}\\right) \\sim \\left(x _ {1} + 1, x _ {2}, x _ {3}, x _ {4}\\right) \\\\ (x _ {1}, x _ {2}, x _ {3}, x _ {4}) \\sim (x _ {1}, x _ {2} + x _ {4}, x _ {3} + 1, x _ {4}) \\\\ \\end{array}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/53f9ef8a4f8394d510060cfa8fcfe963063a1fc3ca27b93f262855dbcaca0431.jpg"
                }
            },
            "bbox": [
                386,
                479,
                680,
                545
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Compute "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H _ { 1 } ( X , \\mathbb { Z } )"
                    }
                ]
            },
            "bbox": [
                157,
                574,
                305,
                589
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E"
                    },
                    {
                        "type": "text",
                        "content": "be a vector bundle over a smooth manifold "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": ". Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\nabla ^ { E }"
                    },
                    {
                        "type": "text",
                        "content": "be a connection "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R ^ { E } \\in"
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Omega ^ { 2 } ( M , { \\mathrm { E n d } } ( E ) )"
                    },
                    {
                        "type": "text",
                        "content": "be its curvature tensor. For any polynomial "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f ( x ) = a _ { 0 } + a _ { 1 } x + a _ { 2 } x ^ { 2 } + \\cdot \\cdot \\cdot + a _ { n } x ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": ", we denote "
                    }
                ]
            },
            "bbox": [
                134,
                596,
                907,
                638
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "f \\left(R ^ {E}\\right) = a _ {0} + a _ {1} R ^ {E} + a _ {2} \\left(R ^ {E}\\right) ^ {2} \\dots + a _ {n} \\left(R ^ {E}\\right) ^ {n} \\in \\Omega^ {*} (M, \\operatorname {E n d} (E)).",
                "math_type": "latex",
                "image_source": {
                    "path": "images/f9233da8bf0ad07648805333f7a14e7ea3c4b715e9799a78f88163f30b669fe5.jpg"
                }
            },
            "bbox": [
                292,
                639,
                771,
                656
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Here "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( R ^ { E } ) ^ { k } \\in \\Omega ^ { 2 k } ( M , { \\mathrm { E n d } } ( E ) )"
                    },
                    {
                        "type": "text",
                        "content": "is the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k"
                    },
                    {
                        "type": "text",
                        "content": "-th wedge product on forms combined with matrix multiplications on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\operatorname { E n d } ( E )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                154,
                661,
                907,
                690
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(a) Show that the differential form "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\operatorname { t r } \\left\\lfloor f ( R ^ { E } ) \\right\\rfloor \\in \\Omega ^ { * } ( M )"
                    },
                    {
                        "type": "text",
                        "content": "is closed "
                    }
                ]
            },
            "bbox": [
                164,
                699,
                647,
                715
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "d \\operatorname {t r} \\left[ f \\left(R ^ {E}\\right) \\right] = 0.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/15708222f56b5b0e9ed50e4f78054640a0b17e471763ece02443a65ea0de381e.jpg"
                }
            },
            "bbox": [
                487,
                726,
                613,
                744
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Here tr is the trace on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\operatorname { E n d } ( E )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                193,
                753,
                430,
                768
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\nabla ^ { E }"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\widetilde { \\nabla } ^ { E }"
                    },
                    {
                        "type": "text",
                        "content": "be two connections on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "R ^ { E }"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\widetilde { R } ^ { E }"
                    },
                    {
                        "type": "text",
                        "content": "be the corresponding curvature tensors. Show that there exists a differential form "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\omega \\in \\Omega ^ { * } ( M )"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    }
                ]
            },
            "bbox": [
                163,
                772,
                907,
                803
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\operatorname {t r} \\left[ f (R ^ {E}) \\right] - \\operatorname {t r} \\left[ f (\\tilde {R} ^ {E}) \\right] = d \\omega .",
                "math_type": "latex",
                "image_source": {
                    "path": "images/6dcb9cbb40350ca1d5c4f22942f356c2831b7d491359bafb5783928b675b9538.jpg"
                }
            },
            "bbox": [
                436,
                813,
                665,
                838
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "1 "
                    }
                ]
            },
            "bbox": [
                507,
                879,
                517,
                891
            ]
        }
    ],
    [
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5) (a) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "u"
                    },
                    {
                        "type": "text",
                        "content": "be a smooth function over a Riemannian manifold "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( M , g )"
                    },
                    {
                        "type": "text",
                        "content": ". Prove the following Bochner’s formula "
                    }
                ]
            },
            "bbox": [
                134,
                85,
                907,
                110
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\frac {1}{2} \\Delta | \\nabla u | ^ {2} = | \\nabla \\nabla u | ^ {2} + \\operatorname {R i c} (\\nabla u, \\nabla u) + g (\\nabla \\Delta u, \\nabla u)",
                "math_type": "latex",
                "image_source": {
                    "path": "images/48d5a223f71ebfed4d74aeedaf5e85d8d46e25fa19156ddf4ec3211ff4c97e85.jpg"
                }
            },
            "bbox": [
                366,
                111,
                734,
                135
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Delta"
                    },
                    {
                        "type": "text",
                        "content": "is the Laplacian and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| \\bullet | ^ { 2 } = g ( \\bullet , \\bullet )"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                193,
                142,
                527,
                156
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( S ^ { 2 } , g )"
                    },
                    {
                        "type": "text",
                        "content": "be the standard unit sphere and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "E"
                    },
                    {
                        "type": "text",
                        "content": "be a constant. Show that the only smooth positive solution to "
                    }
                ]
            },
            "bbox": [
                163,
                161,
                907,
                187
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\Delta \\ln f + E f ^ {2} = 1",
                "math_type": "latex",
                "image_source": {
                    "path": "images/8de0f2288534730032cefe3eac20a7de8cafbd754c9b78cbfd0fa5cc94192575.jpg"
                }
            },
            "bbox": [
                487,
                189,
                615,
                203
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "equation_inline",
                        "content": "\\textstyle f = { \\frac { 1 } { A + \\phi } }"
                    },
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "A"
                    },
                    {
                        "type": "text",
                        "content": "is a constant and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\phi"
                    },
                    {
                        "type": "text",
                        "content": "is some first eigenfunction of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 2 }"
                    }
                ]
            },
            "bbox": [
                193,
                210,
                737,
                227
            ]
        },
        {
            "type": "page_number",
            "content": {
                "page_number_content": [
                    {
                        "type": "text",
                        "content": "2 "
                    }
                ]
            },
            "bbox": [
