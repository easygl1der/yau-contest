                112,
                640,
                133
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 1. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n > 1"
                    },
                    {
                        "type": "text",
                        "content": "be a positive integer. "
                    }
                ]
            },
            "bbox": [
                161,
                152,
                517,
                167
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(i) Does there exist a map "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f : S ^ { 2 n } \\to \\mathbb { C P } ^ { n }"
                            },
                            {
                                "type": "text",
                                "content": "with "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\deg ( f ) \\neq 0"
                            },
                            {
                                "type": "text",
                                "content": "? Construct an example or disprove it. "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(ii) Does there exist a map "
                            },
                            {
                                "type": "equation_inline",
                                "content": "f : \\mathbb { C P } ^ { n } \\to S ^ { 2 n }"
                            },
                            {
                                "type": "text",
                                "content": "with "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\deg ( f ) \\neq 0"
                            },
                            {
                                "type": "text",
                                "content": "? Construct an example or disprove it. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                169,
                170,
                849,
                233
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 2. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Sigma \\subset \\mathbb { R } ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": "be an embedded surface in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": ". A surface is called minimal if, for any "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\in \\Sigma"
                    },
                    {
                        "type": "text",
                        "content": ", we have "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\kappa _ { 1 } ( p ) + \\kappa _ { 2 } ( p ) = 0"
                    },
                    {
                        "type": "text",
                        "content": ", where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\kappa _ { 1 } ( p )"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\kappa _ { 2 } ( p )"
                    },
                    {
                        "type": "text",
                        "content": "are the two principal curvatures at "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Sigma"
                    },
                    {
                        "type": "text",
                        "content": "is closed, then "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Sigma"
                    },
                    {
                        "type": "text",
                        "content": "cannot be minimal. "
                    }
                ]
            },
            "bbox": [
                140,
                258,
                854,
                308
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "be a closed, simply connected 6-dimensional manifold. Suppose "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H _ { 2 } ( M ) = \\mathbb { Z } _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that the Euler characteristic "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\chi ( M ) \\neq - 1"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                140,
                335,
                854,
                369
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( M , g )"
                    },
                    {
                        "type": "text",
                        "content": "be a closed oriented "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "-dimensional Riemannian manifold. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\in M"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "{ \\mathrm { R i c } } _ { p }"
                    },
                    {
                        "type": "text",
                        "content": "be the Ricci curvature tensor at "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "be the scalar curvature at "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p"
                    },
                    {
                        "type": "text",
                        "content": "which is defined to be "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S _ { p } : = \\textstyle { \\frac { 1 } { n } } \\mathrm { T r } _ { g } ( \\mathrm { R i c } _ { p } )"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that the scalar curvature "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ( p )"
                    },
                    {
                        "type": "text",
                        "content": "at "
                    },
                    {
                        "type": "equation_inline",
                        "content": "p \\in M"
                    },
                    {
                        "type": "text",
                        "content": "is given by "
                    }
                ]
            },
            "bbox": [
                140,
                396,
                854,
                448
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "S _ {p} = \\frac {1}{\\omega_ {n - 1}} \\int_ {S ^ {n - 1}} \\operatorname {R i c} _ {p} (V, V) d S ^ {n - 1},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/57c6fb0aee30feb117940ff6c034ac563689435a549bc7a3fec3ae33d11eeaab.jpg"
                }
            },
            "bbox": [
                359,
                450,
                635,
                486
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\omega _ { n - 1 }"
                    },
                    {
                        "type": "text",
                        "content": "is the area of the unit sphere "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { n - 1 }"
                    },
                    {
                        "type": "text",
                        "content": "in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T _ { p } M"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "V \\in S ^ { n - 1 }"
                    },
                    {
                        "type": "text",
                        "content": "are unit vector fields, and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d S ^ { n - 1 }"
                    },
                    {
                        "type": "text",
                        "content": "is the area element on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { n - 1 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                140,
                489,
                854,
                523
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 5. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "be the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "-dimensional sphere with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n \\geq 2"
                    },
                    {
                        "type": "text",
                        "content": ", and let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "be a finite group that acts freely on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": ". Suppose "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "is non-trivial. Then, "
                    }
                ]
            },
            "bbox": [
                140,
                542,
                854,
                575
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(i) Compute the homotopy groups of the quotient space "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\pi _ { i } ( S ^ { n } / G )"
                            },
                            {
                                "type": "text",
                                "content": "for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "0 \\leq i \\leq n"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(ii) Suppose "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": "is even. Prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G"
                            },
                            {
                                "type": "text",
                                "content": "is isomorphic to "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Z } _ { 2 }"
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(iii) Suppose "
                            },
                            {
                                "type": "equation_inline",
                                "content": "n"
                            },
                            {
                                "type": "text",
                                "content": "is odd. Show that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "G"
                            },
                            {
                                "type": "text",
                                "content": "cannot be isomorphic to "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\mathbb { Z } _ { p } \\times \\mathbb { Z } _ { p }"
                            },
                            {
                                "type": "text",
                                "content": "for "
                            },
                            {
                                "type": "equation_inline",
                                "content": "p"
                            },
                            {
                                "type": "text",
                                "content": "a prime number. "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                163,
                579,
                849,
                642
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Problem 6. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "be a closed oriented Riemannian manifold, where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g _ { t }"
                    },
                    {
                        "type": "text",
                        "content": "is a family of smooth Riemannian metrics smoothly depending on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "t \\in ( - \\epsilon , \\epsilon )"
                    },
                    {
                        "type": "text",
                        "content": ". Suppose there exists a family of eigenfunctions "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f _ { t }"
                    },
                    {
                        "type": "text",
                        "content": "and eigenvalues "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda _ { t }"
                    },
                    {
                        "type": "text",
                        "content": "smoothly depending on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "t"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    }
                ]
            },
            "bbox": [
                140,
                666,
                854,
                715
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\Delta_ {g t} f _ {t} = \\lambda_ {t} f _ {t},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/7386d1c87b5639ac719841bc846614ee402122a502ecdf017c0617072f787758.jpg"
                }
            },
            "bbox": [
                444,
                732,
                550,
                750
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Delta _ { g _ { t } }"
                    },
                    {
                        "type": "text",
                        "content": "is the Laplace-Beltrami operator defined using the Riemannian metric "
                    },
                    {
                        "type": "equation_inline",
                        "content": "g _ { t }"
                    },
                    {
                        "type": "text",
                        "content": ". Additionally, assume that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f _ { 0 }"
                    },
                    {
                        "type": "text",
                        "content": "is not a constant function. We define "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { \\dot { \\lambda } : = \\frac { d } { d t } | _ { t = 0 } \\lambda _ { t } } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\begin{array} { r } { \\dot { \\Delta } : = \\frac { d } { d t } | _ { t = 0 } \\Delta _ { g _ { t } } } \\end{array}"
                    },
                    {
                        "type": "text",
                        "content": ". Prove the following: "
                    }
                ]
            },
            "bbox": [
                140,
                751,
                854,
                806
            ]
        },
        {
            "type": "list",
            "content": {
                "list_type": "text_list",
                "list_items": [
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(i) As "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\lambda _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": "is an eigenvalue of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Delta _ { g _ { 0 } }"
                            },
                            {
                                "type": "text",
                                "content": ", let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "V _ { \\lambda _ { 0 } } : = \\mathrm { K e r } ( \\Delta _ { g _ { 0 } } - \\lambda _ { 0 } )"
                            },
                            {
                                "type": "text",
                                "content": "be the eigenspace of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\lambda _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": ", and let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Pi : L ^ { : 2 } ( M , g _ { 0 } )  V _ { \\lambda _ { 0 } }"
                            },
                            {
                                "type": "text",
                                "content": "be the orthogonal projection onto the eigenspace. Prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\dot { \\lambda }"
                            },
                            {
                                "type": "text",
                                "content": "is an eigenvalue of the operator "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\Pi \\circ \\Delta ^ { \\prime } : V _ { \\lambda _ { 0 } }  V _ { \\lambda _ { 0 } }"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    },
                    {
                        "item_type": "text",
                        "item_content": [
                            {
                                "type": "text",
                                "content": "(ii) Let "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\varphi _ { t } : { \\cal M }  { \\cal M }"
                            },
                            {
                                "type": "text",
                                "content": "be a 1-parameter family of diffeomorphisms of "
                            },
                            {
                                "type": "equation_inline",
                                "content": "M"
                            },
                            {
                                "type": "text",
                                "content": "and assume "
                            },
                            {
                                "type": "equation_inline",
                                "content": "g _ { t } = \\varphi _ { t } ^ { * } g _ { 0 }"
                            },
                            {
                                "type": "text",
                                "content": ". Prove that "
                            },
                            {
                                "type": "equation_inline",
                                "content": "\\dot { \\lambda } = 0"
                            },
                            {
                                "type": "text",
                                "content": ". "
                            }
                        ]
                    }
                ]
            },
            "bbox": [
                169,
                806,
                849,
                890
            ]
