        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Geometry and Topology "
                    }
                ],
                "level": 1
            },
            "bbox": [
                322,
                172,
                675,
                197
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Individual 9:30–12:00 am, July 10, 2011 (Please select 5 problems to solve) "
                    }
                ]
            },
            "bbox": [
                347,
                231,
                648,
                286
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Suppose "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "is a closed smooth "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "-manifold. "
                    }
                ]
            },
            "bbox": [
                193,
                311,
                591,
                326
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "a) Does there always exist a smooth map "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f : M \\to S ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "from "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "into the "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "-sphere, such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "is essential (i.e. "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f"
                    },
                    {
                        "type": "text",
                        "content": "is not homotopic to a constant map)? Justify your answer. "
                    }
                ]
            },
            "bbox": [
                191,
                328,
                801,
                376
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "b) Same question, replacing "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "by the n-torus "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                193,
                378,
                630,
                394
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Suppose "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( X , d )"
                    },
                    {
                        "type": "text",
                        "content": "is a compact metric space and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f : X \\to X"
                    },
                    {
                        "type": "text",
                        "content": "is a map so that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d ( f ( x ) , f ( y ) ) = d ( x , y )"
                    },
                    {
                        "type": "text",
                        "content": "for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x"
                    },
                    {
                        "type": "text",
                        "content": ", "
                    },
                    {
                        "type": "equation_inline",
                        "content": "y"
                    },
                    {
                        "type": "text",
                        "content": "in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "X"
                    },
                    {
                        "type": "text",
                        "content": ". Show that f is an onto map. "
                    }
                ]
            },
            "bbox": [
                191,
                401,
                801,
                453
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C _ { 1 } , C _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "be two linked circles in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": ". Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C _ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": "cannot be homotopic to a point in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { 3 } \\backslash C _ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                458,
                801,
                495
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M = \\mathbb { R } ^ { 2 } / \\mathbb { Z } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "be the two dimensional torus, "
                    },
                    {
                        "type": "equation_inline",
                        "content": "L"
                    },
                    {
                        "type": "text",
                        "content": "the line "
                    },
                    {
                        "type": "equation_inline",
                        "content": "3 x = 7 y"
                    },
                    {
                        "type": "text",
                        "content": "in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S = \\pi ( L ) \\subset M"
                    },
                    {
                        "type": "text",
                        "content": "where "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\pi : \\mathbb { R } ^ { 2 } \\to M"
                    },
                    {
                        "type": "text",
                        "content": "is the projection map. Find a differential form on "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "which represents the Poincar´e dual of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                191,
                501,
                801,
                552
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. A regular curve "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C"
                    },
                    {
                        "type": "text",
                        "content": "in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": "is called a Bertrand Curve, if there exists a diffeomorphism "
                    },
                    {
                        "type": "equation_inline",
                        "content": "f : C \\to D"
                    },
                    {
                        "type": "text",
                        "content": "from "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C"
                    },
                    {
                        "type": "text",
                        "content": "onto a different regular curve "
                    },
                    {
                        "type": "equation_inline",
                        "content": "D"
                    },
                    {
                        "type": "text",
                        "content": "in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N _ { x } C = N _ { f ( x ) } D"
                    },
                    {
                        "type": "text",
                        "content": "for any "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x \\in C"
                    },
                    {
                        "type": "text",
                        "content": ". Here "
                    },
                    {
                        "type": "equation_inline",
                        "content": "N _ { x } C"
                    },
                    {
                        "type": "text",
                        "content": "denotes the principal normal line of the curve "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C"
                    },
                    {
                        "type": "text",
                        "content": "passing through "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x"
                    },
                    {
                        "type": "text",
                        "content": ", and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T _ { x } C"
                    },
                    {
                        "type": "text",
                        "content": "will denote the tangent line of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C"
                    },
                    {
                        "type": "text",
                        "content": "at "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x"
                    },
                    {
                        "type": "text",
                        "content": ". Prove that: "
                    }
                ]
            },
            "bbox": [
                191,
                558,
                801,
                642
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "a) The distance "
                    },
                    {
                        "type": "equation_inline",
                        "content": "| x - f ( x ) |"
                    },
                    {
                        "type": "text",
                        "content": "is constant for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x \\in C"
                    },
                    {
                        "type": "text",
                        "content": "; and the angle made between the directions of the two tangent lines "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T _ { x } C"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T _ { f ( x ) } D"
                    },
                    {
                        "type": "text",
                        "content": "is also constant. "
                    }
                ]
            },
            "bbox": [
                191,
                643,
                801,
                690
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "b) If the curvature "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k"
                    },
                    {
                        "type": "text",
                        "content": "and torsion "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\tau"
                    },
                    {
                        "type": "text",
                        "content": "of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C"
                    },
                    {
                        "type": "text",
                        "content": "are nowhere zero, then there must be constants "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mu"
                    },
                    {
                        "type": "text",
                        "content": "such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\lambda k + \\mu \\tau = 1"
                    }
                ]
            },
            "bbox": [
                191,
                692,
                801,
                726
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "6. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "be the closed surface generated by carrying a small circle with radius "
                    },
                    {
                        "type": "equation_inline",
                        "content": "r"
                    },
                    {
                        "type": "text",
                        "content": "around a closed curve "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C"
                    },
                    {
                        "type": "text",
                        "content": "embedded in "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": "such that the center moves along "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C"
                    },
                    {
                        "type": "text",
                        "content": "and the circle is in the normal plane to "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C"
                    },
                    {
                        "type": "text",
                        "content": "at each point. Prove that "
                    }
                ]
            },
            "bbox": [
                191,
                733,
                801,
                799
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\int_ {M} H ^ {2} d \\sigma \\geq 2 \\pi^ {2},",
                "math_type": "latex",
                "image_source": {
                    "path": "images/701a607d0b21a34c99eac94294e3d28615733b4387d195b4565a3eeceb9dc328.jpg"
                }
            },
            "bbox": [
                426,
                797,
                569,
                834
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "and the equality holds if and only if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "C"
                    },
                    {
                        "type": "text",
                        "content": "is a circle with radius "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\sqrt { 2 } r"
                    },
                    {
                        "type": "text",
                        "content": ". Here "
                    },
                    {
                        "type": "equation_inline",
                        "content": "H"
                    },
                    {
                        "type": "text",
                        "content": "is the mean curvature of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "d \\sigma"
                    },
                    {
                        "type": "text",
                        "content": "is the area element of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                193,
                835,
                801,
                870
            ]
