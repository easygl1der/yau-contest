        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "Geometry and Topology Team "
                    }
                ],
                "level": 1
            },
            "bbox": [
                324,
                158,
                673,
                204
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "Please solve 5 out of the following 6 problems. "
                    }
                ]
            },
            "bbox": [
                258,
                206,
                739,
                229
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1. Compute the fundamental and homology groups of the wedge sum of a circle "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": "and a torus "
                    },
                    {
                        "type": "equation_inline",
                        "content": "T = S ^ { 1 } \\times S ^ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                193,
                272,
                801,
                305
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "2. Given a properly discontinuous action "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F : G \\times M \\to M"
                    },
                    {
                        "type": "text",
                        "content": "on a smooth manifold "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": ", show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M / G"
                    },
                    {
                        "type": "text",
                        "content": "is orientable if and only if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "is orientable and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "F ( g , \\cdot )"
                    },
                    {
                        "type": "text",
                        "content": "preserves the orientation of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": ". Use this statement to show that the M¨obius band is not orientable and that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } P ^ { n }"
                    },
                    {
                        "type": "text",
                        "content": "is orientable if and only if "
                    },
                    {
                        "type": "equation_inline",
                        "content": "n"
                    },
                    {
                        "type": "text",
                        "content": "is odd. "
                    }
                ]
            },
            "bbox": [
                193,
                325,
                803,
                407
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "3. (a) Consider the space "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y"
                    },
                    {
                        "type": "text",
                        "content": "obtained from "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 2 } \\times [ 0 , 1 ]"
                    },
                    {
                        "type": "text",
                        "content": "by identifying "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( x , 0 )"
                    },
                    {
                        "type": "text",
                        "content": "with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( - x , 0 )"
                    },
                    {
                        "type": "text",
                        "content": "and also identifying "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( x , 1 )"
                    },
                    {
                        "type": "text",
                        "content": "with "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( - x , 1 )"
                    },
                    {
                        "type": "text",
                        "content": ", for all "
                    },
                    {
                        "type": "equation_inline",
                        "content": "x \\in"
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": ". Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "Y"
                    },
                    {
                        "type": "text",
                        "content": "is homeomorphic to the connected sum "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } P ^ { 3 } \\# \\mathbb { R } P ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                193,
                428,
                801,
                476
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(b) Show that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "S ^ { 2 } \\times S ^ { 1 }"
                    },
                    {
                        "type": "text",
                        "content": "is a double cover of the connected sum "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } P ^ { 3 } \\# \\mathbb { R } P ^ { 3 }"
                    },
                    {
                        "type": "text",
                        "content": ". "
                    }
                ]
            },
            "bbox": [
                193,
                478,
                801,
                511
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "4. Prove that a bi-invariant metric on a Lie group "
                    },
                    {
                        "type": "equation_inline",
                        "content": "G"
                    },
                    {
                        "type": "text",
                        "content": "has nonnegative sectional curvature. "
                    }
                ]
            },
            "bbox": [
                193,
                531,
                801,
                563
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "5. Let "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "be the upper half-plane "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } _ { + } ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "with the metric "
                    }
                ]
            },
            "bbox": [
                193,
                583,
                663,
                602
            ]
        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "d s ^ {2} = \\frac {d x ^ {2} + d y ^ {2}}{y ^ {k}}.",
                "math_type": "latex",
                "image_source": {
                    "path": "images/4b7bcb891caf561d7730a7c0f26c6c8ac4de8200e900bf1e45726fd302970d3a.jpg"
                }
            },
            "bbox": [
                423,
                605,
                573,
                643
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "For which values of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "k"
                    },
                    {
                        "type": "text",
                        "content": "is "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "complete? "
                    }
                ]
            },
            "bbox": [
                193,
                645,
                522,
                663
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "6. Given any nonorientable manifold "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "show the existence of a smooth orientable manifold "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\overline { { M } }"
                    },
                    {
                        "type": "text",
                        "content": "which is a double covering of "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": ". Find "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\overline { { M } }"
                    },
                    {
                        "type": "text",
                        "content": "when "
                    },
                    {
                        "type": "equation_inline",
                        "content": "M"
                    },
                    {
                        "type": "text",
                        "content": "is "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\mathbb { R } P ^ { 2 }"
                    },
                    {
                        "type": "text",
                        "content": "or the M¨obius band. "
                    }
                ]
            },
            "bbox": [
                193,
                682,
